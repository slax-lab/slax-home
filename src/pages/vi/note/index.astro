---
<Base
	title="Slax Note — Ghi chú giọng nói AI. Bạn nói, Slax viết."
	description="Bạn nói, Slax viết. Một bản ghi âm, nhiều hình dạng — do prompt bạn chọn định hình. Làm để lớn cùng bạn, năm này qua năm khác."
	ogImage="/og/vi/note.png"
	schema={schema}
>
	<Nav active="note" />

	<main>
		<!-- HERO -->
		<section class="n-hero">
			<div class="n-hero-inner">
				<div>
					<h1 class="n-h1">
						Ghi chú giọng nói AI. <em>Bạn nói, Slax viết.</em>
					</h1>
					<ul class="n-bullets">
						<li>Nghĩ ra là nói ngay. Không gõ phím, không sắp xếp.</li>
						<li>Một bản ghi âm, nhiều hình dạng — do prompt bạn chọn định hình.</li>
						<li>Làm để lớn cùng bạn, năm này qua năm khác.</li>
					</ul>
					<div class="n-stores">
						<a
							class="store-btn is-primary"
							href="https://apps.apple.com/us/app/slax-note-transcribe-voice-pen/id6480166286"
							target="_blank"
							rel="noopener noreferrer"
						>
							<span class="store-small">Tải về trên</span>
							<span class="store-main">App Store</span>
						</a>
						<a
							class="store-btn"
							href="https://play.google.com/store/apps/details?id=app.slax.notes"
							target="_blank"
							rel="noopener noreferrer"
						>
							<span class="store-small">Lấy trên</span>
							<span class="store-main">Google Play</span>
						</a>
					</div>
					<p class="n-web-link">
						Hoặc <a href="https://n.slax.com/">mở trên trình duyệt</a>.
					</p>
				</div>
				<div class="n-visual">
					<img
						src="/images/note/cover.png"
						alt="Slax Note — Ghi chú giọng nói AI"
						class="n-img"
						loading="eager"
					/>
				</div>
			</div>
		</section>

		<!-- EFFICIENCY BOOST -->
		<section class="features" id="features" data-demo-group="efficiency">
			<div class="features-inner">
				<div class="feat-head">
					<h2 class="feat-title">Tăng tốc hiệu suất</h2>
					<p class="feat-sub">Dành thời gian cho điều thực sự quan trọng.</p>
				</div>
				<div class="feat-demo-body">
					<div class="feat-list" role="tablist" aria-label="Tính năng tăng tốc hiệu suất">
						{efficiencyFeatures.map((f, i) => (
							<button
								class="feat-item"
								type="button"
								role="tab"
								data-idx={i}
								aria-selected={i === 0 ? 'true' : 'false'}
								aria-controls={`efficiency-video-${i}`}
							>
								<div class="feat-item-head">
									<span class="feat-num">{String(i + 1).padStart(2, '0')}</span>
									<h3 class="feat-h">{f.title}</h3>
								</div>
								<p class="feat-p">{f.body}</p>
							</button>
						))}
					</div>
					<div class="feat-stage">
						<div class="feat-frame">
							{efficiencyFeatures.map((f, i) => (
								<video
									id={`efficiency-video-${i}`}
									class="feat-video"
									data-idx={i}
									src={f.video}
									muted
									loop
									playsinline
									preload={i === 0 ? 'auto' : 'metadata'}
									aria-hidden={i === 0 ? 'false' : 'true'}
								></video>
							))}
						</div>
					</div>
				</div>
			</div>
		</section>

		<!-- INTELLIGENT GHOSTWRITING -->
		<section class="features features-alt" data-demo-group="ghostwriting">
			<div class="features-inner">
				<div class="feat-head">
					<h2 class="feat-title">Chấp bút thông minh</h2>
					<p class="feat-sub">Để AI mài giũa câu chữ giúp bạn, nhẹ nhàng.</p>
				</div>
				<div class="feat-demo-body feat-demo-body--reverse">
					<div class="feat-stage">
						<div class="feat-frame">
							{ghostwritingFeatures.map((f, i) => (
								<video
									id={`ghostwriting-video-${i}`}
									class="feat-video"
									data-idx={i}
									src={f.video}
									muted
									loop
									playsinline
									preload="metadata"
									aria-hidden={i === 0 ? 'false' : 'true'}
								></video>
							))}
						</div>
					</div>
					<div class="feat-list" role="tablist" aria-label="Tính năng chấp bút thông minh">
						{ghostwritingFeatures.map((f, i) => (
							<button
								class="feat-item"
								type="button"
								role="tab"
								data-idx={i}
								aria-selected={i === 0 ? 'true' : 'false'}
								aria-controls={`ghostwriting-video-${i}`}
							>
								<div class="feat-item-head">
									<span class="feat-num">{String(i + 1).padStart(2, '0')}</span>
									<h3 class="feat-h">{f.title}</h3>
								</div>
								<p class="feat-p">{f.body}</p>
							</button>
						))}
					</div>
				</div>
			</div>
		</section>

		<!-- USE CASES -->
		<section class="usecases">
			<div class="usecases-inner">
				<h2 class="usecases-head">Người khác đang dùng Slax Note thế nào</h2>
				<div class="uc-grid">
					{useCases.map((uc) => (
						<div class="uc">
							<h3 class="uc-h">{uc.title}</h3>
							<p class="uc-p">{uc.body}</p>
						</div>
					))}
				</div>
			</div>
		</section>

		<!-- TESTIMONIALS -->
		<section class="testimonials">
			<div class="testimonials-inner">
				<h2 class="t-head">Được hàng nghìn người dùng yêu thích</h2>
				<p class="t-sub">
					Sẵn sàng thay đổi cách bạn ghi chú? Dùng Slax Note ngay.
				</p>
				<div class="t-grid">
					{testimonials.map((t) => (
						<figure class="testimonial">
							<blockquote class="t-quote">"{t.quote}"</blockquote>
							<figcaption class="t-caption">
								<span class="t-author">{t.author}</span>
								<span class="t-title">{t.title}</span>
							</figcaption>
						</figure>
					))}
				</div>
			</div>
		</section>

		<!-- PRICING -->
		<section class="pricing" id="pricing">
			<div class="pricing-inner">
				<h2 class="pricing-head">Giá</h2>
				<p class="pricing-dek">Tận dụng giá ưu đãi sớm để nâng cấp gói của bạn.</p>

				<div class="plans-grid plans-grid-3">
					<!-- FREE -->
					<div class="plan">
						<div class="plan-eyebrow">Free</div>
						<div class="plan-price">
							<span class="num">$0</span>
						</div>
						<p class="plan-note">Miễn phí trọn đời.</p>
						<ul class="plan-list">
							<li><span class="plan-feat-label">Ghi chú giọng nói</span><span class="plan-feat-value">5 ghi chú</span></li>
							<li><span class="plan-feat-label">AI Polish</span><span class="plan-feat-value">Tổng cộng 10 lần</span></li>
							<li><span class="plan-feat-label">Thời lượng ghi âm</span><span class="plan-feat-value">5 phút</span></li>
						</ul>
						<a href="https://n.slax.com/" class="btn-primary">Dùng thử</a>
					</div>

					<!-- PREMIUM — MONTHLY -->
					<div class="plan">
						<div class="plan-eyebrow">Monthly</div>
						<div class="plan-price">
							<span class="num">$4.99</span><span class="unit">/ tháng</span>
						</div>
						<p class="plan-note">Huỷ bất cứ lúc nào.</p>
						<ul class="plan-list">
							<li><span class="plan-feat-label">Ghi chú giọng nói</span><span class="plan-feat-value">Không giới hạn</span></li>
							<li><span class="plan-feat-label">AI Polish</span><span class="plan-feat-value">300 lần / ngày</span></li>
							<li><span class="plan-feat-label">Thời lượng ghi âm</span><span class="plan-feat-value">30 phút</span></li>
							<li><span class="plan-feat-label">Chất lượng đánh bóng</span><span class="plan-feat-value">Bản cao cấp</span></li>
						</ul>
						<div class="plan-actions">
							<a
								class="btn-primary"
								href="https://apps.apple.com/us/app/slax-note-transcribe-voice-pen/id6480166286"
								target="_blank"
								rel="noopener noreferrer"
							>
								App Store
