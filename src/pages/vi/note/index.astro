const schema = {
	'@context': 'https://schema.org',
	'@type': 'SoftwareApplication',
	name: 'Slax Note',
	alternateName: 'Slax Note — Ghi chú giọng nói AI',

	applicationCategory: 'ProductivityApplication',
	operatingSystem: 'iOS, Android, Web',
	url: 'https://slax.com/note/',
	image: 'https://slax.com/og/note.png',
	screenshot: 'https://slax.com/images/note/cover.png',
	description:
		'Ghi chú giọng nói có AI. Bạn nói, Slax viết. Ghi âm với Slax Note rồi để AI nắn ý nghĩ của bạn thành mọi phong cách văn bản bạn muốn.',
	downloadUrl: [
		'https://apps.apple.com/us/app/slax-note-transcribe-voice-pen/id6480166286',
