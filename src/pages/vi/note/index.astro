			name: 'Premium Annual',
			price: '49.99',
			priceCurrency: 'USD',
			priceSpecification: {
				'@type': 'UnitPriceSpecification',
				price: '49.99',
				priceCurrency: 'USD',
				billingDuration: 'P1Y',
