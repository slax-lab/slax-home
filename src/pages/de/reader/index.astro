---
import Button from '~/components/Button.astro';
import DownloadSection from '~/components/DownloadSection.astro';
import FaqList from '~/components/FaqList.astro';
import Footer from '~/components/Footer.astro';
import Nav from '~/components/Nav.astro';
import Base from '~/layouts/Base.astro';

// Content sourced verbatim from original apps/reader-home components
// (archive/apps-backup): HomeHero / HomeFeatures / HomeHowItWorks /
// HomeComparison / HomeCTA / PricingTable / DownloadPage.
// Plan decision: merge features + pricing + download into single
// anchor-navigable /reader/ page.

const features = [
	{
		title: 'Verstehen mit KI im Rücken',
		body: 'Zusammenfassung, Kernaussagen, Antworten — jederzeit zum Artikel. Wie ein Tutor neben dir, der jeden Text aufschließt.',
	},
	{
		title: 'Inhalte verschwinden nicht mehr',
		body: 'Einmal gespeichert, dauerhaft gesichert. Schluss mit „404 — Seite nicht gefunden". Deine digitale Bibliothek gehört wirklich dir.',
	},
	{
		title: 'Smart sortiert',
		body: 'Die KI taggt und sortiert automatisch. Wenn du suchst, findet die semantische Suche genau den Artikel, den du meinst.',
	},
	{
		title: 'Verbundenes Lesen',
		body: 'Markiere und kommentiere direkt im Artikel. Teile Inhalte, hol andere in die Diskussion. Jeder Text kann zum Gesprächsort werden.',
	},
];

const steps = [
	{
		title: 'Spontan speichern',
		body: 'Ein Klick speichert jeden Artikel, jedes Paper, jeden Blog-Post.',
	},
	{
		title: 'KI analysiert sofort',
		body: 'Eine KI-Schnellsicht zeigt dir, was sich zu lesen lohnt und wo ein Blick reicht. Zeit fürs Beste.',
	},
	{
		title: 'KI fragen',
		body: 'Sprich mit der KI über das Gespeicherte und treib dein Verständnis tiefer.',
	},
	{
		title: 'Tief mit Inhalten arbeiten',
		body: 'Markieren, kommentieren, mit anderen diskutieren. Was du schreibst, zählt mehr als das, was du nur liest.',
	},
];

// Cell value: 'ok' → ● accent,   'no' → — muted,   any other string → inline text (muted italic)
const compareRows: Array<[string, string, string, string]> = [
	[
		'Unbegrenzte kostenlose Speicherungen (frühe Nutzer)',
		'ok',
		'ok',
		'Kostenpflichtig',
	],
	['Dauerhaftes Inhalts-Backup', 'ok', 'Kostenpflichtig', 'Kostenpflichtig'],
	['KI-Outline', 'Kostenpflichtig', 'ok', 'Kostenpflichtig'],
	['Beim Lesen mit KI chatten', 'Kostenpflichtig', 'no', 'Kostenpflichtig'],
	[
		'Markieren und kommentieren — Original und Snapshot, beidseitig synchron',
		'ok',
		'no',
		'Kostenpflichtig',
	],
	['In Diskussionen mit anderen Lesern einsteigen', 'ok', 'no', 'Nur Teilen'],
	['KI-Auto-Tagging', 'Kostenpflichtig', 'Manuell', 'Manuell'],
];

const matrixRows: Array<[string, string, string]> = [
	['Unbegrenzte Artikel speichern', 'ok', 'ok'],
	['Dauerhafte Snapshots (Schluss mit toten Links)', 'ok', 'ok'],
	['Unbegrenzte Markierungen und Kommentare', 'ok', 'ok'],
	['Volltextsuche', 'ok', 'ok'],
	['Geräte-übergreifender Sync', 'ok', 'ok'],
	['Artikel teilen und diskutieren', 'ok', 'ok'],
	['Open Source und Privacy-first', 'ok', 'ok'],
	['Tags erstellen und verwalten', 'ok', 'ok'],
	['Smartes KI-Auto-Tagging', 'no', 'ai'],
	['Sofort-Zusammenfassung per KI', 'no', 'ai'],
	['Interaktive KI-Outline', 'no', 'ai'],
	['KI-Chat — frag deine Bibliothek', 'no', 'ai'],
];

const faqs = [
	{
		q: 'Ist der Free-Plan wirklich für immer kostenlos?',
		a: 'Ja — für frühe Nutzer. In der Early-Access-Phase gibt es unbegrenztes Speichern und dauerhaftes Backup kostenlos. Hol dir den Free-Plan, solange er noch ohne Limits ist.',
	},
	{
		q: 'Spart mir Slax Reader wirklich mehrere Stunden Lesezeit pro Woche?',
		a: 'Dafür ist er gemacht. Mit der klickbaren KI-Outline springst du durch lange Artikel, statt jedes Wort zu lesen. Auto-Tagging übernimmt das Sortieren. Du musst nur noch lesen.',
	},
	{
		q: 'Kann ich das Pro-Abo jederzeit kündigen?',
		a: 'Klar. In den Account-Einstellungen jederzeit kündigen, ohne Aufwand. Deine Artikel und Markierungen bleiben im Free-Plan erhalten.',
	},
	{
		q: 'Wie funktioniert die 1-Monats-Testphase?',
		a: 'Nach dem Login läuft die Testphase sofort — keine Kreditkarte nötig. Nach 30 Tagen fragen wir, ob du mit Pro weitermachst, für 5,99 $/Monat (Listenpreis 9,99 $).',
	},
];

const platforms = [
	{
		icon: '📱',
		title: 'iPhone, iPad, Android',
		bullets: [
			'Dauerhaft speichern, komplett kostenlos.',
			'Jeden Artikel mit einem Tipp speichern.',
			'Sofort KI-Outline und schnelles Überspringen.',
			'Sync über alle Plattformen.',
		],
		downloads: [
			{
				href: 'https://apps.apple.com/us/app/slax-reader-ai-read-it-later/id6596730998',
				small: 'Laden im',
				main: 'App Store',
			},
			{
				href: 'https://play.google.com/store/apps/details?id=com.slax.reader',
				small: 'Holen auf',
				main: 'Google Play',
			},
		],
	},
	{
		icon: '💻',
		title: 'Mac',
		bullets: ['Speichern, lesen, sortieren — wie ein Profi.'],
		downloads: [
			{
				href: 'https://apps.apple.com/us/app/slax-reader-ai-read-it-later/id6596730998',
				small: 'Laden im',
				main: 'Mac App Store',
			},
		],
	},
	{
		icon: '🌐',
		title: 'Browser-Erweiterung',
		bullets: [
			'Jede Seite mit einem Klick speichern und sichern — gehört für immer dir.',
			'Direkt auf der Original-Seite mit der KI über den Artikel sprechen.',
			'Mit semantischer Suche in Sekunden finden, was du brauchst.',
		],
		downloads: [
			{
				href: 'https://chromewebstore.google.com/detail/gdnhaajlomjkhahnmiijphnodkcfikfd?utm_source=web_homepage',
				small: '',
				main: 'Chrome Extension',
			},
		],
	},
];

const schema = {
	'@context': 'https://schema.org',
	'@type': 'SoftwareApplication',
	name: 'Slax Reader',
	applicationCategory: 'ProductivityApplication',
	operatingSystem: 'Web, iOS, iPadOS, Android, macOS',
	url: 'https://slax.com/reader/',
	image: 'https://slax.com/og/reader.png',
	screenshot: 'https://slax.com/reader/hero.png',
	description:
		'Später lesen, open source, ohne Schnickschnack. Dauerhaft speichern, schneller lernen. Deine smarte Bibliothek — effizienter lesen, tiefer verstehen.',
	downloadUrl: [
		'https://apps.apple.com/us/app/slax-reader-ai-read-it-later/id6596730998',
		'https://play.google.com/store/apps/details?id=com.slax.reader',
		'https://chromewebstore.google.com/detail/gdnhaajlomjkhahnmiijphnodkcfikfd',
	],
	offers: [
		{
			'@type': 'Offer',
			name: 'Free',
			price: '0',
			priceCurrency: 'USD',
		},
		{
			'@type': 'Offer',
			name: 'Pro Reader',
			price: '5.99',
			priceCurrency: 'USD',
			priceSpecification: {
				'@type': 'UnitPriceSpecification',
				price: '5.99',
				priceCurrency: 'USD',
				billingDuration: 'P1M',
			},
		},
	],
	publisher: {
		'@type': 'Organization',
		name: 'Slax Lab',
		url: 'https://slax.com',
		logo: 'https://slax.com/images/slax-logo.png',
	},
};
---
<Base
	title="Slax Reader — später lesen, open source, ohne Schnickschnack"
	description="Später lesen, open source, ohne Schnickschnack. Kein Algorithmus, kein Feed. Du wählst, was du als nächstes liest. Unbegrenzte Snapshots, kostenlos."
	ogImage="/og/reader.png"
	schema={schema}
>
	<Nav active="reader" />

	<main>
		<!-- HERO -->
		<section class="r-hero">
			<div class="r-hero-inner">
				<div>
					<h1 class="r-h1">
						Später lesen, <em>open source, ohne Schnickschnack.</em>
					</h1>
					<ul class="r-bullets">
						<li>Kein Algorithmus, kein Feed. Du wählst, was du als nächstes liest.</li>
						<li>Unbegrenzte Snapshots, kostenlos.</li>
						<li>Open Source.</li>
					</ul>
					<div class="r-hero-stores">
						<a
							class="r-store-btn is-primary"
							href="https://apps.apple.com/us/app/slax-reader-ai-read-it-later/id6596730998"
							target="_blank"
							rel="noopener noreferrer"
						>
							<span class="r-store-small">Laden im</span>
							<span class="r-store-main">App Store</span>
						</a>
						<a
							class="r-store-btn"
							href="https://play.google.com/store/apps/details?id=com.slax.reader"
							target="_blank"
							rel="noopener noreferrer"
						>
							<span class="r-store-small">Holen auf</span>
							<span class="r-store-main">Google Play</span>
						</a>
					</div>
					<p class="r-web-link">
						Oder <a href="https://r.slax.com">im Browser öffnen</a>.
					</p>
				</div>
				<div class="r-preview" aria-hidden="true">
					<img
						src="/reader/hero.png"
						alt="Vorschau der Slax-Reader-Oberfläche"
						loading="eager"
						decoding="async"
					/>
				</div>
			</div>
		</section>

		<!-- FEATURES -->
		<section class="features" id="features">
			<div class="features-inner">
				<div class="features-head">
					<h2 class="features-title">Nicht noch ein Später-lesen-Tool</h2>
					<p class="features-sub">
						Wir bauen klügeres Lesen — die nächste Stufe.
					</p>
				</div>
				<div class="feat-grid">
					{features.map((f, i) => (
						<div class="feat">
							<div class="feat-num">{String(i + 1).padStart(2, '0')}</div>
							<h3 class="feat-h">{f.title}</h3>
							<p class="feat-p">{f.body}</p>
						</div>
					))}
				</div>
			</div>
		</section>

		<!-- HOW IT WORKS -->
		<section class="how">
			<div class="how-inner">
				<h2 class="how-head">Vom Speichern zum echten Aha.</h2>
				<p class="how-sub">
					Vier Schritte, die verändern, wie du liest und lernst.
				</p>
				<div class="how-steps">
					{steps.map((s, i) => (
						<div class="how-step">
							<div class="how-step-num">{String(i + 1).padStart(2, '0')}</div>
							<h3 class="how-step-h">{s.title}</h3>
							<p class="how-step-body">{s.body}</p>
						</div>
					))}
				</div>
			</div>
		</section>

		<!-- COMPARE -->
		<section class="compare">
			<div class="compare-inner">
				<h2 class="compare-head">Warum Leserinnen zu Slax wechseln</h2>
				<p class="compare-sub">
					So deutlich liegen wir vor klassischen Später-lesen-Tools.
				</p>
				<div class="compare-table">
					<div class="compare-row head">
						<div>Funktion</div>
						<div class="highlight">Slax Reader</div>
						<div>Instapaper</div>
						<div>Readwise</div>
					</div>
					{compareRows.map((row) => (
						<div class="compare-row">
							<div>{row[0]}</div>
							{[1, 2, 3].map((i) => {
								const v = row[i];
								const isHighlight = i === 1;
								let cls = 'cell';
								let content: string = v;
								if (v === 'ok') {
									cls += ' cell-ok';
									content = '●';
								} else if (v === 'no') {
									cls += ' cell-no';
									content = '—';
								} else {
									cls += ' cell-text';
								}
								if (isHighlight) cls += ' highlight';
								return <div class={cls}>{content}</div>;
							})}
						</div>
					))}
				</div>
				<p class="compare-more">
					<a href="/de/reader/alternatives/">
						Vollständiger Vergleich — Readwise, Omnivore, Cubox und mehr →
					</a>
				</p>
			</div>
		</section>

		<!-- PRICING -->
		<section class="pricing" id="pricing">
			<div class="pricing-inner">
				<h2 class="pricing-head">Klüger lesen, <em>nicht nur „später".</em></h2>
				<p class="pricing-dek">
					Dauerhaft speichern, schneller lernen. Deine smarte Bibliothek — effizienter lesen, tiefer verstehen.
				</p>
				<a class="pricing-promo" href="https://r.slax.com">
					🎉 Heute starten, 1 Monat Pro gratis
				</a>

				<div class="plans-grid">
					<div class="plan">
						<div class="plan-eyebrow">Free</div>
						<div class="plan-price">
							<span class="num">$0</span><span class="unit">/ Monat</span>
						</div>
						<p class="plan-tag">
							Unbegrenztes Speichern, dauerhaftes Backup — solange noch keine Limits da sind.
						</p>
						<a href="https://r.slax.com" class="btn-primary">Kostenlos starten</a>
					</div>
					<div class="plan featured">
						<div class="plan-eyebrow">Pro Reader</div>
						<div class="plan-price">
							<span class="num">$5.99</span><span class="unit">/ Monat</span>
							<span class="was">$9.99</span>
						</div>
						<p class="plan-tag">
							KI-Analyse dazu — bring dein Lesen ans Limit.
						</p>
						<a href="https://r.slax.com" class="btn-primary">1 Monat kostenlos testen</a>
					</div>
				</div>

				<div class="matrix" aria-label="Funktionsmatrix">
					<div class="matrix-row head">
						<div class="cell-feat">Funktion</div>
						<div class="cell">Free</div>
						<div class="cell">Pro Reader</div>
					</div>
					{matrixRows.map((row) => (
						<div class="matrix-row">
							<div class="cell-feat">{row[0]}</div>
							{[1, 2].map((i) => {
								const v = row[i];
								if (v === 'ok') return <div class="cell ok">✓</div>;
								if (v === 'ai') return <div class="cell ai">AI</div>;
								return <div class="cell no">✕</div>;
							})}
						</div>
					))}
				</div>
			</div>
		</section>

		<!-- FAQ -->
		<section class="faq">
			<div class="faq-inner">
				<h2 class="faq-head">Häufige Fragen</h2>
				<FaqList items={faqs} />
			</div>
		</section>


		<!-- DOWNLOAD -->
		<DownloadSection platforms={platforms}>
			<Fragment slot="heading">
				Slax Reader — <em>dauerhaft speichern, klüger lesen.</em>
			</Fragment>
			<Fragment slot="dek">
				Kostenlos für jede Plattform, die du nutzt.
			</Fragment>
		</DownloadSection>

		<!-- FINALE -->
		<section class="finale">
			<div class="finale-inner">
				<h2 class="finale-h">
					Heute mit <em>klügerem</em> Lesen starten
				</h2>
				<p class="finale-p">Klüger lesen, schneller lernen, mehr behalten.</p>
				<div class="actions actions-center">
					<Button variant="primary" href="https://r.slax.com" arrow>
						Loslegen — komplett kostenlos
					</Button>
					<Button variant="secondary" href="https://github.com/slax-lab/slax-reader">
						Quellcode ansehen
					</Button>
				</div>
			</div>
		</section>
	</main>

	<Footer />
</Base>

<style>
	/* HERO */
	.r-hero {
		padding: 6rem 0 5rem;
	}
	.r-hero-inner {
		max-width: 1180px;
		margin: 0 auto;
		padding: 0 2rem;
		display: grid;
		grid-template-columns: 1fr;
		gap: 4rem;
		align-items: center;
	}
	@media (min-width: 960px) {
		.r-hero-inner {
			grid-template-columns: 1.1fr 1fr;
		}
	}
	.r-h1 {
		font-family: var(--serif);
		font-weight: 400;
		font-size: clamp(2rem, 4vw, 3.2rem);
		line-height: 1.1;
		letter-spacing: -0.02em;
		margin: 1rem 0 1.75rem;
		color: var(--ink);
		max-width: 22ch;
	}
	.r-h1 :global(em) {
		font-style: italic;
		font-weight: 300;
		color: var(--accent);
	}
	.r-bullets {
		list-style: none;
		padding: 0;
		margin: 0 0 2.25rem;
		display: flex;
		flex-direction: column;
		gap: 0.75rem;
		max-width: 48ch;
	}
	.r-bullets li {
		position: relative;
		padding-left: 1.5rem;
		font-family: var(--serif);
		font-size: 1.05rem;
		line-height: 1.55;
		color: var(--ink-soft);
	}
	.r-bullets li::before {
		content: "—";
		position: absolute;
		left: 0;
		top: 0;
		color: var(--ink-mute);
		font-weight: 300;
	}
	.r-hero-stores {
		display: flex;
		gap: 0.75rem;
		flex-wrap: wrap;
	}
	.r-web-link {
		margin: 0.9rem 0 0;
		font-family: var(--serif);
		font-size: 0.95rem;
		color: var(--ink-mute);
	}
	.r-web-link a {
		color: var(--ink-soft);
		text-decoration: underline;
		text-decoration-color: var(--rule);
		text-underline-offset: 3px;
		transition: color 0.2s ease, text-decoration-color 0.2s ease;
	}
	.r-web-link a:hover {
		color: var(--accent);
		text-decoration-color: var(--accent);
	}
	.r-store-btn {
		display: inline-flex;
		flex-direction: column;
		align-items: flex-start;
		gap: 0.15rem;
		background: transparent;
		color: var(--ink);
		text-decoration: none;
		padding: 0.7rem 1.2rem;
		border: 1px solid var(--ink);
		transition:
			background 0.2s ease,
			color 0.2s ease;
		min-width: 160px;
	}
	.r-store-btn:hover {
		background: var(--ink);
		color: var(--bg);
	}
	.r-store-btn.is-primary,
	.r-store-btn.is-primary:hover {
		background: var(--accent);
		border-color: var(--accent);
		color: var(--bg);
	}
	.r-store-btn.is-primary .r-store-small,
	.r-store-btn.is-primary:hover .r-store-small {
		color: var(--bg);
		opacity: 0.8;
	}
	.r-store-small {
		font-family: var(--mono);
		font-size: 0.62rem;
		letter-spacing: 0.08em;
		text-transform: uppercase;
		color: var(--ink-mute);
		line-height: 1.2;
	}
	.r-store-btn:hover .r-store-small {
		color: var(--bg);
		opacity: 0.75;
	}
	.r-store-main {
		font-family: var(--serif);
		font-size: 0.98rem;
		font-weight: 500;
		line-height: 1.3;
	}
	.actions {
		display: flex;
		gap: 1rem;
		flex-wrap: wrap;
		align-items: center;
	}
	.actions-center {
		justify-content: center;
	}
	.r-preview {
		display: flex;
		justify-content: center;
	}
	.r-preview img {
		display: block;
		width: 100%;
		height: auto;
		max-width: 480px;
	}

	/* FEATURES */
	.features {
		padding: var(--section-pad) 0;
		border-top: 1px solid var(--rule-soft);
	}
	.features-inner {
		max-width: 1180px;
		margin: 0 auto;
		padding: 0 2rem;
	}
	.features-head {
		margin-bottom: 4rem;
	}
	.features-title {
		font-family: var(--serif);
		font-weight: 400;
		font-size: clamp(1.8rem, 3vw, 2.4rem);
		line-height: 1.15;
		letter-spacing: -0.02em;
		margin: 1rem 0 0.5rem;
	}
	.features-sub {
		font-family: var(--serif);
		font-size: 1.1rem;
		color: var(--ink-soft);
		margin: 0;
		max-width: 44ch;
	}
	.feat-grid {
		display: grid;
		grid-template-columns: 1fr;
		gap: 0;
		border-top: 1px solid var(--rule);
	}
	@media (min-width: 760px) {
		.feat-grid {
			grid-template-columns: 1fr 1fr;
		}
	}
	@media (min-width: 1040px) {
		.feat-grid {
			grid-template-columns: repeat(4, 1fr);
		}
	}
	.feat {
		padding: 2.5rem 2rem;
		border-bottom: 1px solid var(--rule);
	}
	@media (min-width: 760px) {
		.feat:nth-child(2n) {
			border-left: 1px solid var(--rule);
		}
	}
	@media (min-width: 1040px) {
		.feat:nth-child(2n) {
			border-left: 0;
		}
		.feat:not(:nth-child(4n + 1)) {
			border-left: 1px solid var(--rule);
		}
	}
	.feat-num {
		font-family: var(--mono);
		font-size: 0.7rem;
		letter-spacing: 0.2em;
		color: var(--ink-mute);
		margin-bottom: 1.5rem;
	}
	.feat-h {
		font-family: var(--serif);
		font-weight: 500;
		font-size: 1.2rem;
		letter-spacing: -0.015em;
		margin: 0 0 0.75rem;
