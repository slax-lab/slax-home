const useCases = [
	{
		title: 'Persönliche Sprach-Memos',
		body: 'Beim Gehen oder Fahren spontane Ideen einfangen. Wir machen aus deiner Stimme klaren, lesbaren Text — kein Geistesblitz geht verloren.',
	},
