const schema = {
	'@context': 'https://schema.org',
	'@type': 'SoftwareApplication',
	name: 'Slax Note',
	alternateName: 'Slax Note — KI-Sprachnotizen',
	applicationCategory: 'ProductivityApplication',
	operatingSystem: 'iOS, Android, Web',
	url: 'https://www.slax.com/note/',
	image: 'https://www.slax.com/og/note.png',
	screenshot: 'https://www.slax.com/images/note/cover.png',
	description:
		'KI-Sprachnotizen. Du sprichst, ich schreibe. Nimm mit Slax Note auf, lass die KI deine Idee festhalten und sie in jeden gewünschten Stil polieren.',
	downloadUrl: [
		'https://apps.apple.com/us/app/slax-note-transcribe-voice-pen/id6480166286',
		'https://play.google.com/store/apps/details?id=app.slax.notes',
	],
	offers: [
		{
			'@type': 'Offer',
			name: 'Free',
			price: '0',
			priceCurrency: 'USD',
		},
		{
			'@type': 'Offer',
			name: 'Premium Monthly',
			price: '4.99',
			priceCurrency: 'USD',
			priceSpecification: {
				'@type': 'UnitPriceSpecification',
				price: '4.99',
				priceCurrency: 'USD',
				billingDuration: 'P1M',
			},
		},
		{
			'@type': 'Offer',
			name: 'Premium Annual',
			price: '49.99',
			priceCurrency: 'USD',
			priceSpecification: {
				'@type': 'UnitPriceSpecification',
				price: '49.99',
				priceCurrency: 'USD',
				billingDuration: 'P1Y',
			},
		},
	],
	publisher: {
		'@type': 'Organization',
		name: 'Starry Tech Pte. Ltd.',
		url: 'https://www.slax.com',
		logo: 'https://www.slax.com/images/slax-logo.png',
	},
};
---
<Base
	title="Slax Note — KI-Sprachnotizen. Du sprichst, ich schreibe."
	description="Du sprichst, ich schreibe. Eine Aufnahme, viele Formen — geformt durch die Prompts, die du wählst. Wächst mit dir, Jahr für Jahr."
	ogImage="/og/note.png"
	schema={schema}
>
	<Nav active="note" />

	<main>
		<!-- HERO -->
		<section class="n-hero">
			<div class="n-hero-inner">
				<div>
					<h1 class="n-h1">
						KI-Sprachnotizen. <em>Du sprichst, ich schreibe.</em>
					</h1>
					<ul class="n-bullets">
						<li>Sag es, sobald die Idee da ist. Kein Tippen, kein Sortieren.</li>
						<li>Eine Aufnahme, viele Formen — geformt durch die Prompts, die du wählst.</li>
						<li>Wächst mit dir, Jahr für Jahr.</li>
					</ul>
					<div class="n-stores">
						<a
							class="store-btn is-primary"
							href="https://apps.apple.com/us/app/slax-note-transcribe-voice-pen/id6480166286"
							target="_blank"
							rel="noopener noreferrer"
						>
							<span class="store-small">Laden im</span>
							<span class="store-main">App Store</span>
						</a>
						<a
							class="store-btn"
							href="https://play.google.com/store/apps/details?id=app.slax.notes"
							target="_blank"
							rel="noopener noreferrer"
						>
							<span class="store-small">Holen auf</span>
							<span class="store-main">Google Play</span>
						</a>
					</div>
					<p class="n-web-link">
						Oder <a href="https://n.slax.com/">im Browser öffnen</a>.
					</p>
				</div>
				<div class="n-visual">
					<img
						src="/images/note/cover.png"
						alt="Slax Note — KI-Sprachnotizen"
						class="n-img"
						loading="eager"
					/>
				</div>
			</div>
		</section>

		<!-- EFFICIENCY BOOST -->
		<section class="features" id="features" data-demo-group="efficiency">
			<div class="features-inner">
				<div class="feat-head">
					<h2 class="feat-title">Mehr Tempo</h2>
					<p class="feat-sub">Zeit für das, was wirklich zählt.</p>
				</div>
				<div class="feat-demo-body">
					<div class="feat-list" role="tablist" aria-label="Funktionen für mehr Tempo">
						{efficiencyFeatures.map((f, i) => (
							<button
								class="feat-item"
								type="button"
								role="tab"
								data-idx={i}
								aria-selected={i === 0 ? 'true' : 'false'}
								aria-controls={`efficiency-video-${i}`}
							>
								<div class="feat-item-head">
									<span class="feat-num">{String(i + 1).padStart(2, '0')}</span>
									<h3 class="feat-h">{f.title}</h3>
								</div>
								<p class="feat-p">{f.body}</p>
							</button>
						))}
					</div>
					<div class="feat-stage">
						<div class="feat-frame">
							{efficiencyFeatures.map((f, i) => (
								<video
									id={`efficiency-video-${i}`}
									class="feat-video"
									data-idx={i}
									src={f.video}
									muted
									loop
									playsinline
									preload={i === 0 ? 'auto' : 'metadata'}
									aria-hidden={i === 0 ? 'false' : 'true'}
								></video>
							))}
						</div>
					</div>
				</div>
			</div>
		</section>

		<!-- INTELLIGENT GHOSTWRITING -->
		<section class="features features-alt" data-demo-group="ghostwriting">
			<div class="features-inner">
				<div class="feat-head">
					<h2 class="feat-title">Smartes Ghostwriting</h2>
					<p class="feat-sub">KI poliert deinen Text — mühelos.</p>
				</div>
				<div class="feat-demo-body feat-demo-body--reverse">
					<div class="feat-stage">
						<div class="feat-frame">
							{ghostwritingFeatures.map((f, i) => (
								<video
									id={`ghostwriting-video-${i}`}
									class="feat-video"
									data-idx={i}
									src={f.video}
									muted
									loop
									playsinline
									preload="metadata"
									aria-hidden={i === 0 ? 'false' : 'true'}
								></video>
							))}
						</div>
					</div>
					<div class="feat-list" role="tablist" aria-label="Funktionen für smartes Ghostwriting">
						{ghostwritingFeatures.map((f, i) => (
							<button
								class="feat-item"
								type="button"
								role="tab"
								data-idx={i}
								aria-selected={i === 0 ? 'true' : 'false'}
								aria-controls={`ghostwriting-video-${i}`}
							>
								<div class="feat-item-head">
									<span class="feat-num">{String(i + 1).padStart(2, '0')}</span>
									<h3 class="feat-h">{f.title}</h3>
								</div>
								<p class="feat-p">{f.body}</p>
							</button>
						))}
					</div>
				</div>
			</div>
		</section>

		<!-- USE CASES -->
		<section class="usecases">
			<div class="usecases-inner">
				<h2 class="usecases-head">Wofür andere Slax Note nutzen</h2>
				<div class="uc-grid">
					{useCases.map((uc) => (
						<div class="uc">
							<h3 class="uc-h">{uc.title}</h3>
							<p class="uc-p">{uc.body}</p>
						</div>
					))}
				</div>
			</div>
		</section>

		<!-- TESTIMONIALS -->
		<section class="testimonials">
			<div class="testimonials-inner">
				<h2 class="t-head">Von Tausenden geschätzt.</h2>
				<p class="t-sub">
					Zeit, deine Notiz-Routine umzustellen? Hol dir Slax Note.
				</p>
				<div class="t-grid">
					{testimonials.map((t) => (
						<figure class="testimonial">
							<blockquote class="t-quote">„{t.quote}"</blockquote>
							<figcaption class="t-caption">
								<span class="t-author">{t.author}</span>
								<span class="t-title">{t.title}</span>
							</figcaption>
						</figure>
					))}
				</div>
			</div>
		</section>

		<!-- PRICING -->
		<section class="pricing" id="pricing">
			<div class="pricing-inner">
				<h2 class="pricing-head">Preise</h2>
				<p class="pricing-dek">Hol dir den Early-Bird-Preis und upgrade dein Paket.</p>

				<div class="plans-grid plans-grid-3">
					<!-- FREE -->
					<div class="plan">
						<div class="plan-eyebrow">Free</div>
						<div class="plan-price">
							<span class="num">$0</span>
						</div>
						<p class="plan-note">Lebenslang kostenlos.</p>
						<ul class="plan-list">
							<li><span class="plan-feat-label">Sprachnotizen</span><span class="plan-feat-value">5 Stück</span></li>
							<li><span class="plan-feat-label">KI-Polish</span><span class="plan-feat-value">10 insgesamt</span></li>
							<li><span class="plan-feat-label">Aufnahmedauer</span><span class="plan-feat-value">5 Minuten</span></li>
						</ul>
						<a href="https://n.slax.com/" class="btn-primary">Erst mal ausprobieren</a>
					</div>

					<!-- PREMIUM — MONTHLY -->
					<div class="plan">
						<div class="plan-eyebrow">Monthly</div>
						<div class="plan-price">
							<span class="num">$4.99</span><span class="unit">/ Monat</span>
						</div>
						<p class="plan-note">Jederzeit kündbar.</p>
						<ul class="plan-list">
							<li><span class="plan-feat-label">Sprachnotizen</span><span class="plan-feat-value">Unbegrenzt</span></li>
							<li><span class="plan-feat-label">KI-Polish</span><span class="plan-feat-value">300 pro Tag</span></li>
							<li><span class="plan-feat-label">Aufnahmedauer</span><span class="plan-feat-value">30 Minuten</span></li>
							<li><span class="plan-feat-label">Polish-Qualität</span><span class="plan-feat-value">Premium</span></li>
						</ul>
						<div class="plan-actions">
							<a
								class="btn-primary"
								href="https://apps.apple.com/us/app/slax-note-transcribe-voice-pen/id6480166286"
								target="_blank"
								rel="noopener noreferrer"
							>
								App Store
							</a>
							<a
								class="btn-primary btn-primary-outline"
								href="https://play.google.com/store/apps/details?id=app.slax.notes"
								target="_blank"
								rel="noopener noreferrer"
							>
								Google Play
							</a>
						</div>
					</div>

					<!-- PREMIUM — ANNUAL -->
					<div class="plan featured">
						<div class="plan-eyebrow">
							Annual <span class="plan-badge">2 Monate sparen</span>
						</div>
						<div class="plan-price">
							<span class="num">$49.99</span><span class="unit">/ Jahr</span>
						</div>
						<p class="plan-note">Entspricht 4,16 $/Monat. Jederzeit kündbar.</p>
						<ul class="plan-list">
							<li><span class="plan-feat-label">Sprachnotizen</span><span class="plan-feat-value">Unbegrenzt</span></li>
							<li><span class="plan-feat-label">KI-Polish</span><span class="plan-feat-value">300 pro Tag</span></li>
							<li><span class="plan-feat-label">Aufnahmedauer</span><span class="plan-feat-value">30 Minuten</span></li>
							<li><span class="plan-feat-label">Polish-Qualität</span><span class="plan-feat-value">Premium</span></li>
						</ul>
						<div class="plan-actions">
							<a
								class="btn-primary"
								href="https://apps.apple.com/us/app/slax-note-transcribe-voice-pen/id6480166286"
								target="_blank"
								rel="noopener noreferrer"
							>
								App Store
							</a>
							<a
								class="btn-primary btn-primary-outline"
								href="https://play.google.com/store/apps/details?id=app.slax.notes"
								target="_blank"
								rel="noopener noreferrer"
							>
								Google Play
							</a>
						</div>
					</div>
				</div>
			</div>
		</section>

		<!-- FAQ -->
		<section class="faq">
			<div class="faq-inner">
				<h2 class="faq-head">Häufige Fragen</h2>
				<p class="faq-sub">
					Weitere Fragen oder Vorschläge? Erreich uns auf
					<a href="https://discord.gg/kznNsZvWSk">Discord</a> oder per E-Mail an
					<a href="mailto:note@slax.com">note@slax.com</a>.
				</p>
				<FaqList items={faqs} />
			</div>
		</section>

		<!-- DOWNLOAD -->
		<DownloadSection platforms={notePlatforms}>
			<Fragment slot="heading">
				Slax Note — <em>aus deiner Stimme wird sauberer Text.</em>
			</Fragment>
			<Fragment slot="dek">
				Kostenlos für iOS und Android.
			</Fragment>
		</DownloadSection>

		<!-- FINALE -->
		<section class="finale">
			<div class="finale-inner">
				<h2 class="finale-h">Jede <em>Idee</em> festhalten.</h2>
				<p class="finale-p">
					Kostenlos für iPhone, Android und Web.
				</p>
				<div class="actions actions-center">
					<Button variant="primary" href="https://n.slax.com/" arrow>Slax Note öffnen</Button>
					<Button variant="secondary" href="#pricing">Preise ansehen</Button>
				</div>
			</div>
		</section>
	</main>

	<Footer />
</Base>

<style>
	/* HERO */
	.n-hero {
		padding: 6rem 0 5rem;
	}
	.n-hero-inner {
		max-width: 1180px;
		margin: 0 auto;
		padding: 0 2rem;
		display: grid;
		grid-template-columns: 1fr;
		gap: 4rem;
		align-items: center;
	}
	@media (min-width: 960px) {
		.n-hero-inner {
			grid-template-columns: 1.1fr 1fr;
		}
	}
	.n-h1 {
		font-family: var(--serif);
		font-weight: 400;
		font-size: clamp(2rem, 4vw, 3.2rem);
		line-height: 1.1;
		letter-spacing: -0.02em;
		margin: 1rem 0 1.75rem;
		color: var(--ink);
		max-width: 20ch;
	}
	.n-h1 :global(em) {
		font-style: italic;
		font-weight: 300;
		color: var(--accent);
	}
	.n-bullets {
		list-style: none;
		padding: 0;
		margin: 0 0 2.25rem;
		display: flex;
		flex-direction: column;
		gap: 0.75rem;
		max-width: 48ch;
	}
	.n-bullets li {
		position: relative;
		padding-left: 1.5rem;
		font-family: var(--serif);
		font-size: 1.05rem;
		line-height: 1.55;
		color: var(--ink-soft);
	}
	.n-bullets li::before {
		content: "—";
		position: absolute;
		left: 0;
		top: 0;
		color: var(--ink-mute);
		font-weight: 300;
	}
	.n-stores {
		display: flex;
		gap: 0.75rem;
		flex-wrap: wrap;
	}
	.n-web-link {
		margin: 0.9rem 0 0;
		font-family: var(--serif);
