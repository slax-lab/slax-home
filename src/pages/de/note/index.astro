		video: '/note/videos/click.mp4',
	},
	{
		title: 'Text und Satzzeichen automatisch ordnen',
		body: 'Unsere KI transkribiert deine Stimme präzise und schleift den Text in deinem Ton — inklusive Satzzeichen.',
