const ghostwritingFeatures = [
	{
		title: 'Fertige Stile für jede Situation',
		body: 'Wähl aus eingebauten Stilen — Zusammenfassung, Tweet, Lob und mehr. Weitere folgen.',
		video: '/note/videos/choose-ready-made.mp4',
	},
	{
		title: 'Eigene Prompts für deinen Bedarf',
