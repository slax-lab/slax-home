---
import { getCollection } from 'astro:content';
import BlogListPage from '~/components/BlogListPage.astro';
import { type Locale, PREFIXED_LOCALES } from '~/i18n/locales';
import { entryLocale } from '~/lib/content';

export async function getStaticPaths() {
	return PREFIXED_LOCALES.map((lang) => ({ params: { lang } }));
}

const lang = Astro.params.lang as Locale;
const posts = (
	await getCollection('blog', ({ data, id }) => {
		if (data.draft || data.product !== 'note') return false;
		const entryLang = data.lang ?? entryLocale(id);
		return entryLang === lang;
	})
).sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
---
<BlogListPage
	posts={posts}
	lang={lang}
	productScope="note"
	titleKey="meta.noteBlogTitle"
/>
