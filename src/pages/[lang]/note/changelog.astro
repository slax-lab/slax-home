---
import { getCollection } from 'astro:content';
import ChangelogPage from '~/components/ChangelogPage.astro';
import { type Locale, PREFIXED_LOCALES } from '~/i18n/locales';
import { filterByLocale } from '~/lib/content';

export async function getStaticPaths() {
	return PREFIXED_LOCALES.map((lang) => ({ params: { lang } }));
}

const lang = Astro.params.lang as Locale;
const entries = filterByLocale(await getCollection('noteChangelog'), lang);
---
<ChangelogPage
	entries={entries}
	lang={lang}
	product="note"
	titleKey="meta.noteChangelogTitle"
	ogImage="/og/note-changelog.png"
/>
