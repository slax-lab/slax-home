---
import { getCollection } from 'astro:content';
import AlternativesListPage from '~/components/AlternativesListPage.astro';
import { type Locale, PREFIXED_LOCALES } from '~/i18n/locales';
import { filterByLocale } from '~/lib/content';

export async function getStaticPaths() {
	return PREFIXED_LOCALES.map((lang) => ({ params: { lang } }));
}

const lang = Astro.params.lang as Locale;
const entries = filterByLocale(
	await getCollection('noteAlternatives'),
	lang,
).sort((a, b) => a.data.competitor.localeCompare(b.data.competitor));
---
<AlternativesListPage entries={entries} lang={lang} product="note" />
