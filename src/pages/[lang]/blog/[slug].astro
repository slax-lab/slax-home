---
import { getCollection } from 'astro:content';
import BlogArticlePage from '~/components/BlogArticlePage.astro';
import { type Locale, PREFIXED_LOCALES } from '~/i18n/locales';
import {
	availableLocalesForSlug,
	entrySlug,
	filterByLocale,
} from '~/lib/content';

export async function getStaticPaths() {
	const all = await getCollection('blog');
	const paths: Array<{
		params: { lang: Locale; slug: string };
		props: {
			post: (typeof all)[number];
			slug: string;
			available: Locale[];
		};
	}> = [];
	for (const lang of PREFIXED_LOCALES) {
		const inLang = filterByLocale(all, lang).filter((p) => !p.data.draft);
		for (const post of inLang) {
			const slug = entrySlug(post);
			paths.push({
				params: { lang, slug },
				props: {
					post,
					slug,
					available: availableLocalesForSlug(all, slug),
				},
			});
		}
	}
	return paths;
}

const { post, slug, available } = Astro.props;
const lang = Astro.params.lang as Locale;
---
<BlogArticlePage post={post} slug={slug} lang={lang} availableLocales={available} />
