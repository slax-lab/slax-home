---
import Button from '~/components/Button.astro';
import DownloadSection from '~/components/DownloadSection.astro';
import FaqList from '~/components/FaqList.astro';
import Footer from '~/components/Footer.astro';
import Nav from '~/components/Nav.astro';
import Base from '~/layouts/Base.astro';

// Content sourced verbatim from original apps/reader-home components
// (archive/apps-backup): HomeHero / HomeFeatures / HomeHowItWorks /
// HomeComparison / HomeCTA / PricingTable / DownloadPage.
// Plan decision: merge features + pricing + download into single
// anchor-navigable /reader/ page.

const features = [
	{
		title: 'AI-Powered Understanding',
		body: "Get instant summaries, key insights, and answers to your questions about any article. It's like having a personal tutor for everything you read.",
	},
	{
		title: 'Content Never Dies',
		body: 'Articles saved once are backed up forever. No more "404 Page Not Found" disappointments. Your digital library is truly permanent.',
	},
	{
		title: 'Smart Organization',
		body: 'AI automatically tags and categorizes your content. Find exactly what you need when you need it with powerful semantic search.',
	},
	{
		title: 'Connected Reading',
		body: 'Highlight and comment on any article you save. Share your content and invite others to add insights and discuss. Every article becomes a place for conversation.',
	},
];

const steps = [
	{
		title: 'Save Anything',
		body: 'One click to save articles, papers, or blog posts from anywhere on the web.',
	},
	{
		title: 'AI Analyzes',
		body: 'Instant AI overviews help you decide what deserves deep reading and what to skim. Save time for the best content.',
	},
	{
		title: 'Ask Questions',
		body: 'Chat with AI about your saved content to deepen understanding.',
	},
	{
		title: 'Engage with Your Content',
		body: 'Highlight, comment & discuss with others. What you write is more valuable than what you read.',
	},
];

// Cell value: 'ok' → ● accent,   'no' → — muted,   any other string → inline text (muted italic)
const compareRows: Array<[string, string, string, string]> = [
	['Unlimited free bookmarks (for early users)', 'ok', 'ok', 'Paid'],
	['Permanent content backup', 'ok', 'Paid', 'Paid'],
	['AI outline', 'Paid', 'ok', 'Paid'],
	['Chat with AI while reading', 'Paid', 'no', 'Paid'],
	[
		'Highlight & comment on original pages & snapshots, two-way synced',
		'ok',
		'no',
		'Paid',
	],
	['Join reader discussions', 'ok', 'no', 'Shared only'],
	['AI auto-tagging', 'Paid', 'Manual', 'Manual'],
];

const matrixRows: Array<[string, string, string]> = [
	['Save Unlimited Articles', 'ok', 'ok'],
	['Permanent Snapshots (no broken links)', 'ok', 'ok'],
	['Unlimited Highlights & Comments', 'ok', 'ok'],
	['Full-Text Search', 'ok', 'ok'],
	['Sync Across All Devices', 'ok', 'ok'],
	['Share Articles & Join Discussions', 'ok', 'ok'],
	['Open Source & Privacy-First', 'ok', 'ok'],
	['Create & Manage Tags', 'ok', 'ok'],
	['Smart AI Auto-Tagging', 'no', 'ai'],
	['Instant AI Summaries', 'no', 'ai'],
	['Interactive AI Outlines', 'no', 'ai'],
	['AI Chatbot — Ask Your Library Anything', 'no', 'ai'],
];

const faqs = [
	{
		q: 'Is the Free plan really free forever?',
		a: "Yes — for early users. We're offering unlimited bookmarks and permanent backups at no cost while we're in early access. Lock in free usage now before limits apply.",
	},
	{
		q: 'Will Slax Reader really save me hours of reading every week?',
		a: "That's what it's built for. Clickable AI outlines let you navigate long articles without reading every word. Auto-tagging handles the organizing, so you can just read.",
	},
	{
		q: 'Can I cancel my Pro subscription anytime?',
		a: 'Absolutely. Cancel any time from your account settings with no penalties. Your saved articles and highlights remain accessible on the Free plan.',
	},
	{
		q: 'How does the 1 Month Free trial work?',
		a: "Sign in and start your trial — no credit card required. After 30 days you'll be asked if you'd like to continue with Pro at $5.99 / month (regular price $9.99).",
	},
];

const platforms = [
	{
		icon: '📱',
		title: 'iPhone, iPad, Android',
		bullets: [
			'Save forever, for free.',
			'Save any article with one tap.',
			'Get instant AI outlines and quick navigation.',
			'Cross-platform sync.',
		],
		downloads: [
			{
				href: 'https://apps.apple.com/us/app/slax-reader-ai-read-it-later/id6596730998',
				small: 'Download on the',
				main: 'App Store',
			},
			{
				href: 'https://play.google.com/store/apps/details?id=com.slax.reader',
				small: 'GET IT ON',
				main: 'Google Play',
			},
		],
	},
	{
		icon: '💻',
		title: 'Mac',
		bullets: ['Save, read and organize like a pro.'],
		downloads: [
			{
				href: 'https://apps.apple.com/us/app/slax-reader-ai-read-it-later/id6596730998',
				small: 'Download on the',
				main: 'Mac App Store',
			},
		],
	},
	{
		icon: '🌐',
		title: 'Browser Extension',
		bullets: [
			'One tap to save and back up any web page — yours to keep forever.',
			'AI chat with your articles — right on the same page.',
			'Find what you need fast with powerful semantic search.',
		],
		downloads: [
			{
				href: 'https://chromewebstore.google.com/detail/gdnhaajlomjkhahnmiijphnodkcfikfd?utm_source=web_homepage',
				small: '',
				main: 'Chrome Extension',
			},
		],
	},
];

const schema = {
	'@context': 'https://schema.org',
	'@type': 'SoftwareApplication',
	name: 'Slax Reader',
	applicationCategory: 'ProductivityApplication',
	operatingSystem: 'Web, iOS, iPadOS, Android, macOS',
	url: 'https://slax.com/reader/',
	image: 'https://slax.com/og/reader.png',
	screenshot: 'https://slax.com/reader/hero.png',
	description:
		'Save Forever, Learn faster. Your intelligent library for high efficiency and deep understanding.',
	downloadUrl: [
		'https://apps.apple.com/us/app/slax-reader-ai-read-it-later/id6596730998',
		'https://play.google.com/store/apps/details?id=com.slax.reader',
		'https://chromewebstore.google.com/detail/gdnhaajlomjkhahnmiijphnodkcfikfd',
	],
	offers: [
		{
			'@type': 'Offer',
			name: 'Free',
			price: '0',
			priceCurrency: 'USD',
		},
		{
			'@type': 'Offer',
			name: 'Pro Reader',
			price: '5.99',
			priceCurrency: 'USD',
			priceSpecification: {
				'@type': 'UnitPriceSpecification',
				price: '5.99',
				priceCurrency: 'USD',
				billingDuration: 'P1M',
			},
		},
	],
	publisher: {
		'@type': 'Organization',
		name: 'Slax Lab',
		url: 'https://slax.com',
		logo: 'https://slax.com/images/slax-logo.png',
	},
};
---
<Base
	title="Slax Reader — A read-it-later app that doesn't try to be everything"
	description="No algorithm. No feed. You choose what to read next. Unlimited snapshots, for free. Open-source."
	ogImage="/og/reader.png"
	schema={schema}
>
	<Nav active="reader" />

	<main>
		<!-- HERO -->
		<section class="r-hero">
			<div class="r-hero-inner">
				<div>
					<h1 class="r-h1">
						A read-it-later app <em>that doesn't try to be everything.</em>
					</h1>
					<ul class="r-bullets">
						<li>No algorithm. No feed. You choose what to read next.</li>
						<li>Unlimited snapshots, for free.</li>
						<li>Open-source.</li>
					</ul>
					<div class="r-hero-stores">
						<a
							class="r-store-btn is-primary"
							href="https://apps.apple.com/us/app/slax-reader-ai-read-it-later/id6596730998"
							target="_blank"
							rel="noopener noreferrer"
						>
							<span class="r-store-small">Download on the</span>
							<span class="r-store-main">App Store</span>
						</a>
						<a
							class="r-store-btn"
							href="https://play.google.com/store/apps/details?id=com.slax.reader"
							target="_blank"
							rel="noopener noreferrer"
						>
							<span class="r-store-small">GET IT ON</span>
							<span class="r-store-main">Google Play</span>
						</a>
					</div>
					<p class="r-web-link">
						Or <a href="https://r.slax.com/login">open in your browser</a>.
					</p>
				</div>
				<div class="r-preview" aria-hidden="true">
					<img
						src="/reader/hero.png"
						alt="Slax Reader interface preview"
						loading="eager"
						decoding="async"
					/>
				</div>
			</div>
		</section>

		<!-- FEATURES -->
		<section class="features" id="features">
			<div class="features-inner">
				<div class="features-head">
					<h2 class="features-title">Not Just Another Read-Later Tool</h2>
					<p class="features-sub">
						We're building the future of intelligent reading.
					</p>
				</div>
				<div class="feat-grid">
					{features.map((f, i) => (
						<div class="feat">
							<div class="feat-num">{String(i + 1).padStart(2, '0')}</div>
							<h3 class="feat-h">{f.title}</h3>
							<p class="feat-p">{f.body}</p>
						</div>
					))}
				</div>
			</div>
		</section>

		<!-- HOW IT WORKS -->
		<section class="how">
			<div class="how-inner">
				<h2 class="how-head">From Bookmark to Breakthrough.</h2>
				<p class="how-sub">
					Four simple steps to transform how you read and learn.
				</p>
				<div class="how-steps">
					{steps.map((s, i) => (
						<div class="how-step">
							<div class="how-step-num">{String(i + 1).padStart(2, '0')}</div>
							<h3 class="how-step-h">{s.title}</h3>
							<p class="how-step-body">{s.body}</p>
						</div>
					))}
				</div>
			</div>
		</section>

		<!-- COMPARE -->
		<section class="compare">
			<div class="compare-inner">
				<h2 class="compare-head">Why Readers Are Switching to Slax</h2>
				<p class="compare-sub">
					See how we compare to traditional read-later tools.
				</p>
				<div class="compare-table">
					<div class="compare-row head">
						<div>Feature</div>
						<div class="highlight">Slax Reader</div>
						<div>Instapaper</div>
						<div>Readwise</div>
					</div>
					{compareRows.map((row) => (
						<div class="compare-row">
							<div>{row[0]}</div>
							{[1, 2, 3].map((i) => {
								const v = row[i];
								const isHighlight = i === 1;
								let cls = 'cell';
								let content: string = v;
								if (v === 'ok') {
									cls += ' cell-ok';
									content = '●';
								} else if (v === 'no') {
									cls += ' cell-no';
									content = '—';
								} else {
									cls += ' cell-text';
								}
								if (isHighlight) cls += ' highlight';
								return <div class={cls}>{content}</div>;
							})}
						</div>
					))}
				</div>
				<p class="compare-more">
					<a href="/reader/alternatives/">
						Full comparisons — Readwise, Omnivore, Cubox & more →
					</a>
				</p>
			</div>
		</section>

		<!-- PRICING -->
		<section class="pricing" id="pricing">
			<div class="pricing-inner">
				<h2 class="pricing-head">Read Smarter, <em>Not Just Later.</em></h2>
				<p class="pricing-dek">
					Save Forever, Learn faster. Your intelligent library for high
					efficiency and deep understanding.
				</p>
				<a class="pricing-promo" href="https://r.slax.com/login">
					🎉 Join today and get 1 Month of Pro Free
				</a>

				<div class="plans-grid">
					<div class="plan">
						<div class="plan-eyebrow">Free</div>
						<div class="plan-price">
							<span class="num">$0</span><span class="unit">/ month</span>
						</div>
						<p class="plan-tag">
							Unlimited bookmarks & backup forever — join now before limits
							apply!
						</p>
						<a href="https://r.slax.com/login" class="btn-primary">Start Free</a>
					</div>
					<div class="plan featured">
						<div class="plan-eyebrow">Pro Reader</div>
						<div class="plan-price">
							<span class="num">$5.99</span><span class="unit">/ month</span>
							<span class="was">$9.99</span>
						</div>
						<p class="plan-tag">
							Unleash your reading superpowers with integrated AI analysis.
						</p>
						<a href="https://r.slax.com/login" class="btn-primary">Try 1 Month Free</a>
					</div>
				</div>

				<div class="matrix" aria-label="Feature matrix">
					<div class="matrix-row head">
						<div class="cell-feat">Feature</div>
						<div class="cell">Free</div>
						<div class="cell">Pro Reader</div>
					</div>
					{matrixRows.map((row) => (
						<div class="matrix-row">
							<div class="cell-feat">{row[0]}</div>
							{[1, 2].map((i) => {
								const v = row[i];
								if (v === 'ok') return <div class="cell ok">✓</div>;
								if (v === 'ai') return <div class="cell ai">AI</div>;
								return <div class="cell no">✕</div>;
							})}
						</div>
					))}
				</div>
			</div>
		</section>

		<!-- FAQ -->
		<section class="faq">
			<div class="faq-inner">
				<h2 class="faq-head">Frequently Asked Questions</h2>
				<FaqList items={faqs} />
			</div>
		</section>


		<!-- DOWNLOAD -->
		<DownloadSection platforms={platforms}>
			<Fragment slot="heading">
				Slax Reader — <em>Save Forever. Read Smarter.</em>
			</Fragment>
			<Fragment slot="dek">
				Free to download, available on all your favorite platforms.
			</Fragment>
		</DownloadSection>

		<!-- FINALE -->
		<section class="finale">
			<div class="finale-inner">
				<h2 class="finale-h">
					Start Your <em>Intelligent</em> Reading Journey Today
				</h2>
				<p class="finale-p">Read smarter, learn faster, remember more.</p>
				<div class="actions actions-center">
					<Button variant="primary" href="https://r.slax.com/login" arrow>
						Get Started — It's Free
					</Button>
					<Button variant="secondary" href="https://github.com/slax-lab/slax-reader">
						Read the code
					</Button>
				</div>
			</div>
		</section>
	</main>

	<Footer />
</Base>

<style>
	/* HERO */
	.r-hero {
		padding: 6rem 0 5rem;
	}
	.r-hero-inner {
		max-width: 1180px;
		margin: 0 auto;
		padding: 0 2rem;
		display: grid;
		grid-template-columns: 1fr;
		gap: 4rem;
		align-items: center;
	}
	@media (min-width: 960px) {
		.r-hero-inner {
			grid-template-columns: 1.1fr 1fr;
		}
	}
	.r-h1 {
		font-family: var(--serif);
		font-weight: 400;
		font-size: clamp(2rem, 4vw, 3.2rem);
		line-height: 1.1;
		letter-spacing: -0.02em;
		margin: 1rem 0 1.75rem;
		color: var(--ink);
		max-width: 22ch;
	}
	.r-h1 :global(em) {
		font-style: italic;
		font-weight: 300;
		color: var(--accent);
	}
	.r-bullets {
		list-style: none;
		padding: 0;
		margin: 0 0 2.25rem;
		display: flex;
		flex-direction: column;
		gap: 0.75rem;
		max-width: 48ch;
	}
	.r-bullets li {
		position: relative;
		padding-left: 1.5rem;
		font-family: var(--serif);
		font-size: 1.05rem;
		line-height: 1.55;
		color: var(--ink-soft);
	}
	.r-bullets li::before {
		content: "—";
		position: absolute;
		left: 0;
		top: 0;
		color: var(--ink-mute);
		font-weight: 300;
	}
	.r-hero-stores {
		display: flex;
		gap: 0.75rem;
		flex-wrap: wrap;
	}
	.r-web-link {
		margin: 0.9rem 0 0;
		font-family: var(--serif);
		font-size: 0.95rem;
		color: var(--ink-mute);
	}
	.r-web-link a {
		color: var(--ink-soft);
		text-decoration: underline;
		text-decoration-color: var(--rule);
		text-underline-offset: 3px;
		transition: color 0.2s ease, text-decoration-color 0.2s ease;
	}
	.r-web-link a:hover {
		color: var(--accent);
		text-decoration-color: var(--accent);
	}
	.r-store-btn {
		display: inline-flex;
		flex-direction: column;
		align-items: flex-start;
		gap: 0.15rem;
		background: transparent;
		color: var(--ink);
		text-decoration: none;
		padding: 0.7rem 1.2rem;
		border: 1px solid var(--ink);
		transition:
			background 0.2s ease,
			color 0.2s ease;
		min-width: 160px;
	}
	.r-store-btn:hover {
		background: var(--ink);
		color: var(--bg);
	}
	.r-store-btn.is-primary,
	.r-store-btn.is-primary:hover {
		background: var(--accent);
		border-color: var(--accent);
		color: var(--bg);
	}
	.r-store-btn.is-primary .r-store-small,
	.r-store-btn.is-primary:hover .r-store-small {
		color: var(--bg);
		opacity: 0.8;
	}
	.r-store-small {
		font-family: var(--mono);
		font-size: 0.62rem;
		letter-spacing: 0.08em;
		text-transform: uppercase;
		color: var(--ink-mute);
		line-height: 1.2;
	}
	.r-store-btn:hover .r-store-small {
		color: var(--bg);
		opacity: 0.75;
	}
	.r-store-main {
		font-family: var(--serif);
		font-size: 0.98rem;
		font-weight: 500;
		line-height: 1.3;
	}
	.actions {
		display: flex;
		gap: 1rem;
		flex-wrap: wrap;
		align-items: center;
	}
	.actions-center {
		justify-content: center;
	}
	.r-preview {
		display: flex;
		justify-content: center;
	}
	.r-preview img {
		display: block;
		width: 100%;
		height: auto;
		max-width: 480px;
	}

	/* FEATURES */
	.features {
		padding: var(--section-pad) 0;
		border-top: 1px solid var(--rule-soft);
	}
	.features-inner {
		max-width: 1180px;
		margin: 0 auto;
		padding: 0 2rem;
	}
	.features-head {
		margin-bottom: 4rem;
	}
	.features-title {
		font-family: var(--serif);
		font-weight: 400;
		font-size: clamp(1.8rem, 3vw, 2.4rem);
		line-height: 1.15;
		letter-spacing: -0.02em;
		margin: 1rem 0 0.5rem;
	}
	.features-sub {
		font-family: var(--serif);
		font-size: 1.1rem;
		color: var(--ink-soft);
		margin: 0;
		max-width: 44ch;
	}
	.feat-grid {
		display: grid;
		grid-template-columns: 1fr;
		gap: 0;
		border-top: 1px solid var(--rule);
	}
	@media (min-width: 760px) {
		.feat-grid {
			grid-template-columns: 1fr 1fr;
		}
	}
	@media (min-width: 1040px) {
		.feat-grid {
			grid-template-columns: repeat(4, 1fr);
		}
	}
	.feat {
		padding: 2.5rem 2rem;
		border-bottom: 1px solid var(--rule);
	}
	@media (min-width: 760px) {
		.feat:nth-child(2n) {
			border-left: 1px solid var(--rule);
		}
	}
	@media (min-width: 1040px) {
		.feat:nth-child(2n) {
			border-left: 0;
		}
		.feat:not(:nth-child(4n + 1)) {
			border-left: 1px solid var(--rule);
		}
	}
	.feat-num {
		font-family: var(--mono);
		font-size: 0.7rem;
		letter-spacing: 0.2em;
		color: var(--ink-mute);
		margin-bottom: 1.5rem;
	}
	.feat-h {
		font-family: var(--serif);
		font-weight: 500;
		font-size: 1.2rem;
		letter-spacing: -0.015em;
		margin: 0 0 0.75rem;
		line-height: 1.25;
	}
	.feat-p {
		font-family: var(--serif);
		font-size: 0.98rem;
		line-height: 1.55;
		color: var(--ink-soft);
		margin: 0;
		max-width: 38ch;
	}

	/* HOW */
	.how {
		padding: var(--section-pad) 0;
		border-top: 1px solid var(--rule-soft);
		background: var(--bg-deep);
	}
	.how-inner {
		max-width: 1180px;
		margin: 0 auto;
		padding: 0 2rem;
	}
	.how-head {
		font-family: var(--serif);
		font-weight: 400;
		font-size: clamp(1.8rem, 3vw, 2.4rem);
		line-height: 1.15;
		letter-spacing: -0.02em;
		margin: 1rem 0 0.5rem;
	}
	.how-sub {
		font-family: var(--serif);
		font-size: 1.1rem;
		color: var(--ink-soft);
		margin: 0 0 4rem;
	}
	.how-steps {
		display: grid;
		grid-template-columns: 1fr;
		gap: 2.5rem;
	}
	@media (min-width: 820px) {
		.how-steps {
			grid-template-columns: repeat(4, 1fr);
		}
	}
	.how-step {
		text-align: left;
	}
	.how-step-num {
		font-family: var(--mono);
		font-size: 0.7rem;
		letter-spacing: 0.2em;
		color: var(--ink-mute);
		margin: 0 0 1.5rem;
	}
	.how-step-h {
		font-family: var(--serif);
		font-weight: 500;
		font-size: 1.3rem;
		letter-spacing: -0.015em;
		line-height: 1.2;
		margin: 0 0 0.6rem;
