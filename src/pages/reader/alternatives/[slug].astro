---
import { getCollection } from 'astro:content';
import AlternativePage from '~/components/AlternativePage.astro';
import {
	availableLocalesForSlug,
	entrySlug,
	filterByLocale,
} from '~/lib/content';

export async function getStaticPaths() {
	const all = await getCollection('readerAlternatives');
	const en = filterByLocale(all, 'en');
	return en.map((entry) => {
		const slug = entrySlug(entry);
		return {
			params: { slug },
			props: { entry, slug, available: availableLocalesForSlug(all, slug) },
		};
	});
}

const { entry, slug, available } = Astro.props;
---
<AlternativePage
	entry={entry}
	slug={slug}
	lang="en"
	availableLocales={available}
	product="reader"
/>
