---
import type { CollectionEntry } from 'astro:content';
import { getCollection, render } from 'astro:content';
import Footer from '~/components/Footer.astro';
import Nav from '~/components/Nav.astro';
import Base from '~/layouts/Base.astro';

export async function getStaticPaths() {
	const entries = await getCollection('readerAlternatives');
	return entries.map((entry) => ({
		params: { slug: entry.id },
		props: entry,
	}));
}

type Props = CollectionEntry<'readerAlternatives'>;
const entry = Astro.props;
const { Content } = await render(entry);
---
<Base title={`${entry.data.title} — Slax`} description={entry.data.description}>
	<Nav active="reader" />
	<article class="article">
		<header class="article-head">
			<div class="crumb">
				<a href="/reader/alternatives/">Reader alternatives</a>
			</div>
			<h1>{entry.data.title}</h1>
			<p class="dek">{entry.data.description}</p>
		</header>
		<div class="prose">
			<Content />
		</div>
	</article>
	<Footer />
</Base>

<style>
	.article {
		max-width: 680px;
		margin: 0 auto;
		padding: 5rem 2rem 6rem;
	}
	.article-head {
		margin-bottom: 4rem;
	}
	.crumb {
		font-family: var(--mono);
		font-size: 0.78rem;
		letter-spacing: 0.12em;
		text-transform: uppercase;
		color: var(--ink-mute);
		margin-bottom: 1.5rem;
	}
	.crumb a {
		color: inherit;
		text-decoration: none;
		border-bottom: 1px dotted var(--ink-mute);
	}
	.crumb a:hover {
		color: var(--accent);
		border-color: var(--accent);
	}
	h1 {
		font-family: var(--serif);
		font-weight: 400;
		font-size: clamp(2.2rem, 4vw, 3.4rem);
		line-height: 1.1;
		letter-spacing: -0.02em;
		margin: 0 0 1.25rem;
	}
	.dek {
		font-family: var(--serif);
		font-style: italic;
		font-size: 1.25rem;
		line-height: 1.4;
		color: var(--ink-soft);
		max-width: 48ch;
		margin: 0;
	}
</style>
