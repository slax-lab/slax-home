---
import { getCollection } from 'astro:content';
import ChangelogPage from '~/components/ChangelogPage.astro';
import { filterByLocale } from '~/lib/content';

const entries = filterByLocale(await getCollection('readerChangelog'), 'en');
---
<ChangelogPage
	entries={entries}
	lang="en"
	product="reader"
	titleKey="meta.readerChangelogTitle"
	ogImage="/og/reader-changelog.png"
/>
