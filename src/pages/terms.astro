---
import { getCollection, getEntry } from 'astro:content';
import LegalPage from '~/components/LegalPage.astro';
import { availableLocalesForSlug, entryLocale } from '~/lib/content';

const entry = await getEntry('legal', 'en/terms');
if (!entry) throw new Error('Missing legal/en/terms.mdx');

const all = await getCollection('legal');
const available = availableLocalesForSlug(all, 'terms').length
	? availableLocalesForSlug(all, 'terms')
	: [entryLocale(entry)];
---
<LegalPage
	entry={entry}
	lang="en"
	availableLocales={available}
	titleKey="meta.termsTitle"
/>
