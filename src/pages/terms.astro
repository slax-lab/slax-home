---
import Footer from '~/components/Footer.astro';
import Nav from '~/components/Nav.astro';
import Base from '~/layouts/Base.astro';
---
<Base
	title="Terms of Service — Slax"
	description="Terms of Service covering Slax Reader, Slax Note, and all Slax products."
>
	<Nav />
	<main class="legal">
		<header class="legal__head">
			<p class="legal__eyebrow">Legal</p>
			<h1>Terms of Service</h1>
			<p class="legal__date">Last updated April 20, 2026</p>
		</header>

		<article class="legal__body">
			<section>
				<h2>Acceptance of Terms</h2>
				<p>By accessing and using Slax — including Slax Reader, Slax Note, and any other Slax products or services (collectively, "Slax") — you accept and agree to be bound by these Terms of Service. If you do not agree to these terms, you should not use Slax.</p>
			</section>

			<section>
				<h2>Use of the Application</h2>
				<p>Slax is intended for your personal, non-commercial use. Any use of Slax that is illegal or infringes upon the rights of others is prohibited. You agree not to engage in any behavior that disrupts or interferes with the functioning of Slax.</p>
			</section>

			<section>
				<h2>Intellectual Property</h2>
				<p>The content, design, and software of Slax are protected by international copyright and trademark laws. You may not copy, reproduce, or distribute any part of Slax without our express written consent.</p>
			</section>

			<section>
				<h2>Open Source Software</h2>
				<p>Slax is built on open source software. You are allowed to access, modify, and distribute the source code under the terms of the specific open source license. However, the distribution of the modified application on platforms such as the App Store is strictly prohibited.</p>
			</section>

			<section>
				<h2>Changes to the Terms</h2>
				<p>We reserve the right to modify these Terms of Service at any time. Changes will be effective immediately upon posting on this page. Your continued use of Slax after any changes signifies your acceptance of the revised terms.</p>
			</section>

			<section>
				<h2>Limitation of Liability</h2>
				<p>Slax is provided "as is" without any guarantees or warranties, express or implied. To the extent permitted by law, we will not be liable for any loss or damage arising from your use of Slax.</p>
			</section>

			<section>
				<h2>Contact Us</h2>
				<p>If you have any questions about these Terms of Service, please contact us at <a href="mailto:hello@slax.com">hello@slax.com</a>.</p>
			</section>

			<section>
				<h2>Governing Law</h2>
				<p>These terms and conditions are governed by and construed in accordance with the laws of the jurisdiction where we are based.</p>
			</section>

			<p class="legal__closing">By using Slax, you signify your acceptance of these Terms of Service. Thank you for choosing us.</p>
		</article>
	</main>
	<Footer />
</Base>

<style>
	.legal {
		max-width: 720px;
		margin: 0 auto;
		padding: 7rem 2rem 6rem;
	}
	.legal__head {
		border-bottom: 1px solid var(--rule);
		padding-bottom: 2.5rem;
		margin-bottom: 3rem;
	}
	.legal__eyebrow {
		font-family: var(--mono);
		font-size: 0.78rem;
		letter-spacing: 0.12em;
		text-transform: uppercase;
		color: var(--ink-mute);
		margin: 0 0 1.25rem;
	}
	.legal__head h1 {
		font-family: var(--serif);
		font-weight: 400;
		font-size: clamp(2.4rem, 4.5vw, 3.5rem);
		line-height: 1.1;
		letter-spacing: -0.02em;
		margin: 0 0 1rem;
		color: var(--ink);
	}
	.legal__date {
		font-family: var(--mono);
		font-size: 0.8rem;
		letter-spacing: 0.04em;
		color: var(--ink-mute);
		margin: 0;
	}
	.legal__body section {
		margin-bottom: 2.75rem;
	}
	.legal__body h2 {
		font-family: var(--serif);
		font-weight: 500;
		font-size: 1.45rem;
		line-height: 1.3;
		letter-spacing: -0.01em;
		margin: 0 0 1rem;
		color: var(--ink);
	}
	.legal__body p {
		font-family: var(--serif);
		font-size: 1.08rem;
		line-height: 1.7;
		color: var(--ink-soft);
		margin: 0 0 1rem;
	}
	.legal__body a {
		color: var(--accent);
		text-decoration: none;
		border-bottom: 1px solid var(--rule);
		transition: border-color 0.2s ease, color 0.2s ease;
	}
	.legal__body a:hover {
		color: var(--accent-hover);
		border-bottom-color: var(--accent);
	}
	.legal__closing {
		margin-top: 3.5rem;
		padding-top: 2rem;
		border-top: 1px solid var(--rule);
		font-family: var(--serif);
		font-style: italic;
		font-size: 1rem;
		line-height: 1.7;
		color: var(--ink-mute);
	}
</style>
