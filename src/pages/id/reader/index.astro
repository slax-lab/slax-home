---
import Button from '~/components/Button.astro';
import DownloadSection from '~/components/DownloadSection.astro';
import FaqList from '~/components/FaqList.astro';
import Footer from '~/components/Footer.astro';
import Nav from '~/components/Nav.astro';
import Base from '~/layouts/Base.astro';

// Content sourced verbatim from original apps/reader-home components
// (archive/apps-backup): HomeHero / HomeFeatures / HomeHowItWorks /
// HomeComparison / HomeCTA / PricingTable / DownloadPage.
// Plan decision: merge features + pricing + download into single
// anchor-navigable /reader/ page.

const features = [
	{
		title: 'Pemahaman yang dibantu AI',
		body: 'Dapatkan ringkasan, poin kunci, dan jawaban atas apa pun yang kamu tanyakan tentang artikelnya. Seperti membawa tutor pribadi yang membantumu memahami setiap tulisan.',
	},
	{
		title: 'Konten tidak akan hilang',
		body: 'Artikel yang sudah kamu simpan dicadangkan selamanya, jadi kamu tidak perlu khawatir membuka tautan dan melihat "Halaman 404 tidak ditemukan". Perpustakaan digitalmu benar-benar milikmu.',
	},
	{
		title: 'Organisasi cerdas',
		body: 'AI memberi tag dan kategori kontenmu secara otomatis. Saat butuh, pakai pencarian semantik yang kuat untuk menemukan artikel yang tepat.',
	},
	{
		title: 'Membaca yang terhubung',
		body: 'Sorot dan tinggalkan komentar di artikel yang kamu simpan. Bagikan dan undang orang lain ikut diskusi. Setiap artikel jadi panggung percakapan.',
	},
];

const steps = [
	{
		title: 'Simpan apa saja',
		body: 'Satu ketukan untuk menyimpan artikel, makalah, atau postingan blog apa pun di internet.',
	},
	{
		title: 'AI otomatis menganalisis',
		body: 'Tinjauan yang dihasilkan AI membantumu memutuskan mana yang layak dibaca dalam, mana yang cukup dipindai. Sisihkan waktu untuk yang terbaik.',
	},
	{
		title: 'Tanyakan ke AI',
		body: 'Ngobrol dengan AI tentang konten yang kamu simpan, dorong pemahaman lebih dalam.',
	},
	{
		title: 'Berinteraksi dengan konten secara mendalam',
		body: 'Sorot, komentari, diskusi dengan orang lain. Yang kamu tulis lebih berharga daripada yang kamu baca.',
	},
];

// Cell value: 'ok' → ● accent,   'no' → — muted,   any other string → inline text (muted italic)
const compareRows: Array<[string, string, string, string]> = [
	['Simpanan gratis tanpa batas (early user)', 'ok', 'ok', 'Berbayar'],
	['Cadangan konten permanen', 'ok', 'Berbayar', 'Berbayar'],
	['Kerangka AI', 'Berbayar', 'ok', 'Berbayar'],
	['Ngobrol dengan AI saat membaca', 'Berbayar', 'no', 'Berbayar'],
	[
		'Sorotan & komentar di teks asli dan snapshot, sinkron dua arah',
		'ok',
		'no',
		'Berbayar',
	],
	['Ikut diskusi pembaca', 'ok', 'no', 'Hanya berbagi'],
	['Penandaan otomatis AI', 'Berbayar', 'Manual', 'Manual'],
];

const matrixRows: Array<[string, string, string]> = [
	['Simpan artikel tanpa batas', 'ok', 'ok'],
	['Snapshot permanen (tanpa tautan mati)', 'ok', 'ok'],
	['Sorotan & komentar tanpa batas', 'ok', 'ok'],
	['Pencarian teks penuh', 'ok', 'ok'],
	['Sinkron lintas perangkat', 'ok', 'ok'],
	['Bagikan artikel dan ikut diskusi', 'ok', 'ok'],
	['Sumber terbuka dan mengutamakan privasi', 'ok', 'ok'],
	['Buat dan kelola tag', 'ok', 'ok'],
	['Penandaan otomatis AI cerdas', 'no', 'ai'],
	['Ringkasan AI instan', 'no', 'ai'],
	['Kerangka AI interaktif', 'no', 'ai'],
	['Chat AI — tanyakan ke pustakamu', 'no', 'ai'],
];

const faqs = [
	{
		q: 'Apakah paket gratis benar-benar gratis selamanya?',
		a: 'Ya — untuk early user. Selama tahap akses awal, kami sediakan simpanan tanpa batas dan cadangan permanen, semuanya gratis. Mumpung belum ada batasan, kunci kuota gratismu sekarang.',
	},
	{
		q: 'Apakah Slax Reader benar-benar bisa menghematkan beberapa jam waktu membaca per minggu?',
		a: 'Ini memang dibangun untuk itu. Kerangka AI yang bisa diklik memungkinkanmu melompati artikel panjang, tanpa baca kata demi kata. Penandaan otomatis menyelesaikan organisasi untukmu, kamu tinggal membaca.',
	},
	{
		q: 'Apakah langganan Pro bisa dibatalkan kapan saja?',
		a: 'Tentu. Batalkan kapan saja di pengaturan akun tanpa biaya. Artikel dan sorotan yang sudah kamu simpan tetap bisa diakses di paket gratis.',
	},
	{
		q: 'Bagaimana cara pakai uji coba gratis 1 bulan?',
		a: 'Setelah login langsung bisa mulai uji coba, tanpa kartu kredit. Setelah 30 hari kami akan tanya apakah kamu mau lanjut Pro dengan harga $5.99 / bulan (harga asli $9.99).',
	},
];

const platforms = [
	{
		icon: '📱',
		title: 'iPhone, iPad, Android',
		bullets: [
			'Simpan permanen, sepenuhnya gratis.',
			'Satu ketukan untuk menyimpan artikel apa pun.',
			'Dapatkan kerangka AI instan, baca-lompat dengan cepat.',
			'Sinkron lintas platform.',
		],
		downloads: [
			{
				href: 'https://apps.apple.com/us/app/slax-reader-ai-read-it-later/id6596730998',
				small: 'Unduh di',
				main: 'App Store',
			},
			{
				href: 'https://play.google.com/store/apps/details?id=com.slax.reader',
				small: 'Dapatkan di',
				main: 'Google Play',
			},
		],
	},
	{
		icon: '💻',
		title: 'Mac',
		bullets: ['Simpan, baca, atur seperti pemain pro.'],
		downloads: [
			{
				href: 'https://apps.apple.com/us/app/slax-reader-ai-read-it-later/id6596730998',
				small: 'Unduh di',
				main: 'Mac App Store',
			},
		],
	},
	{
		icon: '🌐',
		title: 'Ekstensi browser',
		bullets: [
			'Satu klik untuk menyimpan dan mencadangkan halaman web mana pun — selamanya milikmu.',
			'Langsung di halaman asli, ngobrol dengan AI tentang artikelnya.',
			'Dengan pencarian semantik yang kuat, temukan kontenmu dalam hitungan detik.',
		],
		downloads: [
			{
				href: 'https://chromewebstore.google.com/detail/gdnhaajlomjkhahnmiijphnodkcfikfd?utm_source=web_homepage',
				small: '',
				main: 'Chrome Extension',
			},
		],
	},
];

const schema = {
	'@context': 'https://schema.org',
	'@type': 'SoftwareApplication',
	name: 'Slax Reader',
	applicationCategory: 'ProductivityApplication',
	operatingSystem: 'Web, iOS, iPadOS, Android, macOS',
	url: 'https://slax.com/reader/',
	image: 'https://slax.com/og/reader.png',
	screenshot: 'https://slax.com/reader/hero.png',
	description:
		'Alat baca-nanti yang sumber terbuka dan murni. Simpan permanen, belajar lebih cepat. Perpustakaan pintar milikmu, membuat membaca lebih efisien dan pemahaman lebih dalam.',
	downloadUrl: [
		'https://apps.apple.com/us/app/slax-reader-ai-read-it-later/id6596730998',
		'https://play.google.com/store/apps/details?id=com.slax.reader',
		'https://chromewebstore.google.com/detail/gdnhaajlomjkhahnmiijphnodkcfikfd',
	],
	offers: [
		{
			'@type': 'Offer',
			name: 'Free',
			price: '0',
			priceCurrency: 'USD',
		},
		{
			'@type': 'Offer',
			name: 'Pro Reader',
			price: '5.99',
			priceCurrency: 'USD',
			priceSpecification: {
				'@type': 'UnitPriceSpecification',
				price: '5.99',
				priceCurrency: 'USD',
				billingDuration: 'P1M',
			},
		},
	],
	publisher: {
		'@type': 'Organization',
		name: 'Slax Lab',
		url: 'https://slax.com',
		logo: 'https://slax.com/images/slax-logo.png',
	},
};
---
<Base
	title="Slax Reader — Alat baca-nanti yang sumber terbuka dan murni"
	description="Alat baca-nanti yang sumber terbuka dan murni. Tanpa algoritma, tanpa feed. Bacaan berikutnya kamu yang putuskan. Snapshot tanpa batas, sepenuhnya gratis."
	ogImage="/og/reader.png"
	schema={schema}
>
	<Nav active="reader" />

	<main>
		<!-- HERO -->
		<section class="r-hero">
			<div class="r-hero-inner">
				<div>
					<h1 class="r-h1">
						Alat baca-nanti yang <em>sumber terbuka dan murni.</em>
					</h1>
					<ul class="r-bullets">
						<li>Tanpa algoritma, tanpa feed. Bacaan berikutnya kamu yang putuskan.</li>
						<li>Snapshot tanpa batas, sepenuhnya gratis.</li>
						<li>Sumber terbuka.</li>
					</ul>
					<div class="r-hero-stores">
						<a
							class="r-store-btn is-primary"
							href="https://apps.apple.com/us/app/slax-reader-ai-read-it-later/id6596730998"
							target="_blank"
							rel="noopener noreferrer"
						>
							<span class="r-store-small">Unduh di</span>
							<span class="r-store-main">App Store</span>
						</a>
						<a
							class="r-store-btn"
							href="https://play.google.com/store/apps/details?id=com.slax.reader"
							target="_blank"
							rel="noopener noreferrer"
						>
							<span class="r-store-small">Dapatkan di</span>
							<span class="r-store-main">Google Play</span>
						</a>
					</div>
					<p class="r-web-link">
						Atau <a href="https://r.slax.com">buka versi web</a>.
					</p>
				</div>
				<div class="r-preview" aria-hidden="true">
					<img
						src="/reader/hero.png"
						alt="Pratinjau antarmuka Slax Reader"
						loading="eager"
						decoding="async"
					/>
				</div>
			</div>
		</section>

		<!-- FEATURES -->
		<section class="features" id="features">
			<div class="features-inner">
				<div class="features-head">
					<h2 class="features-title">Bukan sekadar alat baca-nanti lain</h2>
					<p class="features-sub">
						Yang kami buat adalah bentuk berikutnya dari membaca cerdas.
					</p>
				</div>
				<div class="feat-grid">
					{features.map((f, i) => (
						<div class="feat">
							<div class="feat-num">{String(i + 1).padStart(2, '0')}</div>
							<h3 class="feat-h">{f.title}</h3>
							<p class="feat-p">{f.body}</p>
						</div>
					))}
				</div>
			</div>
		</section>

		<!-- HOW IT WORKS -->
		<section class="how">
			<div class="how-inner">
				<h2 class="how-head">Dari satu simpanan, jadi satu pencerahan.</h2>
				<p class="how-sub">
					Empat langkah sederhana yang mengubah cara kamu membaca dan belajar.
				</p>
				<div class="how-steps">
					{steps.map((s, i) => (
						<div class="how-step">
							<div class="how-step-num">{String(i + 1).padStart(2, '0')}</div>
							<h3 class="how-step-h">{s.title}</h3>
							<p class="how-step-body">{s.body}</p>
						</div>
					))}
				</div>
			</div>
		</section>

		<!-- COMPARE -->
		<section class="compare">
			<div class="compare-inner">
				<h2 class="compare-head">Kenapa pembaca beralih ke Slax</h2>
				<p class="compare-sub">
					Lihat jarak kami dengan alat baca-nanti tradisional.
				</p>
				<div class="compare-table">
					<div class="compare-row head">
						<div>Fitur</div>
						<div class="highlight">Slax Reader</div>
						<div>Instapaper</div>
						<div>Readwise</div>
					</div>
					{compareRows.map((row) => (
						<div class="compare-row">
							<div>{row[0]}</div>
							{[1, 2, 3].map((i) => {
								const v = row[i];
								const isHighlight = i === 1;
								let cls = 'cell';
								let content: string = v;
								if (v === 'ok') {
									cls += ' cell-ok';
									content = '●';
								} else if (v === 'no') {
									cls += ' cell-no';
									content = '—';
								} else {
									cls += ' cell-text';
								}
								if (isHighlight) cls += ' highlight';
								return <div class={cls}>{content}</div>;
							})}
						</div>
					))}
				</div>
				<p class="compare-more">
					<a href="/id/reader/alternatives/">
						Perbandingan lengkap — Readwise, Omnivore, Cubox, dll. →
					</a>
				</p>
			</div>
		</section>

		<!-- PRICING -->
		<section class="pricing" id="pricing">
			<div class="pricing-inner">
				<h2 class="pricing-head">Membaca lebih pintar, <em>bukan sekadar "nanti".</em></h2>
				<p class="pricing-dek">
					Simpan permanen, belajar lebih cepat. Perpustakaan pintar milikmu, membuat membaca lebih efisien dan pemahaman lebih dalam.
				</p>
				<a class="pricing-promo" href="https://r.slax.com">
					🎉 Gabung hari ini, dapat 1 bulan Pro gratis
				</a>

				<div class="plans-grid">
					<div class="plan">
						<div class="plan-eyebrow">Free</div>
						<div class="plan-price">
							<span class="num">$0</span><span class="unit">/ bulan</span>
						</div>
						<p class="plan-tag">
							Simpanan tanpa batas, cadangan permanen — mumpung belum ada batasan, langsung gabung!
						</p>
						<a href="https://r.slax.com" class="btn-primary">Mulai gratis</a>
					</div>
					<div class="plan featured">
						<div class="plan-eyebrow">Pro Reader</div>
						<div class="plan-price">
							<span class="num">$5.99</span><span class="unit">/ bulan</span>
							<span class="was">$9.99</span>
						</div>
						<p class="plan-tag">
							Akses analisis AI, dorong kemampuan membacamu ke batas.
						</p>
						<a href="https://r.slax.com" class="btn-primary">Uji coba gratis 1 bulan</a>
					</div>
				</div>

				<div class="matrix" aria-label="Tabel perbandingan fitur">
					<div class="matrix-row head">
						<div class="cell-feat">Fitur</div>
						<div class="cell">Free</div>
						<div class="cell">Pro Reader</div>
					</div>
					{matrixRows.map((row) => (
						<div class="matrix-row">
							<div class="cell-feat">{row[0]}</div>
							{[1, 2].map((i) => {
								const v = row[i];
								if (v === 'ok') return <div class="cell ok">✓</div>;
								if (v === 'ai') return <div class="cell ai">AI</div>;
								return <div class="cell no">✕</div>;
							})}
						</div>
					))}
				</div>
			</div>
		</section>

		<!-- FAQ -->
		<section class="faq">
			<div class="faq-inner">
				<h2 class="faq-head">Pertanyaan yang sering ditanyakan</h2>
				<FaqList items={faqs} />
			</div>
		</section>


		<!-- DOWNLOAD -->
		<DownloadSection platforms={platforms}>
			<Fragment slot="heading">
				Slax Reader — <em>Simpan permanen, baca lebih pintar.</em>
			</Fragment>
			<Fragment slot="dek">
				Unduh gratis di semua platform yang biasa kamu pakai.
			</Fragment>
		</DownloadSection>

		<!-- FINALE -->
		<section class="finale">
			<div class="finale-inner">
				<h2 class="finale-h">
					Mulai perjalanan membaca <em>pintarmu</em> hari ini
				</h2>
				<p class="finale-p">Membaca lebih pintar, belajar lebih cepat, mengingat lebih banyak.</p>
				<div class="actions actions-center">
					<Button variant="primary" href="https://r.slax.com" arrow>
						Mulai pakai — sepenuhnya gratis
					</Button>
					<Button variant="secondary" href="https://github.com/slax-lab/slax-reader">
						Lihat kode sumber
					</Button>
				</div>
			</div>
		</section>
	</main>

	<Footer />
</Base>

<style>
	/* HERO */
	.r-hero {
		padding: 6rem 0 5rem;
	}
	.r-hero-inner {
		max-width: 1180px;
		margin: 0 auto;
		padding: 0 2rem;
		display: grid;
		grid-template-columns: 1fr;
		gap: 4rem;
		align-items: center;
	}
	@media (min-width: 960px) {
		.r-hero-inner {
			grid-template-columns: 1.1fr 1fr;
		}
	}
	.r-h1 {
		font-family: var(--serif);
		font-weight: 400;
		font-size: clamp(2rem, 4vw, 3.2rem);
		line-height: 1.1;
		letter-spacing: -0.02em;
		margin: 1rem 0 1.75rem;
		color: var(--ink);
		max-width: 22ch;
	}
	.r-h1 :global(em) {
		font-style: italic;
		font-weight: 300;
		color: var(--accent);
	}
	.r-bullets {
		list-style: none;
		padding: 0;
		margin: 0 0 2.25rem;
		display: flex;
		flex-direction: column;
		gap: 0.75rem;
		max-width: 48ch;
	}
	.r-bullets li {
		position: relative;
		padding-left: 1.5rem;
		font-family: var(--serif);
		font-size: 1.05rem;
		line-height: 1.55;
		color: var(--ink-soft);
	}
	.r-bullets li::before {
		content: "—";
		position: absolute;
		left: 0;
		top: 0;
		color: var(--ink-mute);
		font-weight: 300;
	}
	.r-hero-stores {
		display: flex;
		gap: 0.75rem;
		flex-wrap: wrap;
	}
	.r-web-link {
		margin: 0.9rem 0 0;
		font-family: var(--serif);
		font-size: 0.95rem;
		color: var(--ink-mute);
	}
	.r-web-link a {
		color: var(--ink-soft);
		text-decoration: underline;
		text-decoration-color: var(--rule);
		text-underline-offset: 3px;
		transition: color 0.2s ease, text-decoration-color 0.2s ease;
	}
	.r-web-link a:hover {
		color: var(--accent);
		text-decoration-color: var(--accent);
	}
	.r-store-btn {
		display: inline-flex;
		flex-direction: column;
		align-items: flex-start;
		gap: 0.15rem;
		background: transparent;
		color: var(--ink);
		text-decoration: none;
		padding: 0.7rem 1.2rem;
		border: 1px solid var(--ink);
		transition:
			background 0.2s ease,
			color 0.2s ease;
		min-width: 160px;
	}
	.r-store-btn:hover {
		background: var(--ink);
		color: var(--bg);
	}
	.r-store-btn.is-primary,
	.r-store-btn.is-primary:hover {
		background: var(--accent);
		border-color: var(--accent);
		color: var(--bg);
	}
	.r-store-btn.is-primary .r-store-small,
	.r-store-btn.is-primary:hover .r-store-small {
		color: var(--bg);
		opacity: 0.8;
	}
	.r-store-small {
		font-family: var(--mono);
		font-size: 0.62rem;
		letter-spacing: 0.08em;
		text-transform: uppercase;
		color: var(--ink-mute);
		line-height: 1.2;
	}
	.r-store-btn:hover .r-store-small {
		color: var(--bg);
		opacity: 0.75;
	}
	.r-store-main {
		font-family: var(--serif);
		font-size: 0.98rem;
		font-weight: 500;
		line-height: 1.3;
	}
	.actions {
		display: flex;
		gap: 1rem;
		flex-wrap: wrap;
		align-items: center;
	}
	.actions-center {
		justify-content: center;
	}
	.r-preview {
		display: flex;
		justify-content: center;
	}
	.r-preview img {
		display: block;
		width: 100%;
		height: auto;
		max-width: 480px;
	}

	/* FEATURES */
	.features {
		padding: var(--section-pad) 0;
		border-top: 1px solid var(--rule-soft);
	}
	.features-inner {
		max-width: 1180px;
		margin: 0 auto;
		padding: 0 2rem;
	}
	.features-head {
		margin-bottom: 4rem;
	}
	.features-title {
		font-family: var(--serif);
		font-weight: 400;
		font-size: clamp(1.8rem, 3vw, 2.4rem);
		line-height: 1.15;
		letter-spacing: -0.02em;
		margin: 1rem 0 0.5rem;
	}
	.features-sub {
		font-family: var(--serif);
		font-size: 1.1rem;
		color: var(--ink-soft);
		margin: 0;
		max-width: 44ch;
	}
	.feat-grid {
		display: grid;
		grid-template-columns: 1fr;
		gap: 0;
		border-top: 1px solid var(--rule);
	}
	@media (min-width: 760px) {
		.feat-grid {
			grid-template-columns: 1fr 1fr;
		}
	}
	@media (min-width: 1040px) {
		.feat-grid {
			grid-template-columns: repeat(4, 1fr);
		}
	}
	.feat {
		padding: 2.5rem 2rem;
		border-bottom: 1px solid var(--rule);
	}
	@media (min-width: 760px) {
		.feat:nth-child(2n) {
			border-left: 1px solid var(--rule);
		}
	}
