		a: 'Buka aplikasi, mulai rekam, atau klik "Catatan teks" untuk memasukkan konten, akan masuk ke halaman poles otomatis. Di sini, klik tombol "Default" di sebelah kanan untuk mengganti gaya tulisan, atau bebas membuat gaya yang kamu mau.',
	},
	{
		q: 'Bahasa apa saja yang didukung pengenalan suara Slax Note?',
		a: 'Saat ini mendukung Inggris, Tionghoa, Jerman, Jepang, dan bahasa utama lainnya, ke depan akan ditambah lebih banyak bahasa.',
	},
];

const schema = {
	'@context': 'https://schema.org',
	'@type': 'SoftwareApplication',
	name: 'Slax Note',
	alternateName: 'Slax Note — Catatan Suara AI',
	applicationCategory: 'ProductivityApplication',
	operatingSystem: 'iOS, Android, Web',
	url: new URL('/note/', SITE).toString(),
	image: new URL('/og/note.png', SITE).toString(),
	screenshot: new URL('/images/note/cover.png', SITE).toString(),
	description:
		'Catatan suara AI. Kamu bicara, kami catat. Rekam dengan Slax Note, biarkan AI menangkap idemu dan memolesnya jadi teks dengan gaya apa pun yang kamu mau.',
	downloadUrl: [
		'https://apps.apple.com/us/app/slax-note-transcribe-voice-pen/id6480166286',
		'https://play.google.com/store/apps/details?id=app.slax.notes',
	],
	offers: [
		{
			'@type': 'Offer',
			name: 'Free',
			price: '0',
			priceCurrency: 'USD',
		},
		{
			'@type': 'Offer',
			name: 'Premium Monthly',
			price: '4.99',
			priceCurrency: 'USD',
			priceSpecification: {
				'@type': 'UnitPriceSpecification',
				price: '4.99',
				priceCurrency: 'USD',
				billingDuration: 'P1M',
			},
		},
		{
			'@type': 'Offer',
			name: 'Premium Annual',
			price: '49.99',
			priceCurrency: 'USD',
			priceSpecification: {
				'@type': 'UnitPriceSpecification',
				price: '49.99',
				priceCurrency: 'USD',
				billingDuration: 'P1Y',
			},
		},
	],
	publisher: {
		'@type': 'Organization',
		name: 'Starry Tech Pte. Ltd.',
		url: SITE,
		logo: new URL('/images/slax-logo.png', SITE).toString(),
	},
};
---
<Base
	title="Slax Note — Catatan Suara AI. Kamu bicara, kami catat."
	description="Kamu bicara, kami catat. Satu rekaman, banyak bentuk — dibentuk prompt pilihanmu. Menemanimu tumbuh tahun demi tahun."
	ogImage="/og/note.png"
	schema={schema}
>
	<Nav active="note" />

	<main>
		<!-- HERO -->
		<section class="n-hero">
			<div class="n-hero-inner">
				<div>
					<h1 class="n-h1">
						Catatan Suara AI. <em>Kamu bicara, kami catat.</em>
					</h1>
					<ul class="n-bullets">
						<li>Begitu ide muncul, langsung ucapkan. Tanpa ketik, tanpa rapikan.</li>
						<li>Satu rekaman, banyak bentuk — dibentuk prompt pilihanmu.</li>
						<li>Menemanimu tumbuh tahun demi tahun.</li>
					</ul>
					<div class="n-stores">
						<a
							class="store-btn is-primary"
							href="https://apps.apple.com/us/app/slax-note-transcribe-voice-pen/id6480166286"
							target="_blank"
							rel="noopener noreferrer"
						>
							<span class="store-small">Unduh di</span>
							<span class="store-main">App Store</span>
						</a>
						<a
							class="store-btn"
							href="https://play.google.com/store/apps/details?id=app.slax.notes"
							target="_blank"
							rel="noopener noreferrer"
						>
							<span class="store-small">Dapatkan di</span>
							<span class="store-main">Google Play</span>
						</a>
					</div>
					<p class="n-web-link">
						Atau <a href="https://n.slax.com/">buka versi web</a>.
					</p>
				</div>
				<div class="n-visual">
					<img
						src="/images/note/cover.png"
						alt="Slax Note — Catatan Suara AI"
						class="n-img"
						loading="eager"
					/>
				</div>
			</div>
		</section>

		<!-- EFFICIENCY BOOST -->
		<section class="features" id="features" data-demo-group="efficiency">
			<div class="features-inner">
				<div class="feat-head">
					<h2 class="feat-title">Tingkatkan efisiensi</h2>
					<p class="feat-sub">Sisihkan waktumu untuk yang benar-benar penting.</p>
				</div>
				<div class="feat-demo-body">
					<div class="feat-list" role="tablist" aria-label="Fitur tingkatkan efisiensi">
						{efficiencyFeatures.map((f, i) => (
							<button
								class="feat-item"
								type="button"
								role="tab"
								data-idx={i}
								aria-selected={i === 0 ? 'true' : 'false'}
								aria-controls={`efficiency-video-${i}`}
							>
								<div class="feat-item-head">
									<span class="feat-num">{String(i + 1).padStart(2, '0')}</span>
									<h3 class="feat-h">{f.title}</h3>
								</div>
								<p class="feat-p">{f.body}</p>
							</button>
						))}
					</div>
					<div class="feat-stage">
						<div class="feat-frame">
							{efficiencyFeatures.map((f, i) => (
								<video
									id={`efficiency-video-${i}`}
									class="feat-video"
									data-idx={i}
									src={f.video}
									muted
									loop
									playsinline
									preload={i === 0 ? 'auto' : 'metadata'}
									aria-hidden={i === 0 ? 'false' : 'true'}
								></video>
							))}
						</div>
					</div>
				</div>
			</div>
		</section>

		<!-- INTELLIGENT GHOSTWRITING -->
		<section class="features features-alt" data-demo-group="ghostwriting">
			<div class="features-inner">
				<div class="feat-head">
					<h2 class="feat-title">Penulis bayangan cerdas</h2>
					<p class="feat-sub">Biarkan AI memoles teksmu dengan ringan.</p>
				</div>
				<div class="feat-demo-body feat-demo-body--reverse">
					<div class="feat-stage">
						<div class="feat-frame">
							{ghostwritingFeatures.map((f, i) => (
								<video
									id={`ghostwriting-video-${i}`}
									class="feat-video"
									data-idx={i}
									src={f.video}
									muted
									loop
									playsinline
									preload="metadata"
									aria-hidden={i === 0 ? 'false' : 'true'}
								></video>
							))}
						</div>
					</div>
					<div class="feat-list" role="tablist" aria-label="Fitur penulis bayangan cerdas">
						{ghostwritingFeatures.map((f, i) => (
							<button
								class="feat-item"
								type="button"
								role="tab"
								data-idx={i}
								aria-selected={i === 0 ? 'true' : 'false'}
								aria-controls={`ghostwriting-video-${i}`}
							>
								<div class="feat-item-head">
									<span class="feat-num">{String(i + 1).padStart(2, '0')}</span>
									<h3 class="feat-h">{f.title}</h3>
								</div>
								<p class="feat-p">{f.body}</p>
							</button>
						))}
					</div>
				</div>
			</div>
		</section>

		<!-- USE CASES -->
		<section class="usecases">
			<div class="usecases-inner">
				<h2 class="usecases-head">Bagaimana orang lain memakai Slax Note</h2>
				<div class="uc-grid">
					{useCases.map((uc) => (
						<div class="uc">
							<h3 class="uc-h">{uc.title}</h3>
							<p class="uc-p">{uc.body}</p>
						</div>
					))}
				</div>
			</div>
		</section>

		<!-- TESTIMONIALS -->
		<section class="testimonials">
			<div class="testimonials-inner">
				<h2 class="t-head">Pilihan ribuan pengguna</h2>
				<p class="t-sub">
					Siap mengubah cara kamu mencatat? Saatnya pakai Slax Note.
				</p>
				<div class="t-grid">
					{testimonials.map((t) => (
						<figure class="testimonial">
							<blockquote class="t-quote">"{t.quote}"</blockquote>
							<figcaption class="t-caption">
								<span class="t-author">{t.author}</span>
								<span class="t-title">{t.title}</span>
							</figcaption>
						</figure>
					))}
				</div>
			</div>
		</section>

		<!-- PRICING -->
		<section class="pricing" id="pricing">
			<div class="pricing-inner">
				<h2 class="pricing-head">Harga</h2>
				<p class="pricing-dek">Nikmati harga early-bird, naikkan paketmu sekarang.</p>

				<div class="plans-grid plans-grid-3">
					<!-- FREE -->
					<div class="plan">
						<div class="plan-eyebrow">Free</div>
						<div class="plan-price">
							<span class="num">$0</span>
						</div>
						<p class="plan-note">Gratis seumur hidup.</p>
						<ul class="plan-list">
							<li><span class="plan-feat-label">Catatan suara</span><span class="plan-feat-value">5 buah</span></li>
							<li><span class="plan-feat-label">AI Polish</span><span class="plan-feat-value">10 kali total</span></li>
							<li><span class="plan-feat-label">Durasi rekaman</span><span class="plan-feat-value">5 menit</span></li>
						</ul>
						<a href="https://n.slax.com/" class="btn-primary">Coba dulu</a>
					</div>

					<!-- PREMIUM — MONTHLY -->
					<div class="plan">
						<div class="plan-eyebrow">Monthly</div>
						<div class="plan-price">
							<span class="num">$4.99</span><span class="unit">/ bulan</span>
						</div>
						<p class="plan-note">Bisa berhenti kapan saja.</p>
						<ul class="plan-list">
							<li><span class="plan-feat-label">Catatan suara</span><span class="plan-feat-value">Tanpa batas</span></li>
							<li><span class="plan-feat-label">AI Polish</span><span class="plan-feat-value">300 per hari</span></li>
							<li><span class="plan-feat-label">Durasi rekaman</span><span class="plan-feat-value">30 menit</span></li>
							<li><span class="plan-feat-label">Kualitas polish</span><span class="plan-feat-value">Tingkat lanjut</span></li>
						</ul>
						<div class="plan-actions">
							<a
								class="btn-primary"
								href="https://apps.apple.com/us/app/slax-note-transcribe-voice-pen/id6480166286"
								target="_blank"
								rel="noopener noreferrer"
							>
								App Store
							</a>
							<a
								class="btn-primary btn-primary-outline"
								href="https://play.google.com/store/apps/details?id=app.slax.notes"
								target="_blank"
								rel="noopener noreferrer"
							>
								Google Play
							</a>
						</div>
					</div>

					<!-- PREMIUM — ANNUAL -->
					<div class="plan featured">
						<div class="plan-eyebrow">
							Annual <span class="plan-badge">Hemat 2 bulan</span>
						</div>
						<div class="plan-price">
							<span class="num">$49.99</span><span class="unit">/ tahun</span>
						</div>
						<p class="plan-note">Setara $4.16 / bulan. Bisa berhenti kapan saja.</p>
						<ul class="plan-list">
							<li><span class="plan-feat-label">Catatan suara</span><span class="plan-feat-value">Tanpa batas</span></li>
							<li><span class="plan-feat-label">AI Polish</span><span class="plan-feat-value">300 per hari</span></li>
							<li><span class="plan-feat-label">Durasi rekaman</span><span class="plan-feat-value">30 menit</span></li>
							<li><span class="plan-feat-label">Kualitas polish</span><span class="plan-feat-value">Tingkat lanjut</span></li>
						</ul>
						<div class="plan-actions">
							<a
								class="btn-primary"
								href="https://apps.apple.com/us/app/slax-note-transcribe-voice-pen/id6480166286"
								target="_blank"
								rel="noopener noreferrer"
							>
								App Store
							</a>
							<a
								class="btn-primary btn-primary-outline"
								href="https://play.google.com/store/apps/details?id=app.slax.notes"
								target="_blank"
								rel="noopener noreferrer"
							>
								Google Play
							</a>
						</div>
					</div>
				</div>
			</div>
		</section>

		<!-- FAQ -->
		<section class="faq">
			<div class="faq-inner">
				<h2 class="faq-head">Pertanyaan yang sering ditanyakan</h2>
				<p class="faq-sub">
					Ada pertanyaan atau saran lain, sampaikan ke kami di
					<a href="https://discord.gg/kznNsZvWSk">Discord</a> atau email ke
					<a href="mailto:note@slax.com">note@slax.com</a>.
				</p>
				<FaqList items={faqs} />
			</div>
		</section>

		<!-- DOWNLOAD -->
		<DownloadSection platforms={notePlatforms}>
			<Fragment slot="heading">
				Slax Note — <em>Suaramu, jadi tulisan dengan ringan.</em>
			</Fragment>
			<Fragment slot="dek">
				Unduh gratis, tersedia di iOS dan Android.
			</Fragment>
		</DownloadSection>

		<!-- FINALE -->
		<section class="finale">
			<div class="finale-inner">
				<h2 class="finale-h">Catat setiap <em>inspirasi</em>.</h2>
				<p class="finale-p">
					Unduh gratis, mendukung iPhone, Android, dan web.
				</p>
				<div class="actions actions-center">
					<Button variant="primary" href="https://n.slax.com/" arrow>Buka Slax Note</Button>
					<Button variant="secondary" href="#pricing">Lihat harga</Button>
				</div>
			</div>
		</section>
	</main>

	<Footer />
</Base>

<style>
	/* HERO */
	.n-hero {
		padding: 6rem 0 5rem;
	}
	.n-hero-inner {
		max-width: 1180px;
		margin: 0 auto;
		padding: 0 2rem;
		display: grid;
		grid-template-columns: 1fr;
		gap: 4rem;
		align-items: center;
	}
	@media (min-width: 960px) {
		.n-hero-inner {
			grid-template-columns: 1.1fr 1fr;
		}
	}
	.n-h1 {
		font-family: var(--serif);
		font-weight: 400;
		font-size: clamp(2rem, 4vw, 3.2rem);
		line-height: 1.1;
		letter-spacing: -0.02em;
		margin: 1rem 0 1.75rem;
		color: var(--ink);
		max-width: 20ch;
	}
