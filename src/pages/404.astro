---
import Button from '~/components/Button.astro';
import Eyebrow from '~/components/Eyebrow.astro';
import Footer from '~/components/Footer.astro';
import Nav from '~/components/Nav.astro';
import Base from '~/layouts/Base.astro';
---
<Base title="Not found — Slax">
	<Nav />
	<main class="error-page">
		<Eyebrow>Error · 404</Eyebrow>
		<h1>This page has moved,<br />or never existed.</h1>
		<p>No drama. Head back and try another thread.</p>
		<div class="actions">
			<Button variant="primary" href="/" arrow>Back to Slax</Button>
			<Button variant="secondary" href="/blog/">Read the blog</Button>
		</div>
	</main>
	<Footer />
</Base>

<style>
	.error-page {
		max-width: 680px;
		margin: 0 auto;
		padding: 10rem 2rem 6rem;
		text-align: center;
	}
	h1 {
		font-family: var(--serif);
		font-weight: 400;
		font-size: clamp(2.5rem, 5vw, 4rem);
		line-height: 1.05;
		letter-spacing: -0.025em;
		margin: 2.5rem 0 1.5rem;
	}
	p {
		font-family: var(--serif);
		font-size: 1.25rem;
		color: var(--ink-soft);
		margin: 0 0 3rem;
	}
	.actions {
		display: flex;
		gap: 1rem;
		justify-content: center;
		flex-wrap: wrap;
	}
</style>
