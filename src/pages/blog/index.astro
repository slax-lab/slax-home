---
import { getCollection } from 'astro:content';
import Eyebrow from '~/components/Eyebrow.astro';
import Footer from '~/components/Footer.astro';
import Nav from '~/components/Nav.astro';
import Base from '~/layouts/Base.astro';

const posts = (await getCollection('blog', ({ data }) => !data.draft)).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);

const dateFmt = new Intl.DateTimeFormat('en-US', {
	year: 'numeric',
	month: 'long',
	day: 'numeric',
});
---
<Base title="Blog — Slax">
	<Nav active="blog" />
	<main class="blog-index">
		<header class="head">
			<Eyebrow>Writing</Eyebrow>
			<h1>Notes from building Slax.</h1>
			<p class="dek">
				Essays about reading, writing, attention, and the quiet tools we make for them.
			</p>
		</header>

		{posts.length === 0 ? (
			<p class="empty">
				No posts yet. Essays start landing in stage 3.
			</p>
		) : (
			<ul class="post-list">
				{posts.map((post) => (
					<li class="post-item">
						<time datetime={post.data.pubDate.toISOString()}>
							{dateFmt.format(post.data.pubDate)}
						</time>
						<h2><a href={`/blog/${post.id}/`}>{post.data.title}</a></h2>
						<p>{post.data.description}</p>
					</li>
				))}
			</ul>
		)}
	</main>
	<Footer />
</Base>

<style>
	.blog-index {
		max-width: 720px;
		margin: 0 auto;
		padding: 6rem 2rem 4rem;
	}
	.head {
		margin-bottom: 5rem;
	}
	h1 {
		font-family: var(--serif);
		font-weight: 400;
		font-size: clamp(2.5rem, 4.5vw, 3.8rem);
		line-height: 1.05;
		letter-spacing: -0.025em;
		margin: 2.5rem 0 1.5rem;
	}
	.dek {
		font-family: var(--serif);
		font-size: 1.2rem;
		line-height: 1.5;
		color: var(--ink-soft);
		max-width: 38ch;
	}

	.empty {
		font-family: var(--mono);
		font-size: 0.85rem;
		letter-spacing: 0.1em;
		text-transform: uppercase;
		color: var(--ink-mute);
		padding: 4rem 0;
	}

	.post-list {
		list-style: none;
		padding: 0;
		margin: 0;
		display: grid;
		gap: 4rem;
	}
	.post-item time {
		font-family: var(--mono);
		font-size: 0.78rem;
		letter-spacing: 0.12em;
		text-transform: uppercase;
		color: var(--ink-mute);
	}
	.post-item h2 {
		font-family: var(--serif);
		font-weight: 500;
		font-size: 1.85rem;
		line-height: 1.2;
		letter-spacing: -0.015em;
		margin: 0.8rem 0 0.8rem;
	}
	.post-item h2 a {
		color: var(--ink);
		text-decoration: none;
		transition: color 0.2s;
	}
	.post-item h2 a:hover {
		color: var(--accent);
	}
	.post-item p {
		font-family: var(--serif);
		font-size: 1.1rem;
		line-height: 1.5;
		color: var(--ink-soft);
		margin: 0;
		max-width: 52ch;
	}
</style>
