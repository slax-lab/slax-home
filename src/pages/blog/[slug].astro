---
import { getCollection } from 'astro:content';
import BlogArticlePage from '~/components/BlogArticlePage.astro';
import {
	availableLocalesForSlug,
	entrySlug,
	filterByLocale,
} from '~/lib/content';

export async function getStaticPaths() {
	const all = await getCollection('blog');
	const en = filterByLocale(all, 'en').filter((p) => !p.data.draft);
	return en.map((post) => {
		const slug = entrySlug(post);
		return {
			params: { slug },
			props: {
				post,
				slug,
				available: availableLocalesForSlug(all, slug),
			},
		};
	});
}

const { post, slug, available } = Astro.props;
---
<BlogArticlePage post={post} slug={slug} lang="en" availableLocales={available} />
