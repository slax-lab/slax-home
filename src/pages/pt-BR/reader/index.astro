---
import Button from '~/components/Button.astro';
import DownloadSection from '~/components/DownloadSection.astro';
import FaqList from '~/components/FaqList.astro';
import Footer from '~/components/Footer.astro';
import Nav from '~/components/Nav.astro';
import Base from '~/layouts/Base.astro';

// Content sourced verbatim from original apps/reader-home components
// (archive/apps-backup): HomeHero / HomeFeatures / HomeHowItWorks /
// HomeComparison / HomeCTA / PricingTable / DownloadPage.
// Plan decision: merge features + pricing + download into single
// anchor-navigable /reader/ page.

const features = [
	{
		title: 'Compreensão potencializada por IA',
		body: 'Receba o resumo, os pontos-chave e respostas para suas dúvidas sobre o artigo a qualquer momento. É como ter um tutor particular no bolso, ajudando você a entender cada texto.',
	},
	{
		title: 'Conteúdo que nunca some',
		body: 'Tudo que você salva fica em backup para sempre. Acabou abrir o link e ver "404 — página não encontrada". Sua biblioteca digital é sua de verdade.',
	},
	{
		title: 'Organização inteligente',
		body: 'A IA marca e categoriza os conteúdos automaticamente. Quando precisar, use a busca semântica poderosa para achar exatamente o artigo que você quer.',
	},
	{
		title: 'Leitura conectada',
		body: 'Destaque e comente nos artigos que você salvou. Compartilhe e convide outras pessoas para a discussão. Cada artigo vira um lugar de conversa.',
	},
];

const steps = [
	{
		title: 'Salve sem pensar',
		body: 'Um clique para salvar qualquer artigo, paper ou post de blog da web.',
	},
	{
		title: 'IA analisa por você',
		body: 'O panorama gerado pela IA te ajuda a decidir o que vale leitura cuidadosa e o que dá pra correr o olho. Reserve o tempo para o melhor conteúdo.',
	},
	{
		title: 'Pergunte para a IA',
		body: 'Converse com a IA sobre o que você salvou e leve o entendimento mais fundo.',
	},
	{
		title: 'Interaja com o conteúdo',
		body: 'Destaque, comente e discuta com outras pessoas. O que você escreve vale mais do que o que você só leu.',
	},
];

// Cell value: 'ok' → ● accent,   'no' → — muted,   any other string → inline text (muted italic)
const compareRows: Array<[string, string, string, string]> = [
	['Bookmarks ilimitados grátis (usuários iniciais)', 'ok', 'ok', 'Pago'],
	['Backup permanente de conteúdo', 'ok', 'Pago', 'Pago'],
	['Tópicos com IA', 'Pago', 'ok', 'Pago'],
	['Chat com IA durante a leitura', 'Pago', 'no', 'Pago'],
	[
		'Destaques e comentários no original e no snapshot, sincronizados nos dois sentidos',
		'ok',
		'no',
		'Pago',
	],
	['Entrar nas discussões dos leitores', 'ok', 'no', 'Só compartilhar'],
	['Marcação automática com IA', 'Pago', 'Manual', 'Manual'],
];

const matrixRows: Array<[string, string, string]> = [
	['Salvar artigos ilimitados', 'ok', 'ok'],
	['Snapshots permanentes (sem mais link quebrado)', 'ok', 'ok'],
	['Destaques e comentários ilimitados', 'ok', 'ok'],
	['Busca em texto completo', 'ok', 'ok'],
	['Sincronização em todos os dispositivos', 'ok', 'ok'],
	['Compartilhar artigos e entrar na discussão', 'ok', 'ok'],
	['Open source e privacidade em primeiro lugar', 'ok', 'ok'],
	['Criar e gerenciar tags', 'ok', 'ok'],
	['Marcação automática inteligente com IA', 'no', 'ai'],
	['Resumos instantâneos com IA', 'no', 'ai'],
	['Tópicos interativos com IA', 'no', 'ai'],
	['Chat com IA — pergunte à sua biblioteca', 'no', 'ai'],
];

const faqs = [
	{
		q: 'O plano grátis é mesmo grátis para sempre?',
		a: 'É — para usuários iniciais. Na fase de acesso antecipado, oferecemos bookmarks ilimitados e backup permanente, tudo grátis. Aproveite enquanto não tem limite e garanta sua cota gratuita.',
	},
	{
		q: 'O Slax Reader realmente me poupa algumas horas de leitura por semana?',
		a: 'Foi feito exatamente para isso. Os tópicos clicáveis com IA deixam você pular pelos textos longos sem precisar ler palavra por palavra. A marcação automática faz a organização por você. Você só lê.',
	},
	{
		q: 'Posso cancelar o Pro a qualquer momento?',
		a: 'Claro. Cancele a qualquer hora nas configurações da conta, sem custo. Seus artigos salvos e destaques continuam acessíveis no plano grátis.',
	},
	{
		q: 'Como funciona o 1 mês grátis?',
		a: 'Entre na conta e o teste começa, sem cartão de crédito. Depois de 30 dias, te perguntamos se quer seguir no Pro por US$ 5,99/mês (de US$ 9,99).',
	},
];

const platforms = [
	{
		icon: '📱',
		title: 'iPhone, iPad, Android',
		bullets: [
			'Salvar para sempre, totalmente grátis.',
			'Salve qualquer artigo com um toque.',
			'Pegue tópicos com IA na hora e leia em saltos.',
			'Sincronização em todas as plataformas.',
		],
		downloads: [
			{
				href: 'https://apps.apple.com/us/app/slax-reader-ai-read-it-later/id6596730998',
				small: 'Baixar na',
				main: 'App Store',
			},
			{
				href: 'https://play.google.com/store/apps/details?id=com.slax.reader',
				small: 'Disponível na',
				main: 'Google Play',
			},
		],
	},
	{
		icon: '💻',
		title: 'Mac',
		bullets: ['Salve, leia e organize como um profissional.'],
		downloads: [
			{
				href: 'https://apps.apple.com/us/app/slax-reader-ai-read-it-later/id6596730998',
				small: 'Baixar na',
				main: 'Mac App Store',
			},
		],
	},
	{
		icon: '🌐',
		title: 'Extensão de navegador',
		bullets: [
			'Salve e faça backup de qualquer página com um clique — é sua para sempre.',
			'Converse com a IA sobre o artigo, direto na página original.',
			'Encontre o que precisa em segundos com a busca semântica poderosa.',
		],
		downloads: [
			{
				href: 'https://chromewebstore.google.com/detail/gdnhaajlomjkhahnmiijphnodkcfikfd?utm_source=web_homepage',
				small: '',
				main: 'Chrome Extension',
			},
		],
	},
];

const schema = {
	'@context': 'https://schema.org',
	'@type': 'SoftwareApplication',
	name: 'Slax Reader',
	applicationCategory: 'ProductivityApplication',
	operatingSystem: 'Web, iOS, iPadOS, Android, macOS',
	url: 'https://slax.com/reader/',
	image: 'https://slax.com/og/reader.png',
	screenshot: 'https://slax.com/reader/hero.png',
	description:
		'Um ler-depois open source e direto ao ponto. Salve para sempre, aprenda mais rápido. Sua biblioteca inteligente, para ler com mais eficiência e entender mais fundo.',
	downloadUrl: [
		'https://apps.apple.com/us/app/slax-reader-ai-read-it-later/id6596730998',
		'https://play.google.com/store/apps/details?id=com.slax.reader',
		'https://chromewebstore.google.com/detail/gdnhaajlomjkhahnmiijphnodkcfikfd',
	],
	offers: [
		{
			'@type': 'Offer',
			name: 'Free',
			price: '0',
			priceCurrency: 'USD',
		},
		{
			'@type': 'Offer',
			name: 'Pro Reader',
			price: '5.99',
			priceCurrency: 'USD',
			priceSpecification: {
				'@type': 'UnitPriceSpecification',
				price: '5.99',
				priceCurrency: 'USD',
				billingDuration: 'P1M',
			},
		},
	],
	publisher: {
		'@type': 'Organization',
		name: 'Slax Lab',
		url: 'https://slax.com',
		logo: 'https://slax.com/images/slax-logo.png',
	},
};
---
<Base
	title="Slax Reader — Um ler-depois open source e direto ao ponto"
	description="Um ler-depois open source e direto ao ponto. Sem algoritmo. Sem feed. Você escolhe o que ler em seguida. Snapshots ilimitados, de graça."
	ogImage="/og/reader.png"
	schema={schema}
>
	<Nav active="reader" />

	<main>
		<!-- HERO -->
		<section class="r-hero">
			<div class="r-hero-inner">
				<div>
					<h1 class="r-h1">
						Um ler-depois open source e <em>direto ao ponto.</em>
					</h1>
					<ul class="r-bullets">
						<li>Sem algoritmo. Sem feed. Você escolhe o que ler em seguida.</li>
						<li>Snapshots ilimitados, de graça.</li>
						<li>Open source.</li>
					</ul>
					<div class="r-hero-stores">
						<a
							class="r-store-btn is-primary"
							href="https://apps.apple.com/us/app/slax-reader-ai-read-it-later/id6596730998"
							target="_blank"
							rel="noopener noreferrer"
						>
							<span class="r-store-small">Baixar na</span>
							<span class="r-store-main">App Store</span>
						</a>
						<a
							class="r-store-btn"
							href="https://play.google.com/store/apps/details?id=com.slax.reader"
							target="_blank"
							rel="noopener noreferrer"
						>
							<span class="r-store-small">Disponível na</span>
							<span class="r-store-main">Google Play</span>
						</a>
					</div>
					<p class="r-web-link">
						Ou <a href="https://r.slax.com/login">acesse a versão web</a>.
					</p>
				</div>
				<div class="r-preview" aria-hidden="true">
					<img
						src="/reader/hero.png"
						alt="Pré-visualização da interface do Slax Reader"
						loading="eager"
						decoding="async"
					/>
				</div>
			</div>
		</section>

		<!-- FEATURES -->
		<section class="features" id="features">
			<div class="features-inner">
				<div class="features-head">
					<h2 class="features-title">Não é só mais um ler-depois</h2>
					<p class="features-sub">
						O que estamos fazendo é a próxima forma de leitura inteligente.
					</p>
				</div>
				<div class="feat-grid">
					{features.map((f, i) => (
						<div class="feat">
							<div class="feat-num">{String(i + 1).padStart(2, '0')}</div>
							<h3 class="feat-h">{f.title}</h3>
							<p class="feat-p">{f.body}</p>
						</div>
					))}
				</div>
			</div>
		</section>

		<!-- HOW IT WORKS -->
		<section class="how">
			<div class="how-inner">
				<h2 class="how-head">De um clique de salvar a um clique de entender.</h2>
				<p class="how-sub">
					Quatro passos simples que mudam como você lê e aprende.
				</p>
				<div class="how-steps">
					{steps.map((s, i) => (
						<div class="how-step">
							<div class="how-step-num">{String(i + 1).padStart(2, '0')}</div>
							<h3 class="how-step-h">{s.title}</h3>
							<p class="how-step-body">{s.body}</p>
						</div>
					))}
				</div>
			</div>
		</section>

		<!-- COMPARE -->
		<section class="compare">
			<div class="compare-inner">
				<h2 class="compare-head">Por que os leitores estão migrando para o Slax</h2>
				<p class="compare-sub">
					Veja a distância entre nós e as ferramentas tradicionais de ler-depois.
				</p>
				<div class="compare-table">
					<div class="compare-row head">
						<div>Recurso</div>
						<div class="highlight">Slax Reader</div>
						<div>Instapaper</div>
						<div>Readwise</div>
					</div>
					{compareRows.map((row) => (
						<div class="compare-row">
							<div>{row[0]}</div>
							{[1, 2, 3].map((i) => {
								const v = row[i];
								const isHighlight = i === 1;
								let cls = 'cell';
								let content: string = v;
								if (v === 'ok') {
									cls += ' cell-ok';
									content = '●';
								} else if (v === 'no') {
									cls += ' cell-no';
									content = '—';
								} else {
									cls += ' cell-text';
								}
								if (isHighlight) cls += ' highlight';
								return <div class={cls}>{content}</div>;
							})}
						</div>
					))}
				</div>
				<p class="compare-more">
					<a href="/pt-BR/reader/alternatives/">
						Comparativo completo — Readwise, Omnivore, Cubox e mais →
					</a>
				</p>
			</div>
		</section>

		<!-- PRICING -->
		<section class="pricing" id="pricing">
			<div class="pricing-inner">
				<h2 class="pricing-head">Leia com mais inteligência, <em>não só "depois".</em></h2>
				<p class="pricing-dek">
					Salve para sempre, aprenda mais rápido. Sua biblioteca inteligente, para ler com mais eficiência e entender mais fundo.
				</p>
				<a class="pricing-promo" href="https://r.slax.com/login">
					🎉 Entre hoje e ganhe 1 mês de Pro grátis
				</a>

				<div class="plans-grid">
					<div class="plan">
						<div class="plan-eyebrow">Free</div>
						<div class="plan-price">
							<span class="num">$0</span><span class="unit">/ mês</span>
						</div>
						<p class="plan-tag">
							Bookmarks ilimitados, backup permanente — aproveite enquanto não tem limite e entre agora!
						</p>
						<a href="https://r.slax.com/login" class="btn-primary">Começar grátis</a>
					</div>
					<div class="plan featured">
						<div class="plan-eyebrow">Pro Reader</div>
						<div class="plan-price">
							<span class="num">$5.99</span><span class="unit">/ mês</span>
							<span class="was">$9.99</span>
						</div>
						<p class="plan-tag">
							Ligue a análise com IA e leve sua capacidade de leitura ao limite.
						</p>
						<a href="https://r.slax.com/login" class="btn-primary">Testar grátis por 1 mês</a>
					</div>
				</div>

				<div class="matrix" aria-label="Tabela comparativa de recursos">
					<div class="matrix-row head">
						<div class="cell-feat">Recurso</div>
						<div class="cell">Free</div>
						<div class="cell">Pro Reader</div>
					</div>
					{matrixRows.map((row) => (
						<div class="matrix-row">
							<div class="cell-feat">{row[0]}</div>
							{[1, 2].map((i) => {
								const v = row[i];
								if (v === 'ok') return <div class="cell ok">✓</div>;
								if (v === 'ai') return <div class="cell ai">AI</div>;
								return <div class="cell no">✕</div>;
							})}
						</div>
					))}
				</div>
			</div>
		</section>

		<!-- FAQ -->
		<section class="faq">
			<div class="faq-inner">
				<h2 class="faq-head">Perguntas frequentes</h2>
				<FaqList items={faqs} />
			</div>
		</section>


		<!-- DOWNLOAD -->
		<DownloadSection platforms={platforms}>
			<Fragment slot="heading">
				Slax Reader — <em>salve para sempre, leia com mais inteligência.</em>
			</Fragment>
			<Fragment slot="dek">
				Baixe grátis em todas as plataformas que você usa.
			</Fragment>
		</DownloadSection>

		<!-- FINALE -->
		<section class="finale">
			<div class="finale-inner">
				<h2 class="finale-h">
					Comece hoje sua jornada de leitura <em>inteligente</em>
				</h2>
				<p class="finale-p">Leia com mais inteligência, aprenda mais rápido, lembre de mais.</p>
				<div class="actions actions-center">
					<Button variant="primary" href="https://r.slax.com/login" arrow>
						Começar agora — totalmente grátis
					</Button>
					<Button variant="secondary" href="https://github.com/slax-lab/slax-reader">
						Ver o código-fonte
					</Button>
				</div>
			</div>
		</section>
	</main>

	<Footer />
</Base>

<style>
	/* HERO */
	.r-hero {
		padding: 6rem 0 5rem;
	}
	.r-hero-inner {
		max-width: 1180px;
		margin: 0 auto;
		padding: 0 2rem;
		display: grid;
		grid-template-columns: 1fr;
		gap: 4rem;
		align-items: center;
	}
	@media (min-width: 960px) {
		.r-hero-inner {
			grid-template-columns: 1.1fr 1fr;
		}
	}
	.r-h1 {
		font-family: var(--serif);
		font-weight: 400;
		font-size: clamp(2rem, 4vw, 3.2rem);
		line-height: 1.1;
		letter-spacing: -0.02em;
		margin: 1rem 0 1.75rem;
		color: var(--ink);
		max-width: 22ch;
	}
	.r-h1 :global(em) {
		font-style: italic;
		font-weight: 300;
		color: var(--accent);
	}
	.r-bullets {
		list-style: none;
		padding: 0;
		margin: 0 0 2.25rem;
		display: flex;
		flex-direction: column;
		gap: 0.75rem;
		max-width: 48ch;
	}
	.r-bullets li {
		position: relative;
		padding-left: 1.5rem;
		font-family: var(--serif);
		font-size: 1.05rem;
		line-height: 1.55;
		color: var(--ink-soft);
	}
	.r-bullets li::before {
		content: "—";
		position: absolute;
		left: 0;
		top: 0;
		color: var(--ink-mute);
		font-weight: 300;
	}
	.r-hero-stores {
		display: flex;
		gap: 0.75rem;
		flex-wrap: wrap;
	}
	.r-web-link {
		margin: 0.9rem 0 0;
		font-family: var(--serif);
		font-size: 0.95rem;
		color: var(--ink-mute);
	}
	.r-web-link a {
		color: var(--ink-soft);
		text-decoration: underline;
		text-decoration-color: var(--rule);
		text-underline-offset: 3px;
		transition: color 0.2s ease, text-decoration-color 0.2s ease;
	}
	.r-web-link a:hover {
		color: var(--accent);
		text-decoration-color: var(--accent);
	}
	.r-store-btn {
		display: inline-flex;
		flex-direction: column;
		align-items: flex-start;
		gap: 0.15rem;
		background: transparent;
		color: var(--ink);
		text-decoration: none;
		padding: 0.7rem 1.2rem;
		border: 1px solid var(--ink);
		transition:
			background 0.2s ease,
			color 0.2s ease;
		min-width: 160px;
	}
	.r-store-btn:hover {
		background: var(--ink);
		color: var(--bg);
	}
	.r-store-btn.is-primary,
	.r-store-btn.is-primary:hover {
		background: var(--accent);
		border-color: var(--accent);
		color: var(--bg);
	}
	.r-store-btn.is-primary .r-store-small,
	.r-store-btn.is-primary:hover .r-store-small {
		color: var(--bg);
		opacity: 0.8;
	}
	.r-store-small {
		font-family: var(--mono);
		font-size: 0.62rem;
		letter-spacing: 0.08em;
		text-transform: uppercase;
		color: var(--ink-mute);
		line-height: 1.2;
	}
	.r-store-btn:hover .r-store-small {
		color: var(--bg);
		opacity: 0.75;
	}
	.r-store-main {
		font-family: var(--serif);
		font-size: 0.98rem;
		font-weight: 500;
		line-height: 1.3;
	}
	.actions {
		display: flex;
		gap: 1rem;
		flex-wrap: wrap;
		align-items: center;
	}
	.actions-center {
		justify-content: center;
	}
	.r-preview {
		display: flex;
		justify-content: center;
	}
	.r-preview img {
		display: block;
		width: 100%;
		height: auto;
		max-width: 480px;
	}

	/* FEATURES */
	.features {
		padding: var(--section-pad) 0;
		border-top: 1px solid var(--rule-soft);
	}
	.features-inner {
		max-width: 1180px;
		margin: 0 auto;
		padding: 0 2rem;
	}
	.features-head {
		margin-bottom: 4rem;
	}
	.features-title {
		font-family: var(--serif);
		font-weight: 400;
		font-size: clamp(1.8rem, 3vw, 2.4rem);
		line-height: 1.15;
		letter-spacing: -0.02em;
		margin: 1rem 0 0.5rem;
	}
	.features-sub {
		font-family: var(--serif);
		font-size: 1.1rem;
		color: var(--ink-soft);
		margin: 0;
		max-width: 44ch;
	}
	.feat-grid {
		display: grid;
		grid-template-columns: 1fr;
		gap: 0;
		border-top: 1px solid var(--rule);
	}
	@media (min-width: 760px) {
		.feat-grid {
			grid-template-columns: 1fr 1fr;
		}
	}
	@media (min-width: 1040px) {
		.feat-grid {
			grid-template-columns: repeat(4, 1fr);
		}
	}
	.feat {
		padding: 2.5rem 2rem;
		border-bottom: 1px solid var(--rule);
	}
	@media (min-width: 760px) {
		.feat:nth-child(2n) {
			border-left: 1px solid var(--rule);
		}
	}
	@media (min-width: 1040px) {
		.feat:nth-child(2n) {
			border-left: 0;
		}
		.feat:not(:nth-child(4n + 1)) {
			border-left: 1px solid var(--rule);
		}
	}
	.feat-num {
		font-family: var(--mono);
		font-size: 0.7rem;
		letter-spacing: 0.2em;
		color: var(--ink-mute);
		margin-bottom: 1.5rem;
	}
	.feat-h {
		font-family: var(--serif);
		font-weight: 500;
		font-size: 1.2rem;
