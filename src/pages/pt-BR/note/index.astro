<script>
	const groups = document.querySelectorAll<HTMLElement>('[data-demo-group]');

	groups.forEach((section) => {
		const items = Array.from(
			section.querySelectorAll<HTMLButtonElement>('.feat-item'),
		);
		const videos = Array.from(
			section.querySelectorAll<HTMLVideoElement>('.feat-video'),
		);
		if (items.length === 0 || videos.length === 0) return;

		let activeIdx = 0;

		const activate = (idx: number) => {
			if (idx === activeIdx || idx < 0 || idx >= items.length) return;
			items.forEach((it, i) =>
				it.setAttribute('aria-selected', i === idx ? 'true' : 'false'),
			);
			videos.forEach((v, i) => {
				const active = i === idx;
				v.setAttribute('aria-hidden', active ? 'false' : 'true');
				if (active) {
					try {
						v.currentTime = 0;
					} catch (_) {
						/* noop */
					}
					v.play().catch(() => {});
				} else {
					v.pause();
				}
			});
			activeIdx = idx;
		};

		items.forEach((item) => {
			item.addEventListener('click', () => {
				const idx = Number(item.dataset.idx);
				activate(idx);
			});
		});

		// Lazy start: only kick off the first video once the section enters view.
		const first = videos[0];
		if (first) {
			const io = new IntersectionObserver(
				(entries) => {
					entries.forEach((e) => {
						if (e.isIntersecting) {
							first.play().catch(() => {});
							io.disconnect();
						}
					});
				},
				{ rootMargin: '0px 0px -10% 0px' },
			);
			io.observe(section);
		}
	});
</script>
