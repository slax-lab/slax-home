		a: 'A gravação funciona offline, mas a transcrição precisa de internet.',
	},
	{
		q: 'Como troco o conteúdo para um estilo diferente?',
		a: 'Abra o app e comece a gravar, ou toque em "Nota em texto" para digitar — você entra na página de polimento automático. Lá, toque no botão "Padrão" à direita para alternar entre estilos de escrita ou montar um estilo personalizado.',
	},
	{
		q: 'Quais idiomas o reconhecimento de voz do Slax Note suporta?',
		a: 'Hoje suportamos inglês, chinês, alemão, japonês e outros idiomas principais; mais idiomas serão adicionados aos poucos.',
	},
];

const schema = {
	'@context': 'https://schema.org',
	'@type': 'SoftwareApplication',
	name: 'Slax Note',
	alternateName: 'Slax Note — Notas por voz com IA',
	applicationCategory: 'ProductivityApplication',
	operatingSystem: 'iOS, Android, Web',
	url: 'https://slax.com/note/',
	image: 'https://slax.com/og/note.png',
	screenshot: 'https://slax.com/images/note/cover.png',
	description:
		'Notas por voz com IA. Você fala, a gente escreve. Grave com o Slax Note e deixe a IA capturar sua ideia, transformando em texto no estilo que você quiser.',
	downloadUrl: [
		'https://apps.apple.com/us/app/slax-note-transcribe-voice-pen/id6480166286',
		'https://play.google.com/store/apps/details?id=app.slax.notes',
	],
	offers: [
		{
			'@type': 'Offer',
			name: 'Free',
			price: '0',
			priceCurrency: 'USD',
		},
		{
			'@type': 'Offer',
			name: 'Premium Monthly',
			price: '4.99',
			priceCurrency: 'USD',
			priceSpecification: {
				'@type': 'UnitPriceSpecification',
				price: '4.99',
				priceCurrency: 'USD',
				billingDuration: 'P1M',
			},
		},
		{
			'@type': 'Offer',
			name: 'Premium Annual',
			price: '49.99',
			priceCurrency: 'USD',
			priceSpecification: {
				'@type': 'UnitPriceSpecification',
				price: '49.99',
				priceCurrency: 'USD',
				billingDuration: 'P1Y',
			},
		},
	],
	publisher: {
		'@type': 'Organization',
		name: 'Starry Tech Pte. Ltd.',
		url: 'https://slax.com',
		logo: 'https://slax.com/images/slax-logo.png',
	},
};
---
<Base
	title="Slax Note — Notas por voz com IA. Você fala, a gente escreve."
	description="Você fala, a gente escreve. Uma gravação, várias formas — modelada pelos prompts que você escolher. Companhia para ano após ano."
	ogImage="/og/note.png"
	schema={schema}
>
	<Nav active="note" />

	<main>
		<!-- HERO -->
		<section class="n-hero">
			<div class="n-hero-inner">
				<div>
					<h1 class="n-h1">
						Notas por voz com IA. <em>Você fala, a gente escreve.</em>
					</h1>
					<ul class="n-bullets">
						<li>Bateu a ideia, fala. Sem digitar, sem organizar.</li>
						<li>Uma gravação, várias formas — modelada pelos prompts que você escolher.</li>
						<li>Acompanha você ano após ano.</li>
					</ul>
					<div class="n-stores">
						<a
							class="store-btn is-primary"
							href="https://apps.apple.com/us/app/slax-note-transcribe-voice-pen/id6480166286"
							target="_blank"
							rel="noopener noreferrer"
						>
							<span class="store-small">Baixar na</span>
							<span class="store-main">App Store</span>
						</a>
						<a
							class="store-btn"
							href="https://play.google.com/store/apps/details?id=app.slax.notes"
							target="_blank"
							rel="noopener noreferrer"
						>
							<span class="store-small">Disponível na</span>
							<span class="store-main">Google Play</span>
						</a>
					</div>
					<p class="n-web-link">
						Ou <a href="https://n.slax.com/">acesse a versão web</a>.
					</p>
				</div>
				<div class="n-visual">
					<img
						src="/images/note/cover.png"
						alt="Slax Note — Notas por voz com IA"
						class="n-img"
						loading="eager"
					/>
				</div>
			</div>
		</section>

		<!-- EFFICIENCY BOOST -->
		<section class="features" id="features" data-demo-group="efficiency">
			<div class="features-inner">
				<div class="feat-head">
					<h2 class="feat-title">Ganho de eficiência</h2>
					<p class="feat-sub">Reserve o tempo para o que importa.</p>
				</div>
				<div class="feat-demo-body">
					<div class="feat-list" role="tablist" aria-label="Recursos de ganho de eficiência">
						{efficiencyFeatures.map((f, i) => (
							<button
								class="feat-item"
								type="button"
								role="tab"
								data-idx={i}
								aria-selected={i === 0 ? 'true' : 'false'}
								aria-controls={`efficiency-video-${i}`}
							>
								<div class="feat-item-head">
									<span class="feat-num">{String(i + 1).padStart(2, '0')}</span>
									<h3 class="feat-h">{f.title}</h3>
								</div>
								<p class="feat-p">{f.body}</p>
							</button>
						))}
					</div>
					<div class="feat-stage">
						<div class="feat-frame">
							{efficiencyFeatures.map((f, i) => (
								<video
									id={`efficiency-video-${i}`}
									class="feat-video"
									data-idx={i}
									src={f.video}
									muted
									loop
									playsinline
									preload={i === 0 ? 'auto' : 'metadata'}
									aria-hidden={i === 0 ? 'false' : 'true'}
								></video>
							))}
						</div>
					</div>
				</div>
			</div>
		</section>

		<!-- INTELLIGENT GHOSTWRITING -->
		<section class="features features-alt" data-demo-group="ghostwriting">
			<div class="features-inner">
				<div class="feat-head">
					<h2 class="feat-title">Escrita-fantasma inteligente</h2>
					<p class="feat-sub">Deixe a IA polir seu texto sem esforço.</p>
				</div>
				<div class="feat-demo-body feat-demo-body--reverse">
					<div class="feat-stage">
						<div class="feat-frame">
							{ghostwritingFeatures.map((f, i) => (
								<video
									id={`ghostwriting-video-${i}`}
									class="feat-video"
									data-idx={i}
									src={f.video}
									muted
									loop
									playsinline
									preload="metadata"
									aria-hidden={i === 0 ? 'false' : 'true'}
								></video>
							))}
						</div>
					</div>
					<div class="feat-list" role="tablist" aria-label="Recursos de escrita-fantasma inteligente">
						{ghostwritingFeatures.map((f, i) => (
							<button
								class="feat-item"
								type="button"
								role="tab"
								data-idx={i}
								aria-selected={i === 0 ? 'true' : 'false'}
								aria-controls={`ghostwriting-video-${i}`}
							>
								<div class="feat-item-head">
									<span class="feat-num">{String(i + 1).padStart(2, '0')}</span>
									<h3 class="feat-h">{f.title}</h3>
								</div>
								<p class="feat-p">{f.body}</p>
							</button>
						))}
					</div>
				</div>
			</div>
		</section>

		<!-- USE CASES -->
		<section class="usecases">
			<div class="usecases-inner">
				<h2 class="usecases-head">Como outras pessoas usam o Slax Note</h2>
				<div class="uc-grid">
					{useCases.map((uc) => (
						<div class="uc">
							<h3 class="uc-h">{uc.title}</h3>
							<p class="uc-p">{uc.body}</p>
						</div>
					))}
				</div>
			</div>
		</section>

		<!-- TESTIMONIALS -->
		<section class="testimonials">
			<div class="testimonials-inner">
				<h2 class="t-head">A escolha de milhares de usuários</h2>
				<p class="t-sub">
					Pronto para mudar como você faz anotações? Comece a usar o Slax Note agora.
				</p>
				<div class="t-grid">
					{testimonials.map((t) => (
						<figure class="testimonial">
							<blockquote class="t-quote">"{t.quote}"</blockquote>
							<figcaption class="t-caption">
								<span class="t-author">{t.author}</span>
								<span class="t-title">{t.title}</span>
							</figcaption>
						</figure>
					))}
				</div>
			</div>
		</section>

		<!-- PRICING -->
		<section class="pricing" id="pricing">
			<div class="pricing-inner">
				<h2 class="pricing-head">Preços</h2>
				<p class="pricing-dek">Aproveite o preço early bird e dê um upgrade no plano.</p>

				<div class="plans-grid plans-grid-3">
					<!-- FREE -->
					<div class="plan">
						<div class="plan-eyebrow">Free</div>
						<div class="plan-price">
							<span class="num">$0</span>
						</div>
						<p class="plan-note">Grátis para sempre.</p>
						<ul class="plan-list">
							<li><span class="plan-feat-label">Notas por voz</span><span class="plan-feat-value">5</span></li>
							<li><span class="plan-feat-label">Polimento com IA</span><span class="plan-feat-value">10 no total</span></li>
							<li><span class="plan-feat-label">Duração da gravação</span><span class="plan-feat-value">5 minutos</span></li>
						</ul>
						<a href="https://n.slax.com/" class="btn-primary">Experimentar</a>
					</div>

					<!-- PREMIUM — MONTHLY -->
					<div class="plan">
						<div class="plan-eyebrow">Monthly</div>
						<div class="plan-price">
							<span class="num">$4.99</span><span class="unit">/ mês</span>
						</div>
						<p class="plan-note">Cancele quando quiser.</p>
						<ul class="plan-list">
							<li><span class="plan-feat-label">Notas por voz</span><span class="plan-feat-value">Ilimitadas</span></li>
							<li><span class="plan-feat-label">Polimento com IA</span><span class="plan-feat-value">300 por dia</span></li>
							<li><span class="plan-feat-label">Duração da gravação</span><span class="plan-feat-value">30 minutos</span></li>
							<li><span class="plan-feat-label">Qualidade do polimento</span><span class="plan-feat-value">Premium</span></li>
						</ul>
						<div class="plan-actions">
							<a
								class="btn-primary"
								href="https://apps.apple.com/us/app/slax-note-transcribe-voice-pen/id6480166286"
								target="_blank"
								rel="noopener noreferrer"
							>
								App Store
							</a>
							<a
								class="btn-primary btn-primary-outline"
								href="https://play.google.com/store/apps/details?id=app.slax.notes"
								target="_blank"
								rel="noopener noreferrer"
							>
								Google Play
							</a>
						</div>
					</div>

					<!-- PREMIUM — ANNUAL -->
					<div class="plan featured">
						<div class="plan-eyebrow">
							Annual <span class="plan-badge">Economize 2 meses</span>
						</div>
						<div class="plan-price">
							<span class="num">$49.99</span><span class="unit">/ ano</span>
						</div>
						<p class="plan-note">Equivale a $4.16/mês. Cancele quando quiser.</p>
						<ul class="plan-list">
							<li><span class="plan-feat-label">Notas por voz</span><span class="plan-feat-value">Ilimitadas</span></li>
							<li><span class="plan-feat-label">Polimento com IA</span><span class="plan-feat-value">300 por dia</span></li>
							<li><span class="plan-feat-label">Duração da gravação</span><span class="plan-feat-value">30 minutos</span></li>
							<li><span class="plan-feat-label">Qualidade do polimento</span><span class="plan-feat-value">Premium</span></li>
						</ul>
						<div class="plan-actions">
							<a
								class="btn-primary"
								href="https://apps.apple.com/us/app/slax-note-transcribe-voice-pen/id6480166286"
								target="_blank"
								rel="noopener noreferrer"
							>
								App Store
							</a>
							<a
								class="btn-primary btn-primary-outline"
								href="https://play.google.com/store/apps/details?id=app.slax.notes"
								target="_blank"
								rel="noopener noreferrer"
							>
								Google Play
							</a>
						</div>
					</div>
				</div>
			</div>
		</section>

		<!-- FAQ -->
		<section class="faq">
			<div class="faq-inner">
				<h2 class="faq-head">Perguntas frequentes</h2>
				<p class="faq-sub">
					Tem outras dúvidas ou sugestões? Fale com a gente no
					<a href="https://discord.gg/kznNsZvWSk">Discord</a> ou no
					<a href="mailto:note@slax.com">note@slax.com</a>.
				</p>
				<FaqList items={faqs} />
			</div>
		</section>

		<!-- DOWNLOAD -->
		<DownloadSection platforms={notePlatforms}>
			<Fragment slot="heading">
				Slax Note — <em>sua voz, transformada em texto sem esforço.</em>
			</Fragment>
			<Fragment slot="dek">
				Baixe grátis para iOS e Android.
			</Fragment>
		</DownloadSection>

		<!-- FINALE -->
		<section class="finale">
			<div class="finale-inner">
				<h2 class="finale-h">Capture cada <em>lampejo</em>.</h2>
				<p class="finale-p">
					Download gratuito para iPhone, Android e web.
				</p>
				<div class="actions actions-center">
					<Button variant="primary" href="https://n.slax.com/" arrow>Abrir o Slax Note</Button>
					<Button variant="secondary" href="#pricing">Ver os preços</Button>
				</div>
			</div>
		</section>
	</main>

	<Footer />
</Base>

<style>
	/* HERO */
	.n-hero {
		padding: 6rem 0 5rem;
	}
	.n-hero-inner {
		max-width: 1180px;
		margin: 0 auto;
		padding: 0 2rem;
		display: grid;
		grid-template-columns: 1fr;
		gap: 4rem;
		align-items: center;
	}
	@media (min-width: 960px) {
		.n-hero-inner {
			grid-template-columns: 1.1fr 1fr;
		}
	}
	.n-h1 {
		font-family: var(--serif);
		font-weight: 400;
		font-size: clamp(2rem, 4vw, 3.2rem);
		line-height: 1.1;
		letter-spacing: -0.02em;
		margin: 1rem 0 1.75rem;
		color: var(--ink);
		max-width: 20ch;
	}
	.n-h1 :global(em) {
		font-style: italic;
		font-weight: 300;
		color: var(--accent);
	}
	.n-bullets {
		list-style: none;
		padding: 0;
		margin: 0 0 2.25rem;
		display: flex;
		flex-direction: column;
		gap: 0.75rem;
		max-width: 48ch;
	}
	.n-bullets li {
		position: relative;
		padding-left: 1.5rem;
		font-family: var(--serif);
		font-size: 1.05rem;
		line-height: 1.55;
		color: var(--ink-soft);
	}
	.n-bullets li::before {
		content: "—";
		position: absolute;
		left: 0;
		top: 0;
