		],
		downloads: [
			{
				href: 'https://apps.apple.com/us/app/slax-note-transcribe-voice-pen/id6480166286',
				small: 'Baixar na',
				main: 'App Store',
			},
			{
				href: 'https://play.google.com/store/apps/details?id=app.slax.notes',
				small: 'Disponível na',
				main: 'Google Play',
			},
		],
	},
];

// Efficiency Boost 🚀 — "save your time on what matters"
const efficiencyFeatures = [
	{
		title: 'Capture sua ideia com um toque',
		body: 'Aperte uma vez e a gravação começa. Você pensa, o resto fica com a gente.',
		video: '/note/videos/click.mp4',
	},
	{
		title: 'Texto e pontuação organizados automaticamente',
		body: 'Nossa IA transcreve sua voz com precisão, depois pole o texto e adiciona a pontuação seguindo o seu tom.',
		video: '/note/videos/polish.mp4',
	},
	{
		title: 'Copie e compartilhe a nota em qualquer lugar',
		body: 'Compartilhe sua ideia como texto ou imagem, encaixando direto no seu fluxo de trabalho.',
		video: '/note/videos/copy-share.mp4',
	},
];

// Intelligent Ghostwriting ✍️ — "let AI perfect your text with ease"
const ghostwritingFeatures = [
	{
		title: 'Escolha estilos prontos para cada situação',
		body: 'Use os estilos embutidos: resumo, post, elogio e mais. Outros estilos chegam aos poucos.',
		video: '/note/videos/choose-ready-made.mp4',
	},
	{
		title: 'Personalize prompts para o que você precisa',
		body: 'Monte prompts próprios conforme seu fluxo e suas necessidades.',
		video: '/note/videos/customize.mp4',
	},
];

// How are others using Slax Note — 5 real use cases from note.slax.com
const useCases = [
	{
		title: 'Memorando pessoal por voz',
		body: 'Caminhando ou dirigindo, registre a ideia que passou voando. Transformamos a sua voz num texto claro de ler, sem deixar um lampejo escapar.',
	},
	{
		title: 'Criação de conteúdo',
		body: 'Escreva mais rápido e mais leve do que nunca. Diga a ideia em voz alta e a IA do Slax Note gera um conteúdo bonito em segundos, sem digitar.',
	},
	{
		title: 'Organização da agenda',
		body: 'Conte as tarefas para o Slax Note e ele monta a agenda no seu lugar. Você fica com o tempo para o que realmente importa.',
	},
	{
		title: 'Ata de reunião',
		body: 'Sem notebook na reunião? Chame o Slax Note como seu assistente de IA para gravar e transcrever os resumos.',
	},
	{
		title: 'Notas de estudo',
		body: 'Seu parceiro de IA nos estudos. Abra o Slax Note para gravar uma aula que você poderia perder, ou ensaie uma fala e deixe que ele monte um roteiro limpo.',
	},
];

// Real testimonials from note.slax.com — 6 named users
const testimonials = [
	{
		quote:
			'Se você escreve muito ou precisa anotar ideias o tempo todo, recomendo demais o Slax Note. Ele pole o que falo em voz alta com mais precisão do que eu costumo escrever.',
		author: 'Cao Jiang',
		title: 'Criador de conteúdo independente',
	},
	{
		quote:
			'A ferramenta é elegante e me ajuda a manter o hábito de registrar ideias com ela. Ajudou muito.',
		author: 'Fenng',
		title: 'Blogueiro de tecnologia',
	},
	{
		quote:
			'O Slax Note usa LLM para fazer transcrição automática e polimento do conteúdo. Comparado às ferramentas tradicionais, ele tira vícios de fala e tropeços, deixando a saída clara e lógica — ajuda quem usa a capturar e organizar ideias com eficiência.',
		author: 'Hui Ge Qi Tan',
		title: 'Autor',
	},
	{
		quote:
			'Não me falta conteúdo para escrever, falta tempo. Depois do Slax Note, ganhei muito tempo, e isso é precioso pra mim.',
		author: 'Investor Fan',
		title: 'Investidor / Fundador da Gaozhang Capital',
	},
	{
		quote:
			'Em conversas com amigos ou entrevistas, eu abro o Slax Note. Ele transforma o diálogo direto em um texto, sem precisar organizar a gravação na mão. O Slax Note resolve tudo por mim.',
		author: 'Liu Rong',
		title: 'Gerente de marketing em empresa de internet',
	},
	{
		quote:
			'No grupo da família, eu costumo compartilhar a agenda do dia e os compromissos importantes — sempre uso o Slax Note para registrar e organizar esses planos de forma sistemática. Mantém a nossa comunicação clara e tudo nos eixos.',
		author: 'Vivian',
		title: 'Gerente sênior',
	},
];

// FAQ — verbatim from note.slax.com
const faqs = [
	{
		q: 'Como faço para assinar?',
		a: 'Abra o Slax Note, escolha o plano que quiser e siga o passo a passo para criar a conta e finalizar o pagamento. Depois de assinar, você usa todos os recursos pagos na hora.',
	},
	{
		q: 'Dá para enviar arquivos?',
		a: 'Por enquanto, ainda não suportamos o envio de arquivos de áudio. Esse recurso já está no roadmap e chega no futuro.',
	},
	{
		q: 'Qual é a precisão da voz para texto?',
		a: 'Usamos IA avançada e a precisão é bem alta. Com áudio limpo, chega a mais de 95%.',
	},
	{
		q: 'Existe limite de duração para as gravações?',
		a: 'Cada gravação tem no máximo 30 minutos.',
	},
	{
		q: 'Dá para editar o texto transcrito?',
		a: 'Dá. O texto fica totalmente editável e ainda dá para alternar entre vários estilos de escrita.',
	},
	{
		q: 'Onde os arquivos de áudio ficam guardados? É seguro?',
		a: 'Todas as gravações ficam armazenadas localmente, garantindo a privacidade e a segurança dos usuários.',
	},
	{
		q: 'Como exporto as notas?',
		a: 'As notas podem ser facilmente compartilhadas como texto ou imagem para outros apps.',
	},
	{
