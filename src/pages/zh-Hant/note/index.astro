const schema = {
	'@context': 'https://schema.org',
	'@type': 'SoftwareApplication',
	name: 'Slax Note',
	alternateName: 'Slax Note —— AI 語音筆記',
	applicationCategory: 'ProductivityApplication',
	operatingSystem: 'iOS, Android, Web',
	url: new URL('/zh-Hant/note/', SITE).toString(),
	image: new URL('/og/note.png', SITE).toString(),
	screenshot: new URL('/images/note/cover.png', SITE).toString(),
	description:
		'AI 語音筆記。你說，我記。用 Slax Note 錄音，讓 AI 把你的想法抓下來，潤飾成你想要的任何風格的文字。',
	downloadUrl: [
		'https://apps.apple.com/us/app/slax-note-transcribe-voice-pen/id6480166286',
		'https://play.google.com/store/apps/details?id=app.slax.notes',
	],
	offers: [
		{
			'@type': 'Offer',
			name: 'Free',
			price: '0',
			priceCurrency: 'USD',
		},
		{
			'@type': 'Offer',
			name: 'Premium Monthly',
			price: '4.99',
			priceCurrency: 'USD',
			priceSpecification: {
				'@type': 'UnitPriceSpecification',
				price: '4.99',
				priceCurrency: 'USD',
				billingDuration: 'P1M',
			},
		},
		{
			'@type': 'Offer',
			name: 'Premium Annual',
			price: '49.99',
			priceCurrency: 'USD',
			priceSpecification: {
				'@type': 'UnitPriceSpecification',
				price: '49.99',
				priceCurrency: 'USD',
				billingDuration: 'P1Y',
			},
		},
	],
	publisher: {
		'@type': 'Organization',
		name: 'Starry Tech Pte. Ltd.',
		url: SITE,
		logo: new URL('/images/slax-logo.png', SITE).toString(),
	},
};
---
<Base
	title="Slax Note —— AI 語音筆記。你說，我記。"
	description="你說，我記。一段錄音，多種樣貌 —— 由你選的提示詞決定。陪你年復一年，持續成長。"
	ogImage="/og/note.png"
	schema={schema}
>
	<Nav active="note" />

	<main>
		<!-- HERO -->
		<section class="n-hero">
			<div class="n-hero-inner">
				<div>
					<h1 class="n-h1">
						AI 語音筆記。<em>你說，我記。</em>
					</h1>
					<ul class="n-bullets">
						<li>念頭一冒出就說出口。不必打字，不必整理。</li>
						<li>一段錄音，多種樣貌 —— 由你選的提示詞決定。</li>
						<li>陪你年復一年，持續成長。</li>
					</ul>
					<div class="n-stores">
						<a
							class="store-btn is-primary"
							href="https://apps.apple.com/us/app/slax-note-transcribe-voice-pen/id6480166286"
							target="_blank"
							rel="noopener noreferrer"
						>
							<span class="store-small">Download on the</span>
							<span class="store-main">App Store</span>
						</a>
						<a
							class="store-btn"
							href="https://play.google.com/store/apps/details?id=app.slax.notes"
							target="_blank"
							rel="noopener noreferrer"
						>
							<span class="store-small">GET IT ON</span>
							<span class="store-main">Google Play</span>
						</a>
					</div>
					<p class="n-web-link">
						或<a href="https://n.slax.com/">前往網頁版</a>。
					</p>
				</div>
				<div class="n-visual">
					<img
						src="/images/note/cover.png"
						alt="Slax Note —— AI 語音筆記"
						class="n-img"
						loading="eager"
					/>
				</div>
			</div>
		</section>

		<!-- EFFICIENCY BOOST -->
		<section class="features" id="features" data-demo-group="efficiency">
			<div class="features-inner">
				<div class="feat-head">
					<h2 class="feat-title">效率加成</h2>
					<p class="feat-sub">把時間花在重要的事上。</p>
				</div>
				<div class="feat-demo-body">
					<div class="feat-list" role="tablist" aria-label="效率加成功能">
						{efficiencyFeatures.map((f, i) => (
							<button
								class="feat-item"
								type="button"
								role="tab"
								data-idx={i}
								aria-selected={i === 0 ? 'true' : 'false'}
								aria-controls={`efficiency-video-${i}`}
							>
								<div class="feat-item-head">
									<span class="feat-num">{String(i + 1).padStart(2, '0')}</span>
									<h3 class="feat-h">{f.title}</h3>
								</div>
								<p class="feat-p">{f.body}</p>
							</button>
						))}
					</div>
					<div class="feat-stage">
						<div class="feat-frame">
							{efficiencyFeatures.map((f, i) => (
								<video
									id={`efficiency-video-${i}`}
									class="feat-video"
									data-idx={i}
									src={f.video}
									muted
									loop
									playsinline
									preload={i === 0 ? 'auto' : 'metadata'}
									aria-hidden={i === 0 ? 'false' : 'true'}
								></video>
							))}
						</div>
					</div>
				</div>
			</div>
		</section>

		<!-- INTELLIGENT GHOSTWRITING -->
		<section class="features features-alt" data-demo-group="ghostwriting">
			<div class="features-inner">
				<div class="feat-head">
					<h2 class="feat-title">智慧代筆</h2>
					<p class="feat-sub">讓 AI 輕鬆潤飾你的文字。</p>
				</div>
				<div class="feat-demo-body feat-demo-body--reverse">
					<div class="feat-stage">
						<div class="feat-frame">
							{ghostwritingFeatures.map((f, i) => (
								<video
									id={`ghostwriting-video-${i}`}
									class="feat-video"
									data-idx={i}
									src={f.video}
									muted
									loop
									playsinline
									preload="metadata"
									aria-hidden={i === 0 ? 'false' : 'true'}
								></video>
							))}
						</div>
					</div>
					<div class="feat-list" role="tablist" aria-label="智慧代筆功能">
						{ghostwritingFeatures.map((f, i) => (
							<button
								class="feat-item"
								type="button"
								role="tab"
								data-idx={i}
								aria-selected={i === 0 ? 'true' : 'false'}
								aria-controls={`ghostwriting-video-${i}`}
							>
								<div class="feat-item-head">
									<span class="feat-num">{String(i + 1).padStart(2, '0')}</span>
									<h3 class="feat-h">{f.title}</h3>
								</div>
								<p class="feat-p">{f.body}</p>
							</button>
						))}
					</div>
				</div>
			</div>
		</section>

		<!-- USE CASES -->
		<section class="usecases">
			<div class="usecases-inner">
				<h2 class="usecases-head">大家都怎麼用 Slax Note</h2>
				<div class="uc-grid">
					{useCases.map((uc) => (
						<div class="uc">
							<h3 class="uc-h">{uc.title}</h3>
							<p class="uc-p">{uc.body}</p>
						</div>
					))}
				</div>
			</div>
		</section>

		<!-- TESTIMONIALS -->
		<section class="testimonials">
			<div class="testimonials-inner">
				<h2 class="t-head">數千名使用者愛用</h2>
				<p class="t-sub">
					準備好讓筆記方式煥然一新嗎？現在就試試 Slax Note。
				</p>
				<div class="t-grid">
					{testimonials.map((t) => (
						<figure class="testimonial">
							<blockquote class="t-quote">「{t.quote}」</blockquote>
							<figcaption class="t-caption">
								<span class="t-author">{t.author}</span>
								<span class="t-title">{t.title}</span>
							</figcaption>
						</figure>
					))}
				</div>
			</div>
		</section>

		<!-- PRICING -->
		<section class="pricing" id="pricing">
			<div class="pricing-inner">
				<h2 class="pricing-head">價格方案</h2>
				<p class="pricing-dek">用早鳥優惠價升級你的方案。</p>

				<div class="plans-grid plans-grid-3">
					<!-- FREE -->
					<div class="plan">
						<div class="plan-eyebrow">Free</div>
						<div class="plan-price">
							<span class="num">$0</span>
						</div>
						<p class="plan-note">終身免費。</p>
						<ul class="plan-list">
							<li><span class="plan-feat-label">語音筆記</span><span class="plan-feat-value">5 則</span></li>
							<li><span class="plan-feat-label">AI 潤飾</span><span class="plan-feat-value">總共 10 次</span></li>
							<li><span class="plan-feat-label">錄音時長</span><span class="plan-feat-value">5 分鐘</span></li>
						</ul>
						<a href="https://n.slax.com/" class="btn-primary">免費試用</a>
					</div>

					<!-- PREMIUM — MONTHLY -->
					<div class="plan">
						<div class="plan-eyebrow">Monthly</div>
						<div class="plan-price">
							<span class="num">$4.99</span><span class="unit">/ 月</span>
						</div>
						<p class="plan-note">隨時取消。</p>
						<ul class="plan-list">
							<li><span class="plan-feat-label">語音筆記</span><span class="plan-feat-value">無限</span></li>
							<li><span class="plan-feat-label">AI 潤飾</span><span class="plan-feat-value">每天 300 次</span></li>
							<li><span class="plan-feat-label">錄音時長</span><span class="plan-feat-value">30 分鐘</span></li>
							<li><span class="plan-feat-label">潤飾品質</span><span class="plan-feat-value">進階版</span></li>
						</ul>
						<div class="plan-actions">
							<a
								class="btn-primary"
								href="https://apps.apple.com/us/app/slax-note-transcribe-voice-pen/id6480166286"
								target="_blank"
								rel="noopener noreferrer"
							>
								App Store
							</a>
							<a
								class="btn-primary btn-primary-outline"
								href="https://play.google.com/store/apps/details?id=app.slax.notes"
								target="_blank"
								rel="noopener noreferrer"
							>
								Google Play
							</a>
						</div>
					</div>

					<!-- PREMIUM — ANNUAL -->
					<div class="plan featured">
						<div class="plan-eyebrow">
							Annual <span class="plan-badge">省 2 個月</span>
						</div>
						<div class="plan-price">
							<span class="num">$49.99</span><span class="unit">/ 年</span>
						</div>
						<p class="plan-note">平均每月只要 $4.16。隨時取消。</p>
						<ul class="plan-list">
							<li><span class="plan-feat-label">語音筆記</span><span class="plan-feat-value">無限</span></li>
							<li><span class="plan-feat-label">AI 潤飾</span><span class="plan-feat-value">每天 300 次</span></li>
							<li><span class="plan-feat-label">錄音時長</span><span class="plan-feat-value">30 分鐘</span></li>
							<li><span class="plan-feat-label">潤飾品質</span><span class="plan-feat-value">進階版</span></li>
						</ul>
						<div class="plan-actions">
							<a
								class="btn-primary"
								href="https://apps.apple.com/us/app/slax-note-transcribe-voice-pen/id6480166286"
								target="_blank"
								rel="noopener noreferrer"
							>
								App Store
							</a>
							<a
								class="btn-primary btn-primary-outline"
								href="https://play.google.com/store/apps/details?id=app.slax.notes"
								target="_blank"
								rel="noopener noreferrer"
							>
								Google Play
							</a>
						</div>
					</div>
				</div>
			</div>
		</section>

		<!-- FAQ -->
		<section class="faq">
			<div class="faq-inner">
				<h2 class="faq-head">常見問題</h2>
				<p class="faq-sub">
					其他問題或建議，歡迎到
					<a href="https://discord.gg/kznNsZvWSk">Discord</a> 找我們，或寄信到
					<a href="mailto:note@slax.com">note@slax.com</a>。
				</p>
				<FaqList items={faqs} />
			</div>
		</section>

		<!-- DOWNLOAD -->
		<DownloadSection platforms={notePlatforms}>
			<Fragment slot="heading">
				Slax Note —— <em>讓你的聲音輕鬆出彩。</em>
			</Fragment>
			<Fragment slot="dek">
				免費下載，iOS 與 Android 都能用。
			</Fragment>
		</DownloadSection>

		<!-- FINALE -->
		<section class="finale">
			<div class="finale-inner">
				<h2 class="finale-h">記錄每一個<em>靈感</em>。</h2>
				<p class="finale-p">
					免費下載，iPhone、Android、網頁版都能用。
				</p>
