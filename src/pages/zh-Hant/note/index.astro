// FAQ — verbatim from note.slax.com
const faqs = [
	{
		q: '如何訂閱？',
		a: '打開 Slax Note App，選擇你想要的訂閱方案，依照畫面提示建立帳號並完成付款。訂閱完成後即可立刻使用進階功能。',
	},
	{
		q: '支援上傳檔案嗎？',
		a: '目前還不支援音訊檔案上傳，這個功能已在計畫中，未來會推出。',
	},
	{
		q: '語音轉文字準確度如何？',
		a: '我們使用最新的 AI 技術，準確度非常高。清晰的音訊輸入下，準確度可達 95% 以上。',
	},
	{
		q: '錄音有時間限制嗎？',
		a: '每段錄音最長 30 分鐘。',
