---
import Button from '~/components/Button.astro';
import DownloadSection from '~/components/DownloadSection.astro';
import FaqList from '~/components/FaqList.astro';
import Footer from '~/components/Footer.astro';
import Nav from '~/components/Nav.astro';
import Base from '~/layouts/Base.astro';
import { SITE } from '~/lib/hreflang';

// All content below is copied verbatim from note.slax.com (the live
// marketing landing) plus n.slax.com product i18n where relevant.
// Single source of truth: fetched from note.slax.com 2026-04-19.

const notePlatforms = [
	{
		icon: '📱',
		title: 'iPhone, iPad, Android',
		bullets: [
			'Un toque y queda anotado.',
			'Transcripción con IA, puntuación automática y pulido del estilo.',
			'Copia o comparte la nota cuando quieras, en texto o imagen.',
			'Sincronización en tiempo real en todos los dispositivos.',
		],
		downloads: [
			{
				href: 'https://apps.apple.com/us/app/slax-note-transcribe-voice-pen/id6480166286',
				small: 'Descárgalo en',
				main: 'App Store',
			},
			{
				href: 'https://play.google.com/store/apps/details?id=app.slax.notes',
				small: 'Disponible en',
				main: 'Google Play',
			},
		],
	},
];

// Efficiency Boost 🚀 — "save your time on what matters"
const efficiencyFeatures = [
	{
		title: 'Captura una idea con un toque',
		body: 'Pulsa una vez y empieza a grabar. Tú piensas, del resto nos encargamos nosotros.',
		video: '/note/videos/click.mp4',
	},
	{
		title: 'Texto y puntuación automáticos',
		body: 'Nuestra IA transcribe tu voz con precisión y pule el texto según el tono, añadiendo puntuación.',
		video: '/note/videos/polish.mp4',
	},
	{
		title: 'Copia y comparte donde sea',
		body: 'Comparte la idea como texto o imagen y enchúfala sin fricciones en tu flujo de trabajo.',
		video: '/note/videos/copy-share.mp4',
	},
];

// Intelligent Ghostwriting ✍️ — "let AI perfect your text with ease"
const ghostwritingFeatures = [
	{
		title: 'Elige estilos listos para cada contexto',
		body: 'Usa estilos integrados: resumen, tuit, elogio y más. Iremos sumando más.',
		video: '/note/videos/choose-ready-made.mp4',
	},
	{
		title: 'Prompts personalizados para tus necesidades',
		body: 'Diseña prompts a medida según tu flujo y lo que necesites.',
		video: '/note/videos/customize.mp4',
	},
];

// How are others using Slax Note — 5 real use cases from note.slax.com
const useCases = [
	{
		title: 'Memos de voz personales',
		body: 'Al caminar o al conducir, atrapa esa idea fugaz. Convertimos tu voz en texto legible para que no se te escape ningún chispazo.',
	},
	{
		title: 'Creación de contenido',
		body: 'Escribe más rápido y más ligero que nunca. Habla tu idea y la IA de Slax Note genera contenido pulido en segundos, sin teclear.',
	},
	{
		title: 'Organizar la agenda',
		body: 'Cuéntale a Slax Note tus pendientes y te los ordena. Reserva el tiempo para lo que importa de verdad.',
	},
	{
		title: 'Actas de reunión',
		body: 'En reuniones sin portátil, abre Slax Note y deja que sea tu asistente de IA: graba y transcribe el resumen.',
	},
	{
		title: 'Apuntes de estudio',
		body: 'Tu compañera de IA para estudiar. Abre Slax Note y graba la clase que podrías perderte, o ensaya un discurso y que te lo pase a un guion limpio.',
	},
];

// Real testimonials from note.slax.com — 6 named users
const testimonials = [
	{
		quote:
			'Si escribes a menudo o anotas ideas al vuelo, recomiendo muchísimo Slax Note. Pule lo que digo hablando hasta dejarlo más preciso que cuando lo escribo.',
		author: 'Cao Jiang',
		title: 'Creador independiente de contenido',
	},
	{
		quote:
			'Es una herramienta elegante. Me ayuda a coger el hábito de anotar ideas a diario, y eso me cambia mucho.',
		author: 'Fenng',
		title: 'Blogger de tecnología',
	},
	{
		quote:
			'Slax Note usa LLMs para automatizar la transcripción de voz y el pulido del contenido. A diferencia de las herramientas clásicas, quita las muletillas y los tropiezos del habla, dejando una salida clara y bien estructurada. Te ayuda a capturar y organizar ideas con eficiencia.',
		author: '辉哥奇谭',
		title: 'Autor',
	},
	{
		quote:
			'No me falta contenido que escribir, me falta tiempo para escribir. Con Slax Note me ahorro mucho tiempo, y eso para mí es valiosísimo.',
		author: 'Investor Fan',
		title: 'Inversor / Fundador de Gaozhang Capital',
	},
	{
		quote:
			'Lo abro tanto si charlo con amigos como si hago una entrevista. Convierte la conversación directa en un artículo, sin tener que ordenar la grabación a mano. Slax Note se ocupa de todo por mí.',
		author: '刘容',
		title: 'Responsable de marketing en una empresa de internet',
	},
	{
		quote:
			'En el grupo familiar comparto a diario los planes y avisos importantes. Uso Slax Note para registrarlos y organizarlos de forma sistemática. Mantiene nuestra comunicación clara y todo está donde tiene que estar.',
		author: 'Vivian',
		title: 'Gerente senior',
	},
];

// FAQ — verbatim from note.slax.com
const faqs = [
	{
		q: '¿Cómo me suscribo?',
		a: 'Abre Slax Note, elige el plan que quieras y sigue los pasos para crear cuenta y pagar. En cuanto te suscribes puedes usar todas las funciones de pago.',
	},
	{
		q: '¿Se pueden subir archivos?',
		a: 'Subir archivos de audio todavía no está soportado. Está en el roadmap y llegará en el futuro.',
	},
	{
		q: '¿Qué precisión tiene la transcripción?',
		a: 'Usamos IA puntera con muy alta precisión. Con audio claro, la precisión supera el 95 %.',
	},
	{
		q: '¿Hay límite de duración por grabación?',
		a: 'Cada grabación dura como máximo 30 minutos.',
	},
	{
		q: '¿Se puede editar el texto transcrito?',
		a: 'Sí. El texto resultante es totalmente editable y soporta cambios entre varios estilos.',
	},
	{
		q: '¿Dónde se guarda el audio? ¿Está seguro?',
		a: 'Todas las grabaciones se guardan en local, para proteger tu privacidad y seguridad.',
	},
	{
		q: '¿Cómo se exportan las notas?',
		a: 'Las notas se pueden compartir fácilmente como texto o imagen en otras apps.',
	},
	{
		q: '¿Funciona sin conexión?',
		a: 'La grabación funciona sin conexión, pero la transcripción necesita internet.',
	},
	{
		q: '¿Cómo cambio de estilo de escritura?',
		a: 'Abre la app y empieza a grabar, o toca "nota de texto" para escribir; entrarás en la pantalla de pulido automático. Allí, el botón "Por defecto" a la derecha permite cambiar entre estilos o crear uno propio.',
	},
	{
		q: '¿Qué idiomas reconoce Slax Note?',
		a: 'Ahora mismo soporta inglés, chino, alemán, japonés y otros idiomas mayoritarios. Iremos añadiendo más.',
	},
];

const schema = {
	'@context': 'https://schema.org',
	'@type': 'SoftwareApplication',
	name: 'Slax Note',
	alternateName: 'Slax Note — notas de voz con IA',
	applicationCategory: 'ProductivityApplication',
	operatingSystem: 'iOS, Android, Web',
	url: new URL('/note/', SITE).toString(),
	image: new URL('/og/note.png', SITE).toString(),
	screenshot: new URL('/images/note/cover.png', SITE).toString(),
	description:
		'Notas de voz con IA. Tú hablas, nosotros escribimos. Graba con Slax Note y deja que la IA capture tu idea y la pula en el estilo de texto que quieras.',
	downloadUrl: [
		'https://apps.apple.com/us/app/slax-note-transcribe-voice-pen/id6480166286',
		'https://play.google.com/store/apps/details?id=app.slax.notes',
	],
	offers: [
		{
			'@type': 'Offer',
			name: 'Free',
			price: '0',
			priceCurrency: 'USD',
		},
		{
			'@type': 'Offer',
			name: 'Premium Monthly',
			price: '4.99',
			priceCurrency: 'USD',
			priceSpecification: {
				'@type': 'UnitPriceSpecification',
				price: '4.99',
				priceCurrency: 'USD',
				billingDuration: 'P1M',
			},
		},
		{
			'@type': 'Offer',
			name: 'Premium Annual',
			price: '49.99',
			priceCurrency: 'USD',
			priceSpecification: {
				'@type': 'UnitPriceSpecification',
				price: '49.99',
				priceCurrency: 'USD',
				billingDuration: 'P1Y',
			},
		},
	],
	publisher: {
		'@type': 'Organization',
		name: 'Starry Tech Pte. Ltd.',
		url: SITE,
		logo: new URL('/images/slax-logo.png', SITE).toString(),
	},
};
---
<Base
	title="Slax Note — Notas de voz con IA. Tú hablas, nosotros escribimos."
	description="Tú hablas, nosotros escribimos. Una grabación, varias formas — moldeada por los prompts que tú elijas. Te acompaña año tras año."
	ogImage="/og/note.png"
	schema={schema}
>
	<Nav active="note" />

	<main>
		<!-- HERO -->
		<section class="n-hero">
			<div class="n-hero-inner">
				<div>
					<h1 class="n-h1">
						Notas de voz con IA. <em>Tú hablas, nosotros escribimos.</em>
					</h1>
					<ul class="n-bullets">
						<li>En cuanto se te ocurra una idea, dila. Sin teclear, sin organizar.</li>
						<li>Una grabación, varias formas — moldeada por los prompts que tú elijas.</li>
						<li>Crece contigo año tras año.</li>
					</ul>
					<div class="n-stores">
						<a
							class="store-btn is-primary"
							href="https://apps.apple.com/us/app/slax-note-transcribe-voice-pen/id6480166286"
							target="_blank"
							rel="noopener noreferrer"
						>
							<span class="store-small">Descárgalo en</span>
							<span class="store-main">App Store</span>
						</a>
						<a
							class="store-btn"
							href="https://play.google.com/store/apps/details?id=app.slax.notes"
							target="_blank"
							rel="noopener noreferrer"
						>
							<span class="store-small">Disponible en</span>
							<span class="store-main">Google Play</span>
						</a>
					</div>
					<p class="n-web-link">
						O <a href="https://n.slax.com/">entra desde la web</a>.
					</p>
				</div>
				<div class="n-visual">
					<img
						src="/images/note/cover.png"
						alt="Slax Note — notas de voz con IA"
						class="n-img"
						loading="eager"
					/>
				</div>
			</div>
		</section>

		<!-- EFFICIENCY BOOST -->
		<section class="features" id="features" data-demo-group="efficiency">
			<div class="features-inner">
				<div class="feat-head">
					<h2 class="feat-title">Más eficiencia</h2>
					<p class="feat-sub">Reserva tu tiempo para lo que importa de verdad.</p>
				</div>
				<div class="feat-demo-body">
					<div class="feat-list" role="tablist" aria-label="Funciones de eficiencia">
						{efficiencyFeatures.map((f, i) => (
							<button
								class="feat-item"
								type="button"
								role="tab"
								data-idx={i}
								aria-selected={i === 0 ? 'true' : 'false'}
								aria-controls={`efficiency-video-${i}`}
							>
								<div class="feat-item-head">
									<span class="feat-num">{String(i + 1).padStart(2, '0')}</span>
									<h3 class="feat-h">{f.title}</h3>
								</div>
								<p class="feat-p">{f.body}</p>
							</button>
						))}
					</div>
					<div class="feat-stage">
						<div class="feat-frame">
							{efficiencyFeatures.map((f, i) => (
								<video
									id={`efficiency-video-${i}`}
									class="feat-video"
									data-idx={i}
									src={f.video}
									muted
									loop
									playsinline
									preload={i === 0 ? 'auto' : 'metadata'}
									aria-hidden={i === 0 ? 'false' : 'true'}
								></video>
							))}
						</div>
					</div>
				</div>
			</div>
		</section>

		<!-- INTELLIGENT GHOSTWRITING -->
		<section class="features features-alt" data-demo-group="ghostwriting">
			<div class="features-inner">
				<div class="feat-head">
					<h2 class="feat-title">Ghostwriting con IA</h2>
					<p class="feat-sub">Deja que la IA pula tu texto sin esfuerzo.</p>
				</div>
				<div class="feat-demo-body feat-demo-body--reverse">
					<div class="feat-stage">
						<div class="feat-frame">
							{ghostwritingFeatures.map((f, i) => (
								<video
									id={`ghostwriting-video-${i}`}
									class="feat-video"
									data-idx={i}
									src={f.video}
									muted
									loop
									playsinline
									preload="metadata"
									aria-hidden={i === 0 ? 'false' : 'true'}
								></video>
							))}
						</div>
					</div>
					<div class="feat-list" role="tablist" aria-label="Funciones de ghostwriting con IA">
						{ghostwritingFeatures.map((f, i) => (
							<button
								class="feat-item"
								type="button"
								role="tab"
								data-idx={i}
								aria-selected={i === 0 ? 'true' : 'false'}
								aria-controls={`ghostwriting-video-${i}`}
							>
								<div class="feat-item-head">
									<span class="feat-num">{String(i + 1).padStart(2, '0')}</span>
									<h3 class="feat-h">{f.title}</h3>
								</div>
								<p class="feat-p">{f.body}</p>
							</button>
						))}
					</div>
				</div>
			</div>
		</section>

		<!-- USE CASES -->
		<section class="usecases">
			<div class="usecases-inner">
				<h2 class="usecases-head">Cómo usan otros Slax Note</h2>
				<div class="uc-grid">
					{useCases.map((uc) => (
						<div class="uc">
							<h3 class="uc-h">{uc.title}</h3>
							<p class="uc-p">{uc.body}</p>
						</div>
					))}
				</div>
			</div>
		</section>

		<!-- TESTIMONIALS -->
		<section class="testimonials">
			<div class="testimonials-inner">
				<h2 class="t-head">Lo eligen miles de usuarios</h2>
				<p class="t-sub">
					¿Listo para cambiar la forma en que tomas notas? Empieza con Slax Note hoy mismo.
				</p>
				<div class="t-grid">
					{testimonials.map((t) => (
						<figure class="testimonial">
							<blockquote class="t-quote">«{t.quote}»</blockquote>
							<figcaption class="t-caption">
								<span class="t-author">{t.author}</span>
								<span class="t-title">{t.title}</span>
							</figcaption>
						</figure>
					))}
				</div>
			</div>
		</section>

		<!-- PRICING -->
		<section class="pricing" id="pricing">
			<div class="pricing-inner">
				<h2 class="pricing-head">Precios</h2>
				<p class="pricing-dek">Aprovecha el precio de lanzamiento y sube de plan.</p>

				<div class="plans-grid plans-grid-3">
					<!-- FREE -->
					<div class="plan">
						<div class="plan-eyebrow">Free</div>
						<div class="plan-price">
							<span class="num">0 $</span>
						</div>
						<p class="plan-note">Gratis de por vida.</p>
						<ul class="plan-list">
							<li><span class="plan-feat-label">Notas de voz</span><span class="plan-feat-value">5</span></li>
							<li><span class="plan-feat-label">AI Polish</span><span class="plan-feat-value">10 en total</span></li>
							<li><span class="plan-feat-label">Duración de grabación</span><span class="plan-feat-value">5 minutos</span></li>
						</ul>
						<a href="https://n.slax.com/" class="btn-primary">Pruébalo</a>
					</div>

					<!-- PREMIUM — MONTHLY -->
					<div class="plan">
						<div class="plan-eyebrow">Monthly</div>
						<div class="plan-price">
							<span class="num">4,99 $</span><span class="unit">/ mes</span>
						</div>
						<p class="plan-note">Cancela cuando quieras.</p>
						<ul class="plan-list">
							<li><span class="plan-feat-label">Notas de voz</span><span class="plan-feat-value">Ilimitadas</span></li>
							<li><span class="plan-feat-label">AI Polish</span><span class="plan-feat-value">300 al día</span></li>
							<li><span class="plan-feat-label">Duración de grabación</span><span class="plan-feat-value">30 minutos</span></li>
							<li><span class="plan-feat-label">Calidad del pulido</span><span class="plan-feat-value">Premium</span></li>
						</ul>
						<div class="plan-actions">
							<a
								class="btn-primary"
								href="https://apps.apple.com/us/app/slax-note-transcribe-voice-pen/id6480166286"
								target="_blank"
								rel="noopener noreferrer"
							>
								App Store
							</a>
							<a
								class="btn-primary btn-primary-outline"
								href="https://play.google.com/store/apps/details?id=app.slax.notes"
								target="_blank"
								rel="noopener noreferrer"
							>
								Google Play
							</a>
						</div>
					</div>

					<!-- PREMIUM — ANNUAL -->
					<div class="plan featured">
						<div class="plan-eyebrow">
							Annual <span class="plan-badge">Ahorra 2 meses</span>
						</div>
						<div class="plan-price">
							<span class="num">49,99 $</span><span class="unit">/ año</span>
						</div>
						<p class="plan-note">Equivale a 4,16 $/mes. Cancela cuando quieras.</p>
						<ul class="plan-list">
							<li><span class="plan-feat-label">Notas de voz</span><span class="plan-feat-value">Ilimitadas</span></li>
							<li><span class="plan-feat-label">AI Polish</span><span class="plan-feat-value">300 al día</span></li>
							<li><span class="plan-feat-label">Duración de grabación</span><span class="plan-feat-value">30 minutos</span></li>
							<li><span class="plan-feat-label">Calidad del pulido</span><span class="plan-feat-value">Premium</span></li>
						</ul>
						<div class="plan-actions">
							<a
								class="btn-primary"
								href="https://apps.apple.com/us/app/slax-note-transcribe-voice-pen/id6480166286"
								target="_blank"
								rel="noopener noreferrer"
							>
								App Store
							</a>
							<a
								class="btn-primary btn-primary-outline"
								href="https://play.google.com/store/apps/details?id=app.slax.notes"
								target="_blank"
								rel="noopener noreferrer"
							>
								Google Play
							</a>
						</div>
					</div>
				</div>
			</div>
		</section>

		<!-- FAQ -->
		<section class="faq">
			<div class="faq-inner">
				<h2 class="faq-head">Preguntas frecuentes</h2>
				<p class="faq-sub">
					Si tienes más preguntas o sugerencias, escríbenos por
					<a href="https://discord.gg/kznNsZvWSk">Discord</a> o al correo
					<a href="mailto:note@slax.com">note@slax.com</a>.
				</p>
				<FaqList items={faqs} />
			</div>
		</section>

		<!-- DOWNLOAD -->
		<DownloadSection platforms={notePlatforms}>
			<Fragment slot="heading">
				Slax Note — <em>tu voz, lista para publicar.</em>
			</Fragment>
			<Fragment slot="dek">
				Descarga gratis para iOS y Android.
			</Fragment>
		</DownloadSection>

		<!-- FINALE -->
		<section class="finale">
			<div class="finale-inner">
				<h2 class="finale-h">Captura cada <em>chispa</em>.</h2>
				<p class="finale-p">
					Descarga gratis para iPhone, Android y web.
				</p>
				<div class="actions actions-center">
					<Button variant="primary" href="https://n.slax.com/" arrow>Abrir Slax Note</Button>
					<Button variant="secondary" href="#pricing">Ver precios</Button>
				</div>
			</div>
		</section>
	</main>

	<Footer />
</Base>

<style>
	/* HERO */
	.n-hero {
		padding: 6rem 0 5rem;
	}
	.n-hero-inner {
		max-width: 1180px;
		margin: 0 auto;
		padding: 0 2rem;
		display: grid;
		grid-template-columns: 1fr;
		gap: 4rem;
		align-items: center;
	}
	@media (min-width: 960px) {
		.n-hero-inner {
			grid-template-columns: 1.1fr 1fr;
		}
	}
	.n-h1 {
		font-family: var(--serif);
		font-weight: 400;
		font-size: clamp(2rem, 4vw, 3.2rem);
		line-height: 1.1;
		letter-spacing: -0.02em;
		margin: 1rem 0 1.75rem;
		color: var(--ink);
		max-width: 20ch;
	}
	.n-h1 :global(em) {
		font-style: italic;
		font-weight: 300;
		color: var(--accent);
	}
	.n-bullets {
		list-style: none;
		padding: 0;
		margin: 0 0 2.25rem;
		display: flex;
		flex-direction: column;
		gap: 0.75rem;
		max-width: 48ch;
	}
	.n-bullets li {
		position: relative;
		padding-left: 1.5rem;
		font-family: var(--serif);
		font-size: 1.05rem;
		line-height: 1.55;
		color: var(--ink-soft);
	}
	.n-bullets li::before {
		content: "—";
		position: absolute;
		left: 0;
		top: 0;
		color: var(--ink-mute);
		font-weight: 300;
	}
	.n-stores {
		display: flex;
		gap: 0.75rem;
		flex-wrap: wrap;
	}
	.n-web-link {
		margin: 0.9rem 0 0;
		font-family: var(--serif);
