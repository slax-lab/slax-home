---
import { getCollection } from 'astro:content';
import Footer from '~/components/Footer.astro';
import Nav from '~/components/Nav.astro';
import Base from '~/layouts/Base.astro';
import { entryLocale, entrySlug, filterByLocale } from '~/lib/content';

const dateFmt = new Intl.DateTimeFormat('es', {
	year: 'numeric',
	month: 'long',
	day: 'numeric',
	timeZone: 'UTC',
});

const teaserFromBody = (body: string | undefined) => {
	if (!body) return '';
	const firstBullet = body
		.split('\n')
		.map((l) => l.trim())
		.find((l) => l.startsWith('-'));
	if (!firstBullet) return '';
	const cleaned = firstBullet.replace(/^-\s*/, '').replace(/\*\*/g, '');
	return cleaned.length > 110 ? `${cleaned.slice(0, 107).trimEnd()}…` : cleaned;
};

const latestChangelog = async (name: 'readerChangelog' | 'noteChangelog') => {
	const all = filterByLocale(await getCollection(name), 'es');
	const sorted = all.sort(
		(a, b) => b.data.date.valueOf() - a.data.date.valueOf(),
	);
	const latest = sorted[0];
	return {
		version: latest.data.version,
		date: latest.data.date,
		platforms: latest.data.platforms as string[],
		teaser: teaserFromBody(latest.body),
	};
};

const latestPost = async (product: 'reader' | 'note') => {
	const posts = await getCollection('blog', ({ data, id }) => {
		if (data.draft || data.product !== product) return false;
		const lang = data.lang ?? entryLocale(id);
		return lang === 'es';
	});
	const sorted = posts.sort(
		(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
	);
	const latest = sorted[0];
	return latest
		? {
				slug: entrySlug(latest),
				title: latest.data.title,
				description: latest.data.description,
				pubDate: latest.data.pubDate,
			}
		: null;
};

const [readerLatest, noteLatest, readerPost, notePost] = await Promise.all([
	latestChangelog('readerChangelog'),
	latestChangelog('noteChangelog'),
	latestPost('reader'),
	latestPost('note'),
]);

const beliefs = [
	{
		n: '01',
		line: 'Hacemos software que nosotros mismos usamos.',
		note: 'Si nosotros no lo usamos a diario, no lo lanzamos.',
	},
	{
		n: '02',
		line: 'Dispuestos a ir por el camino lento.',
		note: 'Software pequeño y cuidado, hecho despacio — vuelve dentro de diez años y seguirá ahí.',
	},
	{
		n: '03',
		line: 'Nosotros escribimos el código, tú eres dueño de tus datos.',
		note: 'Código abierto, sin secuestros. Los datos son tuyos, las decisiones también.',
	},
];

const products = [
	{
		key: 'reader',
		href: '/es/reader/',
		logo: '/images/reader-logo-new.png',
		name: 'Slax Reader',
		headline:
			'Una herramienta de leer después, de código abierto y sin adornos.',
		bullets: [
			'Sin algoritmo, sin feed. Tú eliges qué leer ahora.',
			'Capturas web ilimitadas y gratis.',
			'Código abierto.',
		],
		cta: 'Entrar en Reader →',
	},
	{
		key: 'note',
		href: '/es/note/',
		logo: '/images/note-logo-new.png',
		name: 'Slax Note',
		headline: 'Notas de voz con IA. Tú hablas, nosotros escribimos.',
		bullets: [
			'Lo dices y queda, sin teclear, sin organizar.',
			'Una grabación, varias formas — moldeada por los prompts que tú elijas.',
			'Hecha para acompañarte año tras año.',
		],
		cta: 'Entrar en Note →',
	},
];
---
<Base
	title="Slax — Slax Reader open source + Slax Note. Hecho para durar."
	description="Slax Reader — read-later open source con resúmenes con IA. Slax Note — notas de voz con IA y Prompts compartibles. Software pequeño, hecho para durar."
	ogImage="/og/es/home.png"
>
	<Nav />

	<!-- Pantalla 1 · Slax Hero · postura de marca + creencias -->
	<section class="slax-hero">
		<div class="slax-hero-inner">
			<div class="slax-hero-main">
				<h1 class="slax-hero-title">
					Simple. Relajado.<br /><em>Hecho para durar.</em>
				</h1>
				<p class="slax-hero-sub">
					Hacemos el software que queríamos para nosotros.
				</p>
				<div class="slax-hero-cta">
					<a class="slax-hero-btn" href="/es/reader/">Conoce Reader</a>
					<a class="slax-hero-btn" href="/es/note/">Conoce Note</a>
				</div>
			</div>
			<aside class="slax-hero-aside" aria-labelledby="beliefs-label">
				<span id="beliefs-label" class="beliefs-eyebrow">—— Cómo lo hacemos</span>
				<ol class="beliefs-list">
					{beliefs.map((b) => (
						<li class="belief">
							<span class="belief-num">{b.n}</span>
							<div class="belief-body">
								<span class="belief-line">{b.line}</span>
								<p class="belief-note">{b.note}</p>
							</div>
						</li>
					))}
				</ol>
			</aside>
		</div>
	</section>

	<!-- Pantalla 2 · Productos · cuadrícula plana, logo delante -->
	<section class="products" id="products">
		<div class="products-inner">
			<span class="products-eyebrow">—— Nuestros productos</span>
			<div class="products-grid">
				{products.map((p) => (
					<a class={`product product-${p.key}`} href={p.href}>
						<div class="product-body">
							<h2 class="product-name">{p.name}</h2>
							<p class="product-headline">{p.headline}</p>
							<ul class="product-bullets">
								{p.bullets.map((b) => <li>{b}</li>)}
							</ul>
							<span class="product-cta">{p.cta}</span>
						</div>
						<span class="product-logo-frame">
							<img
								src={p.logo}
								alt={`Logo de ${p.name}`}
								class="product-logo"
								width="112"
								height="112"
								loading="eager"
								decoding="async"
							/>
						</span>
					</a>
				))}
			</div>
		</div>
	</section>

	<!-- Pantalla 3 · Novedades · última versión por producto -->
	<section class="whats-new">
		<div class="whats-new-inner">
			<span class="section-eyebrow">—— Novedades</span>
			<div class="whats-new-grid">
				<article class="release-card">
					<p class="release-product">Slax Reader</p>
					<p class="release-meta">
						<span class="release-version">v{readerLatest.version}</span>
						<span class="release-sep">·</span>
						<span>{dateFmt.format(readerLatest.date)}</span>
					</p>
					<p class="release-platforms">{readerLatest.platforms.join(' · ')}</p>
					{readerLatest.teaser && <p class="release-teaser">{readerLatest.teaser}</p>}
					<a class="release-cta" href="/es/reader/changelog/">Ver todas las novedades de Reader →</a>
				</article>
				<article class="release-card">
					<p class="release-product">Slax Note</p>
					<p class="release-meta">
						<span class="release-version">v{noteLatest.version}</span>
						<span class="release-sep">·</span>
						<span>{dateFmt.format(noteLatest.date)}</span>
					</p>
					<p class="release-platforms">{noteLatest.platforms.join(' · ')}</p>
					{noteLatest.teaser && <p class="release-teaser">{noteLatest.teaser}</p>}
					<a class="release-cta" href="/es/note/changelog/">Ver todas las novedades de Note →</a>
				</article>
			</div>
		</div>
	</section>

	<!-- Pantalla 4 · Desde el blog · último post por producto -->
	<section class="from-blog">
		<div class="from-blog-inner">
			<span class="section-eyebrow">—— Desde el blog</span>
			<div class="from-blog-grid">
				{readerPost && (
					<article class="post-card">
						<p class="post-product">Slax Reader</p>
						<time class="post-date" datetime={readerPost.pubDate.toISOString()}>
							{dateFmt.format(readerPost.pubDate)}
						</time>
						<h3 class="post-title">
							<a href={`/es/blog/${readerPost.slug}/`}>{readerPost.title}</a>
						</h3>
						<p class="post-desc">{readerPost.description}</p>
						<a class="post-cta" href={`/es/blog/${readerPost.slug}/`}>Seguir leyendo →</a>
					</article>
				)}
				{notePost && (
					<article class="post-card">
						<p class="post-product">Slax Note</p>
						<time class="post-date" datetime={notePost.pubDate.toISOString()}>
							{dateFmt.format(notePost.pubDate)}
						</time>
						<h3 class="post-title">
							<a href={`/es/blog/${notePost.slug}/`}>{notePost.title}</a>
						</h3>
						<p class="post-desc">{notePost.description}</p>
						<a class="post-cta" href={`/es/blog/${notePost.slug}/`}>Seguir leyendo →</a>
					</article>
				)}
			</div>
			<a class="from-blog-all" href="/es/blog/">Todos los artículos de Slax →</a>
		</div>
	</section>

	<Footer />
</Base>

<style>
	/* ─── Pantalla 1 · Slax Hero + aside de creencias ─── */
	.slax-hero {
		width: 100%;
		background: var(--bg);
		border-bottom: 1px solid var(--rule-soft);
	}
	.slax-hero-inner {
		max-width: 1200px;
		margin: 0 auto;
		padding: clamp(3.5rem, 7vw, 5.5rem) 2rem clamp(3rem, 5vw, 4.5rem);
		display: grid;
		grid-template-columns: 1fr;
		gap: 3rem;
		align-items: start;
	}
	@media (min-width: 960px) {
		.slax-hero-inner {
			grid-template-columns: minmax(0, 1fr) minmax(340px, 0.85fr);
			gap: 4.5rem;
		}
	}
	.slax-hero-main {
		min-width: 0;
		padding-top: 0.25rem;
	}
	.slax-hero-aside {
		min-width: 0;
	}
	@media (min-width: 960px) {
		.slax-hero-aside {
			border-left: 1px solid var(--rule-soft);
			padding-left: 3rem;
		}
	}
	.slax-hero-title {
		font-family: var(--serif);
		font-weight: 400;
		font-size: clamp(2.4rem, 5vw, 4rem);
		line-height: 1.02;
		letter-spacing: -0.03em;
		color: var(--ink);
		margin: 0 0 1.75rem;
	}
	.slax-hero-title em {
		font-style: italic;
		font-weight: 300;
		color: var(--accent);
	}
	.slax-hero-sub {
		font-family: var(--serif);
		font-size: clamp(1.1rem, 1.6vw, 1.35rem);
		line-height: 1.5;
		color: var(--ink-soft);
		margin: 0 0 2.5rem;
		max-width: 36ch;
	}
	.slax-hero-cta {
		display: flex;
		gap: 0.75rem;
		flex-wrap: wrap;
	}
	.slax-hero-btn {
		display: inline-block;
		font-family: var(--mono);
		font-size: 0.78rem;
		letter-spacing: 0.1em;
		text-transform: uppercase;
		color: var(--ink);
		padding: 0.85rem 1.4rem;
		border: 1px solid var(--ink);
		text-decoration: none;
		transition:
			background 0.2s ease,
			color 0.2s ease;
	}
	.slax-hero-btn:hover {
		background: var(--ink);
		color: var(--bg);
	}

	/* creencias — anidadas en el aside del hero */
	.beliefs-eyebrow {
		display: block;
		font-family: var(--mono);
		font-size: 0.72rem;
		letter-spacing: 0.18em;
		text-transform: uppercase;
		color: var(--ink-mute);
		margin: 0 0 1.5rem;
	}
	.beliefs-list {
		list-style: none;
		padding: 0;
		margin: 0;
	}
	.belief {
		display: grid;
		grid-template-columns: 36px 1fr;
		gap: 1rem;
		align-items: baseline;
		padding: 1.1rem 0;
	}
	.belief + .belief {
		border-top: 1px solid var(--rule-soft);
	}
	.belief-num {
		font-family: var(--mono);
		font-size: 0.7rem;
		letter-spacing: 0.14em;
		color: var(--ink-mute);
	}
	.belief-body {
		display: flex;
		flex-direction: column;
		gap: 0.4rem;
	}
	.belief-line {
		font-family: var(--serif);
		font-weight: 400;
		font-size: clamp(1.1rem, 1.5vw, 1.35rem);
		line-height: 1.3;
		letter-spacing: -0.01em;
		color: var(--ink);
	}
	.belief-note {
		font-family: var(--serif);
		font-size: 0.92rem;
		line-height: 1.55;
		color: var(--ink-mute);
		margin: 0;
	}

	/* ─── Pantalla 2 · Productos ─── */
	.products {
		width: 100%;
		background: var(--bg);
		padding: clamp(3.5rem, 6vw, 5rem) 0;
	}
	.products-inner {
		max-width: 1200px;
		margin: 0 auto;
		padding: 0 2rem;
	}
	.products-eyebrow {
		display: block;
		font-family: var(--mono);
		font-size: 0.72rem;
		letter-spacing: 0.18em;
		text-transform: uppercase;
		color: var(--ink-mute);
		margin: 0 0 2rem;
	}
	.products-grid {
		display: grid;
		grid-template-columns: 1fr;
		gap: 0;
	}
	@media (min-width: 820px) {
		.products-grid {
			grid-template-columns: 1fr 1fr;
		}
	}
	.product {
		display: grid;
		grid-template-columns: minmax(0, 1fr) auto;
		gap: 1.5rem;
		align-items: start;
		padding: clamp(2.25rem, 3.5vw, 3rem) clamp(1.5rem, 2.5vw, 2.25rem);
		text-decoration: none;
		background: var(--bg);
		transition:
			background 0.25s ease,
			transform 0.25s ease;
	}
	.product + .product {
		border-top: 1px solid var(--rule-soft);
	}
	@media (min-width: 820px) {
		.product + .product {
			border-top: 0;
			border-left: 1px solid var(--rule);
		}
	}
	.product:hover {
		background: var(--bg-deep);
	}
	.product:hover .product-logo-frame {
		transform: translateY(-2px);
	}
	.product-body {
		display: flex;
		flex-direction: column;
		min-width: 0;
	}
	.product-logo-frame {
		width: 88px;
		height: 88px;
		border-radius: 20px;
		overflow: hidden;
		box-shadow: 0 8px 26px -14px rgba(27, 26, 23, 0.28);
		transition: transform 0.25s ease;
		align-self: start;
		flex-shrink: 0;
		display: block;
	}
	.product-logo {
		width: 100%;
		height: 100%;
		object-fit: cover;
		display: block;
	}
	.product-reader .product-logo {
		transform: scale(1.06);
		transform-origin: center;
	}
	@media (max-width: 520px) {
		.product-logo-frame {
			width: 64px;
			height: 64px;
			border-radius: 14px;
		}
	}
	.product-name {
		font-family: var(--serif);
		font-weight: 500;
		font-size: clamp(1.6rem, 2.4vw, 2.1rem);
		letter-spacing: -0.02em;
		color: var(--ink);
		margin: 0 0 0.6rem;
	}
	.product-headline {
		font-family: var(--serif);
		font-size: clamp(1.05rem, 1.4vw, 1.2rem);
		line-height: 1.4;
		color: var(--ink-soft);
		margin: 0 0 1.5rem;
		max-width: 28ch;
	}
	.product-bullets {
		list-style: none;
		padding: 0;
		margin: 0 0 2rem;
		display: flex;
		flex-direction: column;
		gap: 0.6rem;
	}
	.product-bullets li {
		position: relative;
		padding-left: 1.5rem;
		font-family: var(--serif);
		font-size: 0.98rem;
		line-height: 1.5;
		color: var(--ink-soft);
		max-width: 44ch;
	}
	.product-bullets li::before {
		content: "—";
		position: absolute;
		left: 0;
		top: 0;
		color: var(--ink-mute);
		font-weight: 300;
	}
	.product-cta {
		margin-top: auto;
		font-family: var(--mono);
		font-size: 0.8rem;
		letter-spacing: 0.08em;
		text-transform: uppercase;
		color: var(--accent);
		align-self: flex-start;
		padding-bottom: 2px;
		border-bottom: 1px solid transparent;
		transition: border-color 0.2s ease;
	}
	.product:hover .product-cta {
		border-bottom-color: var(--accent);
	}

	/* ─── helpers de sección compartidos ─── */
	.section-eyebrow {
		display: block;
		font-family: var(--mono);
		font-size: 0.72rem;
		letter-spacing: 0.18em;
		text-transform: uppercase;
		color: var(--ink-mute);
		margin: 0 0 2rem;
	}

	/* ─── Pantalla 3 · Novedades ─── */
	.whats-new {
		width: 100%;
		background: var(--bg);
		padding: clamp(3.5rem, 6vw, 5rem) 0;
		border-top: 1px solid var(--rule-soft);
	}
	.whats-new-inner {
		max-width: 1200px;
		margin: 0 auto;
		padding: 0 2rem;
	}
	.whats-new-grid {
		display: grid;
		grid-template-columns: 1fr;
		gap: 0;
	}
	@media (min-width: 820px) {
		.whats-new-grid {
			grid-template-columns: 1fr 1fr;
		}
	}
	.release-card {
		display: flex;
		flex-direction: column;
		padding: clamp(2rem, 3vw, 2.5rem) clamp(1.5rem, 2.5vw, 2.25rem);
	}
	.release-card + .release-card {
		border-top: 1px solid var(--rule-soft);
	}
	@media (min-width: 820px) {
		.release-card + .release-card {
			border-top: 0;
			border-left: 1px solid var(--rule);
		}
	}
	.release-product {
		font-family: var(--mono);
		font-size: 0.72rem;
		letter-spacing: 0.18em;
		text-transform: uppercase;
		color: var(--ink-mute);
		margin: 0 0 1rem;
	}
	.release-meta {
		font-family: var(--serif);
		font-size: clamp(1.2rem, 1.7vw, 1.5rem);
		line-height: 1.2;
		color: var(--ink);
		margin: 0 0 0.4rem;
		display: flex;
		gap: 0.55rem;
		align-items: baseline;
		flex-wrap: wrap;
	}
	.release-version {
		font-weight: 500;
		letter-spacing: -0.01em;
	}
	.release-sep {
		color: var(--ink-mute);
	}
	.release-platforms {
		font-family: var(--mono);
		font-size: 0.74rem;
		letter-spacing: 0.06em;
		color: var(--accent);
		margin: 0 0 1rem;
	}
	.release-teaser {
		font-family: var(--serif);
		font-size: 1rem;
		line-height: 1.55;
		color: var(--ink-soft);
		margin: 0 0 1.5rem;
		max-width: 44ch;
	}
	.release-cta {
		margin-top: auto;
		font-family: var(--mono);
		font-size: 0.78rem;
		letter-spacing: 0.08em;
		text-transform: uppercase;
		color: var(--accent);
		text-decoration: none;
		align-self: flex-start;
		padding-bottom: 2px;
		border-bottom: 1px solid transparent;
		transition: border-color 0.2s ease;
	}
	.release-cta:hover {
		border-bottom-color: var(--accent);
	}

	/* ─── Pantalla 4 · Desde el blog ─── */
	.from-blog {
		width: 100%;
		background: var(--bg);
		padding: clamp(3.5rem, 6vw, 5rem) 0;
		border-top: 1px solid var(--rule-soft);
	}
	.from-blog-inner {
		max-width: 1200px;
		margin: 0 auto;
		padding: 0 2rem;
	}
	.from-blog-grid {
		display: grid;
		grid-template-columns: 1fr;
		gap: 0;
	}
	@media (min-width: 820px) {
		.from-blog-grid {
			grid-template-columns: 1fr 1fr;
		}
	}
	.post-card {
		display: flex;
		flex-direction: column;
		padding: clamp(2rem, 3vw, 2.5rem) clamp(1.5rem, 2.5vw, 2.25rem);
	}
	.post-card + .post-card {
		border-top: 1px solid var(--rule-soft);
	}
	@media (min-width: 820px) {
		.post-card + .post-card {
			border-top: 0;
			border-left: 1px solid var(--rule);
		}
	}
	.post-product {
		font-family: var(--mono);
		font-size: 0.72rem;
		letter-spacing: 0.18em;
		text-transform: uppercase;
		color: var(--ink-mute);
		margin: 0 0 0.75rem;
	}
	.post-date {
		font-family: var(--mono);
		font-size: 0.74rem;
		letter-spacing: 0.06em;
		color: var(--accent);
		margin: 0 0 0.85rem;
		display: block;
	}
	.post-title {
		font-family: var(--serif);
		font-weight: 500;
		font-size: clamp(1.25rem, 1.8vw, 1.55rem);
		line-height: 1.25;
		letter-spacing: -0.01em;
		margin: 0 0 0.85rem;
		color: var(--ink);
	}
	.post-title a {
		color: inherit;
		text-decoration: none;
		transition: color 0.2s ease;
	}
	.post-title a:hover {
		color: var(--accent);
	}
