---
import Button from '~/components/Button.astro';
import DownloadSection from '~/components/DownloadSection.astro';
import FaqList from '~/components/FaqList.astro';
import Footer from '~/components/Footer.astro';
import Nav from '~/components/Nav.astro';
import Base from '~/layouts/Base.astro';

// Content sourced verbatim from original apps/reader-home components
// (archive/apps-backup): HomeHero / HomeFeatures / HomeHowItWorks /
// HomeComparison / HomeCTA / PricingTable / DownloadPage.
// Plan decision: merge features + pricing + download into single
// anchor-navigable /reader/ page.

const features = [
	{
		title: 'Une compréhension portée par l’IA',
		body: 'Résumés instantanés, idées-clés et réponses à toutes vos questions sur n’importe quel article. Comme un tuteur personnel pour tout ce que vous lisez.',
	},
	{
		title: 'Vos contenus ne disparaissent jamais',
		body: 'Sauvegardé une fois, archivé pour toujours. Plus jamais de « 404 page introuvable ». Votre bibliothèque numérique vous appartient vraiment.',
	},
	{
		title: 'Un classement intelligent',
		body: 'L’IA étiquette et range vos contenus toute seule. Une recherche sémantique puissante retrouve exactement ce qu’il vous faut, quand il le faut.',
	},
	{
		title: 'Une lecture connectée',
		body: 'Surlignez et commentez n’importe quel article sauvegardé. Partagez, invitez d’autres lecteurs à apporter leurs idées et à discuter. Chaque article devient un lieu de conversation.',
	},
];

const steps = [
	{
		title: 'Sauvegarder, en un geste',
		body: 'Un clic pour enregistrer un article, un papier ou un billet de blog depuis n’importe où sur le web.',
	},
	{
		title: 'L’IA analyse',
		body: 'Des aperçus IA instantanés vous aident à trier : ce qui mérite une lecture approfondie, ce qu’on peut survoler. Gardez votre temps pour ce qui le mérite.',
	},
	{
		title: 'Posez vos questions',
		body: 'Dialoguez avec l’IA à propos de ce que vous avez sauvegardé. Pour creuser, vraiment.',
	},
	{
		title: 'Engagez-vous avec vos contenus',
		body: 'Surlignez, commentez, échangez. Ce que vous écrivez vaut plus que ce que vous lisez.',
	},
];

// Cell value: 'ok' → ● accent,   'no' → — muted,   any other string → inline text (muted italic)
const compareRows: Array<[string, string, string, string]> = [
	[
		'Marque-pages illimités gratuits (utilisateurs précoces)',
		'ok',
		'ok',
		'Payant',
	],
	['Sauvegarde permanente du contenu', 'ok', 'Payant', 'Payant'],
	['Plan IA', 'Payant', 'ok', 'Payant'],
	['Dialogue IA pendant la lecture', 'Payant', 'no', 'Payant'],
	[
		'Surlignage et commentaire sur la page d’origine et la capture, synchronisation deux sens',
		'ok',
		'no',
		'Payant',
	],
	['Rejoindre les discussions entre lecteurs', 'ok', 'no', 'Partagé seulement'],
	['Étiquetage IA automatique', 'Payant', 'Manuel', 'Manuel'],
];

const matrixRows: Array<[string, string, string]> = [
	['Sauvegarder un nombre illimité d’articles', 'ok', 'ok'],
	['Captures permanentes (fini les liens morts)', 'ok', 'ok'],
	['Surlignages et commentaires illimités', 'ok', 'ok'],
	['Recherche plein texte', 'ok', 'ok'],
	['Synchronisation sur tous vos appareils', 'ok', 'ok'],
	['Partager les articles et rejoindre les discussions', 'ok', 'ok'],
	['Open source et respect de la vie privée', 'ok', 'ok'],
	['Créer et gérer ses étiquettes', 'ok', 'ok'],
	['Étiquetage IA intelligent', 'no', 'ai'],
	['Résumés IA instantanés', 'no', 'ai'],
	['Plans IA interactifs', 'no', 'ai'],
	['Chatbot IA — interrogez votre bibliothèque', 'no', 'ai'],
];

const faqs = [
	{
		q: 'L’offre gratuite est-elle vraiment gratuite à vie ?',
		a: 'Oui — pour les utilisateurs précoces. Pendant cet accès anticipé, nous offrons marque-pages illimités et sauvegardes permanentes, sans rien payer. Verrouillez votre usage gratuit avant qu’on impose des limites.',
	},
	{
		q: 'Slax Reader va-t-il vraiment me faire gagner des heures de lecture chaque semaine ?',
		a: 'C’est fait pour ça. Les plans IA cliquables vous laissent parcourir un long article sans en lire chaque mot. L’étiquetage automatique gère le classement, vous n’avez plus qu’à lire.',
	},
	{
		q: 'Puis-je résilier Pro à tout moment ?',
		a: 'Bien sûr. Vous résiliez quand vous voulez depuis vos réglages, sans pénalité. Vos articles et surlignages restent accessibles avec l’offre gratuite.',
	},
	{
		q: 'Comment fonctionne l’essai gratuit d’un mois ?',
		a: 'Connectez-vous et lancez votre essai — pas besoin de carte. Au bout de 30 jours, nous vous proposons de continuer en Pro à 5,99 $/mois (au lieu de 9,99 $).',
	},
];

const platforms = [
	{
		icon: '📱',
		title: 'iPhone, iPad, Android',
		bullets: [
			'Sauvegardé pour toujours, gratuitement.',
			'Un article en un geste.',
			'Plans IA instantanés et navigation rapide.',
			'Synchronisation multi-plateforme.',
		],
		downloads: [
			{
				href: 'https://apps.apple.com/us/app/slax-reader-ai-read-it-later/id6596730998',
				small: 'Télécharger dans l’',
				main: 'App Store',
			},
			{
				href: 'https://play.google.com/store/apps/details?id=com.slax.reader',
				small: 'DISPONIBLE SUR',
				main: 'Google Play',
			},
		],
	},
	{
		icon: '💻',
		title: 'Mac',
		bullets: ['Sauvegarder, lire et ranger comme un pro.'],
		downloads: [
			{
				href: 'https://apps.apple.com/us/app/slax-reader-ai-read-it-later/id6596730998',
				small: 'Télécharger dans le',
				main: 'Mac App Store',
			},
		],
	},
	{
		icon: '🌐',
		title: 'Extension navigateur',
		bullets: [
			'Un geste pour sauvegarder et archiver n’importe quelle page web — à vous pour toujours.',
			'Dialoguez avec l’IA depuis la page elle-même.',
			'Une recherche sémantique puissante trouve ce qu’il vous faut en quelques secondes.',
		],
		downloads: [
			{
				href: 'https://chromewebstore.google.com/detail/gdnhaajlomjkhahnmiijphnodkcfikfd?utm_source=web_homepage',
				small: '',
				main: 'Extension Chrome',
			},
		],
	},
];

const schema = {
	'@context': 'https://schema.org',
	'@type': 'SoftwareApplication',
	name: 'Slax Reader',
	applicationCategory: 'ProductivityApplication',
	operatingSystem: 'Web, iOS, iPadOS, Android, macOS',
	url: 'https://slax.com/reader/',
	image: 'https://slax.com/og/reader.png',
	screenshot: 'https://slax.com/reader/hero.png',
	description:
		'Sauvegardez pour toujours, apprenez plus vite. Votre bibliothèque intelligente pour lire efficacement et comprendre en profondeur.',
	downloadUrl: [
		'https://apps.apple.com/us/app/slax-reader-ai-read-it-later/id6596730998',
		'https://play.google.com/store/apps/details?id=com.slax.reader',
		'https://chromewebstore.google.com/detail/gdnhaajlomjkhahnmiijphnodkcfikfd',
	],
	offers: [
		{
			'@type': 'Offer',
			name: 'Free',
			price: '0',
			priceCurrency: 'USD',
		},
		{
			'@type': 'Offer',
			name: 'Pro Reader',
			price: '5.99',
			priceCurrency: 'USD',
			priceSpecification: {
				'@type': 'UnitPriceSpecification',
				price: '5.99',
				priceCurrency: 'USD',
				billingDuration: 'P1M',
			},
		},
	],
	publisher: {
		'@type': 'Organization',
		name: 'Slax Lab',
		url: 'https://slax.com',
		logo: 'https://slax.com/images/slax-logo.png',
	},
};
---
<Base
	title="Slax Reader — Une appli à-lire-plus-tard qui n’essaie pas de tout faire"
	description="Pas d’algorithme. Pas de fil. Vous choisissez ce que vous lisez ensuite. Captures illimitées, gratuites. Open source."
	ogImage="/og/reader.png"
	schema={schema}
>
	<Nav active="reader" />

	<main>
		<!-- HERO -->
		<section class="r-hero">
			<div class="r-hero-inner">
				<div>
					<h1 class="r-h1">
						Une appli à-lire-plus-tard <em>qui n’essaie pas de tout faire.</em>
					</h1>
					<ul class="r-bullets">
						<li>Pas d’algorithme. Pas de fil. Vous choisissez ce que vous lisez ensuite.</li>
						<li>Captures illimitées, gratuites.</li>
						<li>Open source.</li>
					</ul>
					<div class="r-hero-stores">
						<a
							class="r-store-btn is-primary"
							href="https://apps.apple.com/us/app/slax-reader-ai-read-it-later/id6596730998"
							target="_blank"
							rel="noopener noreferrer"
						>
							<span class="r-store-small">Télécharger dans l’</span>
							<span class="r-store-main">App Store</span>
						</a>
						<a
							class="r-store-btn"
							href="https://play.google.com/store/apps/details?id=com.slax.reader"
							target="_blank"
							rel="noopener noreferrer"
						>
							<span class="r-store-small">DISPONIBLE SUR</span>
							<span class="r-store-main">Google Play</span>
						</a>
					</div>
					<p class="r-web-link">
						Ou bien <a href="https://r.slax.com/login">ouvrez dans votre navigateur</a>.
					</p>
				</div>
				<div class="r-preview" aria-hidden="true">
					<img
						src="/reader/hero.png"
						alt="Aperçu de l’interface Slax Reader"
						loading="eager"
						decoding="async"
					/>
				</div>
			</div>
		</section>

		<!-- FEATURES -->
		<section class="features" id="features">
			<div class="features-inner">
				<div class="features-head">
					<h2 class="features-title">Pas un énième outil à-lire-plus-tard.</h2>
					<p class="features-sub">
						Nous construisons la lecture intelligente de demain.
					</p>
				</div>
				<div class="feat-grid">
					{features.map((f, i) => (
						<div class="feat">
							<div class="feat-num">{String(i + 1).padStart(2, '0')}</div>
							<h3 class="feat-h">{f.title}</h3>
							<p class="feat-p">{f.body}</p>
						</div>
					))}
				</div>
			</div>
		</section>

		<!-- HOW IT WORKS -->
		<section class="how">
			<div class="how-inner">
				<h2 class="how-head">Du marque-page au déclic.</h2>
				<p class="how-sub">
					Quatre étapes simples pour transformer votre façon de lire et d’apprendre.
				</p>
				<div class="how-steps">
					{steps.map((s, i) => (
						<div class="how-step">
							<div class="how-step-num">{String(i + 1).padStart(2, '0')}</div>
							<h3 class="how-step-h">{s.title}</h3>
							<p class="how-step-body">{s.body}</p>
						</div>
					))}
				</div>
			</div>
		</section>

		<!-- COMPARE -->
		<section class="compare">
			<div class="compare-inner">
				<h2 class="compare-head">Pourquoi les lecteurs passent à Slax</h2>
				<p class="compare-sub">
					Comparé aux outils à-lire-plus-tard classiques.
				</p>
				<div class="compare-table">
					<div class="compare-row head">
						<div>Fonctionnalité</div>
						<div class="highlight">Slax Reader</div>
						<div>Instapaper</div>
						<div>Readwise</div>
					</div>
					{compareRows.map((row) => (
						<div class="compare-row">
							<div>{row[0]}</div>
							{[1, 2, 3].map((i) => {
								const v = row[i];
								const isHighlight = i === 1;
								let cls = 'cell';
								let content: string = v;
								if (v === 'ok') {
									cls += ' cell-ok';
									content = '●';
								} else if (v === 'no') {
									cls += ' cell-no';
									content = '—';
								} else {
									cls += ' cell-text';
								}
								if (isHighlight) cls += ' highlight';
								return <div class={cls}>{content}</div>;
							})}
						</div>
					))}
				</div>
				<p class="compare-more">
					<a href="/fr/reader/alternatives/">
						Comparatifs complets — Readwise, Omnivore, Cubox et autres →
					</a>
				</p>
			</div>
		</section>

		<!-- PRICING -->
		<section class="pricing" id="pricing">
			<div class="pricing-inner">
				<h2 class="pricing-head">Lisez plus malin, <em>pas seulement plus tard.</em></h2>
				<p class="pricing-dek">
					Sauvegardez pour toujours, apprenez plus vite. Votre bibliothèque intelligente pour lire efficacement et comprendre en profondeur.
				</p>
				<a class="pricing-promo" href="https://r.slax.com/login">
					🎉 Inscrivez-vous aujourd’hui et profitez d’un mois de Pro offert
				</a>

				<div class="plans-grid">
					<div class="plan">
						<div class="plan-eyebrow">Free</div>
						<div class="plan-price">
							<span class="num">$0</span><span class="unit">/ mois</span>
						</div>
						<p class="plan-tag">
							Marque-pages illimités et sauvegarde à vie — venez avant que des limites s’appliquent !
						</p>
						<a href="https://r.slax.com/login" class="btn-primary">Commencer gratuitement</a>
					</div>
					<div class="plan featured">
						<div class="plan-eyebrow">Pro Reader</div>
						<div class="plan-price">
							<span class="num">$5.99</span><span class="unit">/ mois</span>
							<span class="was">$9.99</span>
						</div>
						<p class="plan-tag">
							Lisez avec une longueur d’avance grâce à l’analyse IA intégrée.
						</p>
						<a href="https://r.slax.com/login" class="btn-primary">Essayer 1 mois gratuit</a>
					</div>
				</div>

				<div class="matrix" aria-label="Tableau des fonctionnalités">
					<div class="matrix-row head">
						<div class="cell-feat">Fonctionnalité</div>
						<div class="cell">Free</div>
						<div class="cell">Pro Reader</div>
					</div>
					{matrixRows.map((row) => (
						<div class="matrix-row">
							<div class="cell-feat">{row[0]}</div>
							{[1, 2].map((i) => {
								const v = row[i];
								if (v === 'ok') return <div class="cell ok">✓</div>;
								if (v === 'ai') return <div class="cell ai">AI</div>;
								return <div class="cell no">✕</div>;
							})}
						</div>
					))}
				</div>
			</div>
		</section>

		<!-- FAQ -->
		<section class="faq">
			<div class="faq-inner">
				<h2 class="faq-head">Questions fréquentes</h2>
				<FaqList items={faqs} />
			</div>
		</section>


		<!-- DOWNLOAD -->
		<DownloadSection platforms={platforms}>
			<Fragment slot="heading">
				Slax Reader — <em>Sauvegardez pour toujours. Lisez plus malin.</em>
			</Fragment>
			<Fragment slot="dek">
				Téléchargement gratuit, sur toutes vos plateformes préférées.
			</Fragment>
		</DownloadSection>

		<!-- FINALE -->
		<section class="finale">
			<div class="finale-inner">
				<h2 class="finale-h">
					Commencez votre lecture <em>intelligente</em> dès aujourd’hui
				</h2>
				<p class="finale-p">Lisez plus malin, apprenez plus vite, retenez davantage.</p>
				<div class="actions actions-center">
					<Button variant="primary" href="https://r.slax.com/login" arrow>
						Commencer — c’est gratuit
					</Button>
					<Button variant="secondary" href="https://github.com/slax-lab/slax-reader">
						Voir le code
					</Button>
				</div>
			</div>
		</section>
	</main>

	<Footer />
</Base>

<style>
	/* HERO */
	.r-hero {
		padding: 6rem 0 5rem;
	}
	.r-hero-inner {
		max-width: 1180px;
		margin: 0 auto;
		padding: 0 2rem;
		display: grid;
		grid-template-columns: 1fr;
		gap: 4rem;
		align-items: center;
	}
	@media (min-width: 960px) {
		.r-hero-inner {
			grid-template-columns: 1.1fr 1fr;
		}
	}
	.r-h1 {
		font-family: var(--serif);
		font-weight: 400;
		font-size: clamp(2rem, 4vw, 3.2rem);
		line-height: 1.1;
		letter-spacing: -0.02em;
		margin: 1rem 0 1.75rem;
		color: var(--ink);
		max-width: 22ch;
	}
	.r-h1 :global(em) {
		font-style: italic;
		font-weight: 300;
		color: var(--accent);
	}
	.r-bullets {
		list-style: none;
		padding: 0;
		margin: 0 0 2.25rem;
		display: flex;
		flex-direction: column;
		gap: 0.75rem;
		max-width: 48ch;
	}
	.r-bullets li {
		position: relative;
		padding-left: 1.5rem;
		font-family: var(--serif);
		font-size: 1.05rem;
		line-height: 1.55;
		color: var(--ink-soft);
	}
	.r-bullets li::before {
		content: "—";
		position: absolute;
		left: 0;
		top: 0;
		color: var(--ink-mute);
		font-weight: 300;
	}
	.r-hero-stores {
		display: flex;
		gap: 0.75rem;
		flex-wrap: wrap;
	}
	.r-web-link {
		margin: 0.9rem 0 0;
		font-family: var(--serif);
		font-size: 0.95rem;
		color: var(--ink-mute);
	}
	.r-web-link a {
		color: var(--ink-soft);
		text-decoration: underline;
		text-decoration-color: var(--rule);
		text-underline-offset: 3px;
		transition: color 0.2s ease, text-decoration-color 0.2s ease;
	}
	.r-web-link a:hover {
		color: var(--accent);
		text-decoration-color: var(--accent);
	}
	.r-store-btn {
		display: inline-flex;
		flex-direction: column;
		align-items: flex-start;
		gap: 0.15rem;
		background: transparent;
		color: var(--ink);
		text-decoration: none;
		padding: 0.7rem 1.2rem;
		border: 1px solid var(--ink);
		transition:
			background 0.2s ease,
			color 0.2s ease;
		min-width: 160px;
	}
	.r-store-btn:hover {
		background: var(--ink);
		color: var(--bg);
	}
	.r-store-btn.is-primary,
	.r-store-btn.is-primary:hover {
		background: var(--accent);
		border-color: var(--accent);
		color: var(--bg);
	}
	.r-store-btn.is-primary .r-store-small,
	.r-store-btn.is-primary:hover .r-store-small {
		color: var(--bg);
		opacity: 0.8;
	}
	.r-store-small {
		font-family: var(--mono);
		font-size: 0.62rem;
		letter-spacing: 0.08em;
		text-transform: uppercase;
		color: var(--ink-mute);
		line-height: 1.2;
	}
	.r-store-btn:hover .r-store-small {
		color: var(--bg);
		opacity: 0.75;
	}
	.r-store-main {
		font-family: var(--serif);
		font-size: 0.98rem;
		font-weight: 500;
		line-height: 1.3;
	}
	.actions {
		display: flex;
		gap: 1rem;
		flex-wrap: wrap;
		align-items: center;
	}
	.actions-center {
		justify-content: center;
	}
	.r-preview {
		display: flex;
		justify-content: center;
	}
	.r-preview img {
		display: block;
		width: 100%;
		height: auto;
		max-width: 480px;
	}

	/* FEATURES */
	.features {
		padding: var(--section-pad) 0;
		border-top: 1px solid var(--rule-soft);
	}
	.features-inner {
		max-width: 1180px;
		margin: 0 auto;
		padding: 0 2rem;
	}
	.features-head {
		margin-bottom: 4rem;
	}
	.features-title {
		font-family: var(--serif);
		font-weight: 400;
		font-size: clamp(1.8rem, 3vw, 2.4rem);
		line-height: 1.15;
		letter-spacing: -0.02em;
		margin: 1rem 0 0.5rem;
	}
	.features-sub {
		font-family: var(--serif);
		font-size: 1.1rem;
		color: var(--ink-soft);
		margin: 0;
		max-width: 44ch;
	}
	.feat-grid {
		display: grid;
		grid-template-columns: 1fr;
		gap: 0;
		border-top: 1px solid var(--rule);
	}
	@media (min-width: 760px) {
		.feat-grid {
			grid-template-columns: 1fr 1fr;
		}
	}
	@media (min-width: 1040px) {
		.feat-grid {
			grid-template-columns: repeat(4, 1fr);
		}
	}
	.feat {
		padding: 2.5rem 2rem;
		border-bottom: 1px solid var(--rule);
	}
	@media (min-width: 760px) {
		.feat:nth-child(2n) {
			border-left: 1px solid var(--rule);
		}
	}
	@media (min-width: 1040px) {
		.feat:nth-child(2n) {
			border-left: 0;
		}
		.feat:not(:nth-child(4n + 1)) {
			border-left: 1px solid var(--rule);
		}
	}
	.feat-num {
		font-family: var(--mono);
		font-size: 0.7rem;
		letter-spacing: 0.2em;
		color: var(--ink-mute);
		margin-bottom: 1.5rem;
	}
	.feat-h {
		font-family: var(--serif);
		font-weight: 500;
