	},
	{
		title: 'コンテンツ制作',
		body: 'これまでよりも速く、かんたんにコンテンツを作成。アイデアを話すだけで、Slax Note の AI が数秒でエレガントな文章を生成します。タイピング不要。',
	},
	{
		title: 'スケジュール整理',
		body: 'やることを Slax Note に話すだけで、スケジュールの整理を引き受けてくれます。本当に大切なことに時間を使えるように。',
	},
	{
		title: '議事録',
		body: 'ノート PC を使わない会議で Slax Note を起動。AI アシスタントが会議の要点を記録して文字起こしします。',
	},
	{
		title: '学習ノート',
		body: 'あなたの AI 学習パートナー。聞き逃しがちな講義を Slax Note でキャプチャ。プレゼンの練習をすれば、整ったスピーチ原稿もかんたんに作れます。',
	},
];

// Real testimonials from note.slax.com — 6 named users
