const schema = {
	'@context': 'https://schema.org',
	'@type': 'SoftwareApplication',
	name: 'Slax Note',
	alternateName: 'Slax Note——AI 音声ノート',
	applicationCategory: 'ProductivityApplication',
	operatingSystem: 'iOS, Android, Web',
	url: 'https://www.slax.com/note/',
	image: 'https://www.slax.com/og/note.png',
	screenshot: 'https://www.slax.com/images/note/cover.png',
	description:
		'AI 音声ノート。あなたが話し、私が記す。Slax Note で録音すれば、AI があなたの考えをとらえ、お好みの文体のテキストに整えます。',
	downloadUrl: [
		'https://apps.apple.com/us/app/slax-note-transcribe-voice-pen/id6480166286',
		'https://play.google.com/store/apps/details?id=app.slax.notes',
	],
	offers: [
		{
			'@type': 'Offer',
			name: 'Free',
			price: '0',
			priceCurrency: 'USD',
		},
		{
			'@type': 'Offer',
			name: 'Premium Monthly',
			price: '4.99',
			priceCurrency: 'USD',
			priceSpecification: {
				'@type': 'UnitPriceSpecification',
				price: '4.99',
				priceCurrency: 'USD',
				billingDuration: 'P1M',
			},
		},
		{
			'@type': 'Offer',
			name: 'Premium Annual',
			price: '49.99',
			priceCurrency: 'USD',
			priceSpecification: {
				'@type': 'UnitPriceSpecification',
				price: '49.99',
				priceCurrency: 'USD',
				billingDuration: 'P1Y',
			},
		},
	],
	publisher: {
		'@type': 'Organization',
		name: 'Starry Tech Pte. Ltd.',
		url: 'https://www.slax.com',
		logo: 'https://www.slax.com/images/slax-logo.png',
	},
};
---
<Base
	title="Slax Note——AI 音声ノート。あなたが話し、私が記す。"
	description="あなたが話し、私が記す。一度の録音から、選んだプロンプトでいろんな形に。年を重ねるごとに育っていくノート。"
	ogImage="/og/note.png"
	schema={schema}
>
	<Nav active="note" />

	<main>
		<!-- HERO -->
		<section class="n-hero">
			<div class="n-hero-inner">
				<div>
					<h1 class="n-h1">
						AI 音声ノート。<em>あなたが話し、私が記す。</em>
					</h1>
					<ul class="n-bullets">
						<li>ひらめいた瞬間に、口にする。タイピングも整理も不要。</li>
						<li>一度の録音から、選んだプロンプトでいろんな形に。</li>
						<li>年を重ねるごとに、あなたと一緒に育つように作りました。</li>
					</ul>
					<div class="n-stores">
						<a
							class="store-btn is-primary"
							href="https://apps.apple.com/us/app/slax-note-transcribe-voice-pen/id6480166286"
							target="_blank"
							rel="noopener noreferrer"
						>
							<span class="store-small">Download on the</span>
							<span class="store-main">App Store</span>
						</a>
						<a
							class="store-btn"
							href="https://play.google.com/store/apps/details?id=app.slax.notes"
							target="_blank"
							rel="noopener noreferrer"
						>
							<span class="store-small">GET IT ON</span>
							<span class="store-main">Google Play</span>
						</a>
					</div>
					<p class="n-web-link">
						または<a href="https://n.slax.com/">Web 版を開く</a>。
					</p>
				</div>
				<div class="n-visual">
					<img
						src="/images/note/cover.png"
						alt="Slax Note——AI 音声ノート"
						class="n-img"
						loading="eager"
					/>
				</div>
			</div>
		</section>

		<!-- EFFICIENCY BOOST -->
		<section class="features" id="features" data-demo-group="efficiency">
			<div class="features-inner">
				<div class="feat-head">
					<h2 class="feat-title">効率アップ</h2>
					<p class="feat-sub">大事なことに、時間を使う。</p>
				</div>
				<div class="feat-demo-body">
					<div class="feat-list" role="tablist" aria-label="効率アップの機能">
						{efficiencyFeatures.map((f, i) => (
							<button
								class="feat-item"
								type="button"
								role="tab"
								data-idx={i}
								aria-selected={i === 0 ? 'true' : 'false'}
								aria-controls={`efficiency-video-${i}`}
							>
								<div class="feat-item-head">
									<span class="feat-num">{String(i + 1).padStart(2, '0')}</span>
									<h3 class="feat-h">{f.title}</h3>
								</div>
								<p class="feat-p">{f.body}</p>
							</button>
						))}
					</div>
					<div class="feat-stage">
						<div class="feat-frame">
							{efficiencyFeatures.map((f, i) => (
								<video
									id={`efficiency-video-${i}`}
									class="feat-video"
									data-idx={i}
									src={f.video}
									muted
									loop
									playsinline
									preload={i === 0 ? 'auto' : 'metadata'}
									aria-hidden={i === 0 ? 'false' : 'true'}
								></video>
							))}
						</div>
					</div>
				</div>
			</div>
		</section>

		<!-- INTELLIGENT GHOSTWRITING -->
		<section class="features features-alt" data-demo-group="ghostwriting">
			<div class="features-inner">
				<div class="feat-head">
					<h2 class="feat-title">賢いゴーストライティング</h2>
					<p class="feat-sub">AI がテキストを軽やかに仕上げます。</p>
				</div>
				<div class="feat-demo-body feat-demo-body--reverse">
					<div class="feat-stage">
						<div class="feat-frame">
							{ghostwritingFeatures.map((f, i) => (
								<video
									id={`ghostwriting-video-${i}`}
									class="feat-video"
									data-idx={i}
									src={f.video}
									muted
									loop
									playsinline
									preload="metadata"
									aria-hidden={i === 0 ? 'false' : 'true'}
								></video>
							))}
						</div>
					</div>
					<div class="feat-list" role="tablist" aria-label="賢いゴーストライティングの機能">
						{ghostwritingFeatures.map((f, i) => (
							<button
								class="feat-item"
								type="button"
								role="tab"
								data-idx={i}
								aria-selected={i === 0 ? 'true' : 'false'}
								aria-controls={`ghostwriting-video-${i}`}
							>
								<div class="feat-item-head">
									<span class="feat-num">{String(i + 1).padStart(2, '0')}</span>
									<h3 class="feat-h">{f.title}</h3>
								</div>
								<p class="feat-p">{f.body}</p>
							</button>
						))}
					</div>
				</div>
			</div>
		</section>

		<!-- USE CASES -->
		<section class="usecases">
			<div class="usecases-inner">
				<h2 class="usecases-head">みんなはどう Slax Note を使っているか</h2>
				<div class="uc-grid">
					{useCases.map((uc) => (
						<div class="uc">
							<h3 class="uc-h">{uc.title}</h3>
							<p class="uc-p">{uc.body}</p>
						</div>
					))}
				</div>
			</div>
		</section>

		<!-- TESTIMONIALS -->
		<section class="testimonials">
			<div class="testimonials-inner">
				<h2 class="t-head">数千人のユーザーに愛されています</h2>
				<p class="t-sub">
					ノートの取り方を変える準備はできていますか？ Slax Note を今すぐ試してください。
				</p>
				<div class="t-grid">
					{testimonials.map((t) => (
						<figure class="testimonial">
							<blockquote class="t-quote">「{t.quote}」</blockquote>
							<figcaption class="t-caption">
								<span class="t-author">{t.author}</span>
								<span class="t-title">{t.title}</span>
							</figcaption>
						</figure>
					))}
				</div>
			</div>
		</section>

		<!-- PRICING -->
		<section class="pricing" id="pricing">
			<div class="pricing-inner">
				<h2 class="pricing-head">料金</h2>
				<p class="pricing-dek">早期割引でプランをアップグレードしませんか。</p>

				<div class="plans-grid plans-grid-3">
					<!-- FREE -->
					<div class="plan">
						<div class="plan-eyebrow">Free</div>
						<div class="plan-price">
							<span class="num">$0</span>
						</div>
						<p class="plan-note">永久に。</p>
						<ul class="plan-list">
							<li><span class="plan-feat-label">音声ノート</span><span class="plan-feat-value">5 ノート</span></li>
							<li><span class="plan-feat-label">AI 仕上げ</span><span class="plan-feat-value">合計 10 回</span></li>
							<li><span class="plan-feat-label">録音時間</span><span class="plan-feat-value">5 分</span></li>
						</ul>
						<a href="https://n.slax.com/" class="btn-primary">試してみる</a>
					</div>

					<!-- PREMIUM — MONTHLY -->
					<div class="plan">
						<div class="plan-eyebrow">Monthly</div>
						<div class="plan-price">
							<span class="num">$4.99</span><span class="unit">/ 月</span>
						</div>
						<p class="plan-note">いつでもキャンセル可能。</p>
						<ul class="plan-list">
							<li><span class="plan-feat-label">音声ノート</span><span class="plan-feat-value">無制限</span></li>
							<li><span class="plan-feat-label">AI 仕上げ</span><span class="plan-feat-value">1 日 300 回</span></li>
							<li><span class="plan-feat-label">録音時間</span><span class="plan-feat-value">30 分</span></li>
							<li><span class="plan-feat-label">仕上げの品質</span><span class="plan-feat-value">Premium バージョン</span></li>
						</ul>
						<div class="plan-actions">
							<a
								class="btn-primary"
								href="https://apps.apple.com/us/app/slax-note-transcribe-voice-pen/id6480166286"
								target="_blank"
								rel="noopener noreferrer"
							>
								App Store
							</a>
							<a
								class="btn-primary btn-primary-outline"
								href="https://play.google.com/store/apps/details?id=app.slax.notes"
								target="_blank"
								rel="noopener noreferrer"
							>
								Google Play
							</a>
						</div>
					</div>

					<!-- PREMIUM — ANNUAL -->
					<div class="plan featured">
						<div class="plan-eyebrow">
							Annual <span class="plan-badge">2 ヶ月分お得</span>
						</div>
						<div class="plan-price">
							<span class="num">$49.99</span><span class="unit">/ 年</span>
						</div>
						<p class="plan-note">月額 $4.16 から。いつでもキャンセル可能。</p>
						<ul class="plan-list">
							<li><span class="plan-feat-label">音声ノート</span><span class="plan-feat-value">無制限</span></li>
							<li><span class="plan-feat-label">AI 仕上げ</span><span class="plan-feat-value">1 日 300 回</span></li>
							<li><span class="plan-feat-label">録音時間</span><span class="plan-feat-value">30 分</span></li>
							<li><span class="plan-feat-label">仕上げの品質</span><span class="plan-feat-value">Premium バージョン</span></li>
						</ul>
						<div class="plan-actions">
							<a
								class="btn-primary"
								href="https://apps.apple.com/us/app/slax-note-transcribe-voice-pen/id6480166286"
								target="_blank"
								rel="noopener noreferrer"
							>
								App Store
							</a>
							<a
								class="btn-primary btn-primary-outline"
								href="https://play.google.com/store/apps/details?id=app.slax.notes"
								target="_blank"
								rel="noopener noreferrer"
							>
								Google Play
							</a>
						</div>
					</div>
				</div>
			</div>
		</section>

		<!-- FAQ -->
		<section class="faq">
			<div class="faq-inner">
				<h2 class="faq-head">よくある質問</h2>
				<p class="faq-sub">
					その他のご質問やご提案は、
					<a href="https://discord.gg/kznNsZvWSk">Discord</a> 、または
					<a href="mailto:note@slax.com">note@slax.com</a> までお問い合わせください。
				</p>
				<FaqList items={faqs} />
			</div>
