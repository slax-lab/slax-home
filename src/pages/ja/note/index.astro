// FAQ — verbatim from note.slax.com
const faqs = [
	{
		q: 'どう申し込めばいいですか？',
		a: 'アプリ Slax Note を開いて、希望のプランを選び、指示に従ってアカウントを作成し、支払いを完了してください。サブスクリプション後すぐにプレミアム機能をお使いいただけます。',
	},
	{
		q: 'ファイルのアップロードに対応していますか？',
		a: '現時点では音声ファイルのアップロードに対応していませんが、将来的に提供する予定です。',
	},
	{
		q: '音声からテキストへの変換の精度はどれくらいですか？',
		a: '先進的な AI 技術により、精度は非常に高いです。クリアな音声入力であれば、精度は 95% を超えます。',
	},
	{
		q: '録音時間に制限はありますか？',
		a: '1 回の録音は最大 30 分です。',
	},
	{
		q: '変換後のテキストは編集できますか？',
		a: 'はい、変換されたテキストは自由に編集でき、さまざまな文体への変換にも対応しています。',
	},
	{
		q: '音声ファイルはどこに保存されますか、安全ですか？',
		a: 'プライバシーとセキュリティを確保するため、すべての録音はローカルに保存されます。',
	},
	{
		q: 'ノートはどうエクスポートできますか？',
		a: 'ノートはテキストや画像として、他のアプリへかんたんに共有できます。',
	},
	{
		q: 'オフラインで使えますか？',
		a: '録音機能はオフラインで動作しますが、変換にはインターネット接続が必要です。',
	},
	{
		q: '異なる文体はどう設定しますか？',
		a: 'アプリを開いて録音を始めるか、「テキストノート」をタップして内容を入力してください。自動整形ページに移動します。右側の「デフォルト」ボタンをクリックすると、複数のライティングスタイルを切り替えられます。あるいは、お好みのスタイルを自由にカスタマイズできます。',
	},
	{
		q: 'Slax Note の音声認識はどの言語に対応していますか？',
