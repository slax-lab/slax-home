---
import Footer from '~/components/Footer.astro';
import Nav from '~/components/Nav.astro';
import Base from '~/layouts/Base.astro';

const beliefs = [
	{
		n: '01',
		line: 'We use what we build.',
		note: "If we wouldn't use it every day, we don't ship it.",
	},
	{
		n: '02',
		line: 'The long way, on purpose.',
		note: 'Small software, made slowly — here when you come back in ten years.',
	},
	{
		n: '03',
		line: 'We hack. You own.',
		note: 'Open source. No lock-in. Your data, your call.',
	},
];

const products = [
	{
		key: 'reader',
		href: '/reader/',
		logo: '/images/reader-logo-new.png',
		name: 'Slax Reader',
		headline: "A read-it-later app that doesn't try to be everything.",
		bullets: [
			'No algorithm. No feed. You choose what to read next.',
			'Unlimited snapshots, for free.',
			'Open-source.',
		],
		cta: 'Explore Reader →',
	},
	{
		key: 'note',
		href: '/note/',
		logo: '/images/note-logo-new.png',
		name: 'Slax Note',
		headline: 'A notes app for your own voice.',
		bullets: [
			"Say it the moment it shows up. Don't type. Don't organize.",
			'One recording, many shapes — shaped by the prompts you choose.',
			'Made to grow with you, year after year.',
		],
		cta: 'Explore Note →',
	},
];
---
<Base
	title="Slax — Simple. Relax. Made to last."
	description="Software we wanted for ourselves. Slax Reader and Slax Note — small software, made to last."
>
	<Nav />

	<!-- 屏 1 · Slax Hero · brand stance + beliefs -->
	<section class="slax-hero">
		<div class="slax-hero-inner">
			<div class="slax-hero-main">
				<h1 class="slax-hero-title">
					Simple. Relax.<br /><em>Made to last.</em>
				</h1>
				<p class="slax-hero-sub">
					Software we wanted for ourselves.
				</p>
				<div class="slax-hero-cta">
					<a class="slax-hero-btn" href="/reader/">Meet Reader</a>
					<a class="slax-hero-btn" href="/note/">Meet Note</a>
				</div>
			</div>
			<aside class="slax-hero-aside" aria-labelledby="beliefs-label">
				<span id="beliefs-label" class="beliefs-eyebrow">— How we work</span>
				<ol class="beliefs-list">
					{beliefs.map((b) => (
						<li class="belief">
							<span class="belief-num">{b.n}</span>
							<div class="belief-body">
								<span class="belief-line">{b.line}</span>
								<p class="belief-note">{b.note}</p>
							</div>
						</li>
					))}
				</ol>
			</aside>
		</div>
	</section>

	<!-- 屏 2 · Products · flat grid, logo-forward -->
	<section class="products" id="products">
		<div class="products-inner">
			<span class="products-eyebrow">— Our products</span>
			<div class="products-grid">
				{products.map((p) => (
					<a class={`product product-${p.key}`} href={p.href}>
						<div class="product-body">
							<h2 class="product-name">{p.name}</h2>
							<p class="product-headline">{p.headline}</p>
							<ul class="product-bullets">
								{p.bullets.map((b) => <li>{b}</li>)}
							</ul>
							<span class="product-cta">{p.cta}</span>
						</div>
						<span class="product-logo-frame">
							<img
								src={p.logo}
								alt={`${p.name} logo`}
								class="product-logo"
								width="112"
								height="112"
								loading="eager"
								decoding="async"
							/>
						</span>
					</a>
				))}
			</div>
		</div>
	</section>

	<Footer />
</Base>

<style>
	/* ─── 屏 1 · Slax Hero + beliefs aside ─── */
	.slax-hero {
		width: 100%;
		background: var(--bg);
		border-bottom: 1px solid var(--rule-soft);
	}
	.slax-hero-inner {
		max-width: 1200px;
		margin: 0 auto;
		padding: clamp(3.5rem, 7vw, 5.5rem) 2rem clamp(3rem, 5vw, 4.5rem);
		display: grid;
		grid-template-columns: 1fr;
		gap: 3rem;
		align-items: start;
	}
	@media (min-width: 960px) {
		.slax-hero-inner {
			grid-template-columns: minmax(0, 1fr) minmax(340px, 0.85fr);
			gap: 4.5rem;
		}
	}
	.slax-hero-main {
		min-width: 0;
		padding-top: 0.25rem;
	}
	.slax-hero-aside {
		min-width: 0;
	}
	@media (min-width: 960px) {
		.slax-hero-aside {
			border-left: 1px solid var(--rule-soft);
			padding-left: 3rem;
		}
	}
	.slax-hero-title {
		font-family: var(--serif);
		font-weight: 400;
		font-size: clamp(2.4rem, 5vw, 4rem);
		line-height: 1.02;
		letter-spacing: -0.03em;
		color: var(--ink);
		margin: 0 0 1.75rem;
	}
	.slax-hero-title em {
		font-style: italic;
		font-weight: 300;
		color: var(--accent);
	}
	.slax-hero-sub {
		font-family: var(--serif);
		font-size: clamp(1.1rem, 1.6vw, 1.35rem);
		line-height: 1.5;
		color: var(--ink-soft);
		margin: 0 0 2.5rem;
		max-width: 36ch;
	}
	.slax-hero-cta {
		display: flex;
		gap: 0.75rem;
		flex-wrap: wrap;
	}
	.slax-hero-btn {
		display: inline-block;
		font-family: var(--mono);
		font-size: 0.78rem;
		letter-spacing: 0.1em;
		text-transform: uppercase;
		color: var(--ink);
		padding: 0.85rem 1.4rem;
		border: 1px solid var(--ink);
		text-decoration: none;
		transition:
			background 0.2s ease,
			color 0.2s ease;
	}
	.slax-hero-btn:hover {
		background: var(--ink);
		color: var(--bg);
	}

	/* beliefs — nested inside hero aside */
	.beliefs-eyebrow {
		display: block;
		font-family: var(--mono);
		font-size: 0.72rem;
		letter-spacing: 0.18em;
		text-transform: uppercase;
		color: var(--ink-mute);
		margin: 0 0 1.5rem;
	}
	.beliefs-list {
		list-style: none;
		padding: 0;
		margin: 0;
	}
	.belief {
		display: grid;
		grid-template-columns: 36px 1fr;
		gap: 1rem;
		align-items: baseline;
		padding: 1.1rem 0;
	}
	.belief + .belief {
		border-top: 1px solid var(--rule-soft);
	}
	.belief-num {
		font-family: var(--mono);
		font-size: 0.7rem;
		letter-spacing: 0.14em;
		color: var(--ink-mute);
	}
	.belief-body {
		display: flex;
		flex-direction: column;
		gap: 0.4rem;
	}
	.belief-line {
		font-family: var(--serif);
		font-weight: 400;
		font-size: clamp(1.1rem, 1.5vw, 1.35rem);
		line-height: 1.3;
		letter-spacing: -0.01em;
		color: var(--ink);
	}
	.belief-note {
		font-family: var(--serif);
		font-size: 0.92rem;
		line-height: 1.55;
		color: var(--ink-mute);
		margin: 0;
	}

	/* ─── 屏 2 · Products ─── */
	.products {
		width: 100%;
		background: var(--bg);
		padding: clamp(3.5rem, 6vw, 5rem) 0;
	}
	.products-inner {
		max-width: 1200px;
		margin: 0 auto;
		padding: 0 2rem;
	}
	.products-eyebrow {
		display: block;
		font-family: var(--mono);
		font-size: 0.72rem;
		letter-spacing: 0.18em;
		text-transform: uppercase;
		color: var(--ink-mute);
		margin: 0 0 2rem;
	}
	.products-grid {
		display: grid;
		grid-template-columns: 1fr;
		gap: 0;
	}
	@media (min-width: 820px) {
		.products-grid {
			grid-template-columns: 1fr 1fr;
		}
	}
	.product {
		display: grid;
		grid-template-columns: minmax(0, 1fr) auto;
		gap: 1.5rem;
		align-items: start;
		padding: clamp(2.25rem, 3.5vw, 3rem) clamp(1.5rem, 2.5vw, 2.25rem);
		text-decoration: none;
		background: var(--bg);
		transition:
			background 0.25s ease,
			transform 0.25s ease;
	}
	.product + .product {
		border-top: 1px solid var(--rule-soft);
	}
	@media (min-width: 820px) {
		.product + .product {
			border-top: 0;
			border-left: 1px solid var(--rule);
		}
	}
	.product:hover {
		background: var(--bg-deep);
	}
	.product:hover .product-logo-frame {
		transform: translateY(-2px);
	}
	.product-body {
		display: flex;
		flex-direction: column;
		min-width: 0;
	}
	.product-logo-frame {
		width: 88px;
		height: 88px;
		border-radius: 20px;
		overflow: hidden;
		box-shadow: 0 8px 26px -14px rgba(27, 26, 23, 0.28);
		transition: transform 0.25s ease;
		align-self: start;
		flex-shrink: 0;
		display: block;
	}
	.product-logo {
		width: 100%;
		height: 100%;
		object-fit: cover;
		display: block;
	}
	.product-reader .product-logo {
		transform: scale(1.06);
		transform-origin: center;
	}
	@media (max-width: 520px) {
		.product-logo-frame {
			width: 64px;
			height: 64px;
			border-radius: 14px;
		}
	}
	.product-name {
		font-family: var(--serif);
		font-weight: 500;
		font-size: clamp(1.6rem, 2.4vw, 2.1rem);
		letter-spacing: -0.02em;
		color: var(--ink);
		margin: 0 0 0.6rem;
	}
	.product-headline {
		font-family: var(--serif);
		font-size: clamp(1.05rem, 1.4vw, 1.2rem);
		line-height: 1.4;
		color: var(--ink-soft);
		margin: 0 0 1.5rem;
		max-width: 28ch;
	}
	.product-bullets {
		list-style: none;
		padding: 0;
		margin: 0 0 2rem;
		display: flex;
		flex-direction: column;
		gap: 0.6rem;
	}
	.product-bullets li {
		position: relative;
		padding-left: 1.5rem;
		font-family: var(--serif);
		font-size: 0.98rem;
		line-height: 1.5;
		color: var(--ink-soft);
		max-width: 44ch;
	}
	.product-bullets li::before {
		content: "—";
		position: absolute;
		left: 0;
		top: 0;
		color: var(--ink-mute);
		font-weight: 300;
	}
	.product-cta {
		margin-top: auto;
		font-family: var(--mono);
		font-size: 0.8rem;
		letter-spacing: 0.08em;
		text-transform: uppercase;
		color: var(--accent);
		align-self: flex-start;
		padding-bottom: 2px;
		border-bottom: 1px solid transparent;
		transition: border-color 0.2s ease;
	}
	.product:hover .product-cta {
		border-bottom-color: var(--accent);
	}
</style>
