---
import Button from '~/components/Button.astro';
import Eyebrow from '~/components/Eyebrow.astro';
import Footer from '~/components/Footer.astro';
import MastheadCard from '~/components/MastheadCard.astro';
import Nav from '~/components/Nav.astro';
import ProductCard from '~/components/ProductCard.astro';
import Scene from '~/components/Scene.astro';
import SectionLabel from '~/components/SectionLabel.astro';
import Base from '~/layouts/Base.astro';

const mastheadEntries = [
	{ label: 'Maker', value: 'Slax Lab' },
	{ label: 'Products', value: 'Reader · Note' },
	{ label: 'Note', value: 'In private beta' },
	{
		label: 'Source',
		value: 'github.com/slax-lab',
		href: 'https://github.com/slax-lab',
	},
	{ label: 'Price', value: 'Free while we learn' },
	{ label: 'Written in', value: 'Vue, Rust, Go' },
];

const ossRepos = [
	{ name: 'slax-lab/slax-reader', meta: 'The product' },
	{ name: 'slax-lab/slax-reader-api', meta: 'Go service' },
	{ name: 'slax-lab/readability', meta: 'Parser' },
	{ name: 'slax-lab/jieba-rs', meta: 'Chinese tokenizer' },
];
---
<Base>
	<Nav />

	<main>
		<!-- HERO -->
		<section class="hero">
			<div class="hero-inner">
				<div>
					<Eyebrow>Slax · Vol. 01</Eyebrow>
					<h1 class="h1">
						Tools for people who still <em>read</em><br />
						and still <span class="accent-ink">write.</span>
					</h1>
					<p class="dek">
						Slax makes a reader and a notebook for the work of paying attention.
						Slow software, made for long-form.
					</p>
					<div class="actions">
						<Button variant="primary" href="/reader/" arrow>Start free</Button>
						<Button variant="secondary" href="/blog/">Read the story</Button>
					</div>
				</div>
				<MastheadCard entries={mastheadEntries} />
			</div>
		</section>

		<!-- MANIFESTO -->
		<section class="manifesto">
			<div class="manifesto-inner">
				<SectionLabel number="01">What this is</SectionLabel>
				<p class="manifesto-body">
					Most reading apps help you save more. We'd rather help you
					<em>finish</em> what you saved, and remember what you read.
				</p>
			</div>
		</section>

		<!-- PRODUCTS -->
		<section class="products">
			<div class="products-head">
				<div>
					<SectionLabel number="02">The products</SectionLabel>
					<h2 class="products-title">Two tools, one quiet habit.</h2>
				</div>
				<div class="products-meta">One reads in · one writes out</div>
			</div>
			<div class="products-grid">
				<ProductCard
					href="/reader/"
					productNumber="Product 01 — Available now"
					ctaText="Open Reader"
					features={[
						'One-click capture, on any platform',
						'Clean reader view, highlights that last',
						'Ask questions of any article, in context',
						'Follow friends, share what you read',
					]}
				>
					<Fragment slot="name">Slax <em>Reader</em></Fragment>
					<Fragment slot="description">
						A read-later that rewards finishing. Save a page, it stays readable
						forever. AI sits beside the text when you want it, not in front of
						it.
					</Fragment>
				</ProductCard>
				<ProductCard
					href="/note/"
					productNumber="Product 02 — Launching 2026"
					badge="Private beta"
					ctaText="Request invite"
					features={[
						'Voice-first capture on the go',
						'Polish once, reshape as needed',
						'Pulls from Reader automatically',
						'Private by default',
					]}
				>
					<Fragment slot="name">Slax <em>Note</em></Fragment>
					<Fragment slot="description">
						A notebook that listens. Speak a thought, and AI reshapes it your
						way — journal, summary, or whatever you ask for.
					</Fragment>
				</ProductCard>
			</div>
		</section>

		<!-- SCENES -->
		<section class="scenes">
			<div class="scenes-head">
				<SectionLabel number="03">How people use it</SectionLabel>
				<h2 class="scenes-intro">Three afternoons, one way to work.</h2>
			</div>
			<Scene
				number="Scene 01"
				kind="Reading"
				title="A long essay, caught on the subway."
			>
				You share a Paul Graham piece from your phone into Slax. On Monday,
				between meetings, it's already waiting — no ads, no paywall, no blue
				links. You highlight three paragraphs. One of them is the reason you'll
				quit your job, eventually. <strong>It stays highlighted forever.</strong>
			</Scene>
			<Scene
				number="Scene 02"
				kind="Thinking"
				title="A question you can't answer."
			>
				Halfway through a paper on attention, you stop. You highlight the
				passage and ask the reader what it means in plainer terms. The answer
				sits in the margin, with a link back to the sentence that prompted it.
				<strong>No chat window. No new tab.</strong>
			</Scene>
			<Scene
				number="Scene 03"
				kind="Writing"
				title="A Sunday, connecting the dots."
			>
				You open Slax Note. Last week's highlights are already there, grouped
				by what you read. You start a note called
				<em>Why soft power is eroding</em>. Two sentences in, Note surfaces a
				quote from Wednesday you'd forgotten.
				<strong>The essay writes itself. Almost.</strong>
			</Scene>
		</section>

		<!-- OPEN SOURCE -->
		<section class="oss" id="oss">
			<div class="oss-inner">
				<div>
					<SectionLabel number="04">Open source</SectionLabel>
					<h2 class="oss-head">
						Our tools for <em>reading</em> are tools you can read.
					</h2>
				</div>
				<div>
					<p class="oss-body">
						Slax Reader is MIT-licensed. You can run the whole thing on your own
						machine, inspect every line, send a patch. If that matters to you,
						it matters to us too.
					</p>
					<ul class="oss-repos">
						{ossRepos.map((repo) => (
							<li>
								<a href={`https://github.com/${repo.name}`}>
									<span>{repo.name}</span>
									<span class="repo-meta">{repo.meta} ⤷</span>
								</a>
							</li>
						))}
					</ul>
				</div>
			</div>
		</section>

		<!-- CLOSING -->
		<section class="closing">
			<div class="closing-inner">
				<h2 class="closing-head">
					Start with <em>one</em> article.<br />
					See where it goes.
				</h2>
				<div class="actions actions-center">
					<Button variant="primary" href="/reader/" arrow>Open Slax Reader</Button>
					<Button variant="secondary" href="/reader/#download">Download apps</Button>
				</div>
			</div>
		</section>
	</main>

	<Footer />
</Base>

<style>
	/* HERO */
	.hero {
		padding: 7rem 0 6rem;
	}
	.hero-inner {
		max-width: 1180px;
		margin: 0 auto;
		padding: 0 2rem;
		display: grid;
		grid-template-columns: 1fr;
		gap: 4rem;
	}
	@media (min-width: 960px) {
		.hero-inner {
			grid-template-columns: 1.25fr 1fr;
			align-items: end;
		}
	}
	.h1 {
		font-family: var(--serif);
		font-weight: 400;
		font-size: clamp(2.6rem, 5.5vw, 4.8rem);
		line-height: 1.02;
		letter-spacing: -0.025em;
		margin: 2.5rem 0 1.75rem;
		text-wrap: pretty;
	}
	.h1 :global(em) {
		font-style: italic;
		font-weight: 300;
		color: var(--ink-soft);
	}
	.h1 .accent-ink {
		color: var(--accent);
		font-style: italic;
		font-weight: 300;
	}
	.dek {
		font-family: var(--serif);
		font-size: clamp(1.1rem, 1.25vw, 1.3rem);
		line-height: 1.5;
		color: var(--ink-soft);
		max-width: 34ch;
		margin: 0 0 2.25rem;
		text-wrap: pretty;
	}
	.actions {
		display: flex;
		gap: 1rem;
		flex-wrap: wrap;
		align-items: center;
	}
	.actions-center {
		justify-content: center;
	}

	/* MANIFESTO */
	.manifesto {
		padding: var(--section-pad) 0;
		border-top: 1px solid var(--rule-soft);
	}
	.manifesto-inner {
		max-width: 1180px;
		margin: 0 auto;
		padding: 0 2rem;
		display: grid;
		grid-template-columns: 1fr;
		gap: 3rem;
	}
	@media (min-width: 960px) {
		.manifesto-inner {
			grid-template-columns: 200px 1fr;
			gap: 5rem;
		}
	}
	.manifesto-body {
		font-family: var(--serif);
		font-size: clamp(1.35rem, 2vw, 1.75rem);
		line-height: 1.4;
		color: var(--ink);
		max-width: 26ch;
		margin: 0;
	}
	.manifesto-body :global(em) {
		font-style: italic;
		color: var(--accent);
	}

	/* PRODUCTS */
	.products {
		padding: var(--section-pad) 0;
		border-top: 1px solid var(--rule-soft);
	}
	.products-head {
		max-width: 1180px;
		margin: 0 auto 4rem;
		padding: 0 2rem;
		display: flex;
		justify-content: space-between;
		align-items: baseline;
		flex-wrap: wrap;
		gap: 1rem;
	}
	.products-title {
		font-family: var(--serif);
		font-weight: 400;
		font-size: clamp(1.8rem, 3vw, 2.6rem);
		letter-spacing: -0.02em;
		line-height: 1.1;
		margin: 0.8rem 0 0;
	}
	.products-meta {
		font-family: var(--mono);
		font-size: 0.78rem;
		color: var(--ink-mute);
		letter-spacing: 0.05em;
	}
	.products-grid {
		max-width: 1180px;
		margin: 0 auto;
		padding: 0 2rem;
		display: grid;
		grid-template-columns: 1fr;
		gap: 2rem;
	}
	@media (min-width: 820px) {
		.products-grid {
			grid-template-columns: 1fr 1fr;
		}
	}

	/* SCENES */
	.scenes {
		padding: var(--section-pad) 0;
		border-top: 1px solid var(--rule-soft);
	}
	.scenes-head {
		max-width: 1180px;
		margin: 0 auto 5rem;
		padding: 0 2rem;
	}
	.scenes-intro {
		font-family: var(--serif);
		font-weight: 400;
		font-size: clamp(1.8rem, 3vw, 2.6rem);
		line-height: 1.2;
		letter-spacing: -0.02em;
		max-width: 22ch;
		margin: 1.5rem 0 0;
	}

	/* OPEN SOURCE */
	.oss {
		padding: var(--section-pad) 0;
		border-top: 1px solid var(--rule-soft);
		background: var(--bg-deep);
	}
	.oss-inner {
		max-width: 1180px;
		margin: 0 auto;
		padding: 0 2rem;
		display: grid;
		grid-template-columns: 1fr;
		gap: 3rem;
	}
	@media (min-width: 960px) {
		.oss-inner {
			grid-template-columns: 1fr 1fr;
			gap: 6rem;
			align-items: start;
		}
	}
	.oss-head {
		font-family: var(--serif);
		font-weight: 400;
		font-size: clamp(1.8rem, 3vw, 2.4rem);
		letter-spacing: -0.02em;
		line-height: 1.15;
		margin: 1rem 0 0;
	}
	.oss-head :global(em) {
		font-style: italic;
		color: var(--accent);
	}
	.oss-body {
		font-family: var(--serif);
		font-size: 1.1rem;
		line-height: 1.6;
		color: var(--ink-soft);
		max-width: 42ch;
	}
	.oss-repos {
		list-style: none;
		padding: 0;
		margin: 1.5rem 0 0;
		display: grid;
		gap: 0;
		font-family: var(--mono);
		font-size: 0.85rem;
	}
	.oss-repos a {
		display: flex;
		justify-content: space-between;
		align-items: baseline;
		padding: 0.85rem 0;
		border-bottom: 1px solid var(--rule);
		text-decoration: none;
		color: var(--ink);
		transition:
			color 0.2s,
			padding-left 0.2s;
	}
	.oss-repos a:hover {
		color: var(--accent);
		padding-left: 0.3rem;
	}
	.oss-repos .repo-meta {
		color: var(--ink-mute);
		font-size: 0.8rem;
	}

	/* CLOSING */
	.closing {
		padding: calc(var(--section-pad) * 1.1) 0;
		border-top: 1px solid var(--rule-soft);
		text-align: center;
	}
	.closing-inner {
		max-width: 820px;
		margin: 0 auto;
		padding: 0 2rem;
	}
	.closing-head {
		font-family: var(--serif);
		font-weight: 400;
		font-size: clamp(2.5rem, 5vw, 4.5rem);
		letter-spacing: -0.025em;
		line-height: 1.05;
		margin: 0 auto 2.5rem;
		max-width: 18ch;
	}
	.closing-head :global(em) {
		color: var(--accent);
		font-style: italic;
		font-weight: 300;
	}
</style>
