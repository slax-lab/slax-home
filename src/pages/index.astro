---
import Footer from '~/components/Footer.astro';
import Nav from '~/components/Nav.astro';
import Base from '~/layouts/Base.astro';

const beliefs = [
	{
		n: '01',
		line: 'We use what we build.',
		note: "If we wouldn't use it every day, we don't ship it.",
	},
	{
		n: '02',
		line: 'The long way, on purpose.',
		note: 'Small software, made slowly — here when you come back in ten years.',
	},
	{
		n: '03',
		line: 'We hack. You own.',
		note: 'Open source. No lock-in. Your data, your call.',
	},
];

const readerBullets = [
	'No algorithm. No feed. You choose what to read next.',
	'Unlimited snapshots, for free.',
	'Open-source.',
];

const noteBullets = [
	"Say it the moment it shows up. Don't type. Don't organize.",
	'One recording, many shapes — shaped by the prompts you choose.',
	'Made to grow with you, year after year.',
];

const readerStores = {
	ios: 'https://apps.apple.com/cn/app/slax-reader-ai-read-it-later/id6596730998',
	android: 'https://play.google.com/store/apps/details?id=com.slax.reader',
};

const noteStores = {
	ios: 'https://apps.apple.com/us/app/slax-note-transcribe-voice-pen/id6480166286',
	android: 'https://play.google.com/store/apps/details?id=app.slax.notes',
};
---
<Base
	title="Slax — Simple. Relax. Made to last."
	description="Software we wanted for ourselves. Slax Reader and Slax Note — small software, made to last."
>
	<Nav />

	<!-- 屏 1 · Slax Hero · brand stance + beliefs -->
	<section class="slax-hero">
		<div class="slax-hero-inner">
			<div class="slax-hero-main">
				<h1 class="slax-hero-title">
					Simple. Relax.<br /><em>Made to last.</em>
				</h1>
				<p class="slax-hero-sub">
					Software we wanted for ourselves.
				</p>
				<div class="slax-hero-cta">
					<a class="slax-hero-btn" href="/reader/">Meet Reader</a>
					<a class="slax-hero-btn" href="/note/">Meet Note</a>
				</div>
			</div>
			<aside class="slax-hero-aside" aria-labelledby="beliefs-label">
				<span id="beliefs-label" class="beliefs-eyebrow">— How we work</span>
				<ol class="beliefs-list">
					{beliefs.map((b) => (
						<li class="belief">
							<span class="belief-num">{b.n}</span>
							<div class="belief-body">
								<span class="belief-line">{b.line}</span>
								<p class="belief-note">{b.note}</p>
							</div>
						</li>
					))}
				</ol>
			</aside>
		</div>
	</section>

	<section class="shh" id="products">
		<!-- Hero alternates between Reader and Note; product cards below lock
		     the panel on hover -->
		<div class="shh-hero-wrap">
			<!-- READER -->
			<div class="shh-panel shh-panel-reader is-active" data-panel="reader" id="reader">
				<div class="shh-reader-inner">
					<div class="shh-reader-text">
						<span class="shh-product-eyebrow">— Slax Reader</span>
						<h2 class="shh-reader-title">
							A read-it-later app that doesn't try to be everything.
						</h2>
						<ul class="shh-bullets">
							{readerBullets.map((b) => <li>{b}</li>)}
						</ul>
						<div class="shh-stores">
							<a class="shh-store-btn" href="https://r.slax.com/login">
								<span class="shh-store-small">Open in</span>
								<span class="shh-store-main">Your browser</span>
							</a>
							<a
								class="shh-store-btn"
								href={readerStores.ios}
								target="_blank"
								rel="noopener noreferrer"
							>
								<span class="shh-store-small">Download on the</span>
								<span class="shh-store-main">App Store</span>
							</a>
							<a
								class="shh-store-btn"
								href={readerStores.android}
								target="_blank"
								rel="noopener noreferrer"
							>
								<span class="shh-store-small">GET IT ON</span>
								<span class="shh-store-main">Google Play</span>
							</a>
						</div>
					</div>
					<div class="shh-reader-visual">
						<div class="shh-reader-preview">
							<div class="shh-reader-card">
								<h4>🤖 AI Analysis</h4>
								<p>
									This article explains how knowledge workers can build a
									permanent reading library. Key points:<br />1. Save content
									before it disappears.<br />2. Use AI to summarize and surface
									key ideas.<br />3. Turn reading into reusable knowledge.
								</p>
							</div>
							<div class="shh-reader-card">
								<h4>💬 Ask AI</h4>
								<p>
									<strong>You:</strong> "What should I remember from this
									article?"<br />
									<strong>AI:</strong> "Focus on the permanent archive,
									AI-assisted understanding, and collaboration layer. Those are
									the main reasons users switch."
								</p>
							</div>
						</div>
					</div>
				</div>
			</div>

			<!-- NOTE -->
			<div class="shh-panel shh-panel-note" data-panel="note" id="note">
				<div class="shh-note-inner">
					<div class="shh-note-text">
						<span class="shh-product-eyebrow">— Slax Note</span>
						<h2 class="shh-note-title">
							A notes app <em>for your own voice.</em>
						</h2>
						<ul class="shh-bullets">
							{noteBullets.map((b) => <li>{b}</li>)}
						</ul>
						<div class="shh-stores">
							<a
								class="shh-store-btn"
								href={noteStores.ios}
								target="_blank"
								rel="noopener noreferrer"
							>
								<span class="shh-store-small">Download on the</span>
								<span class="shh-store-main">App Store</span>
							</a>
							<a
								class="shh-store-btn"
								href={noteStores.android}
								target="_blank"
								rel="noopener noreferrer"
							>
								<span class="shh-store-small">GET IT ON</span>
								<span class="shh-store-main">Google Play</span>
							</a>
						</div>
					</div>
					<div class="shh-note-visual">
						<img
							src="/images/note-hero.png"
							alt="Slax Note — voice to text app"
							class="shh-note-img"
							loading="eager"
						/>
					</div>
				</div>
			</div>
		</div>

		<!-- Product cards — hovering switches the hero above -->
		<div class="shh-cards">
			<a
				class="shh-card shh-card-reader"
				href="/reader/"
				data-trigger="reader"
			>
				<div class="shh-card-header">
					<img src="/images/reader-logo-new.png" alt="Slax Reader" class="shh-card-logo" />
					<span class="shh-card-name">Slax Reader</span>
				</div>
				<p class="shh-card-desc">
					Save it. Read it. Own it. A read-it-later app that doesn't try to be everything.
				</p>
				<span class="shh-card-cta">Explore Reader →</span>
			</a>
			<a
				class="shh-card shh-card-note"
				href="/note/"
				data-trigger="note"
			>
				<div class="shh-card-header">
					<img src="/images/note-logo-new.png" alt="Slax Note" class="shh-card-logo" />
					<span class="shh-card-name">Slax Note</span>
				</div>
				<p class="shh-card-desc">
					Say it. Shape it. Keep it. A notes app for your own voice.
				</p>
				<span class="shh-card-cta">Explore Note →</span>
			</a>
		</div>
	</section>

	<Footer />
</Base>

<script>
	const section = document.querySelector<HTMLElement>('.shh');
	const panels = document.querySelectorAll<HTMLElement>('[data-panel]');
	const triggers = document.querySelectorAll<HTMLElement>('[data-trigger]');

	const ROTATE_KEYS = ['reader', 'note'] as const;
	const ROTATE_INTERVAL = 6000;

	let current: string = 'reader';
	let rotateTimer: ReturnType<typeof setInterval> | null = null;

	function activate(state: string) {
		current = state;
		panels.forEach((p) =>
			p.classList.toggle('is-active', p.dataset.panel === state),
		);
		triggers.forEach((t) =>
			t.classList.toggle('is-hovered', t.dataset.trigger === state),
		);
	}

	function startRotate() {
		if (rotateTimer) return;
		rotateTimer = setInterval(() => {
			const i = ROTATE_KEYS.indexOf(current as (typeof ROTATE_KEYS)[number]);
			const next = ROTATE_KEYS[(i + 1) % ROTATE_KEYS.length];
			activate(next);
		}, ROTATE_INTERVAL);
	}

	function stopRotate() {
		if (rotateTimer) {
			clearInterval(rotateTimer);
			rotateTimer = null;
		}
	}

	triggers.forEach((trigger) => {
		const key = trigger.dataset.trigger!;
		trigger.addEventListener('mouseenter', () => {
			stopRotate();
			activate(key);
		});
		trigger.addEventListener('mouseleave', startRotate);
		trigger.addEventListener('focus', () => {
			stopRotate();
			activate(key);
		});
		trigger.addEventListener('blur', startRotate);
	});

	// Respect users who prefer reduced motion
	const reduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
	if (!reduced) startRotate();
</script>

<style>
	.shh {
		width: 100%;
		font-family: var(--sans);
	}

	/* ─── Hero wrap: stacked panels ─── */
	.shh-hero-wrap {
		display: grid;
		grid-template-areas: 'hero';
		min-height: 460px;
	}
	.shh-panel {
		grid-area: hero;
		display: flex;
		align-items: center;
		opacity: 0;
		transform: translateY(14px);
		transition:
			opacity 0.42s cubic-bezier(0.22, 1, 0.36, 1),
			transform 0.42s cubic-bezier(0.22, 1, 0.36, 1);
		pointer-events: none;
	}
	.shh-panel.is-active {
		opacity: 1;
		transform: translateY(0);
		pointer-events: auto;
	}

	/* ─── Reader panel ─── */
	.shh-panel-reader {
		background: var(--bg);
	}
	.shh-reader-inner {
		display: grid;
		grid-template-columns: 1fr;
		gap: 3rem;
		align-items: center;
		width: 100%;
		max-width: 1200px;
		margin: 0 auto;
		padding: 5rem 2rem 4rem;
	}
	@media (min-width: 900px) {
		.shh-reader-inner {
			grid-template-columns: 1fr 1fr;
			gap: 4rem;
		}
	}
	.shh-reader-title {
		font-family: var(--serif);
		font-weight: 400;
		font-size: clamp(1.75rem, 3vw, 2.6rem);
		line-height: 1.15;
		letter-spacing: -0.02em;
		color: var(--ink);
		margin: 0 0 1.75rem;
		max-width: 22ch;
	}
	.shh-reader-preview {
		width: 100%;
		max-width: 480px;
		padding: 1.75rem;
		border: 1px solid var(--rule);
		background: var(--bg-deep);
		box-shadow: 0 6px 32px -16px rgba(27, 26, 23, 0.18);
	}
	.shh-reader-card {
		padding: 1.1rem 1.25rem;
		background: var(--bg);
		border: 1px solid var(--rule-soft);
	}
	.shh-reader-card + .shh-reader-card {
		margin-top: 0.9rem;
	}
	.shh-reader-card h4 {
		font-family: var(--mono);
		font-size: 0.78rem;
		letter-spacing: 0.12em;
		color: var(--accent);
		margin: 0 0 0.6rem;
		text-transform: uppercase;
	}
	.shh-reader-card p {
		font-family: var(--serif);
		font-size: 0.95rem;
		line-height: 1.55;
		color: var(--ink-soft);
		margin: 0;
	}
	.shh-reader-card :global(strong) {
		color: var(--ink);
		font-weight: 500;
	}

	/* ─── Note panel ─── */
	.shh-panel-note {
		background: var(--bg-deep);
	}
	.shh-note-inner {
		display: grid;
		grid-template-columns: 1fr;
		gap: 3rem;
		align-items: center;
		width: 100%;
		max-width: 1200px;
		margin: 0 auto;
		padding: 4.5rem 2rem 3.5rem;
	}
	@media (min-width: 900px) {
		.shh-note-inner {
			grid-template-columns: 1fr 1fr;
			gap: 4rem;
		}
	}
	.shh-note-title {
		font-family: var(--serif);
		font-weight: 400;
		font-size: clamp(1.75rem, 3vw, 2.6rem);
		line-height: 1.15;
		letter-spacing: -0.02em;
		color: var(--ink);
		margin: 0 0 1.75rem;
		max-width: 20ch;
	}
	.shh-note-title :global(em) {
		font-style: italic;
		font-weight: 300;
		color: var(--accent);
	}
	.shh-stores {
		display: flex;
		gap: 0.75rem;
		flex-wrap: wrap;
	}
	.shh-store-btn {
		display: inline-flex;
		flex-direction: column;
		align-items: flex-start;
		gap: 0.15rem;
		background: transparent;
		color: var(--ink);
		text-decoration: none;
		padding: 0.7rem 1.2rem;
		border: 1px solid var(--ink);
		transition:
			background 0.2s ease,
			color 0.2s ease;
		min-width: 160px;
	}
	.shh-store-btn:hover {
		background: var(--ink);
		color: var(--bg);
	}
	.shh-store-small {
		font-family: var(--mono);
		font-size: 0.62rem;
		letter-spacing: 0.08em;
		text-transform: uppercase;
		color: var(--ink-mute);
		line-height: 1.2;
	}
	.shh-store-btn:hover .shh-store-small {
		color: var(--bg);
		opacity: 0.75;
	}
	.shh-store-main {
		font-family: var(--serif);
		font-size: 0.98rem;
		font-weight: 500;
		line-height: 1.3;
	}
	.shh-note-img {
		width: 100%;
		max-width: 480px;
		height: auto;
		display: block;
	}

	/* ─── Product cards ─── */
	.shh-cards {
		display: grid;
		grid-template-columns: 1fr;
		gap: 1rem;
		max-width: 1200px;
		width: 100%;
		margin-inline: auto;
		padding: 1.5rem 2rem 3rem;
		background: var(--bg);
		border-top: 1px solid var(--rule-soft);
	}
	@media (min-width: 820px) {
		.shh-cards {
			grid-template-columns: 1fr 1fr;
		}
	}
	.shh-card {
		display: flex;
		flex-direction: column;
		gap: 0.5rem;
		padding: 1.5rem 1.75rem;
		border: 1px solid var(--rule);
		text-decoration: none;
		background: var(--bg);
		transition:
			border-color 0.25s ease,
			background 0.25s ease,
			transform 0.25s ease;
		position: relative;
	}
	.shh-card:hover,
	.shh-card.is-hovered {
		transform: translateY(-3px);
		border-color: var(--accent);
		background: var(--bg-deep);
	}
	.shh-card-header {
		display: flex;
		align-items: center;
		gap: 0.6rem;
	}
	.shh-card-logo {
		width: 22px;
		height: 22px;
		border-radius: 6px;
		object-fit: cover;
		flex-shrink: 0;
	}
	.shh-card-name {
		font-family: var(--serif);
		font-size: 1.05rem;
		font-weight: 500;
		color: var(--ink);
		letter-spacing: -0.01em;
	}
	.shh-card-desc {
		font-family: var(--serif);
		font-size: 0.98rem;
		line-height: 1.5;
		color: var(--ink-soft);
		margin: 0.2rem 0 0;
		max-width: 42ch;
	}
	.shh-card-cta {
		margin-top: 0.6rem;
		font-family: var(--mono);
		font-size: 0.78rem;
		letter-spacing: 0.08em;
		color: var(--accent);
		align-self: flex-start;
	}

	@media (max-width: 900px) {
		.shh-hero-wrap {
			min-height: 380px;
		}
	}
	@media (prefers-reduced-motion: reduce) {
		.shh-panel {
			transition: opacity 0.2s ease;
			transform: none !important;
		}
	}

	/* ─── 屏 1 · Slax Hero + beliefs aside ─── */
	.slax-hero {
		width: 100%;
		background: var(--bg);
		border-bottom: 1px solid var(--rule-soft);
	}
	.slax-hero-inner {
		max-width: 1200px;
		margin: 0 auto;
		padding: clamp(3.5rem, 7vw, 5.5rem) 2rem clamp(3rem, 5vw, 4.5rem);
		display: grid;
		grid-template-columns: 1fr;
		gap: 3rem;
		align-items: start;
	}
	@media (min-width: 960px) {
		.slax-hero-inner {
			grid-template-columns: minmax(0, 1fr) minmax(340px, 0.85fr);
			gap: 4.5rem;
		}
	}
	.slax-hero-main {
		min-width: 0;
		padding-top: 0.25rem;
	}
	.slax-hero-aside {
		min-width: 0;
	}
	@media (min-width: 960px) {
		.slax-hero-aside {
			border-left: 1px solid var(--rule-soft);
			padding-left: 3rem;
		}
	}
	.slax-hero-title {
		font-family: var(--serif);
		font-weight: 400;
		font-size: clamp(2.4rem, 5vw, 4rem);
		line-height: 1.02;
		letter-spacing: -0.03em;
		color: var(--ink);
		margin: 0 0 1.75rem;
	}
	.slax-hero-title em {
		font-style: italic;
		font-weight: 300;
		color: var(--accent);
	}
	.slax-hero-sub {
		font-family: var(--serif);
		font-size: clamp(1.1rem, 1.6vw, 1.35rem);
		line-height: 1.5;
		color: var(--ink-soft);
		margin: 0 0 2.5rem;
		max-width: 36ch;
	}
	.slax-hero-cta {
		display: flex;
		gap: 0.75rem;
		flex-wrap: wrap;
	}
	.slax-hero-btn {
		display: inline-block;
		font-family: var(--mono);
		font-size: 0.78rem;
		letter-spacing: 0.1em;
		text-transform: uppercase;
		color: var(--ink);
		padding: 0.85rem 1.4rem;
		border: 1px solid var(--ink);
		text-decoration: none;
		transition:
			background 0.2s ease,
			color 0.2s ease;
	}
	.slax-hero-btn:hover {
		background: var(--ink);
		color: var(--bg);
	}

	/* beliefs — now nested inside hero aside */
	.beliefs-eyebrow {
		display: block;
		font-family: var(--mono);
		font-size: 0.72rem;
		letter-spacing: 0.18em;
		text-transform: uppercase;
		color: var(--ink-mute);
		margin: 0 0 1.5rem;
	}
	.beliefs-list {
		list-style: none;
		padding: 0;
		margin: 0;
	}
	.belief {
		display: grid;
		grid-template-columns: 36px 1fr;
		gap: 1rem;
		align-items: baseline;
		padding: 1.1rem 0;
		border-top: 1px solid var(--rule-soft);
	}
	.belief:last-child {
		border-bottom: 1px solid var(--rule-soft);
	}
	.belief-num {
		font-family: var(--mono);
		font-size: 0.7rem;
		letter-spacing: 0.14em;
		color: var(--ink-mute);
	}
	.belief-body {
		display: flex;
		flex-direction: column;
		gap: 0.4rem;
	}
	.belief-line {
		font-family: var(--serif);
		font-weight: 400;
		font-size: clamp(1.1rem, 1.5vw, 1.35rem);
		line-height: 1.3;
		letter-spacing: -0.01em;
		color: var(--ink);
	}
	.belief-note {
		font-family: var(--serif);
		font-size: 0.92rem;
		line-height: 1.55;
		color: var(--ink-mute);
		margin: 0;
	}

	/* ─── Product section bullets ─── */
	.shh-product-eyebrow {
		display: block;
		font-family: var(--mono);
		font-size: 0.72rem;
		letter-spacing: 0.18em;
		text-transform: uppercase;
		color: var(--ink-mute);
		margin: 0 0 1rem;
	}
	.shh-bullets {
		list-style: none;
		padding: 0;
		margin: 0 0 2rem;
		display: flex;
		flex-direction: column;
		gap: 0.7rem;
		max-width: 46ch;
	}
	.shh-bullets li {
		position: relative;
		padding-left: 1.5rem;
		font-family: var(--serif);
		font-size: 1.02rem;
		line-height: 1.55;
		color: var(--ink-soft);
	}
	.shh-bullets li::before {
		content: "—";
		position: absolute;
		left: 0;
		top: 0;
		color: var(--ink-mute);
		font-weight: 300;
	}
</style>
