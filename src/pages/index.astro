---
import Button from '~/components/Button.astro';
import Eyebrow from '~/components/Eyebrow.astro';
import Footer from '~/components/Footer.astro';
import MastheadCard from '~/components/MastheadCard.astro';
import Nav from '~/components/Nav.astro';
import ProductCard from '~/components/ProductCard.astro';
import Scene from '~/components/Scene.astro';
import SectionLabel from '~/components/SectionLabel.astro';
import Base from '~/layouts/Base.astro';

const mastheadEntries = [
	{ label: 'Maker', value: 'Slax Lab' },
	{ label: 'Products', value: 'Reader · Note' },
	{
		label: 'Source',
		value: 'github.com/slax-lab',
		href: 'https://github.com/slax-lab',
	},
	{ label: 'Price', value: 'Free while we learn' },
];
---
<Base title="Slax — components smoke test">
	<Nav />

	<main>
		<section class="hero">
			<div class="hero-inner">
				<div>
					<Eyebrow>Slax · Vol. 01 · Components online</Eyebrow>
					<h1 class="h1">Visual system is <em>in</em>. Components next.</h1>
					<p class="dek">
						Eight shared components compiled. Tokens, fonts, and layouts live.
						Full homepage (step 1.5) replaces this smoke test.
					</p>
					<div class="actions">
						<Button variant="primary" href="/reader/" arrow>Start free</Button>
						<Button variant="secondary" href="/blog/">Read the story</Button>
					</div>
				</div>
				<MastheadCard entries={mastheadEntries} />
			</div>
		</section>

		<section class="products">
			<div class="products-head">
				<SectionLabel number="01">The products</SectionLabel>
				<h2 class="products-title">Two tools, one quiet habit.</h2>
			</div>
			<div class="products-grid">
				<ProductCard
					href="/reader/"
					productNumber="Product 01 — Available now"
					ctaText="Open Reader"
					features={[
						'One-click capture, on any platform',
						'Clean reader view, highlights that last',
						'Ask questions of any article, in context',
					]}
				>
					<Fragment slot="name">Slax <em>Reader</em></Fragment>
					<Fragment slot="description">
						A read-later that rewards finishing. Save a page, it stays readable forever.
					</Fragment>
				</ProductCard>
				<ProductCard
					href="/note/"
					productNumber="Product 02 — Launching 2026"
					badge="Private beta"
					ctaText="Request invite"
					features={[
						'Voice-first capture on the go',
						'Polish once, reshape as needed',
						'Private by default',
					]}
				>
					<Fragment slot="name">Slax <em>Note</em></Fragment>
					<Fragment slot="description">
						A notebook that listens. Speak a thought, and AI reshapes it your way.
					</Fragment>
				</ProductCard>
			</div>
		</section>

		<section class="scenes">
			<div class="scenes-head">
				<SectionLabel number="02">How people use it</SectionLabel>
				<h2 class="scenes-intro">A single afternoon, paying attention.</h2>
			</div>
			<Scene
				number="Scene 01"
				kind="Reading"
				title="A long essay, caught on the subway."
			>
				You share a Paul Graham piece from your phone into Slax. On Monday,
				between meetings, it's already waiting — no ads, no paywall. You highlight
				three paragraphs. <strong>One of them stays with you for years.</strong>
			</Scene>
		</section>
	</main>

	<Footer />
</Base>

<style>
	.hero {
		padding: 7rem 0 6rem;
	}
	.hero-inner {
		max-width: 1180px;
		margin: 0 auto;
		padding: 0 2rem;
		display: grid;
		grid-template-columns: 1fr;
		gap: 4rem;
	}
	@media (min-width: 960px) {
		.hero-inner {
			grid-template-columns: 1.25fr 1fr;
			align-items: end;
		}
	}
	.h1 {
		font-family: var(--serif);
		font-weight: 400;
		font-size: clamp(2.6rem, 5.5vw, 4.8rem);
		line-height: 1.02;
		letter-spacing: -0.025em;
		margin: 2.5rem 0 1.75rem;
		text-wrap: pretty;
	}
	.h1 :global(em) {
		font-style: italic;
		font-weight: 300;
		color: var(--accent);
	}
	.dek {
		font-family: var(--serif);
		font-size: clamp(1.1rem, 1.25vw, 1.3rem);
		line-height: 1.5;
		color: var(--ink-soft);
		max-width: 44ch;
		margin: 0 0 2.25rem;
	}
	.actions {
		display: flex;
		gap: 1rem;
		flex-wrap: wrap;
		align-items: center;
	}

	.products {
		padding: var(--section-pad) 0;
		border-top: 1px solid var(--rule-soft);
	}
	.products-head {
		max-width: 1180px;
		margin: 0 auto 4rem;
		padding: 0 2rem;
	}
	.products-title {
		font-family: var(--serif);
		font-weight: 400;
		font-size: clamp(1.8rem, 3vw, 2.6rem);
		letter-spacing: -0.02em;
		line-height: 1.1;
		margin: 0.8rem 0 0;
	}
	.products-grid {
		max-width: 1180px;
		margin: 0 auto;
		padding: 0 2rem;
		display: grid;
		grid-template-columns: 1fr;
		gap: 2rem;
	}
	@media (min-width: 820px) {
		.products-grid {
			grid-template-columns: 1fr 1fr;
		}
	}

	.scenes {
		padding: var(--section-pad) 0;
		border-top: 1px solid var(--rule-soft);
	}
	.scenes-head {
		max-width: 1180px;
		margin: 0 auto 5rem;
		padding: 0 2rem;
	}
	.scenes-intro {
		font-family: var(--serif);
		font-weight: 400;
		font-size: clamp(1.8rem, 3vw, 2.6rem);
		line-height: 1.2;
		letter-spacing: -0.02em;
		max-width: 22ch;
		margin: 1.5rem 0 0;
	}
</style>
