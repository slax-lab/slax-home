---
import Base from '~/layouts/Base.astro';
---
<Base title="Slax — scaffold">
	<main class="scaffold">
		<div class="eyebrow">Slax · Vol. 01 · Scaffold</div>
		<h1>Visual system is <em>in</em>.</h1>
		<p class="dek">
			Fontsource variable fonts loaded. Tokens and global styles split.
			Components (step 1.4) next.
		</p>
		<p class="meta">Step 1.3 / 1.6 complete.</p>
	</main>
</Base>

<style>
	.scaffold {
		max-width: 720px;
		margin: 0 auto;
		padding: 7rem 2rem;
	}
	.eyebrow {
		margin-bottom: 2.5rem;
	}
	h1 {
		font-family: var(--serif);
		font-weight: 400;
		font-size: clamp(2.6rem, 5.5vw, 4.8rem);
		line-height: 1.05;
		letter-spacing: -0.025em;
		margin: 0 0 1.75rem;
	}
	h1 em {
		font-style: italic;
		font-weight: 300;
		color: var(--accent);
	}
	.dek {
		font-family: var(--serif);
		font-size: 1.25rem;
		line-height: 1.5;
		color: var(--ink-soft);
		max-width: 34ch;
		margin: 0 0 4rem;
	}
	.meta {
		font-family: var(--mono);
		font-size: 0.78rem;
		letter-spacing: 0.12em;
		text-transform: uppercase;
		color: var(--ink-mute);
	}
</style>
