---
import { getCollection } from 'astro:content';
import BlogListPage from '~/components/BlogListPage.astro';
import { entryLocale } from '~/lib/content';

const posts = (
	await getCollection('blog', ({ data, id }) => {
		if (data.draft || data.product !== 'note') return false;
		const lang = data.lang ?? entryLocale(id);
		return lang === 'en';
	})
).sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
---
<BlogListPage
	posts={posts}
	lang="en"
	productScope="note"
	titleKey="meta.noteBlogTitle"
/>
