---
import Button from '~/components/Button.astro';
import Footer from '~/components/Footer.astro';
import Nav from '~/components/Nav.astro';
import Base from '~/layouts/Base.astro';

// All Note strings below are copied verbatim from the live product at
// n.slax.com. Sources: slax-note-web src/i18n/locales/en.json plus
// SubscriptionModal / LoginModal component templates. No invented copy.

// Polish prompt labels — i18n polish.prompts.*
const polishModes = [
	{
		label: 'Intelligent polishing',
		desc: 'Cleaned-up prose, still in your voice.',
	},
	{ label: 'Summarize', desc: 'The gist of a recording, condensed.' },
	{ label: 'Tweets (X.com)', desc: 'A short, postable version.' },
	{ label: 'Custom Prompt', desc: 'Whatever you ask for.' },
];

// Polish conversation actions — i18n polish.actions.*
const polishActions = ['Copy', 'Edit', 'Retry', 'Other Styles'];

// i18n subscription.plans.free.features.*
const freeFeatures = ['5 notes', '10 polishes', '5 minutes per recording'];

// i18n subscription.plans.monthly|annual.features.* — identical set,
// also doubles as the "Enjoying 4 Benefits" list
const proBenefits = [
	'Unlimited notes',
	'300 polishing times per day',
	'30 minutes recording per session',
	'Advanced polishing versions',
];

const schema = {
	'@context': 'https://schema.org',
	'@type': 'SoftwareApplication',
	name: 'Slax Note',
	alternateName: 'Slax Note — Transcribe Voice Pen',
	applicationCategory: 'ProductivityApplication',
	operatingSystem: 'iOS, Android, Web',
	description:
		'Record with Slax Note on the go. Let AI capture and refine your thoughts into various text styles.',
	offers: [
		{ '@type': 'Offer', name: 'Free', price: '0', priceCurrency: 'USD' },
		{
			'@type': 'Offer',
			name: 'Pro Monthly',
			price: '4.99',
			priceCurrency: 'USD',
		},
		{
			'@type': 'Offer',
			name: 'Pro Annual',
			price: '49.99',
			priceCurrency: 'USD',
		},
	],
	publisher: {
		'@type': 'Organization',
		name: 'Slax Lab',
		url: 'https://slax.com',
	},
};
---
<Base
	title="Slax Note — Your AI-powered voice notes"
	description="Record with Slax Note on the go. Let AI capture and refine your thoughts into various text styles. Never lose an idea."
	schema={schema}
>
	<Nav active="note" />

	<main>
		<!-- HERO -->
		<section class="n-hero">
			<div class="n-hero-inner">
				<div>
					<h1 class="n-h1">
						Your AI-powered<br />voice notes.<br />
						<em>Turn voice into text</em><br />in seconds.
					</h1>
					<p class="n-dek">
						Record with Slax Note on the go. Let AI capture and refine your
						thoughts into various text styles. Never lose an idea.
					</p>
					<div class="n-stores">
						<a
							class="store-btn"
							href="https://apps.apple.com/us/app/slax-note-transcribe-voice-pen/id6480166286"
							target="_blank"
							rel="noopener noreferrer"
						>
							<svg class="store-icon" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
								<path d="M18.71 19.5c-.83 1.24-1.71 2.45-3.05 2.47-1.34.03-1.77-.79-3.29-.79-1.53 0-2 .77-3.27.82-1.31.05-2.3-1.32-3.14-2.53C4.25 17 2.94 12.45 4.7 9.39c.87-1.52 2.43-2.48 4.12-2.51 1.28-.02 2.5.87 3.29.87.78 0 2.26-1.07 3.8-.91.65.03 2.47.26 3.64 1.98-.09.06-2.17 1.28-2.15 3.81.03 3.02 2.65 4.03 2.68 4.04-.03.07-.42 1.44-1.38 2.83M13 3.5c.73-.83 1.94-1.46 2.94-1.5.13 1.17-.34 2.35-1.04 3.19-.69.85-1.83 1.51-2.95 1.42-.15-1.15.41-2.35 1.05-3.11z"/>
							</svg>
							<div class="store-text">
								<span class="store-small">Download on the</span>
								<span class="store-main">App Store</span>
							</div>
						</a>
						<a
							class="store-btn"
							href="https://play.google.com/store/apps/details?id=app.slax.notes"
							target="_blank"
							rel="noopener noreferrer"
						>
							<svg class="store-icon" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
								<path d="M3.18 23.76c.3.17.64.24.99.2L14.64 12 11 8.36 3.18 23.76zM20.9 10.49l-2.8-1.6-3.6 3.11 3.6 3.12 2.82-1.62c.8-.46.8-1.54-.02-2.01zM2.01 1.05C1.7 1.4 1.5 1.9 1.5 2.53v18.94c0 .63.2 1.13.52 1.48L2.13 23 13.06 12 2.13 1 2.01 1.05zM14.64 12L3.18.24c-.35-.04-.69.03-.99.2l7.82 15.4L14.64 12z"/>
							</svg>
							<div class="store-text">
								<span class="store-small">GET IT ON</span>
								<span class="store-main">Google Play</span>
							</div>
						</a>
					</div>
					<p class="n-web-cta">
						Or <a href="https://n.slax.com/">open Note on the web →</a>
					</p>
				</div>
				<div class="n-visual">
					<img
						src="/images/note-hero.png"
						alt="Slax Note — voice to text app"
						class="n-img"
						loading="eager"
					/>
				</div>
			</div>
		</section>

		<!-- POLISH MODES -->
		<section class="polish">
			<div class="polish-inner">
				<h2 class="polish-head">
					One recording, <em>many text styles.</em>
				</h2>
				<p class="polish-dek">
					Record once. Pick a prompt. Slax Note returns your words in the shape
					you need — keep every version.
				</p>
				<div class="polish-grid">
					{polishModes.map((m, i) => (
						<div class="polish-item">
							<div class="polish-num">{String(i + 1).padStart(2, '0')}</div>
							<h3 class="polish-label">{m.label}</h3>
							<p class="polish-desc">{m.desc}</p>
						</div>
					))}
				</div>
				<div class="polish-actions">
					<p class="polish-actions-label">Each result is a conversation —</p>
					<ul class="polish-actions-list">
						{polishActions.map((a) => <li>{a}</li>)}
					</ul>
					<p class="polish-actions-note">
						Copy what you like. Edit in place. Retry when the words aren't
						right. Switch to another style with one tap.
					</p>
				</div>
			</div>
		</section>

		<!-- PRICING -->
		<section class="pricing" id="pricing">
			<div class="pricing-inner">
				<h2 class="pricing-head">
					Become a <em>prestigious</em> member of Slax Note.
				</h2>
				<p class="pricing-dek">Enjoying 4 Benefits:</p>
				<ul class="pricing-benefits">
					{proBenefits.map((b) => <li>{b}</li>)}
				</ul>

				<div class="plans-grid">
					<!-- FREE -->
					<div class="plan">
						<div class="plan-eyebrow">Free</div>
						<div class="plan-tag">Lifetime</div>
						<div class="plan-price">
							<span class="num">$0</span>
						</div>
						<ul class="plan-list">
							{freeFeatures.map((f) => <li>{f}</li>)}
						</ul>
						<a href="https://n.slax.com/" class="btn-primary">Open Note</a>
					</div>

					<!-- MONTHLY -->
					<div class="plan featured">
						<div class="plan-eyebrow">Monthly</div>
						<div class="plan-tag">Slax Note Pro for one month</div>
						<div class="plan-price">
							<span class="num">$4.99</span><span class="unit">/ month</span>
						</div>
						<p class="plan-note">Cancel anytime.</p>
						<ul class="plan-list">
							{proBenefits.map((b) => <li>{b}</li>)}
						</ul>
						<a href="https://n.slax.com/" class="btn-primary">Subscribe monthly</a>
						<p class="plan-renew">
							Auto-renew monthly, cancel anytime. We will charge $4.99/month.
						</p>
					</div>

					<!-- ANNUAL -->
					<div class="plan">
						<div class="plan-eyebrow">
							Annual <span class="plan-badge">As low as $4.16/mo</span>
						</div>
						<div class="plan-tag">Slax Note Pro for one year</div>
						<div class="plan-price">
							<span class="num">$49.99</span><span class="unit">/ year</span>
						</div>
						<p class="plan-note">Cancel anytime.</p>
						<ul class="plan-list">
							{proBenefits.map((b) => <li>{b}</li>)}
						</ul>
						<a href="https://n.slax.com/" class="btn-primary">Subscribe annually</a>
						<p class="plan-renew">
							Auto-renew annually, cancel anytime. We will charge $49.99/year.
						</p>
					</div>
				</div>

				<div class="pricing-footer">
					<span>
						By subscribing, you authorize Slax Note to charge you according
						to the terms until you cancel.
					</span>
					<span class="pricing-footer-links">
						<a href="https://n.slax.com/">Agreement</a> ·
						<a href="https://n.slax.com/">Redeem Membership</a> ·
						<a href="https://n.slax.com/">Restore Purchases</a>
					</span>
				</div>
			</div>
		</section>

		<!-- FINALE -->
		<section class="finale">
			<div class="finale-inner">
				<h2 class="finale-h">Never lose an <em>idea</em> again.</h2>
				<p class="finale-p">
					Record it. Refine it. Keep it. Free to download, on iPhone, Android,
					and the web.
				</p>
				<div class="actions actions-center">
					<Button variant="primary" href="https://n.slax.com/" arrow>Open Slax Note</Button>
					<Button variant="secondary" href="#pricing">See pricing</Button>
				</div>
			</div>
		</section>
	</main>

	<Footer />
</Base>

<style>
	/* HERO */
	.n-hero {
		padding: 6rem 0 5rem;
	}
	.n-hero-inner {
		max-width: 1180px;
		margin: 0 auto;
		padding: 0 2rem;
		display: grid;
		grid-template-columns: 1fr;
		gap: 4rem;
		align-items: center;
	}
	@media (min-width: 960px) {
		.n-hero-inner {
			grid-template-columns: 1.1fr 1fr;
		}
	}
	.n-h1 {
		font-family: var(--serif);
		font-weight: 400;
		font-size: clamp(2.2rem, 4.5vw, 3.8rem);
		line-height: 1.08;
		letter-spacing: -0.025em;
		margin: 2rem 0 1.5rem;
		color: var(--ink);
	}
	.n-h1 :global(em) {
		font-style: italic;
		font-weight: 300;
		color: var(--accent);
	}
	.n-dek {
		font-family: var(--serif);
		font-size: 1.2rem;
		line-height: 1.55;
		color: var(--ink-soft);
		max-width: 42ch;
		margin: 0 0 2rem;
	}
	.n-stores {
		display: flex;
		gap: 0.75rem;
		flex-wrap: wrap;
	}
	.store-btn {
		display: inline-flex;
		align-items: center;
		gap: 0.6rem;
		background: var(--ink);
		color: var(--bg);
		text-decoration: none;
		padding: 0.7rem 1.1rem;
		border-radius: 10px;
		transition:
			background 0.2s ease,
			transform 0.2s ease;
		min-width: 150px;
	}
	.store-btn:hover {
		background: var(--accent);
		transform: translateY(-1px);
	}
	.store-icon {
		width: 24px;
		height: 24px;
		flex-shrink: 0;
	}
	.store-text {
		display: flex;
		flex-direction: column;
	}
	.store-small {
		font-size: 0.62rem;
		opacity: 0.75;
		line-height: 1.2;
		letter-spacing: 0.02em;
	}
	.store-main {
		font-size: 0.9rem;
		font-weight: 600;
		line-height: 1.3;
	}
	.n-web-cta {
		margin: 1.5rem 0 0;
		font-family: var(--mono);
		font-size: 0.82rem;
		color: var(--ink-mute);
		letter-spacing: 0.04em;
	}
	.n-web-cta a {
		color: var(--ink);
		text-decoration: none;
		border-bottom: 1px dotted var(--ink-mute);
		transition: color 0.2s, border-color 0.2s;
	}
	.n-web-cta a:hover {
		color: var(--accent);
		border-color: var(--accent);
	}
	.n-visual {
		display: flex;
		justify-content: center;
	}
	.n-img {
		width: 100%;
		max-width: 480px;
		height: auto;
		display: block;
	}

	/* POLISH MODES */
	.polish {
		padding: var(--section-pad) 0;
		border-top: 1px solid var(--rule-soft);
		background: var(--bg-deep);
	}
	.polish-inner {
		max-width: 1180px;
		margin: 0 auto;
		padding: 0 2rem;
	}
	.polish-head {
		font-family: var(--serif);
		font-weight: 400;
		font-size: clamp(1.8rem, 3vw, 2.4rem);
		letter-spacing: -0.02em;
		line-height: 1.15;
		margin: 1rem 0 0.5rem;
	}
	.polish-head :global(em) {
		font-style: italic;
		color: var(--accent);
	}
	.polish-dek {
		font-family: var(--serif);
		font-size: 1.1rem;
		line-height: 1.5;
		color: var(--ink-soft);
		max-width: 46ch;
		margin: 0 0 3.5rem;
	}
	.polish-grid {
		display: grid;
		grid-template-columns: 1fr;
		gap: 0;
		border-top: 1px solid var(--rule);
	}
	@media (min-width: 760px) {
		.polish-grid {
			grid-template-columns: 1fr 1fr;
		}
	}
	@media (min-width: 1040px) {
		.polish-grid {
			grid-template-columns: repeat(4, 1fr);
		}
	}
	.polish-item {
		padding: 2.25rem 2rem;
		border-bottom: 1px solid var(--rule);
		background: var(--bg);
	}
	@media (min-width: 760px) {
		.polish-item:nth-child(2n) {
			border-left: 1px solid var(--rule);
		}
	}
	@media (min-width: 1040px) {
		.polish-item:nth-child(2n) {
			border-left: 0;
		}
		.polish-item:not(:nth-child(4n + 1)) {
			border-left: 1px solid var(--rule);
		}
	}
	.polish-num {
		font-family: var(--mono);
		font-size: 0.7rem;
		letter-spacing: 0.2em;
		color: var(--ink-mute);
		margin-bottom: 1.25rem;
	}
	.polish-label {
		font-family: var(--serif);
		font-weight: 500;
		font-size: 1.2rem;
		letter-spacing: -0.01em;
		margin: 0 0 0.6rem;
	}
	.polish-desc {
		font-family: var(--serif);
		font-size: 0.98rem;
		line-height: 1.5;
		color: var(--ink-soft);
		margin: 0;
	}
	.polish-actions {
		margin-top: 3.5rem;
		padding-top: 2.5rem;
		border-top: 1px solid var(--rule-soft);
	}
	.polish-actions-label {
		font-family: var(--serif);
		font-style: italic;
		font-size: 1.15rem;
		color: var(--ink);
		margin: 0 0 1rem;
	}
	.polish-actions-list {
		list-style: none;
		padding: 0;
		margin: 0 0 1.25rem;
		display: flex;
		flex-wrap: wrap;
		gap: 0.5rem;
	}
	.polish-actions-list li {
		font-family: var(--mono);
		font-size: 0.78rem;
		letter-spacing: 0.08em;
		padding: 0.35rem 0.8rem;
		background: var(--bg);
		border: 1px solid var(--rule);
		border-radius: 999px;
		color: var(--ink-soft);
	}
	.polish-actions-note {
		font-family: var(--serif);
		font-size: 1rem;
		line-height: 1.55;
		color: var(--ink-soft);
		margin: 0;
		max-width: 52ch;
	}

	/* PRICING */
	.pricing {
		padding: var(--section-pad) 0;
		border-top: 1px solid var(--rule-soft);
		scroll-margin-top: 5rem;
	}
	.pricing-inner {
		max-width: 1180px;
		margin: 0 auto;
		padding: 0 2rem;
	}
	.pricing-head {
		font-family: var(--serif);
		font-weight: 400;
		font-size: clamp(2rem, 3.5vw, 3rem);
		line-height: 1.1;
		letter-spacing: -0.025em;
		margin: 1rem 0 0.5rem;
	}
	.pricing-head :global(em) {
		font-style: italic;
		color: var(--accent);
		font-weight: 300;
	}
	.pricing-dek {
		font-family: var(--mono);
		font-size: 0.78rem;
		letter-spacing: 0.12em;
		text-transform: uppercase;
		color: var(--ink-mute);
		margin: 0 0 1.5rem;
	}
	.pricing-benefits {
		list-style: none;
		padding: 0;
		margin: 0 0 3.5rem;
		display: grid;
		gap: 0.6rem;
		font-family: var(--serif);
		font-size: 1.1rem;
		color: var(--ink);
		max-width: 42ch;
	}
	.pricing-benefits li {
		padding-left: 1.5rem;
		position: relative;
	}
	.pricing-benefits li::before {
		content: "●";
		position: absolute;
		left: 0;
		color: var(--accent);
		font-size: 0.7em;
		top: 0.25em;
	}
	.plans-grid {
		display: grid;
		grid-template-columns: 1fr;
		gap: 0;
		border-top: 1px solid var(--rule);
		border-bottom: 1px solid var(--rule);
	}
	@media (min-width: 820px) {
		.plans-grid {
			grid-template-columns: repeat(3, 1fr);
		}
	}
	.plan {
		padding: 2.5rem 2rem;
		background: var(--bg);
		display: flex;
		flex-direction: column;
		align-items: flex-start;
	}
	@media (min-width: 820px) {
		.plan + .plan {
			border-left: 1px solid var(--rule);
		}
	}
	@media (max-width: 819px) {
		.plan + .plan {
			border-top: 1px solid var(--rule);
		}
	}
	.plan.featured {
		background: var(--bg-deep);
		position: relative;
	}
	.plan.featured::before {
		content: "Most popular";
		position: absolute;
		top: 1rem;
		right: 1rem;
		font-family: var(--mono);
		font-size: 0.68rem;
		letter-spacing: 0.15em;
		text-transform: uppercase;
		color: var(--accent);
	}
	.plan-eyebrow {
		font-family: var(--serif);
		font-size: 1.35rem;
		font-weight: 500;
		color: var(--ink);
		display: flex;
		align-items: center;
		gap: 0.6rem;
		flex-wrap: wrap;
	}
	.plan.featured .plan-eyebrow {
		color: var(--accent);
	}
	.plan-badge {
		font-family: var(--mono);
		font-size: 0.68rem;
		letter-spacing: 0.08em;
		text-transform: uppercase;
		color: var(--accent);
		background: color-mix(in srgb, var(--accent) 12%, transparent);
		padding: 0.2rem 0.55rem;
		border-radius: 999px;
	}
	.plan-tag {
		font-family: var(--serif);
		font-style: italic;
		font-size: 0.92rem;
		color: var(--ink-mute);
		margin: 0.3rem 0 0.2rem;
	}
	.plan-note {
		font-family: var(--serif);
		font-size: 0.9rem;
		color: var(--ink-mute);
		margin: 0 0 1rem;
	}
	.plan-renew {
		font-family: var(--mono);
		font-size: 0.72rem;
		line-height: 1.5;
		color: var(--ink-mute);
		letter-spacing: 0.02em;
		margin: 1rem 0 0;
		max-width: 44ch;
	}
	.plan-price {
		display: flex;
		align-items: baseline;
		gap: 0.5rem;
		margin: 0.5rem 0 1.5rem;
		flex-wrap: wrap;
	}
	.plan-price .num {
		font-family: var(--serif);
		font-size: 2.5rem;
		font-weight: 400;
		color: var(--ink);
		letter-spacing: -0.03em;
	}
	.plan-price .unit {
		font-family: var(--sans);
		font-size: 0.92rem;
		color: var(--ink-mute);
	}
	.plan-price .was {
		font-family: var(--mono);
		font-size: 0.78rem;
		color: var(--accent);
		margin-left: 0.4rem;
	}
	.plan-list {
		list-style: none;
		padding: 0;
		margin: 0 0 2rem;
		display: grid;
		gap: 0.5rem;
		font-family: var(--serif);
		font-size: 0.98rem;
		color: var(--ink-soft);
	}
	.plan-list li {
		padding-left: 1.25rem;
		position: relative;
	}
	.plan-list li::before {
		content: "—";
		position: absolute;
		left: 0;
		color: var(--ink-mute);
	}
	.pricing-footer {
		margin: 2.5rem 0 0;
		padding-top: 1.5rem;
		border-top: 1px solid var(--rule-soft);
		display: grid;
		gap: 0.6rem;
		font-family: var(--mono);
		font-size: 0.76rem;
		line-height: 1.55;
		letter-spacing: 0.02em;
		color: var(--ink-mute);
		max-width: 64ch;
	}
