---
import Button from '~/components/Button.astro';
import DownloadSection from '~/components/DownloadSection.astro';
import FaqList from '~/components/FaqList.astro';
import Footer from '~/components/Footer.astro';
import Nav from '~/components/Nav.astro';
import Base from '~/layouts/Base.astro';

// All content below is copied verbatim from note.slax.com (the live
// marketing landing) plus n.slax.com product i18n where relevant.
// Single source of truth: fetched from note.slax.com 2026-04-19.

const notePlatforms = [
	{
		icon: '📱',
		title: 'iPhone, iPad, Android',
		bullets: [
			'Capture ideas with a single tap.',
			'AI transcription with auto punctuation and style polish.',
			'Copy or share your notes anywhere, in text or image form.',
			'Everything syncs across devices.',
		],
		downloads: [
			{
				href: 'https://apps.apple.com/us/app/slax-note-transcribe-voice-pen/id6480166286',
				small: 'Download on the',
				main: 'App Store',
			},
			{
				href: 'https://play.google.com/store/apps/details?id=app.slax.notes',
				small: 'GET IT ON',
				main: 'Google Play',
			},
		],
	},
];

// Efficiency Boost 🚀 — "save your time on what matters"
const efficiencyFeatures = [
	{
		title: 'Capture your idea with one click',
		body: "Just record effortlessly with one tap. Focus on your thoughts, and we'll handle the rest.",
		video: '/note/videos/click.mp4',
	},
	{
		title: 'Automatically optimize text and punctuation',
		body: 'Our AI-powered service accurately transcribe your voice, then further polish the text and add punctuation to match your tone.',
		video: '/note/videos/polish.mp4',
	},
	{
		title: 'Copy and share your notes everywhere',
		body: 'Easily share your insights as copied text or image to integrate your insights into your workflow.',
		video: '/note/videos/copy-share.mp4',
	},
];

// Intelligent Ghostwriting ✍️ — "let AI perfect your text with ease"
const ghostwritingFeatures = [
	{
		title: 'Choose ready-made styles for various scenarios',
		body: 'Select our built-in styles, including summarizing, tweets, and compliments. More styles are on the way.',
		video: '/note/videos/choose-ready-made.mp4',
	},
	{
		title: 'Customize prompt to suit personalized needs',
		body: 'Personalize prompts tailored to your unique requirements and workflow.',
		video: '/note/videos/customize.mp4',
	},
];

// How are others using Slax Note — 5 real use cases from note.slax.com
const useCases = [
	{
		title: 'Personal voice memos',
		body: 'Seize and save fleeting thoughts during walks or drives. We transform your voice memos into polished and accessible text. Never let any aha moment slip away.',
	},
	{
		title: 'Content Creation',
		body: "Create content faster and easier than ever. Simply speak your ideas, and Slax Note's AI will generate elegant content in seconds. No typing required!",
	},
	{
		title: 'Schedule organization',
		body: 'Just tell Slax Note your to-dos, and it will help organize your schedule effortlessly, freeing up your time for what truly matters.',
	},
	{
		title: 'Meeting minutes',
		body: 'Wake Slax Note when in a laptop-free meeting, and it will be your AI assistant that records and transcribes the meeting summries.',
	},
	{
		title: 'Learning notes',
		body: 'Your AI study buddy. Open Slax Note to capture lectures you might miss, or practice your presentation and let it generate a polished speech draft with ease.',
	},
];

// Real testimonials from note.slax.com — 6 named users
const testimonials = [
	{
		quote:
			'If you frequently need to write or jot down inspirations, I highly recommend Slax Note. It polishes my spoken content and makes it even more precise than my usual writing.',
		author: 'Cao Jiang',
		title: 'Independent content creator',
	},
	{
		quote:
			'This tool is quite elegant. It can help me develop the habit of consistently using it to record my thoughts, which is truly beneficial.',
		author: 'Fenng',
		title: 'Tech blogger',
	},
	{
		quote:
			'Slax Note utilizes LLM technology to achieve automatic voice transcription and content refinement. Compared to traditional tools, it removes filler words and disfluencies from spoken language, making output clear and logical that helps users capture and organize their ideas effectively.',
		author: '辉哥奇谭',
		title: 'Writer',
	},
	{
		quote:
			"I don't lack content to output, but time to create it. Since using Slax Note, I've saved so much time, which is invaluable to me.",
		author: 'Investor Fan',
		title: 'Investor / Founder of Gaozhang Capital',
	},
	{
		quote:
			"I'll open Slax Note whether chatting with friends or doing interview. It directly turns conversation into articles without manual record arrangement. Slax Note takes care of everything for me.",
		author: '刘容',
		title: 'Internet Company Marketing Manager',
	},
	{
		quote:
			'In our family group chat, I often share daily schedules and important matters, and I always use Slax Note to record and organize the plans systematically. This helps our communication stays clear and all my various things are well-arranged.',
		author: 'Vivian',
		title: 'Senior manager',
	},
];

// FAQ — verbatim from note.slax.com
const faqs = [
	{
		q: 'How to subscribe?',
		a: "Visit our app Slax Note, choose your desired subscription plan, and follow the prompts to create an account and complete the payment process. You'll be able to enjoy premium features immediately after subscribing.",
	},
	{
		q: 'Does it support uploading files?',
		a: 'Audio file uploads are not supported at the moment, but this feature is planned and will be supported in the future.',
	},
	{
		q: 'How accurate is the speech-to-text conversion?',
		a: 'Using advanced AI technology, accuracy is very high. For clear audio input, accuracy can reach over 95%.',
	},
	{
		q: 'Is there a time limit for recordings?',
		a: 'Each recording is limited to 30 minutes.',
	},
	{
		q: 'Can I edit the converted text?',
		a: 'Yes, converted text is fully editable and supports various text style conversions.',
	},
	{
		q: 'Where are audio files stored and are they secure?',
		a: 'All audio recordings are stored locally to ensure user privacy and security.',
	},
	{
		q: 'How can I export notes?',
		a: 'Notes can be easily shared to other apps as text or images.',
	},
	{
		q: 'Does it work offline?',
		a: 'Recording features work offline, but conversion requires internet connection.',
	},
	{
		q: 'How to set content in different styles?',
		a: "Open the App to start recording, or tap 'Text Note' to input content, which will take you to the automatic refinement page. Here, you can click the 'Default' button on the right to switch between different writing styles. Or freely customize the style you desire.",
	},
	{
		q: 'Which languages does Slax Note support for speech recognition?',
		a: 'Currently supports major languages like English, Chinese, German and Japanese, with more languages planned for the future.',
	},
];

const schema = {
	'@context': 'https://schema.org',
	'@type': 'SoftwareApplication',
	name: 'Slax Note',
	alternateName: 'Slax Note — Your Voice Notes Copilot',
	applicationCategory: 'ProductivityApplication',
	operatingSystem: 'iOS, Android, Web',
	url: 'https://slax.com/note/',
	image: 'https://slax.com/og/note.png',
	screenshot: 'https://slax.com/images/note/cover.png',
	description:
		'Transform Speech into Smart Notes Effortlessly. Record with Slax Note on the go. Let AI capture and refine your thoughts into various text styles.',
	downloadUrl: [
		'https://apps.apple.com/us/app/slax-note-transcribe-voice-pen/id6480166286',
		'https://play.google.com/store/apps/details?id=app.slax.notes',
	],
	offers: [
		{
			'@type': 'Offer',
			name: 'Free',
			price: '0',
			priceCurrency: 'USD',
		},
		{
			'@type': 'Offer',
			name: 'Premium Monthly',
			price: '4.99',
			priceCurrency: 'USD',
			priceSpecification: {
				'@type': 'UnitPriceSpecification',
				price: '4.99',
				priceCurrency: 'USD',
				billingDuration: 'P1M',
			},
		},
		{
			'@type': 'Offer',
			name: 'Premium Annual',
			price: '49.99',
			priceCurrency: 'USD',
			priceSpecification: {
				'@type': 'UnitPriceSpecification',
				price: '49.99',
				priceCurrency: 'USD',
				billingDuration: 'P1Y',
			},
		},
	],
	publisher: {
		'@type': 'Organization',
		name: 'Starry Tech Pte. Ltd.',
		url: 'https://slax.com',
		logo: 'https://slax.com/images/slax-logo.png',
	},
};
---
<Base
	title="Slax Note — A notes app for your own voice"
	description="Say it the moment it shows up. One recording, many shapes — shaped by the prompts you choose. Made to grow with you, year after year."
	ogImage="/og/note.png"
	schema={schema}
>
	<Nav active="note" />

	<main>
		<!-- HERO -->
		<section class="n-hero">
			<div class="n-hero-inner">
				<div>
					<h1 class="n-h1">
						A notes app <em>for your own voice.</em>
					</h1>
					<ul class="n-bullets">
						<li>Say it the moment it shows up. Don't type. Don't organize.</li>
						<li>One recording, many shapes — shaped by the prompts you choose.</li>
						<li>Made to grow with you, year after year.</li>
					</ul>
					<div class="n-stores">
						<a
							class="store-btn is-primary"
							href="https://apps.apple.com/us/app/slax-note-transcribe-voice-pen/id6480166286"
							target="_blank"
							rel="noopener noreferrer"
						>
							<span class="store-small">Download on the</span>
							<span class="store-main">App Store</span>
						</a>
						<a
							class="store-btn"
							href="https://play.google.com/store/apps/details?id=app.slax.notes"
							target="_blank"
							rel="noopener noreferrer"
						>
							<span class="store-small">GET IT ON</span>
							<span class="store-main">Google Play</span>
						</a>
					</div>
					<p class="n-web-link">
						Or <a href="https://n.slax.com/">open in your browser</a>.
					</p>
				</div>
				<div class="n-visual">
					<img
						src="/images/note/cover.png"
						alt="Slax Note — Your Voice Notes Copilot"
						class="n-img"
						loading="eager"
					/>
				</div>
			</div>
		</section>

		<!-- EFFICIENCY BOOST -->
		<section class="features" id="features" data-demo-group="efficiency">
			<div class="features-inner">
				<div class="feat-head">
					<h2 class="feat-title">Efficiency Boost</h2>
					<p class="feat-sub">Save your time on what matters.</p>
				</div>
				<div class="feat-demo-body">
					<div class="feat-list" role="tablist" aria-label="Efficiency Boost features">
						{efficiencyFeatures.map((f, i) => (
							<button
								class="feat-item"
								type="button"
								role="tab"
								data-idx={i}
								aria-selected={i === 0 ? 'true' : 'false'}
								aria-controls={`efficiency-video-${i}`}
							>
								<div class="feat-item-head">
									<span class="feat-num">{String(i + 1).padStart(2, '0')}</span>
									<h3 class="feat-h">{f.title}</h3>
								</div>
								<p class="feat-p">{f.body}</p>
							</button>
						))}
					</div>
					<div class="feat-stage">
						<div class="feat-frame">
							{efficiencyFeatures.map((f, i) => (
								<video
									id={`efficiency-video-${i}`}
									class="feat-video"
									data-idx={i}
									src={f.video}
									muted
									loop
									playsinline
									preload={i === 0 ? 'auto' : 'metadata'}
									aria-hidden={i === 0 ? 'false' : 'true'}
								></video>
							))}
						</div>
					</div>
				</div>
			</div>
		</section>

		<!-- INTELLIGENT GHOSTWRITING -->
		<section class="features features-alt" data-demo-group="ghostwriting">
			<div class="features-inner">
				<div class="feat-head">
					<h2 class="feat-title">Intelligent Ghostwriting</h2>
					<p class="feat-sub">Let AI perfect your text with ease.</p>
				</div>
				<div class="feat-demo-body feat-demo-body--reverse">
					<div class="feat-stage">
						<div class="feat-frame">
							{ghostwritingFeatures.map((f, i) => (
								<video
									id={`ghostwriting-video-${i}`}
									class="feat-video"
									data-idx={i}
									src={f.video}
									muted
									loop
									playsinline
									preload="metadata"
									aria-hidden={i === 0 ? 'false' : 'true'}
								></video>
							))}
						</div>
					</div>
					<div class="feat-list" role="tablist" aria-label="Intelligent Ghostwriting features">
						{ghostwritingFeatures.map((f, i) => (
							<button
								class="feat-item"
								type="button"
								role="tab"
								data-idx={i}
								aria-selected={i === 0 ? 'true' : 'false'}
								aria-controls={`ghostwriting-video-${i}`}
							>
								<div class="feat-item-head">
									<span class="feat-num">{String(i + 1).padStart(2, '0')}</span>
									<h3 class="feat-h">{f.title}</h3>
								</div>
								<p class="feat-p">{f.body}</p>
							</button>
						))}
					</div>
				</div>
			</div>
		</section>

		<!-- USE CASES -->
		<section class="usecases">
			<div class="usecases-inner">
				<h2 class="usecases-head">How are others using Slax Note</h2>
				<div class="uc-grid">
					{useCases.map((uc) => (
						<div class="uc">
							<h3 class="uc-h">{uc.title}</h3>
							<p class="uc-p">{uc.body}</p>
						</div>
					))}
				</div>
			</div>
		</section>

		<!-- TESTIMONIALS -->
		<section class="testimonials">
			<div class="testimonials-inner">
				<h2 class="t-head">Loved by thousands of users</h2>
				<p class="t-sub">
					Ready to revolutionize your note-taking? Try Slax Note now.
				</p>
				<div class="t-grid">
					{testimonials.map((t) => (
						<figure class="testimonial">
							<blockquote class="t-quote">"{t.quote}"</blockquote>
							<figcaption class="t-caption">
								<span class="t-author">{t.author}</span>
								<span class="t-title">{t.title}</span>
							</figcaption>
						</figure>
					))}
				</div>
			</div>
		</section>

		<!-- PRICING -->
		<section class="pricing" id="pricing">
			<div class="pricing-inner">
				<h2 class="pricing-head">Pricing</h2>
				<p class="pricing-dek">Enjoy early-bird pricing to upgrade your plan.</p>

				<div class="plans-grid plans-grid-3">
					<!-- FREE -->
					<div class="plan">
						<div class="plan-eyebrow">Free</div>
						<div class="plan-price">
							<span class="num">$0</span>
						</div>
						<p class="plan-note">Lifetime.</p>
						<ul class="plan-list">
							<li><span class="plan-feat-label">Voice notes</span><span class="plan-feat-value">5 notes</span></li>
							<li><span class="plan-feat-label">AI Polish</span><span class="plan-feat-value">10 times total</span></li>
							<li><span class="plan-feat-label">Recording duration</span><span class="plan-feat-value">5 minutes</span></li>
						</ul>
						<a href="https://n.slax.com/" class="btn-primary">Give it a try</a>
					</div>

					<!-- PREMIUM — MONTHLY -->
					<div class="plan">
						<div class="plan-eyebrow">Monthly</div>
						<div class="plan-price">
							<span class="num">$4.99</span><span class="unit">/ month</span>
						</div>
						<p class="plan-note">Cancel anytime.</p>
						<ul class="plan-list">
							<li><span class="plan-feat-label">Voice notes</span><span class="plan-feat-value">Unlimited</span></li>
							<li><span class="plan-feat-label">AI Polish</span><span class="plan-feat-value">300 times / day</span></li>
							<li><span class="plan-feat-label">Recording duration</span><span class="plan-feat-value">30 minutes</span></li>
							<li><span class="plan-feat-label">Polishing quality</span><span class="plan-feat-value">Premium version</span></li>
						</ul>
						<div class="plan-actions">
							<a
								class="btn-primary"
								href="https://apps.apple.com/us/app/slax-note-transcribe-voice-pen/id6480166286"
								target="_blank"
								rel="noopener noreferrer"
							>
								App Store
							</a>
							<a
								class="btn-primary btn-primary-outline"
								href="https://play.google.com/store/apps/details?id=app.slax.notes"
								target="_blank"
								rel="noopener noreferrer"
							>
								Google Play
							</a>
						</div>
					</div>

					<!-- PREMIUM — ANNUAL -->
					<div class="plan featured">
						<div class="plan-eyebrow">
							Annual <span class="plan-badge">Save 2 months</span>
						</div>
						<div class="plan-price">
							<span class="num">$49.99</span><span class="unit">/ year</span>
						</div>
						<p class="plan-note">As low as $4.16/month. Cancel anytime.</p>
						<ul class="plan-list">
							<li><span class="plan-feat-label">Voice notes</span><span class="plan-feat-value">Unlimited</span></li>
							<li><span class="plan-feat-label">AI Polish</span><span class="plan-feat-value">300 times / day</span></li>
							<li><span class="plan-feat-label">Recording duration</span><span class="plan-feat-value">30 minutes</span></li>
							<li><span class="plan-feat-label">Polishing quality</span><span class="plan-feat-value">Premium version</span></li>
						</ul>
						<div class="plan-actions">
							<a
								class="btn-primary"
								href="https://apps.apple.com/us/app/slax-note-transcribe-voice-pen/id6480166286"
								target="_blank"
								rel="noopener noreferrer"
							>
								App Store
							</a>
							<a
								class="btn-primary btn-primary-outline"
								href="https://play.google.com/store/apps/details?id=app.slax.notes"
								target="_blank"
								rel="noopener noreferrer"
							>
								Google Play
							</a>
						</div>
					</div>
				</div>
			</div>
		</section>

		<!-- FAQ -->
		<section class="faq">
			<div class="faq-inner">
				<h2 class="faq-head">Frequently Asked Questions</h2>
				<p class="faq-sub">
					Any other questions or suggestions, please contact us on
					<a href="https://discord.gg/kznNsZvWSk">Discord</a> or email us at
					<a href="mailto:note@slax.com">note@slax.com</a>.
				</p>
				<FaqList items={faqs} />
			</div>
		</section>

		<!-- DOWNLOAD -->
		<DownloadSection platforms={notePlatforms}>
			<Fragment slot="heading">
				Slax Note — <em>Your voice, effortlessly polished.</em>
			</Fragment>
			<Fragment slot="dek">
				Free to download, available on iOS and Android.
			</Fragment>
		</DownloadSection>

		<!-- FINALE -->
		<section class="finale">
			<div class="finale-inner">
				<h2 class="finale-h">Never lose an <em>idea</em> again.</h2>
				<p class="finale-p">
					Free to download, on iPhone, Android, and the web.
				</p>
				<div class="actions actions-center">
					<Button variant="primary" href="https://n.slax.com/" arrow>Open Slax Note</Button>
					<Button variant="secondary" href="#pricing">See pricing</Button>
				</div>
			</div>
		</section>
	</main>

	<Footer />
</Base>

<style>
	/* HERO */
	.n-hero {
		padding: 6rem 0 5rem;
	}
	.n-hero-inner {
		max-width: 1180px;
		margin: 0 auto;
		padding: 0 2rem;
		display: grid;
		grid-template-columns: 1fr;
		gap: 4rem;
		align-items: center;
	}
	@media (min-width: 960px) {
		.n-hero-inner {
			grid-template-columns: 1.1fr 1fr;
		}
	}
	.n-h1 {
		font-family: var(--serif);
		font-weight: 400;
		font-size: clamp(2rem, 4vw, 3.2rem);
		line-height: 1.1;
		letter-spacing: -0.02em;
		margin: 1rem 0 1.75rem;
		color: var(--ink);
		max-width: 20ch;
	}
	.n-h1 :global(em) {
		font-style: italic;
		font-weight: 300;
		color: var(--accent);
	}
	.n-bullets {
		list-style: none;
		padding: 0;
		margin: 0 0 2.25rem;
		display: flex;
		flex-direction: column;
		gap: 0.75rem;
		max-width: 48ch;
	}
	.n-bullets li {
		position: relative;
		padding-left: 1.5rem;
		font-family: var(--serif);
		font-size: 1.05rem;
		line-height: 1.55;
		color: var(--ink-soft);
	}
	.n-bullets li::before {
		content: "—";
		position: absolute;
		left: 0;
		top: 0;
		color: var(--ink-mute);
		font-weight: 300;
	}
	.n-stores {
		display: flex;
		gap: 0.75rem;
		flex-wrap: wrap;
	}
	.n-web-link {
		margin: 0.9rem 0 0;
		font-family: var(--serif);
		font-size: 0.95rem;
		color: var(--ink-mute);
	}
	.n-web-link a {
		color: var(--ink-soft);
		text-decoration: underline;
		text-decoration-color: var(--rule);
		text-underline-offset: 3px;
		transition: color 0.2s ease, text-decoration-color 0.2s ease;
	}
	.n-web-link a:hover {
		color: var(--accent);
		text-decoration-color: var(--accent);
	}
	.store-btn {
		display: inline-flex;
		flex-direction: column;
		align-items: flex-start;
		gap: 0.15rem;
		background: transparent;
		color: var(--ink);
		text-decoration: none;
		padding: 0.7rem 1.2rem;
		border: 1px solid var(--ink);
		transition:
			background 0.2s ease,
			color 0.2s ease;
		min-width: 160px;
	}
	.store-btn:hover {
		background: var(--ink);
		color: var(--bg);
	}
	.store-btn.is-primary,
	.store-btn.is-primary:hover {
		background: var(--accent);
		border-color: var(--accent);
		color: var(--bg);
	}
	.store-btn.is-primary .store-small,
	.store-btn.is-primary:hover .store-small {
		color: var(--bg);
		opacity: 0.8;
	}
	.store-small {
		font-family: var(--mono);
		font-size: 0.62rem;
		letter-spacing: 0.08em;
		text-transform: uppercase;
		color: var(--ink-mute);
		line-height: 1.2;
	}
	.store-btn:hover .store-small {
