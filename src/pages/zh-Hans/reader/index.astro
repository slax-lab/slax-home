---
import Button from '~/components/Button.astro';
import DownloadSection from '~/components/DownloadSection.astro';
import FaqList from '~/components/FaqList.astro';
import Footer from '~/components/Footer.astro';
import Nav from '~/components/Nav.astro';
import Base from '~/layouts/Base.astro';
import { SITE } from '~/lib/hreflang';

// Content sourced verbatim from original apps/reader-home components
// (archive/apps-backup): HomeHero / HomeFeatures / HomeHowItWorks /
// HomeComparison / HomeCTA / PricingTable / DownloadPage.
// Plan decision: merge features + pricing + download into single
// anchor-navigable /reader/ page.

const features = [
	{
		title: 'AI 加持的理解力',
		body: '随时获取文章的摘要、要点和你想问的答案。就像随身带着一位私人导师，帮你读懂每一篇文章。',
	},
	{
		title: '内容永不消失',
		body: '保存过一次的文章会被永久备份，再也不用担心打开链接看到「404 页面不存在」。你的数字图书馆真正归你所有。',
	},
	{
		title: '智能整理',
		body: 'AI 自动给内容打标签和分类。需要时用强大的语义搜索，准确找到你想要的那一篇。',
	},
	{
		title: '联结式阅读',
		body: '在保存的文章上高亮、写评论。分享内容，邀请别人加入讨论。每一篇文章都能变成对话的现场。',
	},
];

const steps = [
	{
		title: '随手保存',
		body: '一键保存网上任何文章、论文或博客。',
	},
	{
		title: 'AI 自动分析',
		body: 'AI 生成的速览帮你判断哪些值得细读、哪些扫一眼就够。把时间留给最好的内容。',
	},
	{
		title: '向 AI 提问',
		body: '就保存的内容和 AI 对话，把理解推得更深。',
	},
	{
		title: '与内容深度互动',
		body: '高亮、评论、和别人一起讨论。你写下的东西，比你读过的更有价值。',
	},
];

// Cell value: 'ok' → ● accent,   'no' → — muted,   any other string → inline text (muted italic)
const compareRows: Array<[string, string, string, string]> = [
	['无限免费收藏（早期用户）', 'ok', 'ok', '付费'],
	['内容永久备份', 'ok', '付费', '付费'],
	['AI 大纲', '付费', 'ok', '付费'],
	['阅读时和 AI 对话', '付费', 'no', '付费'],
	['在原文和快照上高亮、评论，双向同步', 'ok', 'no', '付费'],
	['加入读者讨论', 'ok', 'no', '仅分享'],
	['AI 自动打标签', '付费', '手动', '手动'],
];

const matrixRows: Array<[string, string, string]> = [
	['无限保存文章', 'ok', 'ok'],
	['永久快照（不再有失效链接）', 'ok', 'ok'],
	['无限次高亮和评论', 'ok', 'ok'],
	['全文搜索', 'ok', 'ok'],
	['全设备同步', 'ok', 'ok'],
	['分享文章并加入讨论', 'ok', 'ok'],
	['开源并以隐私为先', 'ok', 'ok'],
	['创建和管理标签', 'ok', 'ok'],
	['智能 AI 自动打标签', 'no', 'ai'],
	['即时 AI 摘要', 'no', 'ai'],
	['可交互 AI 大纲', 'no', 'ai'],
	['AI 对话——向你的资料库提问', 'no', 'ai'],
];

const faqs = [
	{
		q: '免费套餐真的能永久免费吗？',
		a: '是的——对早期用户来说。在早期访问阶段，我们提供无限收藏和永久备份，全部免费。趁现在没有限制，先把免费额度锁定下来。',
	},
	{
		q: 'Slax Reader 真的能帮我每周省下几个小时的阅读时间吗？',
		a: '它就是为这件事造出来的。可点击的 AI 大纲让你跳着读长文，不必逐字阅读。自动打标签替你完成整理，你只管读。',
	},
	{
		q: 'Pro 订阅可以随时取消吗？',
		a: '当然。任何时候在账户设置里取消都没有任何代价。你保存的文章和高亮在免费套餐下依然可以继续访问。',
	},
	{
		q: '1 个月免费试用怎么用？',
		a: '登录后即可开始试用，不需要信用卡。30 天后会询问你是否继续使用 Pro，价格为 $5.99 / 月（原价 $9.99）。',
	},
];

const platforms = [
	{
		icon: '📱',
		title: 'iPhone、iPad、Android',
		bullets: [
			'永久保存，完全免费。',
			'一键保存任何文章。',
			'即时获取 AI 大纲，快速跳读。',
			'全平台同步。',
		],
		downloads: [
			{
				href: 'https://apps.apple.com/us/app/slax-reader-ai-read-it-later/id6596730998',
				small: '下载于',
				main: 'App Store',
			},
			{
				href: 'https://play.google.com/store/apps/details?id=com.slax.reader',
				small: '获取于',
				main: 'Google Play',
			},
		],
	},
	{
		icon: '💻',
		title: 'Mac',
		bullets: ['像专业玩家一样保存、阅读、整理。'],
		downloads: [
			{
				href: 'https://apps.apple.com/us/app/slax-reader-ai-read-it-later/id6596730998',
				small: '下载于',
				main: 'Mac App Store',
			},
		],
	},
	{
		icon: '🌐',
		title: '浏览器扩展',
		bullets: [
			'一键保存并备份任何网页——永远归你所有。',
			'就在原网页上，直接和 AI 对话讨论文章。',
			'用强大的语义搜索，几秒钟找到你要的内容。',
		],
		downloads: [
			{
				href: 'https://chromewebstore.google.com/detail/gdnhaajlomjkhahnmiijphnodkcfikfd?utm_source=web_homepage',
				small: '',
				main: 'Chrome Extension',
			},
		],
	},
];

const schema = {
	'@context': 'https://schema.org',
	'@type': 'SoftwareApplication',
	name: 'Slax Reader',
	applicationCategory: 'ProductivityApplication',
	operatingSystem: 'Web, iOS, iPadOS, Android, macOS',
	url: new URL('/reader/', SITE).toString(),
	image: new URL('/og/reader.png', SITE).toString(),
	screenshot: new URL('/reader/hero.png', SITE).toString(),
	description:
		'开源、纯粹的稍后阅读工具。永久保存，学得更快。属于你的智能图书馆，让阅读更高效、理解更深入。',
	downloadUrl: [
		'https://apps.apple.com/us/app/slax-reader-ai-read-it-later/id6596730998',
		'https://play.google.com/store/apps/details?id=com.slax.reader',
		'https://chromewebstore.google.com/detail/gdnhaajlomjkhahnmiijphnodkcfikfd',
	],
	offers: [
		{
			'@type': 'Offer',
			name: 'Free',
			price: '0',
			priceCurrency: 'USD',
		},
		{
			'@type': 'Offer',
			name: 'Pro Reader',
			price: '5.99',
			priceCurrency: 'USD',
			priceSpecification: {
				'@type': 'UnitPriceSpecification',
				price: '5.99',
				priceCurrency: 'USD',
				billingDuration: 'P1M',
			},
		},
	],
	publisher: {
		'@type': 'Organization',
		name: 'Slax Lab',
		url: SITE,
		logo: new URL('/images/slax-logo.png', SITE).toString(),
	},
};
---
<Base
	title="Slax Reader——开源、纯粹的稍后阅读工具"
	description="开源、纯粹的稍后阅读工具。没有算法，没有信息流。下一篇读什么由你决定。无限快照，完全免费。"
	ogImage="/og/reader.png"
	schema={schema}
>
	<Nav active="reader" />

	<main>
		<!-- HERO -->
		<section class="r-hero">
			<div class="r-hero-inner">
				<div>
					<h1 class="r-h1">
						开源、纯粹的<em>稍后阅读工具。</em>
					</h1>
					<ul class="r-bullets">
						<li>没有算法，没有信息流。下一篇读什么由你决定。</li>
						<li>无限快照，完全免费。</li>
						<li>开源。</li>
					</ul>
					<div class="r-hero-stores">
						<a
							class="r-store-btn is-primary"
							href="https://apps.apple.com/us/app/slax-reader-ai-read-it-later/id6596730998"
							target="_blank"
							rel="noopener noreferrer"
						>
							<span class="r-store-small">下载于</span>
							<span class="r-store-main">App Store</span>
						</a>
						<a
							class="r-store-btn"
							href="https://play.google.com/store/apps/details?id=com.slax.reader"
							target="_blank"
							rel="noopener noreferrer"
						>
							<span class="r-store-small">获取于</span>
							<span class="r-store-main">Google Play</span>
						</a>
					</div>
					<p class="r-web-link">
						或者<a href="https://r.slax.com">访问网页版</a>。
					</p>
				</div>
				<div class="r-preview" aria-hidden="true">
					<img
						src="/reader/hero.png"
						alt="Slax Reader 界面预览"
						loading="eager"
						decoding="async"
					/>
				</div>
			</div>
		</section>

		<!-- FEATURES -->
		<section class="features" id="features">
			<div class="features-inner">
				<div class="features-head">
					<h2 class="features-title">不只是又一个稍后读工具</h2>
					<p class="features-sub">
						我们在做的，是智能阅读的下一个形态。
					</p>
				</div>
				<div class="feat-grid">
					{features.map((f, i) => (
						<div class="feat">
							<div class="feat-num">{String(i + 1).padStart(2, '0')}</div>
							<h3 class="feat-h">{f.title}</h3>
							<p class="feat-p">{f.body}</p>
						</div>
					))}
				</div>
			</div>
		</section>

		<!-- HOW IT WORKS -->
		<section class="how">
			<div class="how-inner">
				<h2 class="how-head">从一次收藏，到一次顿悟。</h2>
				<p class="how-sub">
					四个简单的步骤，改变你的阅读和学习方式。
				</p>
				<div class="how-steps">
					{steps.map((s, i) => (
						<div class="how-step">
							<div class="how-step-num">{String(i + 1).padStart(2, '0')}</div>
							<h3 class="how-step-h">{s.title}</h3>
							<p class="how-step-body">{s.body}</p>
						</div>
					))}
				</div>
			</div>
		</section>

		<!-- COMPARE -->
		<section class="compare">
			<div class="compare-inner">
				<h2 class="compare-head">为什么读者都在转向 Slax</h2>
				<p class="compare-sub">
					看看我们和传统稍后读工具的差距。
				</p>
				<div class="compare-table">
					<div class="compare-row head">
						<div>功能</div>
						<div class="highlight">Slax Reader</div>
						<div>Instapaper</div>
						<div>Readwise</div>
					</div>
					{compareRows.map((row) => (
						<div class="compare-row">
							<div>{row[0]}</div>
							{[1, 2, 3].map((i) => {
								const v = row[i];
								const isHighlight = i === 1;
								let cls = 'cell';
								let content: string = v;
								if (v === 'ok') {
									cls += ' cell-ok';
									content = '●';
								} else if (v === 'no') {
									cls += ' cell-no';
									content = '—';
								} else {
									cls += ' cell-text';
								}
								if (isHighlight) cls += ' highlight';
								return <div class={cls}>{content}</div>;
							})}
						</div>
					))}
				</div>
				<p class="compare-more">
					<a href="/zh-Hans/reader/alternatives/">
						完整对比——Readwise、Omnivore、Cubox 等 →
					</a>
				</p>
			</div>
		</section>

		<!-- PRICING -->
		<section class="pricing" id="pricing">
			<div class="pricing-inner">
				<h2 class="pricing-head">更聪明地阅读，<em>而不仅仅是"稍后"。</em></h2>
				<p class="pricing-dek">
					永久保存，学得更快。属于你的智能图书馆，让阅读更高效、理解更深入。
				</p>
				<a class="pricing-promo" href="https://r.slax.com">
					🎉 今天加入，免费获得 1 个月 Pro
				</a>

				<div class="plans-grid">
					<div class="plan">
						<div class="plan-eyebrow">Free</div>
						<div class="plan-price">
							<span class="num">$0</span><span class="unit">/ 月</span>
						</div>
						<p class="plan-tag">
							无限收藏、永久备份——趁现在没有限制，立刻加入！
						</p>
						<a href="https://r.slax.com" class="btn-primary">免费开始</a>
					</div>
					<div class="plan featured">
						<div class="plan-eyebrow">Pro Reader</div>
						<div class="plan-price">
							<span class="num">$5.99</span><span class="unit">/ 月</span>
							<span class="was">$9.99</span>
						</div>
						<p class="plan-tag">
							接入 AI 分析，把阅读能力推到极限。
						</p>
						<a href="https://r.slax.com" class="btn-primary">免费试用 1 个月</a>
					</div>
				</div>

				<div class="matrix" aria-label="功能对照表">
					<div class="matrix-row head">
						<div class="cell-feat">功能</div>
						<div class="cell">Free</div>
						<div class="cell">Pro Reader</div>
					</div>
					{matrixRows.map((row) => (
						<div class="matrix-row">
							<div class="cell-feat">{row[0]}</div>
							{[1, 2].map((i) => {
								const v = row[i];
								if (v === 'ok') return <div class="cell ok">✓</div>;
								if (v === 'ai') return <div class="cell ai">AI</div>;
								return <div class="cell no">✕</div>;
							})}
						</div>
					))}
				</div>
			</div>
		</section>

		<!-- FAQ -->
		<section class="faq">
			<div class="faq-inner">
				<h2 class="faq-head">常见问题</h2>
				<FaqList items={faqs} />
			</div>
		</section>


		<!-- DOWNLOAD -->
		<DownloadSection platforms={platforms}>
			<Fragment slot="heading">
				Slax Reader——<em>永久保存，读得更聪明。</em>
			</Fragment>
			<Fragment slot="dek">
				免费下载，覆盖你常用的所有平台。
			</Fragment>
		</DownloadSection>

		<!-- FINALE -->
		<section class="finale">
			<div class="finale-inner">
				<h2 class="finale-h">
					今天就开启你的<em>智能</em>阅读之旅
				</h2>
				<p class="finale-p">读得更聪明，学得更快，记得更多。</p>
				<div class="actions actions-center">
					<Button variant="primary" href="https://r.slax.com" arrow>
						开始使用——完全免费
					</Button>
					<Button variant="secondary" href="https://github.com/slax-lab/slax-reader">
						查看源码
					</Button>
				</div>
			</div>
		</section>
	</main>

	<Footer />
</Base>

<style>
	/* HERO */
	.r-hero {
		padding: 6rem 0 5rem;
	}
	.r-hero-inner {
		max-width: 1180px;
		margin: 0 auto;
		padding: 0 2rem;
		display: grid;
		grid-template-columns: 1fr;
		gap: 4rem;
		align-items: center;
	}
	@media (min-width: 960px) {
		.r-hero-inner {
			grid-template-columns: 1.1fr 1fr;
		}
	}
	.r-h1 {
		font-family: var(--serif);
		font-weight: 400;
		font-size: clamp(2rem, 4vw, 3.2rem);
		line-height: 1.1;
		letter-spacing: -0.02em;
		margin: 1rem 0 1.75rem;
		color: var(--ink);
		max-width: 22ch;
	}
	.r-h1 :global(em) {
		font-style: italic;
		font-weight: 300;
		color: var(--accent);
	}
	.r-bullets {
		list-style: none;
		padding: 0;
		margin: 0 0 2.25rem;
		display: flex;
		flex-direction: column;
		gap: 0.75rem;
		max-width: 48ch;
	}
	.r-bullets li {
		position: relative;
		padding-left: 1.5rem;
		font-family: var(--serif);
		font-size: 1.05rem;
		line-height: 1.55;
		color: var(--ink-soft);
	}
	.r-bullets li::before {
		content: "—";
		position: absolute;
		left: 0;
		top: 0;
		color: var(--ink-mute);
		font-weight: 300;
	}
	.r-hero-stores {
		display: flex;
		gap: 0.75rem;
		flex-wrap: wrap;
	}
	.r-web-link {
		margin: 0.9rem 0 0;
		font-family: var(--serif);
		font-size: 0.95rem;
		color: var(--ink-mute);
	}
	.r-web-link a {
		color: var(--ink-soft);
		text-decoration: underline;
		text-decoration-color: var(--rule);
		text-underline-offset: 3px;
		transition: color 0.2s ease, text-decoration-color 0.2s ease;
	}
	.r-web-link a:hover {
		color: var(--accent);
		text-decoration-color: var(--accent);
	}
	.r-store-btn {
		display: inline-flex;
		flex-direction: column;
		align-items: flex-start;
		gap: 0.15rem;
		background: transparent;
		color: var(--ink);
		text-decoration: none;
		padding: 0.7rem 1.2rem;
		border: 1px solid var(--ink);
		transition:
			background 0.2s ease,
			color 0.2s ease;
		min-width: 160px;
	}
	.r-store-btn:hover {
		background: var(--ink);
		color: var(--bg);
	}
	.r-store-btn.is-primary,
	.r-store-btn.is-primary:hover {
		background: var(--accent);
		border-color: var(--accent);
		color: var(--bg);
	}
	.r-store-btn.is-primary .r-store-small,
	.r-store-btn.is-primary:hover .r-store-small {
		color: var(--bg);
		opacity: 0.8;
	}
	.r-store-small {
		font-family: var(--mono);
		font-size: 0.62rem;
		letter-spacing: 0.08em;
		text-transform: uppercase;
		color: var(--ink-mute);
		line-height: 1.2;
	}
	.r-store-btn:hover .r-store-small {
		color: var(--bg);
		opacity: 0.75;
	}
	.r-store-main {
		font-family: var(--serif);
		font-size: 0.98rem;
		font-weight: 500;
		line-height: 1.3;
	}
	.actions {
		display: flex;
		gap: 1rem;
		flex-wrap: wrap;
		align-items: center;
	}
	.actions-center {
		justify-content: center;
	}
	.r-preview {
		display: flex;
		justify-content: center;
	}
	.r-preview img {
		display: block;
		width: 100%;
		height: auto;
		max-width: 480px;
	}

	/* FEATURES */
	.features {
		padding: var(--section-pad) 0;
		border-top: 1px solid var(--rule-soft);
	}
	.features-inner {
		max-width: 1180px;
		margin: 0 auto;
		padding: 0 2rem;
	}
	.features-head {
		margin-bottom: 4rem;
	}
	.features-title {
		font-family: var(--serif);
		font-weight: 400;
		font-size: clamp(1.8rem, 3vw, 2.4rem);
		line-height: 1.15;
		letter-spacing: -0.02em;
		margin: 1rem 0 0.5rem;
	}
	.features-sub {
		font-family: var(--serif);
		font-size: 1.1rem;
		color: var(--ink-soft);
		margin: 0;
		max-width: 44ch;
	}
	.feat-grid {
		display: grid;
		grid-template-columns: 1fr;
		gap: 0;
		border-top: 1px solid var(--rule);
	}
	@media (min-width: 760px) {
		.feat-grid {
			grid-template-columns: 1fr 1fr;
		}
	}
	@media (min-width: 1040px) {
		.feat-grid {
			grid-template-columns: repeat(4, 1fr);
		}
	}
