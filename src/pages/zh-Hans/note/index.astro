const ghostwritingFeatures = [
	{
		title: '选用现成风格，应对不同场景',
		body: '选用内置的风格，包括摘要、推文、赞美等。更多风格陆续推出。',
		video: '/note/videos/choose-ready-made.mp4',
	},
	{
		title: '自定义 prompt，满足个性化需求',
		body: '按照自己的需求和工作流，定制专属的 prompt。',
		video: '/note/videos/customize.mp4',
	},
];

// How are others using Slax Note — 5 real use cases from note.slax.com
const useCases = [
	{
		title: '个人语音备忘',
		body: '走路或开车时，把一闪而过的想法抓住。我们会把你的语音变成清晰可读的文字，不让任何灵光乍现的瞬间溜走。',
	},
	{
		title: '内容创作',
		body: '比以往任何时候都更快、更轻松地写作。把想法说出来，Slax Note 的 AI 几秒钟就能生成漂亮的内容，不用打字。',
	},
	{
		title: '日程整理',
		body: '把待办事项告诉 Slax Note，它会替你整理好日程，把时间留给真正重要的事。',
	},
	{
		title: '会议纪要',
		body: '开会没带电脑时唤起 Slax Note，让它当你的 AI 助手，记录并转写会议摘要。',
	},
	{
		title: '学习笔记',
		body: '你的 AI 学习伙伴。打开 Slax Note 把可能错过的讲座录下来，或者练习一次演讲、让它整理出一份干净的讲稿。',
	},
];

// Real testimonials from note.slax.com — 6 named users
const testimonials = [
	{
		quote:
			'如果你经常要写东西、随时记灵感，我非常推荐 Slax Note。它能把我口头说的内容润色得比平时写出来的还要精准。',
		author: 'Cao Jiang',
		title: '独立内容创作者',
	},
	{
		quote: '这个工具挺优雅的，能帮我养成持续用它记录想法的习惯，对我帮助很大。',
		author: 'Fenng',
		title: '科技博客作者',
	},
	{
		quote:
