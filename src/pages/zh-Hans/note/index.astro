---
import Button from '~/components/Button.astro';
import DownloadSection from '~/components/DownloadSection.astro';
import FaqList from '~/components/FaqList.astro';
import Footer from '~/components/Footer.astro';
import Nav from '~/components/Nav.astro';
import Base from '~/layouts/Base.astro';

// All content below is copied verbatim from note.slax.com (the live
// marketing landing) plus n.slax.com product i18n where relevant.
// Single source of truth: fetched from note.slax.com 2026-04-19.

