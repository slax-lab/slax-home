	},
	{
		q: '音频文件存在哪里？安全吗？',
		a: '所有录音都保存在本地，确保用户的隐私和安全。',
	},
	{
		q: '怎么导出笔记？',
		a: '笔记可以以文字或图片的形式，轻松分享到其他应用。',
	},
	{
		q: '可以离线使用吗？',
		a: '录音功能可以离线使用，但转写需要联网。',
	},
	{
		q: '怎么把内容切换成不同风格？',
		a: '打开 App 开始录音，或者点「文字笔记」输入内容，会进入自动润色页面。在这里，点击右侧的「默认」按钮可以切换不同的写作风格，也可以自由定制你想要的风格。',
	},
	{
		q: 'Slax Note 支持哪些语言的语音识别？',
		a: '目前支持英文、中文、德文、日文等主流语言，未来会陆续加入更多语言。',
	},
];

const schema = {
	'@context': 'https://schema.org',
	'@type': 'SoftwareApplication',
	name: 'Slax Note',
	alternateName: 'Slax Note——AI 语音笔记',
	applicationCategory: 'ProductivityApplication',
	operatingSystem: 'iOS, Android, Web',
	url: 'https://slax.com/note/',
	image: 'https://slax.com/og/note.png',
	screenshot: 'https://slax.com/images/note/cover.png',
	description:
		'AI 语音笔记。你说，我记。用 Slax Note 录音，让 AI 把你的想法抓下来，润色成你想要的任何风格的文字。',
	downloadUrl: [
		'https://apps.apple.com/us/app/slax-note-transcribe-voice-pen/id6480166286',
		'https://play.google.com/store/apps/details?id=app.slax.notes',
	],
	offers: [
		{
			'@type': 'Offer',
			name: 'Free',
			price: '0',
			priceCurrency: 'USD',
		},
		{
			'@type': 'Offer',
			name: 'Premium Monthly',
			price: '4.99',
			priceCurrency: 'USD',
			priceSpecification: {
				'@type': 'UnitPriceSpecification',
				price: '4.99',
				priceCurrency: 'USD',
				billingDuration: 'P1M',
			},
		},
		{
			'@type': 'Offer',
			name: 'Premium Annual',
			price: '49.99',
			priceCurrency: 'USD',
			priceSpecification: {
				'@type': 'UnitPriceSpecification',
				price: '49.99',
				priceCurrency: 'USD',
				billingDuration: 'P1Y',
			},
		},
	],
	publisher: {
		'@type': 'Organization',
		name: 'Starry Tech Pte. Ltd.',
		url: 'https://slax.com',
		logo: 'https://slax.com/images/slax-logo.png',
	},
};
---
<Base
	title="Slax Note——AI 语音笔记。你说，我记。"
	description="你说，我记。一段录音，多种形态——由你选的 prompt 来塑形。陪你一年又一年地成长。"
	ogImage="/og/note.png"
	schema={schema}
>
	<Nav active="note" />

	<main>
		<!-- HERO -->
		<section class="n-hero">
			<div class="n-hero-inner">
				<div>
					<h1 class="n-h1">
						AI 语音笔记。<em>你说，我记。</em>
					</h1>
					<ul class="n-bullets">
						<li>想法一冒出来就把它说出来。不用打字，不用整理。</li>
						<li>一段录音，多种形态——由你选的 prompt 来塑形。</li>
						<li>陪你一年又一年地成长。</li>
					</ul>
					<div class="n-stores">
						<a
							class="store-btn is-primary"
							href="https://apps.apple.com/us/app/slax-note-transcribe-voice-pen/id6480166286"
							target="_blank"
							rel="noopener noreferrer"
						>
							<span class="store-small">下载于</span>
							<span class="store-main">App Store</span>
						</a>
						<a
							class="store-btn"
							href="https://play.google.com/store/apps/details?id=app.slax.notes"
							target="_blank"
							rel="noopener noreferrer"
						>
							<span class="store-small">获取于</span>
							<span class="store-main">Google Play</span>
						</a>
					</div>
					<p class="n-web-link">
						或者<a href="https://n.slax.com/">访问网页版</a>。
					</p>
				</div>
				<div class="n-visual">
					<img
						src="/images/note/cover.png"
						alt="Slax Note——AI 语音笔记"
						class="n-img"
						loading="eager"
					/>
				</div>
			</div>
		</section>

		<!-- EFFICIENCY BOOST -->
		<section class="features" id="features" data-demo-group="efficiency">
			<div class="features-inner">
				<div class="feat-head">
					<h2 class="feat-title">效率提升</h2>
					<p class="feat-sub">把时间留给真正重要的事。</p>
				</div>
				<div class="feat-demo-body">
					<div class="feat-list" role="tablist" aria-label="效率提升功能">
						{efficiencyFeatures.map((f, i) => (
							<button
								class="feat-item"
								type="button"
								role="tab"
								data-idx={i}
								aria-selected={i === 0 ? 'true' : 'false'}
								aria-controls={`efficiency-video-${i}`}
							>
								<div class="feat-item-head">
									<span class="feat-num">{String(i + 1).padStart(2, '0')}</span>
									<h3 class="feat-h">{f.title}</h3>
								</div>
								<p class="feat-p">{f.body}</p>
							</button>
						))}
					</div>
					<div class="feat-stage">
						<div class="feat-frame">
							{efficiencyFeatures.map((f, i) => (
								<video
									id={`efficiency-video-${i}`}
									class="feat-video"
									data-idx={i}
									src={f.video}
									muted
									loop
									playsinline
									preload={i === 0 ? 'auto' : 'metadata'}
									aria-hidden={i === 0 ? 'false' : 'true'}
								></video>
							))}
						</div>
					</div>
				</div>
			</div>
		</section>

		<!-- INTELLIGENT GHOSTWRITING -->
		<section class="features features-alt" data-demo-group="ghostwriting">
			<div class="features-inner">
				<div class="feat-head">
					<h2 class="feat-title">智能代笔</h2>
					<p class="feat-sub">让 AI 轻松把你的文字打磨好。</p>
				</div>
				<div class="feat-demo-body feat-demo-body--reverse">
					<div class="feat-stage">
						<div class="feat-frame">
							{ghostwritingFeatures.map((f, i) => (
								<video
									id={`ghostwriting-video-${i}`}
									class="feat-video"
									data-idx={i}
									src={f.video}
									muted
									loop
									playsinline
									preload="metadata"
									aria-hidden={i === 0 ? 'false' : 'true'}
								></video>
							))}
						</div>
					</div>
					<div class="feat-list" role="tablist" aria-label="智能代笔功能">
						{ghostwritingFeatures.map((f, i) => (
							<button
								class="feat-item"
								type="button"
								role="tab"
								data-idx={i}
								aria-selected={i === 0 ? 'true' : 'false'}
								aria-controls={`ghostwriting-video-${i}`}
							>
								<div class="feat-item-head">
									<span class="feat-num">{String(i + 1).padStart(2, '0')}</span>
									<h3 class="feat-h">{f.title}</h3>
								</div>
								<p class="feat-p">{f.body}</p>
							</button>
						))}
					</div>
				</div>
			</div>
		</section>

		<!-- USE CASES -->
		<section class="usecases">
			<div class="usecases-inner">
				<h2 class="usecases-head">别人是怎么用 Slax Note 的</h2>
				<div class="uc-grid">
					{useCases.map((uc) => (
						<div class="uc">
							<h3 class="uc-h">{uc.title}</h3>
							<p class="uc-p">{uc.body}</p>
						</div>
					))}
				</div>
			</div>
		</section>

		<!-- TESTIMONIALS -->
		<section class="testimonials">
			<div class="testimonials-inner">
				<h2 class="t-head">数千用户的喜爱之选</h2>
				<p class="t-sub">
					准备好改变你的记笔记方式了吗？现在就来用 Slax Note。
				</p>
				<div class="t-grid">
					{testimonials.map((t) => (
						<figure class="testimonial">
							<blockquote class="t-quote">「{t.quote}」</blockquote>
							<figcaption class="t-caption">
								<span class="t-author">{t.author}</span>
								<span class="t-title">{t.title}</span>
							</figcaption>
						</figure>
					))}
				</div>
			</div>
		</section>

		<!-- PRICING -->
		<section class="pricing" id="pricing">
			<div class="pricing-inner">
				<h2 class="pricing-head">价格</h2>
				<p class="pricing-dek">享受早鸟价格，把套餐升级一下。</p>

				<div class="plans-grid plans-grid-3">
					<!-- FREE -->
					<div class="plan">
						<div class="plan-eyebrow">Free</div>
						<div class="plan-price">
							<span class="num">$0</span>
						</div>
						<p class="plan-note">终身免费。</p>
						<ul class="plan-list">
							<li><span class="plan-feat-label">语音笔记</span><span class="plan-feat-value">5 条</span></li>
							<li><span class="plan-feat-label">AI 润色</span><span class="plan-feat-value">总共 10 次</span></li>
							<li><span class="plan-feat-label">录音时长</span><span class="plan-feat-value">5 分钟</span></li>
						</ul>
						<a href="https://n.slax.com/" class="btn-primary">先来试试</a>
					</div>

					<!-- PREMIUM — MONTHLY -->
					<div class="plan">
						<div class="plan-eyebrow">Monthly</div>
						<div class="plan-price">
							<span class="num">$4.99</span><span class="unit">/ 月</span>
						</div>
						<p class="plan-note">随时取消。</p>
						<ul class="plan-list">
							<li><span class="plan-feat-label">语音笔记</span><span class="plan-feat-value">无限</span></li>
							<li><span class="plan-feat-label">AI 润色</span><span class="plan-feat-value">每天 300 次</span></li>
							<li><span class="plan-feat-label">录音时长</span><span class="plan-feat-value">30 分钟</span></li>
							<li><span class="plan-feat-label">润色质量</span><span class="plan-feat-value">高级版</span></li>
						</ul>
						<div class="plan-actions">
							<a
								class="btn-primary"
								href="https://apps.apple.com/us/app/slax-note-transcribe-voice-pen/id6480166286"
								target="_blank"
								rel="noopener noreferrer"
							>
								App Store
							</a>
							<a
								class="btn-primary btn-primary-outline"
								href="https://play.google.com/store/apps/details?id=app.slax.notes"
								target="_blank"
								rel="noopener noreferrer"
							>
								Google Play
							</a>
						</div>
					</div>

					<!-- PREMIUM — ANNUAL -->
					<div class="plan featured">
						<div class="plan-eyebrow">
							Annual <span class="plan-badge">省 2 个月</span>
						</div>
						<div class="plan-price">
							<span class="num">$49.99</span><span class="unit">/ 年</span>
						</div>
						<p class="plan-note">折合 $4.16 / 月。随时取消。</p>
						<ul class="plan-list">
							<li><span class="plan-feat-label">语音笔记</span><span class="plan-feat-value">无限</span></li>
							<li><span class="plan-feat-label">AI 润色</span><span class="plan-feat-value">每天 300 次</span></li>
							<li><span class="plan-feat-label">录音时长</span><span class="plan-feat-value">30 分钟</span></li>
							<li><span class="plan-feat-label">润色质量</span><span class="plan-feat-value">高级版</span></li>
						</ul>
						<div class="plan-actions">
							<a
								class="btn-primary"
								href="https://apps.apple.com/us/app/slax-note-transcribe-voice-pen/id6480166286"
								target="_blank"
								rel="noopener noreferrer"
							>
								App Store
							</a>
							<a
								class="btn-primary btn-primary-outline"
								href="https://play.google.com/store/apps/details?id=app.slax.notes"
								target="_blank"
								rel="noopener noreferrer"
							>
								Google Play
							</a>
						</div>
					</div>
				</div>
			</div>
		</section>

		<!-- FAQ -->
		<section class="faq">
			<div class="faq-inner">
				<h2 class="faq-head">常见问题</h2>
				<p class="faq-sub">
					还有其他问题或建议，欢迎在
					<a href="https://discord.gg/kznNsZvWSk">Discord</a> 上联系我们，或者发邮件到
					<a href="mailto:note@slax.com">note@slax.com</a>。
				</p>
				<FaqList items={faqs} />
			</div>
		</section>

		<!-- DOWNLOAD -->
		<DownloadSection platforms={notePlatforms}>
			<Fragment slot="heading">
				Slax Note——<em>你的声音，轻松成稿。</em>
			</Fragment>
			<Fragment slot="dek">
				免费下载，iOS 和 Android 都能用。
			</Fragment>
		</DownloadSection>

		<!-- FINALE -->
		<section class="finale">
			<div class="finale-inner">
				<h2 class="finale-h">记录每一个<em>灵感</em>。</h2>
				<p class="finale-p">
					免费下载，支持 iPhone、Android 和网页。
				</p>
				<div class="actions actions-center">
					<Button variant="primary" href="https://n.slax.com/" arrow>打开 Slax Note</Button>
					<Button variant="secondary" href="#pricing">查看价格</Button>
				</div>
			</div>
		</section>
	</main>

	<Footer />
</Base>

<style>
	/* HERO */
	.n-hero {
		padding: 6rem 0 5rem;
	}
	.n-hero-inner {
		max-width: 1180px;
