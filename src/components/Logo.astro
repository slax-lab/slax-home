---
interface Props {
	size?: number;
	class?: string;
}

const { size = 28, class: className = '' } = Astro.props;
---
<img
	src="/images/slax-logo.png"
	alt="Slax"
	width={size}
	height={size}
	class:list={['slax-logo', className]}
	loading="eager"
	decoding="async"
/>

<style>
	.slax-logo {
		flex-shrink: 0;
		display: block;
	}
</style>
