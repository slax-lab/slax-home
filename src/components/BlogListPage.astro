---
import type { CollectionEntry } from 'astro:content';
import Footer from '~/components/Footer.astro';
import Nav from '~/components/Nav.astro';
import { t } from '~/i18n';
import type { Locale } from '~/i18n/locales';
import Base from '~/layouts/Base.astro';
import { entrySlug } from '~/lib/content';
import { withLocale } from '~/lib/hreflang';

interface Props {
	posts: CollectionEntry<'blog'>[];
	lang: Locale;
	/** Optional product filter active highlight (reader/note for /reader/blog/ etc.) */
	productScope?: 'reader' | 'note';
	titleKey: 'meta.blogTitle' | 'meta.readerBlogTitle' | 'meta.noteBlogTitle';
	ogImage?: string;
}

const {
	posts,
	lang,
	productScope,
	titleKey,
	ogImage = '/og/blog.png',
} = Astro.props;

const dateFmt = new Intl.DateTimeFormat(lang, {
	year: 'numeric',
	month: 'long',
	day: 'numeric',
});

const blogPath = withLocale('/blog/', lang);

const productLabel = (product: 'reader' | 'note' | 'slax') => {
	if (product === 'reader') return 'Slax Reader';
	if (product === 'note') return 'Slax Note';
	return 'Slax';
};

const breadcrumbs = [
	{ name: t(lang, 'nav.brand'), url: lang === 'en' ? '/' : `/${lang}/` },
	{ name: t(lang, titleKey), url: blogPath },
];

const blogSchema = {
	'@context': 'https://schema.org',
	'@type': 'Blog',
	name: t(lang, titleKey),
	url: new URL(blogPath, 'https://www.slax.com').toString(),
	description: t(lang, 'meta.defaultDescription'),
	blogPost: posts.map((post) => ({
		'@type': 'BlogPosting',
		headline: post.data.title,
		description: post.data.description,
		datePublished: post.data.pubDate.toISOString(),
		dateModified: (post.data.updatedDate ?? post.data.pubDate).toISOString(),
		url: new URL(
			`${blogPath}${entrySlug(post)}/`,
			'https://www.slax.com',
		).toString(),
		author: { '@type': 'Organization', name: 'Slax Lab' },
	})),
};

const activeNav = productScope ?? 'blog';
---
<Base
	title={`${t(lang, titleKey)} — Slax`}
	description={t(lang, 'meta.defaultDescription')}
	ogImage={ogImage}
	schema={blogSchema}
	breadcrumbs={breadcrumbs}
	lang={lang}
>
	<Nav active={activeNav} />
	<main class="blog-index">
		<header class="head">
			<h1>{t(lang, titleKey)}</h1>
		</header>

		{posts.length === 0 ? (
			<p class="empty">{t(lang, 'home.comingSoon')} <a href="/blog/">www.slax.com/blog/</a>.</p>
		) : (
			<ul class="post-list">
				{posts.map((post) => (
					<li class="post-item">
						<a href={`${blogPath}${entrySlug(post)}/`} class="post-link">
							<time datetime={post.data.pubDate.toISOString()}>
								{dateFmt.format(post.data.pubDate)}
							</time>
							<div class="post-body">
								<span class={`post-product post-product-${post.data.product}`}>
									{productLabel(post.data.product)}
								</span>
								<h2>{post.data.title}</h2>
								<p>{post.data.description}</p>
								<span class="post-cta">
									{t(lang, 'common.readMore')} <span class="arrow">→</span>
								</span>
							</div>
						</a>
					</li>
				))}
			</ul>
		)}
	</main>
	<Footer />
</Base>

<style>
	.blog-index {
		max-width: 860px;
		margin: 0 auto;
		padding: 5rem 2rem 4rem;
	}
	.head {
		margin-bottom: 4rem;
		padding-bottom: 2.5rem;
		border-bottom: 1px solid var(--rule);
	}
	h1 {
		font-family: var(--serif);
		font-weight: 500;
		font-size: clamp(1.9rem, 3vw, 2.5rem);
		line-height: 1.15;
		letter-spacing: -0.02em;
		margin: 0;
	}
	.empty {
		font-family: var(--serif);
		font-size: 1.05rem;
		color: var(--ink-soft);
		padding: 3rem 0;
		max-width: 50ch;
	}
	.empty a {
		color: var(--accent);
		text-decoration: none;
		border-bottom: 1px solid var(--rule);
	}
	.post-list {
		list-style: none;
		padding: 0;
		margin: 0;
	}
	.post-item {
		border-bottom: 1px solid var(--rule-soft);
	}
	.post-item:last-child {
		border-bottom: none;
	}
	.post-link {
		display: grid;
		grid-template-columns: 1fr;
		gap: 0.4rem;
		padding: 2.25rem 0;
		text-decoration: none;
		color: inherit;
		transition: padding-left 0.25s ease;
	}
	@media (min-width: 760px) {
		.post-link {
			grid-template-columns: 160px 1fr;
			gap: 3rem;
			align-items: baseline;
		}
	}
	.post-link:hover {
		padding-left: 0.5rem;
	}
	.post-link time {
		font-family: var(--mono);
		font-size: 0.76rem;
		letter-spacing: 0.12em;
		text-transform: uppercase;
		color: var(--ink-mute);
		padding-top: 0.15rem;
	}
	.post-product {
		display: inline-block;
		font-family: var(--mono);
		font-size: 0.68rem;
		letter-spacing: 0.12em;
		text-transform: uppercase;
		color: var(--ink-mute);
		margin-bottom: 0.6rem;
	}
	.post-product-reader,
	.post-product-note {
		color: var(--accent);
	}
	.post-body h2 {
		font-family: var(--serif);
		font-weight: 500;
		font-size: 1.35rem;
		line-height: 1.25;
		letter-spacing: -0.01em;
		margin: 0 0 0.5rem;
		color: var(--ink);
		transition: color 0.2s;
	}
	.post-link:hover .post-body h2 {
		color: var(--accent);
	}
	.post-body p {
		font-family: var(--serif);
		font-size: 1rem;
		line-height: 1.55;
		color: var(--ink-soft);
		margin: 0 0 0.75rem;
		max-width: 60ch;
	}
	.post-cta {
		font-family: var(--mono);
		font-size: 0.72rem;
		letter-spacing: 0.12em;
		text-transform: uppercase;
		color: var(--ink-mute);
		display: inline-flex;
		align-items: center;
		gap: 0.3rem;
		transition: color 0.2s;
	}
	.post-link:hover .post-cta {
		color: var(--accent);
	}
	.post-cta .arrow {
		transition: transform 0.25s ease;
	}
	.post-link:hover .post-cta .arrow {
		transform: translateX(3px);
	}
</style>
