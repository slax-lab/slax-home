---
interface Props {
	href: string;
	productNumber: string;
	badge?: string;
	ctaText: string;
	ctaArrow?: boolean;
	features: string[];
}

const {
	href,
	productNumber,
	badge,
	ctaText,
	ctaArrow = true,
	features,
} = Astro.props;
---
<a href={href} class="product">
	{badge && <span class="badge">{badge}</span>}
	<div class="product-num">{productNumber}</div>
	<h3 class="product-name"><slot name="name" /></h3>
	<p class="product-desc"><slot name="description" /></p>
	<ul class="product-feats">
		{features.map((feature) => (
			<li>{feature}</li>
		))}
	</ul>
	<span class="product-cta">
		{ctaText}
		{ctaArrow && <span class="arrow">→</span>}
	</span>
</a>

<style>
	.product {
		background: var(--bg-deep);
		border: 1px solid var(--rule);
		padding: 3rem 2.5rem 2.5rem;
		display: flex;
		flex-direction: column;
		min-height: 460px;
		text-decoration: none;
		color: inherit;
		transition:
			border-color 0.2s,
			transform 0.2s,
			background 0.2s;
		position: relative;
	}
	.product:hover {
		border-color: var(--accent);
		transform: translateY(-2px);
		background: var(--bg-deeper);
	}
	.product-num {
		font-family: var(--mono);
		font-size: 0.7rem;
		letter-spacing: 0.2em;
		color: var(--ink-mute);
		margin-bottom: 2rem;
	}
	.product-name {
		font-family: var(--serif);
		font-weight: 400;
		font-size: 2.2rem;
		letter-spacing: -0.02em;
		line-height: 1.05;
		margin: 0 0 1.25rem;
	}
	.product-name :global(em) {
		color: var(--accent);
		font-style: italic;
		font-weight: 300;
	}
	.product-desc {
		font-family: var(--serif);
		font-size: 1.1rem;
		line-height: 1.5;
		color: var(--ink-soft);
		margin: 0 0 2rem;
		max-width: 32ch;
	}
	.product-feats {
		list-style: none;
		padding: 0;
		margin: 0 0 2.5rem;
		display: grid;
		gap: 0.6rem;
		font-size: 0.9rem;
		color: var(--ink-soft);
	}
	.product-feats li {
		display: flex;
		align-items: baseline;
		gap: 0.75rem;
	}
	.product-feats li::before {
		content: "—";
		color: var(--ink-mute);
		flex-shrink: 0;
	}
	.product-cta {
		margin-top: auto;
		font-size: 0.95rem;
		display: inline-flex;
		align-items: center;
		gap: 0.4rem;
		color: var(--ink);
		align-self: flex-start;
	}
	.product-cta .arrow {
		transition: transform 0.2s;
	}
	.product:hover .product-cta .arrow {
		transform: translateX(4px);
	}
	.badge {
		position: absolute;
		top: 2rem;
		right: 2rem;
		font-family: var(--mono);
		font-size: 0.68rem;
		letter-spacing: 0.15em;
		text-transform: uppercase;
		color: var(--ink-mute);
		padding: 0.25rem 0.6rem;
		border: 1px solid var(--rule);
		border-radius: 999px;
	}
</style>
