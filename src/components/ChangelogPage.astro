---
import { type CollectionEntry, render } from 'astro:content';
import Footer from '~/components/Footer.astro';
import Nav from '~/components/Nav.astro';
import { t } from '~/i18n';
import type { Locale } from '~/i18n/locales';
import Base from '~/layouts/Base.astro';
import { withLocale } from '~/lib/hreflang';

type ReaderPlatform = 'iOS' | 'Android' | 'Web' | 'Extensions';
type NotePlatform = 'iOS' | 'Android';

type AnyEntry =
	| CollectionEntry<'readerChangelog'>
	| CollectionEntry<'noteChangelog'>;

interface Props {
	entries: AnyEntry[];
	lang: Locale;
	product: 'reader' | 'note';
	titleKey: 'meta.readerChangelogTitle' | 'meta.noteChangelogTitle';
	ogImage: string;
}

const { entries, lang, product, titleKey, ogImage } = Astro.props;

// Render each MDX entry so we can interleave Content components into groups.
const rendered = await Promise.all(
	entries.map(async (e) => {
		const { Content } = await render(e);
		return { ...e, Content };
	}),
);

const platformOrder: Array<ReaderPlatform | NotePlatform> =
	product === 'reader'
		? ['iOS', 'Android', 'Web', 'Extensions']
		: ['iOS', 'Android'];

type Platform = (typeof platformOrder)[number];

type SubEntry = {
	platforms: Platform[];
	Content: (typeof rendered)[number]['Content'];
};

type Group = {
	version: string;
	date: Date;
	platforms: Platform[];
	subs: SubEntry[];
};

// Group by (version + ISO date). Same-day, same-version multi-file entries
// (eg. shared iOS + Android release notes vs. iOS-only delta) collapse into
// one card with per-platform sub-sections.
const groups = new Map<string, Group>();
for (const e of rendered) {
	const platforms = e.data.platforms as Platform[];
	const key = `${e.data.version}|${e.data.date.toISOString().slice(0, 10)}`;
	const existing = groups.get(key);
	if (existing) {
		existing.subs.push({ platforms, Content: e.Content });
		for (const p of platforms) {
			if (!existing.platforms.includes(p)) existing.platforms.push(p);
		}
	} else {
		groups.set(key, {
			version: e.data.version,
			date: e.data.date,
			platforms: [...platforms],
			subs: [{ platforms, Content: e.Content }],
		});
	}
}

const sortPlatforms = (ps: Platform[]) =>
	platformOrder.filter((p) => ps.includes(p)) as Platform[];

const ordered = Array.from(groups.values())
	.map((g) => ({ ...g, platforms: sortPlatforms(g.platforms) }))
	.sort((a, b) => b.date.getTime() - a.date.getTime());

const platformLabel = (ps: Platform[]) => sortPlatforms(ps).join(' · ');

const dateFmt = new Intl.DateTimeFormat(lang, {
	year: 'numeric',
	month: 'long',
	day: 'numeric',
	timeZone: 'UTC',
});
const prettyDate = (d: Date) => dateFmt.format(d);

const latest = ordered[0];
// zh typography uses full-width punctuation in the lede sentence
const [ledeComma, ledePeriod] = lang.startsWith('zh')
	? ['，', '。']
	: [', ', '.'];

const releaseAnchor = (g: { version: string; date: Date }) =>
	`v${g.version}-${g.date.toISOString().slice(0, 10)}`;

const productLabel = product === 'reader' ? 'Slax Reader' : 'Slax Note';
const changelogPath = withLocale(`/${product}/changelog/`, lang);
const englishChangelogPath = `/${product}/changelog/`;

const breadcrumbs = [
	{ name: t(lang, 'nav.brand'), url: lang === 'en' ? '/' : `/${lang}/` },
	{ name: productLabel, url: withLocale(`/${product}/`, lang) },
	{ name: t(lang, titleKey), url: changelogPath },
];

const itemListSchema = {
	'@context': 'https://schema.org',
	'@type': 'ItemList',
	name: t(lang, titleKey),
	url: new URL(changelogPath, 'https://www.slax.com').toString(),
	itemListOrder: 'https://schema.org/ItemListOrderDescending',
	numberOfItems: ordered.length,
	itemListElement: ordered.map((g, i) => ({
		'@type': 'ListItem',
		position: i + 1,
		item: {
			'@type': 'TechArticle',
			headline: `${productLabel} v${g.version}`,
			datePublished: g.date.toISOString(),
			url: `${new URL(changelogPath, 'https://www.slax.com').toString()}#${releaseAnchor(g)}`,
			about: productLabel,
		},
	})),
};

const description = latest
	? `${productLabel} — ${ordered.length} ${t(lang, 'common.version').toLowerCase()}.`
	: t(lang, 'meta.defaultDescription');
---
<Base
	title={t(lang, titleKey)}
	description={description}
	ogImage={ogImage}
	schema={itemListSchema}
	breadcrumbs={breadcrumbs}
	lang={lang}
>
	<Nav active={product} />
	<main class="changelog">
		<header class="changelog__head">
			<p class="changelog__eyebrow">{productLabel} · {t(lang, titleKey)}</p>
			<h1>{t(lang, 'changelog.headline')}</h1>
			{latest && (
				<p class="changelog__lede">
					{t(lang, 'changelog.latestIs')} <strong>v{latest.version}</strong>{ledeComma}{t(lang, 'changelog.shippedOn')} {prettyDate(latest.date)}{ledePeriod}
				</p>
			)}
		</header>

		{ordered.length === 0 ? (
			<p class="empty">
				{t(lang, 'changelog.emptyState')} <a href={englishChangelogPath}>www.slax.com{englishChangelogPath}</a>.
			</p>
		) : (
			<section class="changelog__list">
				{ordered.map((g) => (
					<article class="release" id={releaseAnchor(g)}>
						<div class="release__meta">
							<h2 class="release__version">
								<a class="release__anchor" href={`#${releaseAnchor(g)}`} aria-label={`Permalink to v${g.version}`}>v{g.version}</a>
							</h2>
							<p class="release__date">{prettyDate(g.date)}</p>
							<p class="release__platform">{platformLabel(g.platforms)}</p>
						</div>
						<div class="release__notes">
							{g.subs.length === 1 ? (
								<g.subs[0].Content />
							) : (
								g.subs.map((s) => (
									<div class="release__sub">
										<h3 class="release__sub-label">{platformLabel(s.platforms)}</h3>
										<s.Content />
									</div>
								))
							)}
						</div>
					</article>
				))}
			</section>
		)}
	</main>
	<Footer />
</Base>

<style>
	.changelog { max-width: 920px; margin: 0 auto; padding: 7rem 2rem 6rem; }
	.changelog__head {
		border-bottom: 1px solid var(--rule);
		padding-bottom: 2.75rem;
		margin-bottom: 3.5rem;
	}
	.changelog__eyebrow {
		font-family: var(--mono);
		font-size: 0.82rem;
		letter-spacing: 0.04em;
		color: var(--ink-mute);
		margin: 0 0 1.25rem;
	}
	.changelog__head h1 {
		font-family: var(--serif);
		font-weight: 400;
		font-size: clamp(2rem, 3.8vw, 3rem);
		line-height: 1.15;
		letter-spacing: -0.02em;
		margin: 0 0 1.25rem;
		color: var(--ink);
	}
	.changelog__lede {
		font-family: var(--serif);
		font-size: 1.12rem;
		line-height: 1.6;
		color: var(--ink-soft);
		margin: 0;
		max-width: 54ch;
	}
	.changelog__lede strong { font-weight: 500; color: var(--ink); }
	.empty {
		font-family: var(--serif);
		font-size: 1.05rem;
		color: var(--ink-soft);
		padding: 3rem 0;
		max-width: 50ch;
	}
	.empty a {
		color: var(--accent);
		text-decoration: none;
		border-bottom: 1px solid var(--rule);
	}
	.changelog__list { display: flex; flex-direction: column; }
	.release {
		display: grid;
		grid-template-columns: 1fr;
		gap: 1rem;
		padding: 2rem 0;
		border-bottom: 1px solid var(--rule-soft);
		scroll-margin-top: 5rem;
	}
	.release__anchor { color: inherit; text-decoration: none; }
	.release__anchor:hover { color: var(--accent); }
	@media (min-width: 760px) {
		.release {
			grid-template-columns: 14rem 1fr;
			gap: 3rem;
			padding: 2.5rem 0;
		}
	}
	.release__meta { display: flex; flex-direction: column; gap: 0.25rem; }
	.release__version {
		font-family: var(--serif);
		font-weight: 500;
		font-size: 1.55rem;
		line-height: 1.15;
		letter-spacing: -0.015em;
		color: var(--ink);
		margin: 0;
	}
	.release__date {
		font-family: var(--mono);
		font-size: 0.78rem;
		letter-spacing: 0.06em;
		color: var(--ink-mute);
		margin: 0;
	}
	.release__platform {
		font-family: var(--mono);
		font-size: 0.78rem;
		letter-spacing: 0.04em;
		color: var(--accent);
		margin: 0;
	}
	.release__notes :global(ul) {
		margin: 0;
		padding-left: 1.1rem;
		display: flex;
		flex-direction: column;
		gap: 0.55rem;
	}
	.release__notes :global(li) {
		font-family: var(--serif);
		font-size: 1.02rem;
		line-height: 1.6;
		color: var(--ink-soft);
	}
	.release__notes :global(li::marker) { color: var(--ink-mute); }
	.release__sub + .release__sub { margin-top: 1.25rem; }
	.release__sub-label {
		font-family: var(--mono);
		font-size: 0.78rem;
		letter-spacing: 0.04em;
		color: var(--ink-mute);
		margin: 0 0 0.55rem;
	}
</style>
