---
import Logo from '~/components/Logo.astro';

interface Props {
	version?: string;
	lastUpdated?: string;
}

const { version = '0.9.2', lastUpdated = '04/19/26' } = Astro.props;
---
<footer class="footer">
	<div class="footer-inner">
		<div>
			<a href="/" class="brand">
				<Logo size={26} />
				Slax
			</a>
			<p class="footer-colophon">Simple tools, relax life.</p>
		</div>
		<div>
			<h4>Products</h4>
			<ul>
				<li><a href="/reader/">Slax Reader</a></li>
				<li><a href="/note/">Slax Note</a></li>
			</ul>
		</div>
		<div>
			<h4>Read</h4>
			<ul>
				<li><a href="/blog/">Blog</a></li>
				<li><a href="/reader/alternatives/">Compare Reader</a></li>
				<li><a href="/note/alternatives/">Compare Note</a></li>
				<li><a href="/reader/changelog/">Reader Changelog</a></li>
				<li><a href="/note/changelog/">Note Changelog</a></li>
			</ul>
		</div>
		<div>
			<h4>Company</h4>
			<ul>
				<li><a href="/about/">About</a></li>
				<li><a href="/privacy/">Privacy</a></li>
				<li><a href="/terms/">Terms</a></li>
			</ul>
		</div>
		<div class="footer-meta">
			<span>© 2026 Slax Lab</span>
			<span>v{version} · Last updated {lastUpdated}</span>
		</div>
	</div>
</footer>
