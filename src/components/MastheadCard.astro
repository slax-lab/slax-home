---
interface Entry {
	label: string;
	value: string;
	href?: string;
}

interface Props {
	title?: string;
	entries: Entry[];
}

const { title = 'At a glance', entries } = Astro.props;
---
<aside class="masthead" aria-label={title}>
	<div class="masthead-title">{title}</div>
	<dl>
		{entries.map((entry) => (
			<Fragment>
				<dt>{entry.label}</dt>
				<dd>
					{entry.href ? <a href={entry.href}>{entry.value}</a> : entry.value}
				</dd>
			</Fragment>
		))}
	</dl>
</aside>

<style>
	.masthead {
		border: 1px solid var(--rule);
		background: var(--bg-deep);
		padding: 2rem;
		font-family: var(--mono);
		font-size: 0.8rem;
		line-height: 1.7;
		color: var(--ink-soft);
	}
	.masthead-title {
		font-family: var(--mono);
		font-size: 0.7rem;
		letter-spacing: 0.2em;
		text-transform: uppercase;
		color: var(--ink-mute);
		margin-bottom: 1.2rem;
		padding-bottom: 0.8rem;
		border-bottom: 1px solid var(--rule);
	}
	dl {
		margin: 0;
		display: grid;
		grid-template-columns: auto 1fr;
		gap: 0.4rem 1.2rem;
	}
	dt {
		color: var(--ink-mute);
	}
	dd {
		margin: 0;
		color: var(--ink);
	}
	dd a {
		color: inherit;
		text-decoration: none;
		border-bottom: 1px dotted var(--ink-mute);
	}
</style>
