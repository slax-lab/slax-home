---
import interLatin from '@fontsource-variable/inter/files/inter-latin-wght-normal.woff2?url';
import jetbrainsMonoLatin from '@fontsource-variable/jetbrains-mono/files/jetbrains-mono-latin-wght-normal.woff2?url';
import sourceSerifLatin from '@fontsource-variable/source-serif-4/files/source-serif-4-latin-wght-normal.woff2?url';
import '@fontsource-variable/inter';
import '@fontsource-variable/source-serif-4';
import '@fontsource-variable/jetbrains-mono';
import '~/styles/tokens.css';
import '~/styles/global.css';

import {
	DEFAULT_LOCALE,
	HTML_LANG,
	LOCALES,
	type Locale,
	OG_LOCALE,
} from '~/i18n/locales';
import {
	buildAlternates,
	buildCanonical,
	detectLocale,
	SITE,
} from '~/lib/hreflang';

interface Crumb {
	name: string;
	url: string;
}

interface Props {
	title?: string;
	description?: string;
	ogImage?: string;
	ogType?: 'website' | 'article';
	schema?: object | object[];
	breadcrumbs?: Crumb[];
	/** Page locale. If omitted, inferred from URL path. */
	lang?: Locale;
	/** Locales that actually have a translation of this page. Defaults to all LOCALES (use for static pages). */
	availableLocales?: readonly Locale[];
	/** Emit <meta name="robots" content="noindex"> — use for 404, search results, etc. */
	noindex?: boolean;
}

const inferredLocale = detectLocale(Astro.url.pathname);

const {
	title = 'Slax — Reading & writing, taken seriously',
	description = 'Slax makes a reader and a notebook for the work of paying attention. Slow software, made for long-form.',
	ogImage = '/og-default.png',
	ogType = 'website',
	schema,
	breadcrumbs,
	lang = inferredLocale,
	availableLocales = LOCALES,
	noindex = false,
} = Astro.props;

const htmlLang = HTML_LANG[lang];
const canonical = buildCanonical(
	Astro.url.pathname,
	Astro.site?.toString() ?? SITE,
);

// 404 pages shouldn't broadcast hreflang — they aren't indexable.
const isErrorPage =
	Astro.url.pathname.endsWith('/404/') || Astro.url.pathname.endsWith('/404');
const alternates = isErrorPage
	? []
	: buildAlternates(
			Astro.url.pathname,
			availableLocales,
			Astro.site?.toString() ?? SITE,
		);

const defaultSiteSchema = {
	'@context': 'https://schema.org',
	'@type': 'WebSite',
	name: 'Slax',
	url: SITE,
	inLanguage: htmlLang,
	publisher: {
		'@type': 'Organization',
		name: 'Slax Lab',
		url: SITE,
		logo: new URL('/favicon.svg', SITE).toString(),
	},
};

const breadcrumbSchema =
	breadcrumbs && breadcrumbs.length > 0
		? {
				'@context': 'https://schema.org',
				'@type': 'BreadcrumbList',
				itemListElement: breadcrumbs.map((b, i) => ({
					'@type': 'ListItem',
					position: i + 1,
					name: b.name,
					item: new URL(b.url, Astro.site).toString(),
				})),
			}
		: null;

const extraSchemas: object[] = [];
if (breadcrumbSchema) extraSchemas.push(breadcrumbSchema);
if (schema) {
	if (Array.isArray(schema)) extraSchemas.push(...schema);
	else extraSchemas.push(schema);
}

// Schema.org only defines `inLanguage` on CreativeWork and its subtypes.
// Adding it to ItemList/Organization/Offer/etc. trips strict validators.
const INLANGUAGE_TYPES = new Set([
	'Article',
	'Blog',
	'BlogPosting',
	'CreativeWork',
	'NewsArticle',
	'SoftwareApplication',
	'TechArticle',
	'WebPage',
	'WebSite',
]);

const enrichedExtras = extraSchemas.map((s) => {
	if (typeof s !== 'object' || s === null) return s;
	if ('inLanguage' in s) return s;
	const type = (s as { '@type'?: unknown })['@type'];
	if (typeof type !== 'string' || !INLANGUAGE_TYPES.has(type)) return s;
	return { ...s, inLanguage: htmlLang };
});

const schemaList = [defaultSiteSchema, ...enrichedExtras];

const isDefaultLocale = lang === DEFAULT_LOCALE;
---
<!doctype html>
<html lang={htmlLang}>
<head>
<meta charset="utf-8" />
<meta name="viewport" content="width=device-width, initial-scale=1" />
<link rel="preload" as="font" type="font/woff2" href={sourceSerifLatin} crossorigin />
<link rel="preload" as="font" type="font/woff2" href={interLatin} crossorigin />
<link rel="preload" as="font" type="font/woff2" href={jetbrainsMonoLatin} crossorigin />
<title>{title}</title>
<meta name="description" content={description} />
{noindex && <meta name="robots" content="noindex, nofollow" />}
<link rel="canonical" href={canonical} />
{alternates.map((a) => (
	<link rel="alternate" hreflang={a.hreflang} href={a.href} />
))}
<meta property="og:title" content={title} />
<meta property="og:description" content={description} />
<meta property="og:type" content={ogType} />
<meta property="og:site_name" content="Slax" />
<meta property="og:url" content={canonical} />
<meta property="og:locale" content={OG_LOCALE[lang]} />
<meta property="og:image" content={new URL(ogImage, Astro.site).toString()} />
<meta property="og:image:type" content={ogImage.endsWith('.png') ? 'image/png' : ogImage.endsWith('.jpg') || ogImage.endsWith('.jpeg') ? 'image/jpeg' : 'image/png'} />
<meta property="og:image:width" content="1200" />
<meta property="og:image:height" content="630" />
<meta property="og:image:alt" content={title} />
<meta name="twitter:card" content="summary_large_image" />
<meta name="twitter:title" content={title} />
<meta name="twitter:description" content={description} />
<meta name="twitter:image" content={new URL(ogImage, Astro.site).toString()} />
<meta name="twitter:image:alt" content={title} />
<link rel="icon" type="image/png" href="/images/slax-logo.png" sizes="any" />
<link rel="apple-touch-icon" href="/images/slax-logo.png" />
{isDefaultLocale && (
	<link rel="alternate" type="application/rss+xml" title="Slax Blog" href="/rss.xml" />
)}
{schemaList.map((s) => (
	<script type="application/ld+json" set:html={JSON.stringify(s)} />
))}
</head>
<body data-density="airy" data-locale={lang}>
<slot />
</body>
</html>
