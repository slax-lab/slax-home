---
// SlaxHomeHero — Three-state hero that switches on product card hover.
// State 0 (default): Slax portal, centered gradient text
// State 1 (reader):  Ported from reader-home HomeHero.astro
// State 2 (note):    Ported from note.slax.com hero
---

<section class="shh">

  <!-- ═══════════════════════════════════════
       HERO AREA — three stacked panels
  ════════════════════════════════════════ -->
  <div class="shh__hero-wrap">

    <!-- DEFAULT: Slax portal -->
    <div class="shh__panel shh__panel--default is-active" data-panel="default">
      <div class="shh__default-inner">
        <h1 class="shh__default-title">Your AI Productivity Suite</h1>
        <p class="shh__default-tagline">Read smarter. Write better. Stay organized.</p>
      </div>
    </div>

    <!-- READER: Ported from HomeHero.astro -->
    <div class="shh__panel shh__panel--reader" data-panel="reader">
      <div class="shh__reader-inner">
        <div class="shh__reader-text">
          <h2 class="shh__reader-title">Read Smarter<br />Not Just Later</h2>
          <p class="shh__reader-sub">
            Save Forever, Learn faster. Your intelligent library for high efficiency and deep understanding.
          </p>
          <a class="shh__reader-cta" href="https://r.slax.com/login">
            <span>Start Reading Smarter — Free</span>
            <span aria-hidden="true">→</span>
          </a>
          <div class="shh__reader-trust">
            <span>🔒 Your content, forever safe</span>
            <span>🚀 5× faster understanding</span>
            <span>⭐ Interactive reading community</span>
          </div>
        </div>

        <div class="shh__reader-visual">
          <div class="shh__reader-preview">
            <div class="shh__reader-card">
              <h4>🤖 AI Analysis</h4>
              <p>
                This article explains how knowledge workers can build a permanent reading
                library. Key points:<br />1. Save content before it disappears.<br />2. Use AI
                to summarize and surface key ideas.<br />3. Turn reading into reusable knowledge.
              </p>
            </div>
            <div class="shh__reader-card">
              <h4>💬 Ask AI</h4>
              <p>
                <strong>You:</strong> "What should I remember from this article?"<br />
                <strong>AI:</strong> "Focus on the permanent archive, AI-assisted understanding,
                and collaboration layer. Those are the main reasons users switch."
              </p>
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- NOTE: Ported from note.slax.com hero -->
    <div class="shh__panel shh__panel--note" data-panel="note">
      <div class="shh__note-inner">
        <div class="shh__note-text">
          <h2 class="shh__note-title">
            Your AI-powered<br />voice notes.<br />
            <span class="shh__note-accent">Turn voice into text</span><br />in seconds.
          </h2>
          <p class="shh__note-sub">
            Record with Slax Note on the go. Let AI capture and refine your thoughts into
            various text styles. Never lose an idea.
          </p>
          <div class="shh__note-stores">
            <a
              class="shh__store-btn"
              href="https://apps.apple.com/us/app/slax-note-transcribe-voice-pen/id6480166286"
              target="_blank"
              rel="noopener noreferrer"
            >
              <svg class="shh__store-icon" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                <path d="M18.71 19.5c-.83 1.24-1.71 2.45-3.05 2.47-1.34.03-1.77-.79-3.29-.79-1.53 0-2 .77-3.27.82-1.31.05-2.3-1.32-3.14-2.53C4.25 17 2.94 12.45 4.7 9.39c.87-1.52 2.43-2.48 4.12-2.51 1.28-.02 2.5.87 3.29.87.78 0 2.26-1.07 3.8-.91.65.03 2.47.26 3.64 1.98-.09.06-2.17 1.28-2.15 3.81.03 3.02 2.65 4.03 2.68 4.04-.03.07-.42 1.44-1.38 2.83M13 3.5c.73-.83 1.94-1.46 2.94-1.5.13 1.17-.34 2.35-1.04 3.19-.69.85-1.83 1.51-2.95 1.42-.15-1.15.41-2.35 1.05-3.11z"/>
              </svg>
              <div class="shh__store-text">
                <span class="shh__store-small">Download on the</span>
                <span class="shh__store-main">App Store</span>
              </div>
            </a>
            <a
              class="shh__store-btn"
              href="https://play.google.com/store/apps/details?id=app.slax.notes"
              target="_blank"
              rel="noopener noreferrer"
            >
              <svg class="shh__store-icon" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                <path d="M3.18 23.76c.3.17.64.24.99.2L14.64 12 11 8.36 3.18 23.76zM20.9 10.49l-2.8-1.6-3.6 3.11 3.6 3.12 2.82-1.62c.8-.46.8-1.54-.02-2.01zM2.01 1.05C1.7 1.4 1.5 1.9 1.5 2.53v18.94c0 .63.2 1.13.52 1.48L2.13 23 13.06 12 2.13 1 2.01 1.05zM14.64 12L3.18.24c-.35-.04-.69.03-.99.2l7.82 15.4L14.64 12z"/>
              </svg>
              <div class="shh__store-text">
                <span class="shh__store-small">GET IT ON</span>
                <span class="shh__store-main">Google Play</span>
              </div>
            </a>
          </div>
        </div>

        <div class="shh__note-visual">
          <img
            src="/images/note-hero.png"
            alt="Slax Note — voice to text app"
            class="shh__note-img"
            loading="eager"
          />
        </div>
      </div>
    </div>

  </div><!-- /shh__hero-wrap -->

  <!-- ═══════════════════════════════════════
       PRODUCT CARDS
  ════════════════════════════════════════ -->
  <div class="shh__cards">
    <a
      class="shh__card shh__card--reader"
      href="/reader/"
      data-trigger="reader"
    >
      <div class="shh__card-header">
        <img src="/images/reader-logo-new.png" alt="Slax Reader" class="shh__card-logo" />
        <span class="shh__card-name">Slax Reader</span>
      </div>
      <p class="shh__card-desc">
        Save, organize, and annotate articles from across the web. Built for deep reading and
        effortless knowledge capture.
      </p>
      <span class="shh__card-cta">Explore Reader →</span>
    </a>

    <a
      class="shh__card shh__card--note"
      href="https://note.slax.com/"
      target="_blank"
      rel="noopener noreferrer"
      data-trigger="note"
    >
      <div class="shh__card-header">
        <img src="/images/note-logo-new.png" alt="Slax Note" class="shh__card-logo" />
        <span class="shh__card-name">Slax Note</span>
      </div>
      <p class="shh__card-desc">
        Capture ideas, connect thoughts, and build your personal knowledge base with a beautiful
        writing experience.
      </p>
      <span class="shh__card-cta">Explore Note →</span>
    </a>
  </div>

</section>

<!-- ═══════════════════════════════════════
     JS — hover triggers hero switch
════════════════════════════════════════ -->
<script>
  const section  = document.querySelector<HTMLElement>('.shh');
  const panels   = document.querySelectorAll<HTMLElement>('[data-panel]');
  const triggers = document.querySelectorAll<HTMLElement>('[data-trigger]');

  function activate(state: string) {
    panels.forEach((p) => p.classList.toggle('is-active', p.dataset.panel === state));
    triggers.forEach((t) => t.classList.toggle('is-hovered', t.dataset.trigger === state));
  }

  // Switch hero when hovering a card
  triggers.forEach((trigger) => {
    trigger.addEventListener('mouseenter', () => activate(trigger.dataset.trigger!));
    // Keyboard / touch accessibility
    trigger.addEventListener('focus', () => activate(trigger.dataset.trigger!));
    trigger.addEventListener('blur',  () => activate('default'));
  });

  // Only reset to default when the mouse leaves the ENTIRE section —
  // so moving up into the hero panel keeps it alive for clicking.
  section?.addEventListener('mouseleave', () => activate('default'));
</script>

<style>
  /* ═══════════════════════════════════
     Product top nav (below Starlight header)
  ══════════════════════════════════ */
  .shh__topnav {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
    padding: 8px 24px;
    background: #ffffff;
    border-bottom: 1px solid rgba(0, 0, 0, 0.06);
  }

  .shh__topnav-item {
    display: inline-flex;
    align-items: center;
    gap: 7px;
    padding: 5px 14px;
    border-radius: 8px;
    text-decoration: none;
    font-size: 0.875rem;
    font-weight: 600;
    color: var(--sl-color-gray-2, #555);
    transition: background 0.2s ease, color 0.2s ease;
  }

  .shh__topnav-item:hover {
    background: color-mix(in srgb, var(--sl-color-accent) 10%, transparent);
    color: var(--sl-color-accent);
  }

  .shh__topnav-logo {
    width: 20px;
    height: 20px;
    border-radius: 5px;
    object-fit: cover;
    flex-shrink: 0;
  }

  /* ═══════════════════════════════════
     Card logo
  ══════════════════════════════════ */
  .shh__card-logo {
    width: 22px;
    height: 22px;
    border-radius: 6px;
    object-fit: cover;
    flex-shrink: 0;
    border: none;
    box-shadow: 0 1px 4px rgba(0,0,0,0.12);
  }

  /* ═══════════════════════════════════
     Kill Starlight's auto-rendered title h1 and its container.
     Using :global() here is more reliable than head <style> injection
     because Astro guarantees this loads with the component.
  ══════════════════════════════════ */
  :global(h1#_top) {
    display: none !important;
  }

  :global(.main-pane > .content-panel:first-child) {
    display: none !important;
  }

  /* Zero out all content-panel chrome so the hero touches the nav */
  :global(.content-panel) {
    padding-block: 0 !important;
    border-top: none !important;
    margin: 0 !important;
  }

  :global(.sl-markdown-content) {
    max-width: 100% !important;
    width: 100% !important;
    margin: 0 !important;
    padding: 0 !important;
  }

  /* ═══════════════════════════════════
     Layout shell
  ══════════════════════════════════ */
  .shh {
    width: 100%;
    /* Break out of any residual sl-container constraints */
    margin-inline: calc(-1 * var(--sl-content-pad-x, 0px));
    font-family: var(--sl-font);
  }

  /* ═══════════════════════════════════
     Hero wrap — panels stack via grid
  ══════════════════════════════════ */
  .shh__hero-wrap {
    display: grid;
    grid-template-areas: 'hero';
    min-height: 420px;
  }

  .shh__panel {
    grid-area: hero;
    display: flex;
    align-items: center;
    opacity: 0;
    transform: translateY(14px);
    transition:
      opacity 0.42s cubic-bezier(0.22, 1, 0.36, 1),
      transform 0.42s cubic-bezier(0.22, 1, 0.36, 1);
    pointer-events: none;
  }

  .shh__panel.is-active {
    opacity: 1;
    transform: translateY(0);
    pointer-events: auto;
  }

  /* ═══════════════════════════════════
     DEFAULT panel
  ══════════════════════════════════ */
  .shh__panel--default {
    /* Larger radial gradient — covers roughly 40% of panel from top-left */
    background:
      radial-gradient(ellipse 130% 100% at -5% -5%, #cff0e8 0%, transparent 52%),
      #ffffff;
    justify-content: center;
  }

  .shh__default-inner {
    text-align: center;
    padding: 72px 24px 56px;
    max-width: 700px;
    margin: 0 auto;
  }

  .shh__default-title {
    /* Match original landing.css sizing */
    font-size: clamp(2.5rem, 5vw + 1rem, 3.5rem) !important;
    font-weight: 800 !important;
    line-height: 1.15 !important;
    margin: 0 0 16px !important;
    white-space: nowrap;
    /* Force gradient text — !important beats Starlight's h1 color */
    background: linear-gradient(135deg, #16b998 0%, #4ecacd 60%, #16b998 100%) !important;
    -webkit-background-clip: text !important;
    -webkit-text-fill-color: transparent !important;
    background-clip: text !important;
    background-size: 200% 200% !important;
    animation: gradient-shift 6s ease infinite !important;
    /* Reset any Starlight h1 overrides */
    color: transparent !important;
  }

  .shh__default-tagline {
    font-size: clamp(1.05rem, 2vw + 0.25rem, 1.25rem);
    color: #4a6b66;
    margin: 0;
    max-width: 42ch;
    margin-inline: auto;
  }

  @keyframes gradient-shift {
    0%, 100% { background-position: 0% 50%; }
    50%       { background-position: 100% 50%; }
  }

  /* ═══════════════════════════════════
     READER panel
  ══════════════════════════════════ */
  .shh__panel--reader {
    background: linear-gradient(135deg, #f8fffc 0%, #e6fff3 100%);
  }

  .shh__reader-inner {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 48px;
    align-items: center;
    width: 100%;
    max-width: 1200px;
    margin: 0 auto;
    padding: 64px 40px 56px;
  }

  .shh__reader-title {
    font-size: clamp(2rem, 4vw + 0.5rem, 3.2rem);
    font-weight: 800;
    line-height: 1.1;
    color: #1f1f1f;
    margin: 0 0 20px;
  }

  .shh__reader-sub {
    font-size: 1.05rem;
    line-height: 1.7;
    color: #333;
    margin: 0 0 28px;
    max-width: 34rem;
  }

  .shh__reader-cta {
    display: inline-flex;
    align-items: center;
    gap: 12px;
    min-height: 52px;
    padding: 0 28px;
    border-radius: 6px;
    background: linear-gradient(135deg, #25d4b0 0%, #1cb0b5 50%, #16b998 100%);
    color: #fff;
    text-decoration: none;
    font-size: 0.95rem;
    font-weight: 700;
    box-shadow: 0 30px 60px 0 rgba(0,0,0,0.08);
    transition: transform 0.2s ease, box-shadow 0.2s ease;
  }

  .shh__reader-cta:hover {
    transform: translateY(-2px);
    box-shadow: 0 30px 60px 0 rgba(22,185,152,0.18);
  }

  .shh__reader-trust {
    display: flex;
    flex-wrap: wrap;
    gap: 12px 20px;
    margin-top: 20px;
    color: #666;
    font-size: 0.88rem;
  }

  /* AI card panel */
  .shh__reader-visual {
    display: flex;
    justify-content: center;
  }

  .shh__reader-preview {
    width: 100%;
    max-width: 480px;
    padding: 28px;
    border-radius: 12px;
    background: #fff;
    box-shadow: 0 30px 60px 0 rgba(0,0,0,0.08);
    transform: perspective(1000px) rotateY(-8deg);
  }

  .shh__reader-card {
    padding: 20px;
    border-radius: 10px;
    background: #f8f9fa;
  }

  .shh__reader-card + .shh__reader-card {
    margin-top: 14px;
  }

  .shh__reader-card h4 {
    margin: 0 0 10px;
    color: #16b998;
    font-size: 0.95rem;
    font-weight: 700;
  }

  .shh__reader-card p {
    margin: 0;
    color: #333;
    line-height: 1.65;
    font-size: 0.88rem;
  }

  /* ═══════════════════════════════════════
     NOTE panel
  ══════════════════════════════════ */
  .shh__panel--note {
    background: linear-gradient(160deg, #e8fdf9 0%, #f0fffe 40%, #f8fffe 70%, #fff 100%);
  }

  .shh__note-inner {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 48px;
    align-items: center;
    width: 100%;
    max-width: 1200px;
    margin: 0 auto;
    padding: 56px 40px 48px;
  }

  .shh__note-title {
    font-size: clamp(2rem, 3.5vw + 0.5rem, 3rem);
    font-weight: 800;
    line-height: 1.2;
    color: #0a2c2c;
    margin: 0 0 20px;
  }

  .shh__note-accent {
    color: #16b998;
  }

  .shh__note-sub {
    font-size: 1rem;
    line-height: 1.7;
    color: #4a6b68;
    margin: 0 0 32px;
    max-width: 38ch;
  }

  /* App store buttons */
  .shh__note-stores {
    display: flex;
    gap: 12px;
    flex-wrap: wrap;
  }

  .shh__store-btn {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    background: #111;
    color: #fff;
    text-decoration: none;
    padding: 11px 18px;
    border-radius: 10px;
    border: 1.5px solid rgba(255,255,255,0.1);
    transition: background 0.2s ease, transform 0.2s ease;
    min-width: 140px;
  }

  .shh__store-btn:hover {
    background: #222;
    transform: translateY(-1px);
  }

  .shh__store-icon {
    width: 24px;
    height: 24px;
    flex-shrink: 0;
  }

  .shh__store-text {
    display: flex;
    flex-direction: column;
  }

  .shh__store-small {
    font-size: 0.62rem;
    opacity: 0.72;
    line-height: 1.2;
    letter-spacing: 0.01em;
  }

  .shh__store-main {
    font-size: 0.88rem;
    font-weight: 700;
    line-height: 1.3;
  }

  /* Note hero image */
  .shh__note-visual {
    display: flex;
    justify-content: center;
    align-items: center;
  }

  .shh__note-img {
    width: 100%;
    max-width: 480px;
    height: auto;
    display: block;
    border: none;
    outline: none;
    box-shadow: none;
    filter: drop-shadow(0 20px 48px rgba(41,189,178,0.18));
    animation: float 6s ease-in-out infinite;
  }

  @keyframes float {
    0%, 100% { transform: translateY(0); }
    50%       { transform: translateY(-10px); }
  }

  /* ═══════════════════════════════════
     PRODUCT CARDS — constrained to 1200px like reader homepage
  ══════════════════════════════════ */
  .shh__cards {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 16px;
    /* Centered, max-width matches reader homepage content width */
    max-width: 1200px;
    width: 100%;
    margin-inline: auto;
    padding: 20px 40px 40px;
    background: #fff;
  }

  .shh__card {
    display: flex;
    flex-direction: column;
    gap: 6px;
    padding: 20px 22px;
    border-radius: 12px;
    border: 1.5px solid transparent;
    text-decoration: none;
    background: #f9f9f9;
    transition:
      background 0.3s cubic-bezier(0.22, 1, 0.36, 1),
      border-color 0.3s cubic-bezier(0.22, 1, 0.36, 1),
      transform 0.3s cubic-bezier(0.22, 1, 0.36, 1),
      box-shadow 0.3s cubic-bezier(0.22, 1, 0.36, 1);
    position: relative;
  }

  /* Gradient bottom-border reveal on hover */
  .shh__card::after {
    content: '';
    position: absolute;
    bottom: 0;
    left: 1rem;
    right: 1rem;
    height: 3px;
    border-radius: 3px 3px 0 0;
    opacity: 0;
    transform: scaleX(0);
    transition: opacity 0.3s ease, transform 0.3s ease;
  }

  .shh__card--reader::after {
    background: linear-gradient(90deg, #16b998, #4ecacd);
  }

  .shh__card--note::after {
    background: linear-gradient(90deg, #4ecacd, #29bdb2);
  }

  .shh__card:hover,
  .shh__card.is-hovered {
    transform: translateY(-4px);
  }

  .shh__card--reader:hover,
  .shh__card--reader.is-hovered {
    background: #F1FFF9;
    border-color: #a3ede0;
    box-shadow: 0 12px 32px rgba(22,185,152,0.12);
  }

  .shh__card--note:hover,
  .shh__card--note.is-hovered {
    background: #EFFEFC;
    border-color: #C3F7F3;
    box-shadow: 0 12px 32px rgba(78,202,205,0.12);
  }

  .shh__card:hover::after,
  .shh__card.is-hovered::after {
    opacity: 1;
    transform: scaleX(1);
  }

  .shh__card-header {
    display: flex;
    align-items: center;
    gap: 8px;
  }

  .shh__card-icon {
    font-size: 1.1rem;
  }

  .shh__card-name {
    font-size: 0.95rem;
    font-weight: 700;
  }

  .shh__card--reader .shh__card-name { color: #16b998; }
  .shh__card--note  .shh__card-name { color: #4ecacd; }

  .shh__card-desc {
    font-size: 0.82rem;
    color: #666;
    line-height: 1.55;
    margin: 0;
  }

  .shh__card-cta {
    margin-top: 6px;
    font-size: 0.78rem;
    font-weight: 600;
    color: #fff;
    padding: 5px 12px;
    border-radius: 6px;
    align-self: flex-start;
  }

  .shh__card--reader .shh__card-cta { background: #16b998; }
  .shh__card--note  .shh__card-cta { background: #4ecacd; }

  /* ═══════════════════════════════════
     Responsive
  ══════════════════════════════════ */
  @media (max-width: 900px) {
    .shh__reader-inner,
    .shh__note-inner {
      grid-template-columns: 1fr;
      padding: 40px 24px 32px;
    }

    .shh__reader-preview {
      transform: none;
    }

    .shh__note-img {
      height: 200px;
      margin: 0 auto;
    }

    .shh__cards {
      grid-template-columns: 1fr;
      padding: 16px 20px 24px;
    }

    .shh__hero-wrap {
      min-height: 320px;
    }
  }

  /* ═══════════════════════════════════
     Reduced motion
  ══════════════════════════════════ */
  @media (prefers-reduced-motion: reduce) {
    .shh__panel {
      transition: opacity 0.2s ease;
      transform: none !important;
    }

    .shh__default-title { animation: none; }
    .shh__note-img { animation: none; }
  }
</style>
