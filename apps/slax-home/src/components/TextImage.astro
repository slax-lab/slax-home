---
/**
 * TextImage — Foxi-inspired alternating text + image highlight rows.
 * Each row shows text on one side and an image on the other, alternating direction.
 */
interface Props {
	title: string;
	description: string;
	/** Image URL */
	image: string;
	/** Image alt text */
	imageAlt?: string;
	/** Image placement relative to text */
	imagePosition?: 'left' | 'right';
}

const { title, description, image, imageAlt = '', imagePosition = 'right' } = Astro.props;
---

<div class:list={['text-image not-content', `text-image--img-${imagePosition}`]}>
	<div class="text-image__content">
		<h3 class="text-image__title" set:html={title} />
		<p class="text-image__desc">{description}</p>
		<slot />
	</div>
	<div class="text-image__media">
		<img src={image} alt={imageAlt} loading="lazy" decoding="async" />
	</div>
</div>

<style>
	@keyframes text-image-enter {
		from {
			opacity: 0;
			transform: translateY(2rem);
		}
		to {
			opacity: 1;
			transform: translateY(0);
		}
	}

	.text-image {
		display: flex;
		flex-direction: column;
		gap: 2rem;
		align-items: center;
		padding-block: 2.5rem;
		opacity: 0;
		animation: text-image-enter 0.7s cubic-bezier(0.22, 1, 0.36, 1) 0.1s forwards;
	}

	.text-image + .text-image {
		border-top: 1px solid var(--sl-color-gray-5);
	}

	@media (min-width: 50rem) {
		.text-image {
			flex-direction: row;
			gap: 3rem;
		}

		.text-image--img-left {
			flex-direction: row-reverse;
		}
	}

	/* Content */
	.text-image__content {
		flex: 1;
		display: flex;
		flex-direction: column;
		gap: 0.75rem;
	}

	.text-image__title {
		font-size: clamp(1.25rem, 2vw + 0.5rem, 1.75rem);
		font-weight: 700;
		line-height: 1.25;
		margin: 0;
		color: var(--sl-color-white);
	}

	.text-image__title :global(strong) {
		color: var(--sl-color-accent);
	}

	.text-image__desc {
		font-size: 1.05rem;
		color: var(--sl-color-gray-2);
		line-height: 1.65;
		margin: 0;
	}

	/* Media */
	.text-image__media {
		flex: 1;
		display: flex;
		align-items: center;
		justify-content: center;
	}

	.text-image__media img {
		width: 100%;
		max-width: 28rem;
		height: auto;
		border-radius: 0.75rem;
		border: 1px solid var(--sl-color-gray-5);
		box-shadow: 0 8px 32px color-mix(in srgb, var(--sl-color-accent) 6%, transparent);
		transition: transform 0.4s cubic-bezier(0.22, 1, 0.36, 1), box-shadow 0.4s ease;
	}

	.text-image:hover .text-image__media img {
		transform: translateY(-4px);
		box-shadow: 0 16px 48px color-mix(in srgb, var(--sl-color-accent) 12%, transparent);
	}

	@media (prefers-reduced-motion: reduce) {
		.text-image {
			animation: none;
			opacity: 1;
		}
	}
</style>
