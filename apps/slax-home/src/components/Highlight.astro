---
/**
 * Highlight — Foxi-inspired inline text highlight component.
 * Supports colored text, filled background, rotated background, and gradient text.
 */
interface Props {
	/** Highlight type:
	 *  'color' — accent-colored text
	 *  'fill'  — white text on accent background
	 *  'tilt'  — white text on tilted accent background
	 *  'gradient' — gradient text
	 */
	type?: 'color' | 'fill' | 'tilt' | 'gradient';
}

const { type = 'color' } = Astro.props;
---

<span class:list={['highlight', `highlight--${type}`]}>
	<slot />
</span>

<style>
	.highlight {
		display: inline;
		position: relative;
	}

	/* Type 1: Simple colored text */
	.highlight--color {
		color: var(--sl-color-accent);
		font-weight: 600;
	}

	/* Type 2: Filled background */
	.highlight--fill {
		color: var(--sl-color-black);
		background: var(--sl-color-accent);
		padding-inline: 0.4em;
		border-radius: 0.25em;
		font-weight: 600;
	}

	/* Type 3: Tilted background */
	.highlight--tilt {
		color: var(--sl-color-black);
		padding-inline: 0.4em;
		position: relative;
		z-index: 0;
		font-weight: 600;
	}

	.highlight--tilt::before {
		content: '';
		position: absolute;
		inset: -0.1em -0.15em;
		background: var(--sl-color-accent);
		border-radius: 0.25em;
		transform: rotate(-1.5deg);
		z-index: -1;
	}

	/* Type 4: Gradient text */
	.highlight--gradient {
		background: linear-gradient(
			135deg,
			var(--sl-color-accent),
			var(--sl-color-accent-high)
		);
		-webkit-background-clip: text;
		-webkit-text-fill-color: transparent;
		background-clip: text;
		font-weight: 700;
	}
</style>
