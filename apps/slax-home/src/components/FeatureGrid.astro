---
/**
 * FeatureGrid — Foxi-inspired responsive grid wrapper for FeatureCard components.
 * Supports 2, 3, or 4 columns with staggered entrance animations.
 */
interface Props {
	title?: string;
	description?: string;
	/** Number of columns on desktop: 2, 3, or 4 */
	columns?: 2 | 3 | 4;
}

const { title, description, columns = 4 } = Astro.props;
---

<section class="feature-section not-content">
	{(title || description) && (
		<div class="feature-section__header">
			{title && <h2 class="feature-section__title" set:html={title} />}
			{description && <p class="feature-section__desc">{description}</p>}
		</div>
	)}
	<div class:list={['feature-grid', `feature-grid--cols-${columns}`]}>
		<slot />
	</div>
</section>

<style>
	@keyframes feature-enter {
		from {
			opacity: 0;
			transform: translateY(1.5rem);
		}
		to {
			opacity: 1;
			transform: translateY(0);
		}
	}

	.feature-section {
		margin-block: 3rem 2rem;
	}

	.feature-section__header {
		text-align: center;
		max-width: 42rem;
		margin-inline: auto;
		margin-bottom: 2.5rem;
	}

	.feature-section__title {
		font-size: var(--sl-text-h2);
		font-weight: 700;
		line-height: var(--sl-line-height-headings);
		margin: 0 0 1rem;
		background: linear-gradient(
			135deg,
			var(--sl-color-accent-high) 0%,
			var(--sl-color-accent) 50%,
			var(--sl-color-accent-high) 100%
		);
		-webkit-background-clip: text;
		-webkit-text-fill-color: transparent;
		background-clip: text;
	}

	.feature-section__title :global(strong) {
		font-weight: inherit;
		-webkit-text-fill-color: var(--sl-color-white);
	}

	.feature-section__desc {
		font-size: 1.1rem;
		color: var(--sl-color-gray-2);
		line-height: 1.65;
		margin: 0;
	}

	/* Grid */
	.feature-grid {
		display: grid;
		gap: 1.25rem;
	}

	.feature-grid--cols-2 { grid-template-columns: 1fr; }
	.feature-grid--cols-3 { grid-template-columns: 1fr; }
	.feature-grid--cols-4 { grid-template-columns: 1fr; }

	@media (min-width: 36rem) {
		.feature-grid--cols-2 { grid-template-columns: repeat(2, 1fr); }
		.feature-grid--cols-3 { grid-template-columns: repeat(2, 1fr); }
		.feature-grid--cols-4 { grid-template-columns: repeat(2, 1fr); }
	}

	@media (min-width: 60rem) {
		.feature-grid--cols-3 { grid-template-columns: repeat(3, 1fr); }
		.feature-grid--cols-4 { grid-template-columns: repeat(4, 1fr); }
	}

	/* Staggered entrance animation */
	.feature-grid > :global(*) {
		opacity: 0;
		animation: feature-enter 0.6s cubic-bezier(0.22, 1, 0.36, 1) forwards;
	}

	.feature-grid > :global(*:nth-child(1)) { animation-delay: 0.05s; }
	.feature-grid > :global(*:nth-child(2)) { animation-delay: 0.12s; }
	.feature-grid > :global(*:nth-child(3)) { animation-delay: 0.19s; }
	.feature-grid > :global(*:nth-child(4)) { animation-delay: 0.26s; }
	.feature-grid > :global(*:nth-child(5)) { animation-delay: 0.33s; }
	.feature-grid > :global(*:nth-child(6)) { animation-delay: 0.40s; }
	.feature-grid > :global(*:nth-child(7)) { animation-delay: 0.47s; }
	.feature-grid > :global(*:nth-child(8)) { animation-delay: 0.54s; }

	@media (prefers-reduced-motion: reduce) {
		.feature-grid > :global(*) {
			animation: none;
			opacity: 1;
		}
	}
</style>
