---
// ContactPage — Slax Home 联系页
// 主题色：#16b998 / #4ecacd，阴影：0 30px 60px 0 rgba(0,0,0,0.08)
---

<div class="cp">

  <!-- Hero -->
  <header class="cp__hero">
    <h1 class="cp__title">Contact Us</h1>
    <p class="cp__sub">
      We're a small team building Slax with care. Whether you have a question,
      a bug report, or just want to say hi — we'd love to hear from you.
    </p>
  </header>

  <!-- 联系方式卡片 -->
  <section class="cp__methods">

    <a class="cp__card" href="mailto:support@slax.com">
      <div class="cp__card-icon">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <rect x="2" y="4" width="20" height="16" rx="2"/>
          <path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/>
        </svg>
      </div>
      <div class="cp__card-body">
        <h2 class="cp__card-title">Email</h2>
        <p class="cp__card-desc">Best for general questions and support</p>
        <span class="cp__card-link">support@slax.com</span>
      </div>
      <span class="cp__card-arrow" aria-hidden="true">→</span>
    </a>

    <a class="cp__card" href="https://github.com/slax-lab/slax-reader" target="_blank" rel="noopener noreferrer">
      <div class="cp__card-icon">
        <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
          <path d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0022 12.017C22 6.484 17.522 2 12 2z"/>
        </svg>
      </div>
      <div class="cp__card-body">
        <h2 class="cp__card-title">GitHub</h2>
        <p class="cp__card-desc">Best for bug reports and feature requests</p>
        <span class="cp__card-link">slax-lab/slax-reader</span>
      </div>
      <span class="cp__card-arrow" aria-hidden="true">→</span>
    </a>

  </section>

  <!-- CTA -->
  <section class="cp__cta">
    <h2 class="cp__cta-title">Start Your Intelligent Reading Journey</h2>
    <p class="cp__cta-sub">Free to get started. No credit card required.</p>
    <a class="cp__cta-btn" href="https://r.slax.com/login">
      Get Started — It's Free
      <span aria-hidden="true">→</span>
    </a>
  </section>

</div>

<style>
  /* ── Layout shell ── */
  .cp {
    width: 100%;
    max-width: 860px;
    margin-inline: auto;
    padding: 64px 40px 80px;
    font-family: var(--sl-font);
  }

  /* ── Hero ── */
  .cp__hero {
    text-align: center;
    margin-bottom: 56px;
  }

  .cp__title {
    font-size: clamp(2rem, 4vw + 0.5rem, 3rem);
    font-weight: 800;
    line-height: 1.15;
    margin: 0 0 16px !important;
    background: linear-gradient(135deg, #16b998 0%, #4ecacd 60%, #16b998 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    background-size: 200% 200%;
    animation: gradient-shift 6s ease infinite;
  }

  .cp__sub {
    font-size: 1.05rem;
    line-height: 1.7;
    color: #4a6b68;
    max-width: 52ch;
    margin: 0 auto;
  }

  @keyframes gradient-shift {
    0%, 100% { background-position: 0% 50%; }
    50%       { background-position: 100% 50%; }
  }

  /* ── Contact cards ── */
  .cp__methods {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 20px;
    margin-bottom: 64px;
  }

  .cp__card {
    display: flex;
    align-items: flex-start;
    gap: 18px;
    padding: 28px 24px;
    border-radius: 14px;
    border: 1.5px solid #e8f5f3;
    background: #fafffe;
    text-decoration: none;
    color: inherit;
    box-shadow: 0 30px 60px 0 rgba(0, 0, 0, 0.06);
    transition:
      transform 0.25s cubic-bezier(0.22, 1, 0.36, 1),
      box-shadow 0.25s cubic-bezier(0.22, 1, 0.36, 1),
      border-color 0.25s ease;
    position: relative;
  }

  .cp__card:hover {
    transform: translateY(-4px);
    border-color: #a3ede0;
    box-shadow: 0 20px 48px rgba(22, 185, 152, 0.14);
  }

  .cp__card-icon {
    flex-shrink: 0;
    width: 44px;
    height: 44px;
    border-radius: 10px;
    background: linear-gradient(135deg, #e6fff5 0%, #d0faf0 100%);
    display: flex;
    align-items: center;
    justify-content: center;
    color: #16b998;
  }

  .cp__card-icon svg {
    width: 22px;
    height: 22px;
  }

  .cp__card-body {
    flex: 1;
    min-width: 0;
  }

  .cp__card-title {
    font-size: 1rem;
    font-weight: 700;
    color: #1a1a1a;
    margin: 0 0 4px !important;
    border: none !important;
    padding: 0 !important;
  }

  .cp__card-desc {
    font-size: 0.82rem;
    color: #888;
    margin: 0 0 10px;
    line-height: 1.5;
  }

  .cp__card-link {
    font-size: 0.88rem;
    font-weight: 600;
    color: #16b998;
  }

  .cp__card-arrow {
    flex-shrink: 0;
    font-size: 1.1rem;
    color: #cce8e4;
    align-self: center;
    transition: transform 0.2s ease, color 0.2s ease;
  }

  .cp__card:hover .cp__card-arrow {
    transform: translateX(4px);
    color: #16b998;
  }

  /* ── CTA ── */
  .cp__cta {
    text-align: center;
    padding: 48px 40px;
    border-radius: 16px;
    background: linear-gradient(135deg, #edfff8 0%, #d8fff5 50%, #e8fff9 100%);
    border: 1.5px solid #b8ede4;
  }

  .cp__cta-title {
    font-size: clamp(1.4rem, 3vw + 0.3rem, 2rem);
    font-weight: 800;
    color: #0a2c2c;
    margin: 0 0 12px !important;
    border: none !important;
    padding: 0 !important;
  }

  .cp__cta-sub {
    font-size: 1rem;
    color: #4a6b68;
    margin: 0 0 28px;
  }

  .cp__cta-btn {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    padding: 14px 32px;
    border-radius: 8px;
    background: linear-gradient(135deg, #25d4b0 0%, #1cb0b5 50%, #16b998 100%);
    color: #fff;
    text-decoration: none;
    font-size: 0.95rem;
    font-weight: 700;
    box-shadow: 0 8px 24px rgba(22, 185, 152, 0.28);
    transition: transform 0.2s ease, box-shadow 0.2s ease;
  }

  .cp__cta-btn:hover {
    transform: translateY(-2px);
    box-shadow: 0 12px 32px rgba(22, 185, 152, 0.38);
  }

  /* ── Responsive ── */
  @media (max-width: 640px) {
    .cp {
      padding: 40px 20px 56px;
    }

    .cp__methods {
      grid-template-columns: 1fr;
    }

    .cp__cta {
      padding: 36px 24px;
    }
  }

  /* ── Reduced motion ── */
  @media (prefers-reduced-motion: reduce) {
    .cp__title { animation: none; }
  }
</style>
