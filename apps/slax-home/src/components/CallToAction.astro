---
/**
 * CallToAction — Foxi-inspired CTA banner with gradient background, glow, and entrance animation.
 * Supports light and dark modes with optional background pattern.
 */
interface Props {
	title: string;
	description: string;
	/** Primary button text */
	primaryText?: string;
	/** Primary button link */
	primaryLink?: string;
	/** Secondary button text */
	secondaryText?: string;
	/** Secondary button link */
	secondaryLink?: string;
	/** Visual mode */
	mode?: 'light' | 'dark';
}

const {
	title,
	description,
	primaryText,
	primaryLink,
	secondaryText,
	secondaryLink,
	mode = 'dark',
} = Astro.props;
---

<section class:list={['cta not-content', `cta--${mode}`]}>
	<div class="cta__glow" aria-hidden="true"></div>
	<div class="cta__content">
		<h2 class="cta__title" set:html={title} />
		<p class="cta__desc">{description}</p>
		{(primaryText || secondaryText) && (
			<div class="cta__actions">
				{primaryText && primaryLink && (
					<a class="cta__btn cta__btn--primary" href={primaryLink}>
						{primaryText}
						<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
					</a>
				)}
				{secondaryText && secondaryLink && (
					<a class="cta__btn cta__btn--secondary" href={secondaryLink}>
						{secondaryText}
					</a>
				)}
			</div>
		)}
	</div>
</section>

<style>
	@keyframes cta-enter {
		from {
			opacity: 0;
			transform: translateY(2rem) scale(0.97);
		}
		to {
			opacity: 1;
			transform: translateY(0) scale(1);
		}
	}

	.cta {
		position: relative;
		border-radius: 1.25rem;
		padding: 3rem 2rem;
		text-align: center;
		overflow: hidden;
		margin-block: 3rem;
		opacity: 0;
		animation: cta-enter 0.8s cubic-bezier(0.22, 1, 0.36, 1) 0.1s forwards;
	}

	@media (min-width: 50rem) {
		.cta { padding: 4rem 3rem; }
	}

	/* Dark mode */
	.cta--dark {
		background:
			linear-gradient(
				135deg,
				color-mix(in srgb, var(--sl-color-accent) 20%, var(--sl-color-black)) 0%,
				var(--sl-color-black) 40%,
				color-mix(in srgb, var(--sl-color-accent) 12%, var(--sl-color-black)) 100%
			);
		border: 1px solid color-mix(in srgb, var(--sl-color-accent) 20%, transparent);
	}

	/* Light mode */
	.cta--light {
		background:
			linear-gradient(
				135deg,
				color-mix(in srgb, var(--sl-color-accent) 8%, var(--sl-color-gray-6)) 0%,
				var(--sl-color-gray-6) 40%,
				color-mix(in srgb, var(--sl-color-accent) 6%, var(--sl-color-gray-6)) 100%
			);
		border: 1px solid var(--sl-color-gray-5);
	}

	/* Decorative glow — breathing */
	.cta__glow {
		position: absolute;
		top: -40%;
		left: 50%;
		transform: translateX(-50%);
		width: 60%;
		height: 50%;
		border-radius: 50%;
		background: radial-gradient(
			ellipse,
			color-mix(in srgb, var(--sl-color-accent) 18%, transparent) 0%,
			transparent 70%
		);
		pointer-events: none;
		animation: cta-glow-breathe 5s ease-in-out infinite;
	}

	@keyframes cta-glow-breathe {
		0%, 100% { opacity: 0.7; transform: translateX(-50%) scale(1); }
		50% { opacity: 1; transform: translateX(-50%) scale(1.12); }
	}

	/* Content */
	.cta__content {
		position: relative;
		z-index: 1;
		display: flex;
		flex-direction: column;
		align-items: center;
		gap: 1.25rem;
		max-width: 40rem;
		margin-inline: auto;
	}

	.cta__title {
		font-size: clamp(1.5rem, 3vw + 0.5rem, 2.25rem);
		font-weight: 700;
		line-height: 1.2;
		margin: 0;
		background: linear-gradient(
			135deg,
			var(--sl-color-accent-high) 0%,
			var(--sl-color-accent) 50%,
			var(--sl-color-accent-high) 100%
		);
		-webkit-background-clip: text;
		-webkit-text-fill-color: transparent;
		background-clip: text;
	}

	.cta__title :global(strong) {
		font-weight: inherit;
		-webkit-text-fill-color: var(--sl-color-white);
	}

	.cta__desc {
		font-size: 1.05rem;
		color: var(--sl-color-gray-2);
		line-height: 1.65;
		margin: 0;
		max-width: 36rem;
	}

	/* Actions */
	.cta__actions {
		display: flex;
		flex-wrap: wrap;
		gap: 0.75rem;
		justify-content: center;
		margin-top: 0.5rem;
	}

	.cta__btn {
		display: inline-flex;
		align-items: center;
		gap: 0.5rem;
		padding: 0.7rem 1.5rem;
		border-radius: 999px;
		font-weight: 600;
		font-size: var(--sl-text-sm);
		text-decoration: none;
		transition:
			transform 0.3s cubic-bezier(0.22, 1, 0.36, 1),
			box-shadow 0.3s cubic-bezier(0.22, 1, 0.36, 1),
			background 0.2s ease;
		position: relative;
		overflow: hidden;
	}

	.cta__btn--primary {
		background:
			linear-gradient(135deg, rgba(255, 255, 255, 0.22) 0%, rgba(255, 255, 255, 0.08) 100%),
			linear-gradient(135deg, var(--sl-color-accent) 0%, var(--sl-color-accent-high) 100%);
		-webkit-backdrop-filter: blur(12px) saturate(1.6);
		backdrop-filter: blur(12px) saturate(1.6);
		border: 1px solid rgba(255, 255, 255, 0.45);
		color: #ffffff;
		font-weight: 700;
		letter-spacing: 0.01em;
		text-shadow: 0 1px 2px rgba(0, 0, 0, 0.18);
		box-shadow: 0 2px 12px color-mix(in srgb, var(--sl-color-accent) 22%, transparent);
	}

	.cta__btn--primary:hover {
		background:
			linear-gradient(135deg, rgba(255, 255, 255, 0.30) 0%, rgba(255, 255, 255, 0.12) 100%),
			linear-gradient(135deg, var(--sl-color-accent) 0%, var(--sl-color-accent-high) 100%);
		border-color: rgba(255, 255, 255, 0.6);
		transform: translateY(-2px);
		box-shadow:
			0 6px 24px color-mix(in srgb, var(--sl-color-accent) 45%, transparent),
			0 0 40px color-mix(in srgb, var(--sl-color-accent) 15%, transparent),
			inset 0 1px 0 rgba(255, 255, 255, 0.4);
	}

	.cta__btn--primary:active {
		transform: translateY(0) scale(0.98);
	}

	.cta__btn--primary svg {
		transition: transform 0.3s cubic-bezier(0.22, 1, 0.36, 1);
	}

	.cta__btn--primary:hover svg {
		transform: translateX(3px);
	}

	.cta__btn--secondary {
		background: transparent;
		color: var(--sl-color-gray-1);
		border: 1px solid var(--sl-color-gray-4);
	}

	.cta__btn--secondary:hover {
		border-color: var(--sl-color-accent);
		color: var(--sl-color-accent);
		transform: translateY(-1px);
	}

	@media (prefers-reduced-motion: reduce) {
		.cta {
			animation: none;
			opacity: 1;
		}
		.cta__glow {
			animation: none;
		}
	}
</style>
