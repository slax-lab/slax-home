---
/**
 * Testimonial — Foxi-inspired testimonial / quote block.
 * Features a large quote with author attribution and optional star rating.
 */
interface Props {
	quote: string;
	author: string;
	role?: string;
	/** Star rating 0-5, omit to hide */
	rating?: 0 | 1 | 2 | 3 | 4 | 5;
	/** Visual mode */
	mode?: 'light' | 'dark';
}

const { quote, author, role, rating, mode = 'dark' } = Astro.props;
const stars = typeof rating === 'number' ? Array.from({ length: 5 }, (_, i) => i < rating) : null;
---

<section class:list={['testimonial not-content', `testimonial--${mode}`]}>
	<div class="testimonial__glow" aria-hidden="true"></div>
	<div class="testimonial__inner">
		<svg class="testimonial__quote-icon" aria-hidden="true" xmlns="http://www.w3.org/2000/svg" width="48" height="48" viewBox="0 0 24 24" fill="currentColor"><path d="M14.017 21v-7.391c0-5.704 3.731-9.57 8.983-10.609l.995 2.151c-2.432.917-3.995 3.638-3.995 5.849h4v10h-9.983zm-14.017 0v-7.391c0-5.704 3.748-9.57 9-10.609l.996 2.151c-2.433.917-3.996 3.638-3.996 5.849h3.983v10h-9.983z"/></svg>

		<blockquote class="testimonial__text">
			<p>{quote}</p>
		</blockquote>

		{stars && (
			<div class="testimonial__stars">
				{stars.map((filled) => (
					<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24"
						fill={filled ? 'currentColor' : 'none'}
						stroke="currentColor" stroke-width="1.5">
						<polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/>
					</svg>
				))}
			</div>
		)}

		<footer class="testimonial__footer">
			<cite class="testimonial__author">
				<span class="testimonial__name">{author}</span>
				{role && <span class="testimonial__role">{role}</span>}
			</cite>
		</footer>
	</div>
</section>

<style>
	@keyframes testimonial-enter {
		from {
			opacity: 0;
			transform: translateY(1.5rem);
		}
		to {
			opacity: 1;
			transform: translateY(0);
		}
	}

	.testimonial {
		position: relative;
		border-radius: 1.25rem;
		padding: 3rem 2rem;
		text-align: center;
		overflow: hidden;
		margin-block: 3rem;
		opacity: 0;
		animation: testimonial-enter 0.8s cubic-bezier(0.22, 1, 0.36, 1) 0.15s forwards;
	}

	@media (min-width: 50rem) {
		.testimonial { padding: 4rem 3rem; }
	}

	.testimonial--dark {
		background:
			linear-gradient(
				160deg,
				color-mix(in srgb, var(--sl-color-accent) 10%, var(--sl-color-black)) 0%,
				var(--sl-color-black) 50%,
				color-mix(in srgb, var(--sl-color-accent) 8%, var(--sl-color-black)) 100%
			);
		border: 1px solid var(--sl-color-gray-5);
	}

	.testimonial--light {
		background: var(--sl-color-gray-6);
		border: 1px solid var(--sl-color-gray-5);
	}

	/* Glow */
	.testimonial__glow {
		position: absolute;
		bottom: -30%;
		left: 50%;
		transform: translateX(-50%);
		width: 50%;
		height: 40%;
		border-radius: 50%;
		background: radial-gradient(
			ellipse,
			color-mix(in srgb, var(--sl-color-accent) 12%, transparent) 0%,
			transparent 70%
		);
		pointer-events: none;
		animation: glow-breathe 5s ease-in-out infinite;
	}

	@keyframes glow-breathe {
		0%, 100% { opacity: 0.6; transform: translateX(-50%) scale(1); }
		50% { opacity: 1; transform: translateX(-50%) scale(1.1); }
	}

	/* Quote icon — gentle slow drift */
	.testimonial__quote-icon {
		color: color-mix(in srgb, var(--sl-color-accent) 25%, transparent);
		flex-shrink: 0;
		animation: quote-icon-float 7s ease-in-out infinite;
	}

	@keyframes quote-icon-float {
		0%, 100% { transform: translateY(0) rotate(0deg); }
		50% { transform: translateY(-4px) rotate(2deg); }
	}
		position: relative;
		z-index: 1;
		display: flex;
		flex-direction: column;
		align-items: center;
		gap: 1.5rem;
		max-width: 42rem;
		margin-inline: auto;
	}

	/* Quote icon */
	.testimonial__quote-icon {
		color: color-mix(in srgb, var(--sl-color-accent) 25%, transparent);
		flex-shrink: 0;
	}

	/* Quote text */
	.testimonial__text {
		margin: 0;
		padding: 0;
		border: none;
	}

	.testimonial__text p {
		font-size: clamp(1.15rem, 2vw + 0.25rem, 1.5rem);
		font-weight: 500;
		line-height: 1.55;
		color: var(--sl-color-gray-1);
		margin: 0;
		font-style: italic;
	}

	/* Stars */
	.testimonial__stars {
		display: flex;
		justify-content: center;
		gap: 0.25rem;
		color: #f59e0b;
	}

	/* Footer */
	.testimonial__footer {
		margin-top: 0.25rem;
	}

	.testimonial__author {
		display: flex;
		flex-direction: column;
		gap: 0.2rem;
		font-style: normal;
	}

	.testimonial__name {
		font-weight: 700;
		font-size: 1rem;
		color: var(--sl-color-white);
		text-transform: uppercase;
		letter-spacing: 0.05em;
	}

	.testimonial__role {
		font-size: var(--sl-text-sm);
		color: var(--sl-color-gray-3);
	}

	@media (prefers-reduced-motion: reduce) {
		.testimonial {
			animation: none;
			opacity: 1;
		}
		.testimonial__glow {
			animation: none;
		}
		.testimonial__quote-icon {
			animation: none;
		}
	}
</style>
