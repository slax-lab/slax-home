---
// DownloadPage.astro — Download page, based on HTML reference
---

<!-- ===== Hero ===== -->
<header class="dl-hero">
  <div class="dl-hero__inner">
    <h1 class="dl-hero__title">
      Slax Reader — <span class="dl-hero__accent">Save Forever. Read Smarter.</span>
    </h1>
    <p class="dl-hero__sub">
      Free to download, available on all your favorite platforms
    </p>
  </div>
</header>

<!-- ===== Mobile ===== -->
<section class="dl-section dl-section--alt">
  <div class="dl-section__inner">
    <div class="dl-section__icon" aria-hidden="true">📱</div>
    <h2 class="dl-section__heading">iPhone, iPad, Android</h2>
    <ul class="dl-section__list">
      <li>Save forever, for free.</li>
      <li>Save any article with one tap.</li>
      <li>Get instant AI outlines and quick navigation.</li>
      <li>Cross-platform sync.</li>
    </ul>
    <div class="dl-section__actions">
      <a
        class="dl-btn dl-btn--store"
        href="https://apps.apple.com/cn/app/slax-reader-ai-read-it-later/id6596730998"
        target="_blank"
        rel="noopener noreferrer"
      >
        <span class="dl-btn__icon" aria-hidden="true">🍎</span>
        <span>
          <span class="dl-btn__small">Download on the</span>
          <span class="dl-btn__label">App Store</span>
        </span>
      </a>
      <a
        class="dl-btn dl-btn--store"
        href="https://play.google.com/store/apps/details?id=com.slax.reader"
        target="_blank"
        rel="noopener noreferrer"
      >
        <span class="dl-btn__icon" aria-hidden="true">▶</span>
        <span>
          <span class="dl-btn__small">GET IT ON</span>
          <span class="dl-btn__label">Google Play</span>
        </span>
      </a>
    </div>
  </div>
</section>

<!-- ===== Mac ===== -->
<section class="dl-section">
  <div class="dl-section__inner">
    <div class="dl-section__icon" aria-hidden="true">💻</div>
    <h2 class="dl-section__heading">Mac</h2>
    <p class="dl-section__desc">Save, read and organize like a pro.</p>
    <div class="dl-section__actions">
      <a
        class="dl-btn dl-btn--store"
        href="https://apps.apple.com/cn/app/slax-reader-ai-read-it-later/id6596730998"
        target="_blank"
        rel="noopener noreferrer"
      >
        <span class="dl-btn__icon" aria-hidden="true">🍎</span>
        <span>
          <span class="dl-btn__small">Download on the</span>
          <span class="dl-btn__label">Mac App Store</span>
        </span>
      </a>
    </div>
  </div>
</section>

<!-- ===== Browser Extension ===== -->
<section class="dl-section dl-section--alt">
  <div class="dl-section__inner">
    <div class="dl-section__icon" aria-hidden="true">🌐</div>
    <h2 class="dl-section__heading">Browser Extension</h2>
    <ul class="dl-section__list">
      <li>One tap to save and back up any web page — yours to keep forever.</li>
      <li>AI chat with your articles — right on the same page.</li>
      <li>Find what you need fast with powerful semantic search.</li>
    </ul>
    <div class="dl-section__actions">
      <a
        class="dl-btn dl-btn--primary"
        href="https://chromewebstore.google.com/detail/gdnhaajlomjkhahnmiijphnodkcfikfd?utm_source=web_homepage"
        target="_blank"
        rel="noopener noreferrer"
      >
        <span aria-hidden="true">🔗</span>
        Add Chrome Extension
      </a>
    </div>
  </div>
</section>

<style>
  /* ── Hero ── */
  .dl-hero {
    padding: 80px 0 72px;
    background: linear-gradient(135deg, #f8fffc 0%, #e6fff3 100%);
    text-align: center;
  }

  .dl-hero__inner {
    max-width: 760px;
    margin: 0 auto;
    padding: 0 24px;
  }

  .dl-hero__title {
    margin: 0 0 20px;
    font-size: clamp(2rem, 5vw, 3rem);
    font-weight: 800;
    line-height: 1.15;
    color: #1f1f1f;
  }

  .dl-hero__accent {
    color: #16b998;
  }

  .dl-hero__sub {
    margin: 0;
    font-size: 1.125rem;
    line-height: 1.7;
    color: #555555;
  }

  /* ── Sections ── */
  .dl-section {
    padding: 72px 0;
    background: #ffffff;
  }

  .dl-section--alt {
    background: #f8f9fa;
  }

  .dl-section__inner {
    max-width: 700px;
    margin: 0 auto;
    padding: 0 24px;
    text-align: center;
  }

  .dl-section__icon {
    font-size: 3rem;
    margin-bottom: 16px;
    line-height: 1;
  }

  .dl-section__heading {
    margin: 0 0 24px;
    font-size: clamp(1.6rem, 3vw, 2rem);
    font-weight: 700;
    color: #1f1f1f;
  }

  .dl-section__desc {
    margin: 0 0 32px;
    font-size: 1.125rem;
    color: #555555;
    line-height: 1.7;
  }

  .dl-section__list {
    list-style: none;
    padding: 0;
    margin: 0 0 36px;
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  .dl-section__list li {
    position: relative;
    padding-left: 28px;
    text-align: left;
    font-size: 1rem;
    color: #333333;
    line-height: 1.6;
  }

  .dl-section__list li::before {
    content: '✓';
    position: absolute;
    left: 0;
    color: #16b998;
    font-weight: 700;
  }

  /* ── Buttons ── */
  .dl-section__actions {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 16px;
  }

  .dl-btn {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    padding: 12px 20px;
    border-radius: 8px;
    background: #1f1f1f;
    color: #ffffff;
    text-decoration: none;
    font-size: 0.9rem;
    transition: opacity 0.2s ease, transform 0.2s ease;
    min-width: 180px;
  }

  .dl-btn:hover {
    opacity: 0.85;
    transform: translateY(-1px);
  }

  .dl-btn--store {
    background: #1f1f1f;
    color: #ffffff;
  }

  .dl-btn--primary {
    background: linear-gradient(135deg, #25d4b0 0%, #1cb0b5 50%, #16b998 100%);
    color: #ffffff;
    font-weight: 700;
    font-size: 1rem;
    padding: 14px 28px;
    min-width: unset;
  }

  .dl-btn__icon {
    font-size: 1.4rem;
    line-height: 1;
  }

  .dl-btn__small {
    display: block;
    font-size: 0.7rem;
    opacity: 0.8;
    line-height: 1.2;
  }

  .dl-btn__label {
    display: block;
    font-size: 1rem;
    font-weight: 700;
    line-height: 1.2;
  }

  @media (max-width: 600px) {
    .dl-section__actions {
      flex-direction: column;
      align-items: center;
    }

    .dl-btn {
      width: 100%;
      max-width: 280px;
      justify-content: center;
    }
  }
</style>
