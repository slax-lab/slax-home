---
// ContactPage.astro — Contact page, based on HTML reference
---

<!-- ===== Hero ===== -->
<header class="ct-hero">
  <div class="ct-hero__inner">
    <h1 class="ct-hero__title">Contact Us</h1>
    <p class="ct-hero__body">
      Slax Reader is built by a small, dedicated team of deep readers. We want to help you enjoy a
      better read-it-later journey by using AI to take over the tedious parts of information
      overload — summarizing to filter value, outlining to deconstruct long-form content, and
      chatting to deepen understanding.
    </p>
    <p class="ct-hero__body">
      Whether you've found a bug, have a feature request, or just want to chat about the future of
      digital reading — we're listening.
    </p>
  </div>
</header>

<!-- ===== Contact Methods ===== -->
<section class="ct-methods">
  <div class="ct-methods__inner">
    <div class="ct-methods__grid">

      <a class="ct-card" href="mailto:support@slax.com">
        <div class="ct-card__icon" aria-hidden="true">📧</div>
        <h3 class="ct-card__name">Email</h3>
        <p class="ct-card__value">support@slax.com</p>
      </a>

      <a class="ct-card" href="https://x.com/SlaxReader" target="_blank" rel="noopener noreferrer">
        <div class="ct-card__icon" aria-hidden="true">𝕏</div>
        <h3 class="ct-card__name">X (Twitter)</h3>
        <p class="ct-card__value">@SlaxReader</p>
      </a>

      <a class="ct-card" href="https://t.me/slax_app" target="_blank" rel="noopener noreferrer">
        <div class="ct-card__icon" aria-hidden="true">✈️</div>
        <h3 class="ct-card__name">Telegram</h3>
        <p class="ct-card__value">Slax Reader Community</p>
      </a>

      <a
        class="ct-card"
        href="https://github.com/slax-lab/slax-reader"
        target="_blank"
        rel="noopener noreferrer"
      >
        <div class="ct-card__icon" aria-hidden="true">🐙</div>
        <h3 class="ct-card__name">GitHub</h3>
        <p class="ct-card__value">Best for bug reports and feature requests</p>
      </a>

    </div>
  </div>
</section>

<!-- ===== Mission ===== -->
<section class="ct-mission">
  <div class="ct-mission__inner">
    <p class="ct-mission__body">
      Building Slax Reader is a long-haul mission for us, and we couldn't do it without the
      insights and support of our early community. Thank you for joining us on this journey.
    </p>
    <p class="ct-mission__sig">Happy Reading, <strong>The Slax Reader Team</strong></p>
  </div>
</section>

<!-- ===== Quick Links ===== -->
<section class="ct-links">
  <div class="ct-links__inner">
    <h2 class="ct-links__title">Not sure where to start? You might find your answer here:</h2>
    <ul class="ct-links__list">
      <li>
        <a class="ct-links__item" href="/reader/">
          <span>See the full visual tour of what Slax Reader can do</span>
          <span class="ct-links__arrow" aria-hidden="true">→</span>
        </a>
      </li>
      <li>
        <a class="ct-links__item" href="/reader/pricing">
          <span>What's the pricing plans and founding member perks?</span>
          <span class="ct-links__arrow" aria-hidden="true">→</span>
        </a>
      </li>
      <li>
        <a class="ct-links__item" href="/reader/download">
          <span>Get Slax Reader now</span>
          <span class="ct-links__arrow" aria-hidden="true">→</span>
        </a>
      </li>
    </ul>
  </div>
</section>

<!-- ===== CTA ===== -->
<section class="ct-cta">
  <div class="ct-cta__inner">
    <h2 class="ct-cta__title">Start Your Intelligent Reading Journey Today</h2>
    <p class="ct-cta__sub">Read smarter, learn faster, remember more</p>
    <a class="ct-cta__btn" href="/reader/download">
      <span>Get Started — It's Free</span>
      <span aria-hidden="true">→</span>
    </a>
  </div>
</section>

<style>
  /* ── Hero ── */
  .ct-hero {
    padding: 80px 0 72px;
    background: linear-gradient(135deg, #f8fffc 0%, #e6fff3 100%);
    text-align: center;
  }

  .ct-hero__inner {
    max-width: 760px;
    margin: 0 auto;
    padding: 0 24px;
  }

  .ct-hero__title {
    margin: 0 0 28px;
    font-size: clamp(2.4rem, 5vw, 3.5rem);
    font-weight: 800;
    color: #1f1f1f;
  }

  .ct-hero__body {
    margin: 0 0 16px;
    font-size: 1.0625rem;
    line-height: 1.75;
    color: #444444;
  }

  /* ── Contact Methods ── */
  .ct-methods {
    padding: 72px 0;
    background: #ffffff;
  }

  .ct-methods__inner {
    max-width: 900px;
    margin: 0 auto;
    padding: 0 24px;
  }

  .ct-methods__grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 24px;
  }

  .ct-card {
    display: flex;
    flex-direction: column;
    align-items: center;
    padding: 36px 24px;
    border-radius: 12px;
    background: #f8f9fa;
    text-align: center;
    text-decoration: none;
    color: inherit;
    transition: transform 0.2s ease, box-shadow 0.2s ease;
  }

  .ct-card:hover {
    transform: translateY(-4px);
    box-shadow: 0 30px 60px 0 rgba(0, 0, 0, 0.08);
  }

  .ct-card__icon {
    font-size: 2.5rem;
    margin-bottom: 16px;
    line-height: 1;
  }

  .ct-card__name {
    margin: 0 0 10px;
    font-size: 1.1rem;
    font-weight: 700;
    color: #16b998;
  }

  .ct-card__value {
    margin: 0;
    font-size: 0.9375rem;
    color: #555555;
    line-height: 1.5;
  }

  /* ── Mission ── */
  .ct-mission {
    padding: 60px 0;
    background: #f8f9fa;
  }

  .ct-mission__inner {
    max-width: 680px;
    margin: 0 auto;
    padding: 0 24px;
    text-align: center;
  }

  .ct-mission__body {
    margin: 0 0 16px;
    font-size: 1.0625rem;
    line-height: 1.8;
    color: #444444;
  }

  .ct-mission__sig {
    margin: 0;
    font-size: 1rem;
    color: #666666;
  }

  /* ── Quick Links ── */
  .ct-links {
    padding: 72px 0;
    background: #ffffff;
  }

  .ct-links__inner {
    max-width: 720px;
    margin: 0 auto;
    padding: 0 24px;
  }

  .ct-links__title {
    margin: 0 0 36px;
    font-size: clamp(1.2rem, 2.5vw, 1.5rem);
    font-weight: 700;
    color: #1f1f1f;
    text-align: center;
  }

  .ct-links__list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  .ct-links__item {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 18px 20px;
    border-radius: 10px;
    background: #f8f9fa;
    color: #1f1f1f;
    text-decoration: none;
    font-size: 0.9375rem;
    font-weight: 500;
    transition: background 0.2s ease, color 0.2s ease;
  }

  .ct-links__item:hover {
    background: #e6fff3;
    color: #16b998;
  }

  .ct-links__arrow {
    color: #16b998;
    font-size: 1.1rem;
    transition: transform 0.2s ease;
  }

  .ct-links__item:hover .ct-links__arrow {
    transform: translateX(4px);
  }

  /* ── CTA ── */
  .ct-cta {
    padding: 68px 0 80px;
    background: linear-gradient(180deg, #2eb396 0%, #5edda8 100%);
    text-align: center;
  }

  .ct-cta__inner {
    max-width: 700px;
    margin: 0 auto;
    padding: 0 24px;
  }

  .ct-cta__title {
    margin: 0 0 16px;
    font-size: clamp(1.8rem, 4vw, 2.4rem);
    font-weight: 800;
    color: #ffffff;
  }

  .ct-cta__sub {
    margin: 0 0 36px;
    font-size: 1.125rem;
    color: rgba(255, 255, 255, 0.9);
  }

  .ct-cta__btn {
    display: inline-flex;
    align-items: center;
    gap: 12px;
    min-height: 56px;
    padding: 0 32px;
    border-radius: 6px;
    background: #ffffff;
    color: #1f1f1f;
    text-decoration: none;
    font-size: 1rem;
    font-weight: 700;
    box-shadow: 0 30px 60px 0 rgba(0, 0, 0, 0.1);
    transition: transform 0.2s ease, box-shadow 0.2s ease;
  }

  .ct-cta__btn:hover {
    transform: translateY(-2px);
    box-shadow: 0 30px 60px 0 rgba(0, 0, 0, 0.18);
  }

  /* ── Responsive ── */
  @media (max-width: 600px) {
    .ct-methods__grid {
      grid-template-columns: 1fr;
    }
  }
</style>
