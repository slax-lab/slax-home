---
import LanguageSelect from 'virtual:starlight/components/LanguageSelect';
---

<footer class="site-footer">
  <div class="site-footer__container">
    <div class="site-footer__columns">

      <div class="site-footer__col">
        <h4 class="site-footer__heading">Products</h4>
        <ul class="site-footer__list">
          <li><a href="/reader/" class="site-footer__link">Slax Reader</a></li>
          <li><a href="#" class="site-footer__link">Slax Note</a></li>
        </ul>
      </div>

      <div class="site-footer__col">
        <h4 class="site-footer__heading">Resources</h4>
        <ul class="site-footer__list">
          <li><a href="#" class="site-footer__link">Blog</a></li>
          <li><a href="#" class="site-footer__link">Guides</a></li>
          <li><a href="#" class="site-footer__link">Tutorials</a></li>
        </ul>
      </div>

      <div class="site-footer__col">
        <h4 class="site-footer__heading">Legal</h4>
        <ul class="site-footer__list">
          <li><a href="#" class="site-footer__link">Terms</a></li>
          <li><a href="#" class="site-footer__link">Privacy</a></li>
          <li><a href="/reader/contact" class="site-footer__link">Contact Us</a></li>
        </ul>
      </div>

    </div>

    <div class="site-footer__bottom">
      <div class="site-footer__social">
        <a
          href="https://github.com/slax-lab"
          class="site-footer__social-link"
          aria-label="GitHub"
          target="_blank"
          rel="noopener noreferrer"
        >
          <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0022 12.017C22 6.484 17.522 2 12 2z"/>
          </svg>
        </a>
        <a
          href="https://x.com/SlaxReader"
          class="site-footer__social-link"
          aria-label="Twitter / X"
          target="_blank"
          rel="noopener noreferrer"
        >
          <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-4.714-6.231-5.401 6.231H2.744l7.73-8.835L1.254 2.25H8.08l4.253 5.622zm-1.161 17.52h1.833L7.084 4.126H5.117z"/>
          </svg>
        </a>
      </div>

      <p class="site-footer__copy">© 2026 Slax. All rights reserved.</p>

      <div class="site-footer__lang">
        <LanguageSelect />
      </div>
    </div>
  </div>
</footer>

<style>
  .site-footer {
    background: var(--sl-color-black);
    border-top: 1px solid var(--sl-color-gray-6);
    padding: 48px 0 32px;
    margin-top: auto;
  }

  .site-footer__container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 24px;
  }

  .site-footer__columns {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 48px;
    margin-bottom: 48px;
  }

  .site-footer__heading {
    margin: 0 0 16px;
    font-size: 0.8rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--sl-color-gray-3);
  }

  .site-footer__list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 10px;
  }

  .site-footer__link {
    font-size: 0.9rem;
    color: var(--sl-color-gray-2);
    text-decoration: none;
    transition: color 0.2s ease;
  }

  .site-footer__link:hover {
    color: var(--sl-color-accent);
  }

  .site-footer__link:focus-visible {
    outline: 2px solid var(--sl-color-accent);
    outline-offset: 2px;
    border-radius: 2px;
  }

  .site-footer__bottom {
    display: flex;
    align-items: center;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: 16px;
    padding-top: 24px;
    border-top: 1px solid var(--sl-color-gray-6);
  }

  .site-footer__social {
    display: flex;
    gap: 16px;
    align-items: center;
  }

  .site-footer__social-link {
    color: var(--sl-color-gray-3);
    transition: color 0.2s ease;
    display: flex;
    align-items: center;
  }

  .site-footer__social-link:hover {
    color: var(--sl-color-accent);
  }

  .site-footer__social-link:focus-visible {
    outline: 2px solid var(--sl-color-accent);
    outline-offset: 2px;
    border-radius: 4px;
  }

  .site-footer__copy {
    margin: 0;
    font-size: 0.85rem;
    color: var(--sl-color-gray-3);
  }

  .site-footer__lang {
    display: flex;
    align-items: center;
  }

  @media (max-width: 640px) {
    .site-footer__columns {
      grid-template-columns: 1fr;
      gap: 32px;
    }

    .site-footer__bottom {
      flex-direction: column;
      align-items: flex-start;
    }
  }
</style>
