---
import Search from 'virtual:starlight/components/Search';
import SiteTitle from 'virtual:starlight/components/SiteTitle';
import config from 'virtual:starlight/user-config';
import { isNavDropdown, isNavGroup, navActions, navItems } from '../config/nav';

const shouldRenderSearch =
	config.pagefind ||
	config.components.Search !== '@astrojs/starlight/components/Search.astro';

const lang = Astro.currentLocale ?? 'en';

function getLabel(item: { label: string; translations?: Record<string, string> }) {
	if (!item.translations) return item.label;
	const langMap: Record<string, string> = { zh: 'zh-CN' };
	const key = langMap[lang] ?? lang;
	return item.translations[key] ?? item.label;
}

const currentPath = Astro.url.pathname;
---

<div class="header">
  <div class="title-wrapper sl-flex">
    <SiteTitle />
  </div>

  <nav class="nav-items sl-hidden md:sl-flex" aria-label="Main navigation">
    {navItems.map((item) =>
      isNavDropdown(item) ? (
        <div class="nav-dropdown">
          <button class="nav-btn" aria-haspopup="true" aria-expanded="false">
            {getLabel(item)}
            <svg class="nav-chevron" width="12" height="12" viewBox="0 0 12 12" aria-hidden="true">
              <path d="M2 4l4 4 4-4" stroke="currentColor" stroke-width="1.5" fill="none" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </button>
          <ul class="nav-dropdown-panel" role="menu">
            {item.children.map((child) =>
              isNavGroup(child) ? (
                <li role="none" class="nav-group">
                  <a
                    href={child.href}
                    role="menuitem"
                    class:list={['nav-dropdown-link nav-group-label', { active: currentPath === child.href || currentPath.startsWith(child.href + '/') }]}
                  >
                    {getLabel(child)}
                  </a>
                  <ul class="nav-submenu">
                    {child.children.map((sub) => (
                      <li role="none">
                        <a
                          href={sub.href}
                          role="menuitem"
                          class:list={['nav-dropdown-link nav-submenu-link', { active: currentPath === sub.href || currentPath.startsWith(sub.href + '/') }]}
                        >
                          {getLabel(sub)}
                        </a>
                      </li>
                    ))}
                  </ul>
                </li>
              ) : (
                <li role="none">
                  <a
                    href={child.href}
                    role="menuitem"
                    class:list={['nav-dropdown-link', { active: currentPath === child.href || currentPath.startsWith(child.href + '/') }]}
                  >
                    {getLabel(child)}
                  </a>
                </li>
              )
            )}
          </ul>
        </div>
      ) : (
        <a
          href={item.href}
          class:list={['nav-link', { active: currentPath === item.href || currentPath === item.href + '/' }]}
        >
          {getLabel(item)}
        </a>
      )
    )}
  </nav>

  <div class="sl-hidden print:hidden">

  <div class="sl-hidden md:sl-flex print:hidden right-group">
    {navActions.map((action) => (
      <a
        href={action.href}
        class:list={['nav-action', `nav-action--${action.variant}`]}
      >
        {getLabel(action)}
      </a>
    ))}
  </div>
</div>

<script>
  document.querySelectorAll<HTMLElement>('.nav-dropdown').forEach((dropdown) => {
    const btn = dropdown.querySelector<HTMLButtonElement>('.nav-btn');
    const panel = dropdown.querySelector<HTMLElement>('.nav-dropdown-panel');
    if (!btn || !panel) return;

    let closeTimer: ReturnType<typeof setTimeout>;

    const open = () => {
      clearTimeout(closeTimer);
      panel.classList.add('open');
      btn.setAttribute('aria-expanded', 'true');
    };
    const scheduleClose = () => {
      closeTimer = setTimeout(() => {
        panel.classList.remove('open');
        btn.setAttribute('aria-expanded', 'false');
      }, 120);
    };

    dropdown.addEventListener('mouseenter', open);
    dropdown.addEventListener('mouseleave', scheduleClose);
    btn.addEventListener('click', () => {
      panel.classList.contains('open') ? scheduleClose() : open();
    });
  });

  // Submenu hover
  document.querySelectorAll<HTMLElement>('.nav-group').forEach((group) => {
    const submenu = group.querySelector<HTMLElement>('.nav-submenu');
    if (!submenu) return;

    let closeTimer: ReturnType<typeof setTimeout>;

    group.addEventListener('mouseenter', () => {
      clearTimeout(closeTimer);
      submenu.classList.add('open');
    });
    group.addEventListener('mouseleave', () => {
      closeTimer = setTimeout(() => submenu.classList.remove('open'), 120);
    });
  });  document.addEventListener('click', (e) => {
    document.querySelectorAll<HTMLElement>('.nav-dropdown').forEach((dropdown) => {
      const btn = dropdown.querySelector<HTMLButtonElement>('.nav-btn');
      const panel = dropdown.querySelector<HTMLElement>('.nav-dropdown-panel');
      if (!dropdown.contains(e.target as Node) && panel && btn) {
        panel.classList.remove('open');
        btn.setAttribute('aria-expanded', 'false');
      }
    });
  });
</script>

<style>
  @layer starlight.core {
    .header {
      display: flex;
      gap: var(--sl-nav-gap);
      justify-content: space-between;
      align-items: center;
      height: 100%;
    }

    .title-wrapper {
      overflow: clip;
      padding: 0.25rem;
      margin: -0.25rem;
      min-width: 0;
    }

    .right-group {
      gap: 0.5rem;
      align-items: center;
    }

    @media (min-width: 50rem) {
      :global(:root[data-has-sidebar]) {
        --__sidebar-pad: calc(2 * var(--sl-nav-pad-x));
      }
      :global(:root:not([data-has-toc])) {
        --__toc-width: 0rem;
      }
      .header {
        --__sidebar-width: max(0rem, var(--sl-content-inline-start, 0rem) - var(--sl-nav-pad-x));
        --__main-column-fr: calc(
          (
            100% + var(--__sidebar-pad, 0rem) - var(--__toc-width, var(--sl-sidebar-width)) -
            (2 * var(--__toc-width, var(--sl-nav-pad-x))) - var(--sl-content-inline-start, 0rem) -
            var(--sl-content-width)
          ) / 2
        );
        display: grid;
        grid-template-columns:
          minmax(
            calc(var(--__sidebar-width) + max(0rem, var(--__main-column-fr) - var(--sl-nav-gap))),
            auto
          )
          auto
          1fr
          auto;
        align-content: center;
      }
    }
  }

  /* ===== Nav items ===== */
  .nav-items {
    align-items: center;
    gap: 0.25rem;
  }

  .nav-link {
    font-size: 0.9rem;
    font-weight: 500;
    color: var(--sl-color-gray-2);
    text-decoration: none;
    padding: 0.35rem 0.75rem;
    border-radius: 6px;
    transition: color 0.2s ease, background 0.2s ease;
  }

  .nav-link:hover,
  .nav-link.active {
    color: var(--sl-color-accent);
    background: color-mix(in srgb, var(--sl-color-accent) 10%, transparent);
  }

  /* ===== Dropdown ===== */
  .nav-dropdown {
    position: relative;
    padding-bottom: 8px;
    margin-bottom: -8px;
  }

  .nav-btn {
    display: flex;
    align-items: center;
    gap: 4px;
    font-size: 0.9rem;
    font-weight: 500;
    color: var(--sl-color-gray-2);
    background: none;
    border: none;
    cursor: pointer;
    padding: 0.35rem 0.75rem;
    border-radius: 6px;
    transition: color 0.2s ease, background 0.2s ease;
  }

  .nav-btn:hover {
    color: var(--sl-color-accent);
    background: color-mix(in srgb, var(--sl-color-accent) 10%, transparent);
  }

  .nav-chevron {
    transition: transform 0.2s ease;
  }

  .nav-btn[aria-expanded="true"] .nav-chevron {
    transform: rotate(180deg);
  }

  .nav-dropdown-panel {
    display: none;
    position: absolute;
    top: calc(100% + 8px);
    left: 0;
    min-width: 160px;
    background: var(--sl-color-black);
    border: 1px solid var(--sl-color-gray-6);
    border-radius: 8px;
    box-shadow: 0 30px 60px 0 rgba(0, 0, 0, 0.08);
    padding: 6px;
    list-style: none;
    margin: 0;
    z-index: 100;
  }

  .nav-dropdown-panel.open {
    display: block;
  }

  .nav-dropdown-link {
    display: block;
    font-size: 0.875rem;
    color: var(--sl-color-gray-2);
    text-decoration: none;
    padding: 0.4rem 0.75rem;
    border-radius: 6px;
    transition: color 0.2s ease, background 0.2s ease;
  }

  .nav-dropdown-link:hover,
  .nav-dropdown-link.active {
    color: var(--sl-color-accent);
    background: color-mix(in srgb, var(--sl-color-accent) 10%, transparent);
  }

  /* ===== Submenu (third level — always visible inside dropdown) ===== */
  .nav-group {
    position: relative;
  }

  .nav-group-label {
    font-weight: 600;
    color: var(--sl-color-gray-3);
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    padding: 0.5rem 0.75rem 0.25rem;
    pointer-events: auto;
  }

  .nav-group-label:hover {
    background: none;
    color: var(--sl-color-accent);
  }

  .nav-submenu {
    list-style: none;
    margin: 0;
    padding: 0 0 4px 0;
  }

  .nav-submenu-link {
    padding-left: 1.25rem;
    font-size: 0.875rem;
  }

  /* ===== Action buttons ===== */
  .nav-action {
    display: inline-flex;
    align-items: center;
    font-size: 0.875rem;
    font-weight: 600;
    text-decoration: none;
    padding: 0.35rem 0.9rem;
    border-radius: 6px;
    transition: color 0.2s ease, background 0.2s ease, box-shadow 0.2s ease;
    white-space: nowrap;
  }

  .nav-action:focus-visible {
    outline: 2px solid var(--sl-color-accent);
    outline-offset: 2px;
  }

  .nav-action--ghost {
    color: var(--sl-color-gray-2);
    background: transparent;
  }

  .nav-action--ghost:hover {
    color: var(--sl-color-accent);
    background: color-mix(in srgb, var(--sl-color-accent) 10%, transparent);
  }

  .nav-action--primary {
    color: #ffffff;
    background: var(--sl-color-accent);
  }

  .nav-action--primary:hover {
    background: color-mix(in srgb, var(--sl-color-accent) 85%, #000);
    box-shadow: 0 4px 12px color-mix(in srgb, var(--sl-color-accent) 40%, transparent);
  }
</style>
