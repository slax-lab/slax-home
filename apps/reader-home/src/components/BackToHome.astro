---
/**
 * BackToHome — A subtle navigation link back to slax.com main site.
 * Used on reader-home and note-home landing pages.
 */
interface Props {
	label?: string;
}

const { label = 'Back to Slax Home' } = Astro.props;
---

<div class="back-to-home not-content">
	<a href="/" class="back-link">
		<svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m15 18-6-6 6-6"/></svg>
		{label}
	</a>
</div>

<style>
	.back-to-home {
		text-align: center;
		margin-block: 3rem 1rem !important;
	}

	.back-link {
		display: inline-flex;
		align-items: center;
		gap: 0.35rem;
		font-size: var(--sl-text-sm);
		color: var(--sl-color-gray-3);
		text-decoration: none;
		padding: 0.5rem 1rem;
		border-radius: 2rem;
		border: 1px solid var(--sl-color-gray-5);
		transition: all 0.2s ease;
	}
	.back-link:hover {
		color: var(--sl-color-text-accent);
		border-color: var(--sl-color-text-accent);
	}
</style>
