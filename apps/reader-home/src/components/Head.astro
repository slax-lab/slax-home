---
/**
 * Custom Head component that extends Starlight's default Head
 * Adds page-level JSON-LD structured data and GTM tracking automatically
 */
import type { WithContext, WebPage } from 'schema-dts';

const { head } = Astro.locals.starlightRoute;
const entry = Astro.locals.starlightRoute.entry;
const { title, description } = entry.data;
const pageUrl = Astro.url.href;
const siteName = 'Slax Reader';

// --- GTM ---
const gtmId = import.meta.env.PUBLIC_GTM_ID;
const pagePath = Astro.url.pathname;
const isHomePage = pagePath === '/reader/' || pagePath === '/reader/zh/';
const pageType = isHomePage ? 'home' : 'doc';
const locale = pagePath.includes('/zh') ? 'zh-CN' : 'en';
const pageTitle = title || siteName;

// Build JSON-LD
const jsonLd: WithContext<WebPage> = {
	'@context': 'https://schema.org',
	'@type': 'WebPage',
	headline: title,
	description: description || '',
	url: pageUrl,
	isPartOf: {
		'@type': 'WebSite',
		name: siteName,
		url: 'https://slax.com/reader/',
	},
};

// Build BreadcrumbList from URL path
const pathSegments = Astro.url.pathname.split('/').filter(Boolean);
const breadcrumbItems = pathSegments.map((segment, index) => ({
	'@type': 'ListItem' as const,
	position: index + 1,
	name: segment.charAt(0).toUpperCase() + segment.slice(1).replace(/-/g, ' '),
	item: new URL(pathSegments.slice(0, index + 1).join('/') + '/', Astro.site || 'https://slax.com').href,
}));

const breadcrumbJsonLd = {
	'@context': 'https://schema.org',
	'@type': 'BreadcrumbList',
	itemListElement: breadcrumbItems,
};
---

{/* Render default Starlight head tags */}
{head.map(({ tag: Tag, attrs, content }) => <Tag {...attrs} set:html={content} />)}

{/* Page-level JSON-LD */}
<script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />

{/* Breadcrumb JSON-LD (skip for homepage) */}
{breadcrumbItems.length > 0 && (
	<script type="application/ld+json" set:html={JSON.stringify(breadcrumbJsonLd)} />
)}

{/* --- Google Tag Manager --- */}
{gtmId && (
	<script
		is:inline
		set:html={`
window.dataLayer = window.dataLayer || [];
window.dataLayer.push({
  event: 'page_view',
  site_name: '${siteName}',
  locale: '${locale}',
  page_type: '${pageType}',
  page_path: '${pagePath}',
  page_title: '${pageTitle.replace(/'/g, "\\'")}'
});

(function(w,d,s,l,i){w[l]=w[l]||[];w[l].push({'gtm.start':
new Date().getTime(),event:'gtm.js'});var f=d.getElementsByTagName(s)[0],
j=d.createElement(s),dl=l!='dataLayer'?'&l='+l:'';j.async=true;j.src=
'https://www.googletagmanager.com/gtm.js?id='+i+dl;f.parentNode.insertBefore(j,f);
})(window,document,'script','dataLayer','${gtmId}');

document.addEventListener('click', function(e) {
  var el = e.target.closest('[data-gtm-click]');
  if (!el) return;
  window.dataLayer.push({
    event: 'ui_click',
    site_name: '${siteName}',
    locale: '${locale}',
    page_type: '${pageType}',
    page_path: '${pagePath}',
    page_title: '${pageTitle.replace(/'/g, "\\'")}',
    click_text: (el.textContent || '').trim().slice(0, 100),
    click_label: el.getAttribute('data-gtm-label') || '',
    click_href: el.getAttribute('href') || '',
    click_location: el.getAttribute('data-gtm-location') || ''
  });
});
`}
	/>
)}
